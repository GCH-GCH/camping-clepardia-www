{
  "rewrites": [
    {
      "source": "/api/stay/panel",
      "destination": "/api/reservation?ccRoute=stay-panel"
    },
    {
      "source": "/api/stay/admin",
      "destination": "/api/reservation?ccRoute=stay-admin"
    },
    {
      "source": "/api/analytics/event",
      "destination": "/api/reservation?ccRoute=analytics-event"
    },
    {
      "source": "/api/analytics/status",
      "destination": "/api/reservation?ccRoute=analytics-status"
    },
    {
      "source": "/stay/:token",
      "destination": "/stay/?token=:token"
    }
  ],
  "headers": [
    {
      "source": "/stay/:path*",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow, noarchive" },
        { "key": "Referrer-Policy", "value": "no-referrer" },
        { "key": "Cache-Control", "value": "private, no-store, max-age=0" }
      ]
    }
  ]
}
