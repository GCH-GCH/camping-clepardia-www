{
  "name": "camping-clepardia-www",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && node scripts/audit-pricing-i18n.mjs",
    "audit:i18n": "node scripts/audit-public-i18n.mjs",
    "audit:structure": "node scripts/audit-public-structure.mjs",
    "test:planner": "node scripts/test-planner.mjs",
    "test:planner-runtime": "playwright test --config=playwright.config.mjs",
    "test:planner-modal": "playwright test --config=playwright.config.mjs tests/planner-runtime.spec.mjs --grep \"fullscreen modal\"",
    "test:weather": "node scripts/test-weather.mjs && playwright test --config=playwright.config.mjs tests/weather-runtime.spec.mjs",
    "test:weather-drawer": "playwright test --config=playwright.config.mjs tests/weather-runtime.spec.mjs --grep \"weather drawer\"",
    "test:themes": "playwright test --config=playwright.config.mjs tests/themes-runtime.spec.mjs",
    "preview": "astro preview",
    "astro": "astro",
    "images:webp": "node scripts/convert-raw-to-webp.mjs"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.2",
    "@tailwindcss/vite": "^4.3.0",
    "astro": "^6.3.1",
    "flag-icons": "^7.5.0",
    "lenis": "^1.3.23",
    "lucide": "^1.16.0",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "sharp": "^0.34.5",
    "typescript": "^6.0.3"
  }
}
