---
import ImageFrame from '@/components/ImageFrame.astro';
import Icon from '@/components/ui/Icon.astro';
import { siteAssets } from '@/data/assets';
import { getTranslations } from '@/i18n/config';
import { getLocalizedPath, getPathContext } from '@/utils/localizedLinks';

interface Props {
  languageCode?: string;
}

const { languageCode } = Astro.props as Props;
const pathContext = getPathContext(Astro.url.pathname);
const explicitLanguage = pathContext.explicitLanguage ?? (languageCode && languageCode !== 'pl' ? languageCode : undefined);
const activeLanguage = languageCode ?? pathContext.languageCode;
const t = getTranslations(activeLanguage);
const page = t.pages.dojazd;
const timeline = {
  tram: activeLanguage === 'de' ? 'Straßenbahn' : activeLanguage === 'it' ? 'Tram' : activeLanguage === 'pl' ? 'Tramwaj' : 'Tram',
  center: activeLanguage === 'de' ? 'Altstadt' : activeLanguage === 'it' ? 'Città Vecchia' : activeLanguage === 'pl' ? 'Stare Miasto' : 'Old Town',
};
const imageLabels = activeLanguage === 'de'
  ? {
      note: 'Jakdojade • Straßenbahn • Stadtzentrum',
      tram: 'Straßenbahn ins Zentrum',
      tickets: 'Tickets in der Straßenbahn',
      map: 'Anfahrtskarte',
      app: 'Jakdojade',
    }
  : activeLanguage === 'it'
    ? {
        note: 'Jakdojade • tram • centro città',
        tram: 'Tram per il centro',
        tickets: 'Biglietti in tram',
        map: 'Mappa del percorso',
        app: 'Jakdojade',
      }
    : activeLanguage === 'pl'
      ? {
          note: 'Jakdojade • tramwaj • centrum miasta',
          tram: 'Tramwaj do centrum',
          tickets: 'Bilety w tramwaju',
          map: 'Mapa dojazdu',
          app: 'JakDojade',
        }
      : {
          note: 'Jakdojade • tram • city centre',
          tram: 'Tram to the centre',
          tickets: 'Tickets on the tram',
          map: 'Directions map',
          app: 'Jakdojade',
        };
const smartTram = activeLanguage === 'de'
  ? {
      title: 'Smart Tram Assistant',
      copy: 'Die Haltestelle liegt ca. 40 m vom Tor entfernt. Zum Stary Kleparz / Zentrum sind es ca. 9 Haltestellen und etwa 14 Minuten Fahrt.',
      points: ['Google Maps empfohlen', 'Jakdojade für Route und Tickets', 'Tickets in Automaten oder Apps'],
      maps: 'Route in Google Maps prüfen',
      jakdojade: 'Jakdojade öffnen',
    }
  : activeLanguage === 'it'
    ? {
        title: 'Smart Tram Assistant',
        copy: 'La fermata è a circa 40 m dal cancello. Verso Stary Kleparz / centro sono circa 9 fermate e circa 14 minuti in tram.',
        points: ['Google Maps consigliato', 'Jakdojade per percorso e biglietti', 'Biglietti in macchine o app'],
        maps: 'Controlla su Google Maps',
        jakdojade: 'Apri Jakdojade',
      }
    : activeLanguage === 'pl'
      ? {
          title: 'Smart Tram Assistant',
          copy: 'Przystanek jest ok. 40 m od bramy. Do Starego Kleparza / centrum jest ok. 9 przystanków i ok. 14 minut jazdy tramwajem.',
          points: ['Google Maps zalecane', 'Jakdojade do trasy i biletów', 'Bilety w automatach lub aplikacjach'],
          maps: 'Sprawdź trasę w Google Maps',
          jakdojade: 'Otwórz Jakdojade',
        }
      : {
          title: 'Smart Tram Assistant',
          copy: 'The stop is about 40 m from the gate. It is about 9 stops and around 14 minutes by tram to Stary Kleparz / the city centre.',
          points: ['Google Maps recommended', 'Jakdojade for routes and tickets', 'Tickets in machines or apps'],
          maps: 'Check route in Google Maps',
          jakdojade: 'Open Jakdojade',
        };
const mapsRouteHref = 'https://www.google.com/maps/search/?api=1&query=Camping+Clepardia+Henryka+Pacho%C5%84skiego+28A+Krak%C3%B3w';
const jakdojadeHref = 'https://jakdojade.pl/krakow';
---

<section class="site-section transport reveal-section" id="dojazd">
  <div class="container section-grid section-grid--2">
    <div>
      <span class="section-kicker">{page.overline}</span>
      <h2 class="section-title">{page.title}</h2>
      <p class="section-copy">
        {page.lead}
      </p>
      <div class="transport__timeline">
        <span>Camping</span><i></i><span>{timeline.tram}</span><i></i><span>{timeline.center}</span>
      </div>
      <article class="transport__assistant premium-card">
        <span class="transport__assistant-icon" aria-hidden="true">
          <Icon name="tram" size={23} />
        </span>
        <div>
          <h3>{smartTram.title}</h3>
          <p>{smartTram.copy}</p>
          <div class="transport__assistant-points">
            {smartTram.points.map((point) => <span>{point}</span>)}
          </div>
          <div class="transport__assistant-actions">
            <a href={mapsRouteHref} target="_blank" rel="noopener noreferrer">{smartTram.maps}</a>
            <a href={jakdojadeHref} target="_blank" rel="noopener noreferrer">{smartTram.jakdojade}</a>
          </div>
        </div>
      </article>
      <a class="transport__link" href={getLocalizedPath(explicitLanguage, 'dojazd')}>{t.cta.directions}</a>
    </div>
    <div class="premium-card transport__panel">
      <h3>{page.highlights[3].title}</h3>
      <p>{page.highlights[3].copy}</p>
      <div class="transport__note">{imageLabels.note}</div>
      <div class="transport__media">
        <ImageFrame src={siteAssets.transport.tramToCenter} alt={imageLabels.tram} label={imageLabels.tram} />
        <ImageFrame src={siteAssets.transport.ticketMachine} alt={imageLabels.tickets} label={imageLabels.tickets} />
        <ImageFrame src={siteAssets.transport.googleMaps} alt={imageLabels.map} label={imageLabels.map} />
        <ImageFrame src={siteAssets.transport.jakdojade} alt={imageLabels.app} label={imageLabels.app} />
      </div>
    </div>
  </div>
</section>

<style>
.transport {
  position: relative;
  overflow: hidden;
  background:
    radial-gradient(circle at 14% 10%, rgba(60,179,113,.24), transparent 34%),
    radial-gradient(circle at 86% 20%, rgba(242,192,120,.12), transparent 32%),
    linear-gradient(180deg, #101b14, #14261a 58%, #f6f8f2);
}
.transport::before {
  content: '';
  position: absolute;
  inset: 0;
  opacity: .16;
  pointer-events: none;
  background:
    repeating-linear-gradient(135deg, rgba(255,255,255,.08) 0 1px, transparent 1px 34px),
    linear-gradient(90deg, transparent, rgba(60,179,113,.16), transparent);
  mask-image: radial-gradient(circle at 54% 34%, #000, transparent 70%);
}
.transport .section-title { color: #fff; }
.transport .section-copy { color: rgba(255,255,255,.78); }
.transport .section-kicker { color: #8fe0b4; }
.transport__timeline { margin-top: 34px; display: flex; flex-wrap: wrap; align-items: center; gap: 12px; color: #fff; font-weight: 900; }
.transport__timeline span { padding: 13px 16px; border-radius: 999px; background: rgba(255,255,255,.11); border: 1px solid rgba(255,255,255,.14); }
.transport__timeline i { width: 34px; height: 2px; background: rgba(143,224,180,.7); }
.transport__assistant {
  display: grid;
  grid-template-columns: auto minmax(0, 1fr);
  gap: 16px;
  margin-top: 24px;
  padding: 20px;
  border-color: rgba(143,224,180,.18);
  background:
    radial-gradient(circle at 12% 0%, rgba(60,179,113,.22), transparent 34%),
    rgba(255,255,255,.10);
  color: #fff;
}
.transport__assistant-icon {
  display: grid;
  width: 52px;
  height: 52px;
  place-items: center;
  border-radius: 18px;
  color: #fff;
  background: linear-gradient(135deg, rgba(60,179,113,.95), rgba(36,121,78,.72));
  box-shadow: 0 16px 36px rgba(60,179,113,.24);
}
.transport__assistant h3 { margin: 0 0 8px; color: #fff; font-size: 1.18rem; font-weight: 950; }
.transport__assistant p { margin: 0; color: rgba(255,255,255,.76); line-height: 1.62; font-weight: 760; }
.transport__assistant-points { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 14px; }
.transport__assistant-points span {
  padding: 8px 10px;
  border-radius: 999px;
  border: 1px solid rgba(143,224,180,.20);
  background: rgba(255,255,255,.07);
  color: rgba(255,255,255,.82);
  font-size: .78rem;
  font-weight: 900;
}
.transport__assistant-actions { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 14px; }
.transport__assistant-actions a {
  display: inline-flex;
  min-height: 38px;
  align-items: center;
  padding: 0 12px;
  border-radius: 999px;
  color: #092016;
  background: #8fe0b4;
  font-size: .82rem;
  font-weight: 950;
}
.transport__assistant-actions a + a {
  color: #fff;
  background: rgba(255,255,255,.12);
}
.transport__link { display: inline-flex; margin-top: 24px; color: #8fe0b4; font-weight: 950; }
.transport__link:hover { color: #fff; }
.transport__panel { min-width: 0; padding: 34px; background: linear-gradient(145deg, rgba(255,255,255,.12), rgba(255,255,255,.055)); border-color: rgba(255,255,255,.14); color: #fff; overflow: hidden; }
.transport__panel h3 { color: #fff; font-size: 1.7rem; font-weight: 900; margin-bottom: 16px; }
.transport__panel p { color: rgba(255,255,255,.78); line-height: 1.75; }
.transport__note { margin-top: 28px; color: #8fe0b4; font-weight: 900; }
.transport__media { margin-top: 26px; display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 14px; min-width: 0; }
.transport__media :global(.asset-frame) { width: 100%; min-width: 0; min-height: 170px; box-shadow: 0 18px 48px rgba(0,0,0,.18); border-radius: 24px; }
.transport__media :global(.asset-frame:nth-child(1)) { grid-column: span 2; min-height: 250px; border-radius: 30px 26px 24px 30px; }
.transport__media :global(.asset-frame:nth-child(2)),
.transport__media :global(.asset-frame:nth-child(3)),
.transport__media :global(.asset-frame:nth-child(4)) { min-height: 178px; }
@media (max-width: 620px) {
  .transport__media { grid-template-columns: 1fr; }
  .transport__media :global(.asset-frame:nth-child(n)) {
    grid-column: auto;
    min-height: 220px;
    border-radius: 24px;
  }
}
</style>
