const active =
  content[lang as keyof typeof content]
  ?? coreLegalContent[lang as keyof typeof coreLegalContent]
  ?? content.en;
const page = pageSlug === 'regulamin' ? active.rules : active.privacy;
---

<section class="site-section legal-page reveal-section">
  <div class="container legal-page__shell">
    <div class="premium-card legal-page__notice">
      <span aria-hidden="true"><Icon name="warning" size={22} strokeWidth={2} /></span>
      <p>{page.note}</p>
    </div>

    <div class="legal-page__grid">
      {page.sections.map(([title, items], index) => (
        <article class="premium-card legal-page__section reveal-section" style={`--reveal-delay: ${index * 45}ms`}>
          <span>{String(index + 1).padStart(2, '0')}</span>
          <h2>{title}</h2>
          <ul>
            {items.map((item) => <li>{item}</li>)}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
.legal-page {
  background:
    radial-gradient(circle at 14% 8%, rgba(60,179,113,.16), transparent 30%),
    linear-gradient(180deg, var(--color-bg-primary), var(--color-bg-secondary));
}

.legal-page__shell {
  display: grid;
  gap: clamp(22px, 4vw, 34px);
}

.legal-page__notice {
  display: flex;
  gap: 14px;
  align-items: flex-start;
  padding: clamp(20px, 3vw, 28px);
  border-color: rgba(242,192,120,.28);
  background:
    radial-gradient(circle at 92% 10%, rgba(242,192,120,.18), transparent 34%),
    var(--color-surface-glass);
}

.legal-page__notice span {
  width: 44px;
  height: 44px;
  flex: 0 0 44px;
  display: grid;
  place-items: center;
  border-radius: 16px;
  color: #fff;
  background: linear-gradient(135deg, rgba(242,192,120,.82), rgba(60,179,113,.72));
  box-shadow: 0 18px 44px rgba(60,179,113,.18);
}

.legal-page__notice p {
  margin: 0;
  color: var(--color-text-secondary);
  line-height: 1.7;
  font-weight: 750;
}

.legal-page__grid {
  display: grid;
  gap: 16px;
}

.legal-page__section {
  padding: clamp(22px, 4vw, 34px);
  border-radius: 28px;
}

.legal-page__section span {
  display: inline-flex;
  margin-bottom: 14px;
  color: var(--color-primary);
  font-size: .74rem;
  font-weight: 950;
  letter-spacing: .16em;
}

.legal-page__section h2 {
  margin: 0 0 16px;
  color: var(--color-text-primary);
  font-size: clamp(1.25rem, 2.4vw, 1.8rem);
  line-height: 1.12;
}

.legal-page__section ul {
  margin: 0;
  padding-left: 1.1rem;
  color: var(--color-text-secondary);
  line-height: 1.72;
}

.legal-page__section li + li {
  margin-top: 8px;
}

@media (min-width: 900px) {
  .legal-page__grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}
</style>
