---
import Icon from '@/components/ui/Icon.astro';
import { resolveContentLanguage } from '@/i18n/config';

interface Props {
  pageSlug: 'regulamin' | 'polityka-prywatnosci';
  languageCode?: string;
}

const { pageSlug, languageCode } = Astro.props as Props;
const lang = resolveContentLanguage(languageCode);

const content = {
  pl: {
    rules: {
      note: 'Regulamin na stronie ma charakter informacyjny; finalne zasady potwierdza recepcja / dokumenty obiektu.',
      sections: [
        ['Charakter obiektu', ['Camping Clepardia nie jest campingiem imprezowym.', 'Cisza nocna obowiązuje od 22:00 do 07:00.', 'Goście planujący imprezy powinni wybrać inne miejsce.']],
        ['Przyjazd i rejestracja', ['Po przyjeździe zatrzymaj się przy recepcji lub na parkingu.', 'Personel wskaże miejsce i oprowadzi po campingu.', 'Rejestracja odbywa się po wskazaniu miejsca.', 'Do nawigacji zalecamy Google Maps, ponieważ trasa dojazdu zmieniła się w 2022 roku.']],
        ['Doba hotelowa/campingowa', ['Camping: 12:00–12:00.', 'Domki: check-in od 16:00.', 'Domki: check-out do 11:00.']],
        ['Miejsca campingowe', ['Kampery ustawiamy głównie na płytach betonowych.', 'Busy, trucki, autobusy i ciężkie pojazdy ustawiamy na asfalcie, aby uniknąć zakopania pojazdu.', 'Dostęp do trawy jest możliwy zgodnie ze wskazaniem obsługi.']],
        ['Domki', ['Dostępne są tylko domki 2-, 3- i 4-osobowe.', 'Nie prowadzimy dodatkowych kategorii poza domkami 2-, 3- i 4-osobowymi.', 'Dostępność domków potwierdza recepcja.']],
        ['Prąd', ['Prąd jest płatny według cennika.', 'Przyłącze jest przeznaczone dla kamperów i przyczep.', 'Nie wolno ładować samochodów elektrycznych ani hybrydowych.', 'Nie należy podłączać urządzeń o bardzo dużym poborze mocy.']],
        ['Psy', ['Pies przebywa bezpłatnie.', 'Prosimy sprzątać po psie.', 'Pies powinien pozostawać pod kontrolą opiekuna.']],
        ['Bezpieczeństwo i porządek', ['Dbamy o spokój innych gości.', 'Prosimy dbać o wyposażenie i porządek.', 'Rzeczy w lodówkach i kuchni turystycznej należy pilnować samodzielnie.']],
        ['Faktury', ['Faktury wystawiamy wyłącznie dla firm zarejestrowanych w Polsce.', 'Nie wystawiamy faktur dla podmiotów zagranicznych.']],
        ['Rezerwacje i dostępność', ['Kalkulator pokazuje cenę orientacyjną.', 'Finalną dostępność i cenę potwierdza recepcja.', 'W sezonie letnim rezerwacje pola campingowego mogą być ograniczone.']],
      ],
    },
    privacy: {
      note: 'Dane administratora do uzupełnienia przed publikacją produkcyjną.',
      sections: [
        ['Administrator danych', ['Administratorem danych jest Camping Clepardia. Dane administratora wymagają uzupełnienia przed publikacją produkcyjną.', 'Kontakt w sprawie danych i zapytań: clepardia@gmail.com.']],
        ['Zakres danych', ['Formularz może zbierać imię i nazwisko, email, telefon, kraj, język kontaktu, termin pobytu, typ pobytu, liczbę osób, dodatki i treść wiadomości.', 'Nie należy przesyłać danych wrażliwych przez formularz.']],
        ['Cel przetwarzania', ['Dane wykorzystujemy do odpowiedzi na zapytanie o dostępność, cenę i szczegóły pobytu.', 'Dane mogą posłużyć do przygotowania korespondencji mailowej z recepcją.']],
        ['Cookies i analityka', ['Jeśli zostanie wdrożona analityka lub dodatkowe narzędzia cookies, sekcja wymaga aktualizacji.', 'Na obecnym etapie polityka jest bezpiecznym draftem informacyjnym.']],
        ['Okres i bezpieczeństwo', ['Dane przechowujemy tylko tak długo, jak jest to potrzebne do obsługi zapytania i kontaktu z gościem.', 'Nie publikujemy danych gości na stronie.']],
      ],
    },
  },
  en: {
    rules: {
      note: 'The website rules are informational; final rules are confirmed by reception / property documents.',
      sections: [
        ['Property character', ['Camping Clepardia is not a party campsite.', 'Quiet hours are from 22:00 to 07:00.', 'Guests planning parties should choose another place.']],
        ['Arrival and registration', ['After arrival, stop near reception or the parking area.', 'Staff will show you your place and guide you around the campsite.', 'Registration is completed after the place is indicated.', 'We recommend Google Maps because the access route changed in 2022.']],
        ['Check-in and check-out', ['Camping: 12:00–12:00.', 'Bungalows: check-in from 16:00.', 'Bungalows: check-out by 11:00.']],
        ['Camping pitches', ['Camper pitches are mostly concrete slabs.', 'Vans, trucks, buses and heavy vehicles are placed on asphalt to avoid getting stuck.', 'Grass access is possible as indicated by staff.']],
        ['Bungalows', ['Only 2-, 3- and 4-person bungalows are available.', 'No additional categories are offered beyond 2-, 3- and 4-person bungalows.', 'Reception confirms bungalow availability.']],
        ['Electricity', ['Electricity is charged according to the price list.', 'The hook-up is intended for campers and caravans.', 'Charging electric or hybrid cars is not allowed.', 'Do not connect very high-power devices.']],
        ['Dogs', ['Dogs stay free of charge.', 'Please clean up after your dog.', 'Dogs should remain under the owner’s control.']],
        ['Safety and order', ['Please respect the calm of other guests.', 'Please take care of equipment and order.', 'Guests are responsible for their belongings in fridges and the tourist kitchen.']],
        ['Invoices', ['Invoices are issued only to companies registered in Poland.', 'We do not issue invoices to foreign entities.']],
        ['Bookings and availability', ['The calculator shows an indicative price.', 'Final availability and price are confirmed by reception.', 'In summer, campsite pitch bookings may be limited.']],
      ],
    },
    privacy: {
      note: 'Administrator details to be completed before production publication.',
      sections: [
        ['Data administrator', ['The data administrator is Camping Clepardia. Full administrator details must be completed before production publication.', 'Contact for data and enquiries: clepardia@gmail.com.']],
        ['Data scope', ['The form may collect name, email, phone, country, contact language, stay dates, stay type, number of guests, extras and message content.', 'Please do not send sensitive data through the form.']],
        ['Purpose', ['Data is used to answer your availability, price and stay details enquiry.', 'Data may be used to prepare reception email correspondence.']],
        ['Cookies and analytics', ['If analytics or additional cookie tools are implemented, this section must be updated.', 'At this stage the policy is a safe informational draft.']],
        ['Retention and security', ['Data is kept only as long as needed to handle the enquiry and guest contact.', 'Guest data is not published on the website.']],
      ],
    },
  },
  de: {
    rules: {
      note: 'Die Regeln auf der Website sind informativ; endgültige Regeln bestätigt die Rezeption / Objektdokumente.',
      sections: [
        ['Charakter des Objekts', ['Camping Clepardia ist kein Party-Campingplatz.', 'Die Nachtruhe gilt von 22:00 bis 07:00.', 'Gäste, die Partys planen, sollten einen anderen Ort wählen.']],
        ['Ankunft und Anmeldung', ['Halten Sie nach der Ankunft nahe der Rezeption oder am Parkplatz.', 'Das Team zeigt Ihnen den Platz und erklärt den Campingplatz.', 'Die Anmeldung erfolgt nach der Platzzuweisung.', 'Wir empfehlen Google Maps, da sich die Zufahrt 2022 geändert hat.']],
        ['Aufenthaltszeiten', ['Camping: 12:00–12:00.', 'Bungalows: Check-in ab 16:00.', 'Bungalows: Check-out bis 11:00.']],
        ['Stellplätze', ['Wohnmobile stehen überwiegend auf Betonplatten.', 'Vans, Lkw, Busse und schwere Fahrzeuge werden auf Asphalt platziert, um ein Festfahren zu vermeiden.', 'Zugang zur Wiese ist nach Anweisung des Teams möglich.']],
        ['Bungalows', ['Es gibt nur 2-, 3- und 4-Personen-Bungalows.', 'Es werden keine zusätzlichen Kategorien außer 2-, 3- und 4-Personen-Bungalows angeboten.', 'Die Verfügbarkeit bestätigt die Rezeption.']],
        ['Strom', ['Strom wird gemäß Preisliste berechnet.', 'Der Anschluss ist für Wohnmobile und Wohnwagen vorgesehen.', 'Das Laden von Elektro- oder Hybridautos ist nicht erlaubt.', 'Sehr leistungsstarke Geräte dürfen nicht angeschlossen werden.']],
        ['Hunde', ['Hunde bleiben kostenlos.', 'Bitte räumen Sie nach dem Hund auf.', 'Hunde müssen unter Kontrolle bleiben.']],
        ['Sicherheit und Ordnung', ['Bitte respektieren Sie die Ruhe anderer Gäste.', 'Bitte achten Sie auf Ausstattung und Ordnung.', 'Gäste achten selbst auf ihre Sachen in Kühlschränken und Küche.']],
        ['Rechnungen', ['Rechnungen stellen wir nur für in Polen registrierte Firmen aus.', 'Für ausländische Unternehmen stellen wir keine Rechnungen aus.']],
        ['Buchungen und Verfügbarkeit', ['Der Rechner zeigt einen Richtpreis.', 'Endgültige Verfügbarkeit und Preis bestätigt die Rezeption.', 'Im Sommer können Stellplatzbuchungen begrenzt sein.']],
      ],
    },
    privacy: {
      note: 'Administratorangaben vor Produktionsveröffentlichung zu ergänzen.',
      sections: [
        ['Datenadministrator', ['Datenadministrator ist Camping Clepardia. Vollständige Angaben sind vor der Produktionsveröffentlichung zu ergänzen.', 'Kontakt für Daten und Anfragen: clepardia@gmail.com.']],
        ['Datenumfang', ['Das Formular kann Name, E-Mail, Telefon, Land, Kontaktsprache, Aufenthaltsdaten, Aufenthaltsart, Gästezahl, Extras und Nachricht erfassen.', 'Bitte senden Sie keine sensiblen Daten über das Formular.']],
        ['Zweck', ['Die Daten dienen der Beantwortung Ihrer Anfrage zu Verfügbarkeit, Preis und Aufenthalt.', 'Die Daten können zur Vorbereitung der E-Mail-Korrespondenz mit der Rezeption genutzt werden.']],
        ['Cookies und Analytik', ['Wenn Analytik oder zusätzliche Cookie-Tools implementiert werden, muss diese Sektion aktualisiert werden.', 'Derzeit ist die Richtlinie ein sicherer Informationsentwurf.']],
        ['Speicherung und Sicherheit', ['Daten werden nur so lange gespeichert, wie es zur Bearbeitung der Anfrage nötig ist.', 'Gästedaten werden nicht auf der Website veröffentlicht.']],
      ],
    },
  },
  it: {
    rules: {
      note: 'Il regolamento sul sito è informativo; le regole finali sono confermate dalla reception / dai documenti della struttura.',
      sections: [
        ['Carattere della struttura', ['Camping Clepardia non è un camping per feste.', 'Il silenzio notturno vale dalle 22:00 alle 07:00.', 'Chi desidera fare festa dovrebbe scegliere un altro posto.']],
        ['Arrivo e registrazione', ['All’arrivo fermati vicino alla reception o al parcheggio.', 'Lo staff ti indicherà il posto e ti guiderà nel camping.', 'La registrazione avviene dopo l’indicazione del posto.', 'Consigliamo Google Maps perché l’accesso è cambiato nel 2022.']],
        ['Orari di soggiorno', ['Camping: 12:00–12:00.', 'Bungalow: check-in dalle 16:00.', 'Bungalow: check-out entro le 11:00.']],
        ['Piazzole', ['I camper sono posizionati principalmente su piastre in cemento.', 'Van, camion, autobus e veicoli pesanti vengono messi sull’asfalto per evitare che si blocchino.', 'L’accesso all’erba è possibile secondo le indicazioni dello staff.']],
        ['Bungalow', ['Sono disponibili solo bungalow da 2, 3 e 4 persone.', 'Non sono previste categorie aggiuntive oltre ai bungalow da 2, 3 e 4 persone.', 'La disponibilità è confermata dalla reception.']],
        ['Elettricità', ['L’elettricità è pagata secondo il listino.', 'L’allaccio è destinato a camper e roulotte.', 'Non è consentito caricare auto elettriche o ibride.', 'Non collegare dispositivi ad altissimo consumo.']],
        ['Cani', ['Il cane soggiorna gratuitamente.', 'Ti chiediamo di pulire dopo il cane.', 'Il cane deve restare sotto controllo.']],
        ['Sicurezza e ordine', ['Rispettiamo la tranquillità degli altri ospiti.', 'Ti chiediamo di avere cura delle attrezzature e dell’ordine.', 'Gli ospiti controllano autonomamente le proprie cose in frigo e cucina.']],
        ['Fatture', ['Emettiamo fatture solo per aziende registrate in Polonia.', 'Non emettiamo fatture per aziende estere.']],
        ['Prenotazioni e disponibilità', ['Il calcolatore mostra un prezzo indicativo.', 'Disponibilità e prezzo finali sono confermati dalla reception.', 'In estate le prenotazioni delle piazzole possono essere limitate.']],
      ],
    },
    privacy: {
      note: 'Dati dell’amministratore da completare prima della pubblicazione.',
      sections: [
        ['Amministratore dei dati', ['L’amministratore dei dati è Camping Clepardia. I dati completi devono essere completati prima della pubblicazione.', 'Contatto per dati e richieste: clepardia@gmail.com.']],
        ['Ambito dei dati', ['Il modulo può raccogliere nome, email, telefono, paese, lingua di contatto, date, tipo di soggiorno, numero di ospiti, extra e messaggio.', 'Non inviare dati sensibili tramite il modulo.']],
        ['Finalità', ['I dati sono usati per rispondere alla richiesta di disponibilità, prezzo e dettagli di soggiorno.', 'I dati possono servire per preparare la corrispondenza email con la reception.']],
        ['Cookie e analytics', ['Se verranno implementati analytics o ulteriori strumenti cookie, questa sezione dovrà essere aggiornata.', 'Ora la policy è una bozza informativa sicura.']],
        ['Conservazione e sicurezza', ['I dati sono conservati solo per il tempo necessario a gestire la richiesta.', 'I dati degli ospiti non sono pubblicati sul sito.']],
      ],
    },
  },
};

const active = content[lang];
const page = pageSlug === 'regulamin' ? active.rules : active.privacy;
---

<section class="site-section legal-page reveal-section">
  <div class="container legal-page__shell">
    <div class="premium-card legal-page__notice">
      <span aria-hidden="true"><Icon name="warning" size={22} strokeWidth={2} /></span>
      <p>{page.note}</p>
    </div>

    <div class="legal-page__grid">
      {page.sections.map(([title, items], index) => (
        <article class="premium-card legal-page__section reveal-section" style={`--reveal-delay: ${index * 45}ms`}>
          <span>{String(index + 1).padStart(2, '0')}</span>
          <h2>{title}</h2>
          <ul>
            {items.map((item) => <li>{item}</li>)}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
.legal-page {
  background:
    radial-gradient(circle at 14% 8%, rgba(60,179,113,.16), transparent 30%),
    linear-gradient(180deg, var(--color-bg-primary), var(--color-bg-secondary));
}

.legal-page__shell {
  display: grid;
  gap: clamp(22px, 4vw, 34px);
}

.legal-page__notice {
  display: flex;
  gap: 14px;
  align-items: flex-start;
  padding: clamp(20px, 3vw, 28px);
  border-color: rgba(242,192,120,.28);
  background:
    radial-gradient(circle at 92% 10%, rgba(242,192,120,.18), transparent 34%),
    var(--color-surface-glass);
}

.legal-page__notice span {
  width: 44px;
  height: 44px;
  flex: 0 0 44px;
  display: grid;
  place-items: center;
  border-radius: 16px;
  color: #fff;
  background: linear-gradient(135deg, rgba(242,192,120,.82), rgba(60,179,113,.72));
  box-shadow: 0 18px 44px rgba(60,179,113,.18);
}

.legal-page__notice p {
  margin: 0;
  color: var(--color-text-secondary);
  line-height: 1.7;
  font-weight: 750;
}

.legal-page__grid {
  display: grid;
  gap: 16px;
}

.legal-page__section {
  padding: clamp(22px, 4vw, 34px);
  border-radius: 28px;
}

.legal-page__section span {
  display: inline-flex;
  margin-bottom: 14px;
  color: var(--color-primary);
  font-size: .74rem;
  font-weight: 950;
  letter-spacing: .16em;
}

.legal-page__section h2 {
  margin: 0 0 16px;
  color: var(--color-text-primary);
  font-size: clamp(1.25rem, 2.4vw, 1.8rem);
  line-height: 1.12;
}

.legal-page__section ul {
  margin: 0;
  padding-left: 1.1rem;
  color: var(--color-text-secondary);
  line-height: 1.72;
}

.legal-page__section li + li {
  margin-top: 8px;
}

@media (min-width: 900px) {
  .legal-page__grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}
</style>
