        tooMuch: ['Wieliczka + Auschwitz + pełny Kraków w 2 noce', 'Dalekie trasy typu Zakopane bez poświęcenia całego dnia', 'Zbyt późny start w centrum'],
        recommendation: 'Przy 2 nocach najlepiej połączyć centrum z Kazimierzem. Wieliczka jest możliwa, ale warto wtedy odpuścić część miasta albo dodać jeden dzień.',
        days: ['Dzień 1: Stare Miasto + Wawel + powrót tramwajem.', 'Dzień 2: Kazimierz albo Wieliczka, zależnie od energii ekipy.'],
      },
      '3': {
        comfortable: ['Kraków klasycznie: Stare Miasto, Wawel, Kazimierz', 'Wieliczka albo Auschwitz jako osobny dzień', 'Rodzinny dzień z wolniejszym tempem'],
        tooMuch: ['Wieliczka i Auschwitz dzień po dniu przy małych dzieciach', 'Zakopane jako dodatek bez bardzo wczesnego startu', 'Brak dnia zapasowego na pogodę'],
