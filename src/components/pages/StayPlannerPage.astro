---

<section class="site-section stay-planner reveal-section" data-stay-planner data-planner-config={plannerConfigEncoded}>
  <div class="stay-planner__ambient" aria-hidden="true"><span></span><span></span><span></span></div>
  <div class="container stay-planner__shell">
    <div class="stay-planner__head">
      <span class="section-kicker">{copy.kicker}</span>
      <h1>{copy.title}</h1>
      <p>{copy.lead}</p>
      <small>{copy.micro}</small>
    </div>

    <div class="premium-card stay-planner__quiz">
      <div>
        <h2>{copy.quizTitle}</h2>
        <p>{copy.quizCopy}</p>
      </div>
      <div class="stay-planner__scenario-grid">
        {copy.scenarios.map((scenario) => (
          <button
            type="button"
            data-planner-scenario={scenario.id}
            data-nights={scenario.nights}
            data-pace={scenario.pace}
            data-group={scenario.group}
            data-transport={scenario.transport}
            data-interests={scenario.interests.join(',')}
          >
            <Icon name={scenario.icon} size={22} strokeWidth={2} />
            <strong>{scenario.title}</strong>
            <span>{scenario.copy}</span>
          </button>
        ))}
      </div>
    </div>

    <section class="stay-planner__inspiration" aria-labelledby="stayPlannerInspirationTitle">
      <div class="stay-planner__inspiration-copy">
        <span class="section-kicker">{inspirationCopy.kicker}</span>
        <h2 id="stayPlannerInspirationTitle">{inspirationCopy.title}</h2>
      </div>
      <div class="stay-planner__inspiration-grid">
        {inspirationImages.map((image, index) => (
          <ImageFrame
            src={image.src}
            alt={inspirationCopy.items[index]}
            label={inspirationCopy.items[index]}
            className="stay-planner__inspiration-image"
            width={image.width}
            height={image.height}
            sizes={image.sizes}
          />
        ))}
      </div>
    </section>

    <WeatherCard languageCode={requestedLanguage} compact />
    <SummerCampingNotice languageCode={requestedLanguage} compact />

    <div class="stay-planner__layout">
      <div class="premium-card stay-planner__panel">
        <div class="stay-planner__control">
          <h2><Icon name="CalendarDays" size={21} strokeWidth={2} /> {copy.nights}</h2>
          <div class="stay-planner__segments" data-planner-nights>
            {['1', '2', '3', '4', '5+'].map((value, index) => (
              <button type="button" class:list={[index === 1 && 'is-active']} data-value={value}>{value}</button>
            ))}
          </div>
        </div>

        <label class="stay-planner__control stay-planner__date">
          <h2><Icon name="CalendarClock" size={21} strokeWidth={2} /> {copy.date}</h2>
          <input type="date" data-planner-date />
        </label>

        <div class="stay-planner__control">
          <h2><Icon name="Gauge" size={21} strokeWidth={2} /> {copy.pace}</h2>
          <div class="stay-planner__segments" data-planner-pace>
            {[
              ['calm', copy.options.calm],
              ['normal', copy.options.normal],
              ['intensive', copy.options.intensive],
            ].map(([value, label], index) => (
              <button type="button" class:list={[index === 1 && 'is-active']} data-value={value}>{label}</button>
            ))}
          </div>
        </div>

        <div class="stay-planner__control">
          <h2><Icon name="UsersRound" size={21} strokeWidth={2} /> {copy.group}</h2>
          <div class="stay-planner__segments" data-planner-group>
            {[
              ['pair', copy.options.pair],
              ['family', copy.options.family],
              ['solo', copy.options.solo],
              ['group', copy.options.group],
            ].map(([value, label], index) => (
              <button type="button" class:list={[index === 1 && 'is-active']} data-value={value}>{label}</button>
            ))}
          </div>
        </div>

        <div class="stay-planner__control">
          <h2><Icon name="Baby" size={21} strokeWidth={2} /> {copy.children}</h2>
          <div class="stay-planner__segments" data-planner-children>
            <button type="button" class="is-active" data-value="yes">{copy.options.yes}</button>
            <button type="button" data-value="no">{copy.options.no}</button>
          </div>
        </div>

        <div class="stay-planner__control">
          <h2><Icon name="TramFront" size={21} strokeWidth={2} /> {copy.transport}</h2>
          <div class="stay-planner__segments" data-planner-transport>
            {[
              ['tram', copy.options.tram],
              ['car', copy.options.car],
              ['mixed', copy.options.mixed],
            ].map(([value, label], index) => (
              <button type="button" class:list={[index === 0 && 'is-active']} data-value={value}>{label}</button>
            ))}
          </div>
        </div>

        <div class="stay-planner__control stay-planner__control--wide">
          <h2><Icon name="Sparkles" size={21} strokeWidth={2} /> {copy.interests}</h2>
          <div class="stay-planner__attractions" data-planner-interests>
            {copy.interestsList.map(([value, label], index) => (
              <button type="button" data-value={value} class:list={[index < 2 && 'is-active']}>
                <Icon name={value === 'kids' ? 'HeartHandshake' : value === 'nature' ? 'Leaf' : value === 'tours' ? 'Ticket' : value === 'history' ? 'Landmark' : 'Map'} size={18} strokeWidth={2} />
                <span>{label}</span>
              </button>
            ))}
          </div>
        </div>

        <div class="stay-planner__control stay-planner__control--wide">
          <h2><Icon name="MapPinned" size={21} strokeWidth={2} /> {copy.trips}</h2>
          <div class="stay-planner__attractions" data-planner-trips>
            {copy.tripList.map(([value, label], index) => <button type="button" data-value={value} class:list={[index === 0 && 'is-active']}><Icon name={value === 'none' ? 'Minus' : 'Route'} size={17} /><span>{label}</span></button>)}
          </div>
        </div>

        <div class="stay-planner__control stay-planner__control--wide">
          <h2><Icon name="CloudSun" size={21} strokeWidth={2} /> {copy.weatherPreference}</h2>
          <div class="stay-planner__segments" data-planner-weather>
            <button type="button" class="is-active" data-value="flexible">{copy.options.flexible}</button>
            <button type="button" data-value="sun">{copy.options.sun}</button>
            <button type="button" data-value="indoor">{copy.options.indoor}</button>
          </div>
        </div>

        <button class="stay-planner__generate" type="button" data-planner-generate><Icon name="Sparkles" size={18} /> {copy.generate}</button>
      </div>

      <aside class="premium-card stay-planner__result" data-planner-result aria-live="polite"></aside>
    </div>

    <div class="stay-planner__extras">
      <article class="premium-card stay-planner__today">
        <Icon name="SunMedium" size={24} strokeWidth={2} />
        <div>
          <h2>{copy.todayTitle}</h2>
          <p>{copy.todayCopy}</p>
        </div>
      </article>
      <article class="premium-card stay-planner__arrival">
        <Icon name="BadgeCheck" size={24} strokeWidth={2} />
        <div>
          <h2>{copy.arrivalTitle}</h2>
          <ul>
            {copy.arrivalItems.map((item) => <li>{item}</li>)}
          </ul>
        </div>
      </article>
    </div>

    <div class="stay-planner__actions">
      <a class="btn btn-primary premium-button" href={bookingHref}><Icon name="CalendarCheck" size={18} strokeWidth={2} /> {copy.ctaBooking}</a>
      <button class="btn btn-glass" type="button" data-ask-campy-planner><Icon name="BotMessageSquare" size={18} strokeWidth={2} /> {copy.ctaCampy}</button>
      <a class="btn btn-glass" href={transportHref}><Icon name="TramFront" size={18} strokeWidth={2} /> {copy.ctaTram}</a>
      <a class="btn btn-glass" href={attractionsHref}><Icon name="Map" size={18} strokeWidth={2} /> {copy.ctaAttractions}</a>
      <a class="btn btn-glass" href={tourBookingHref} target="_blank" rel="noopener noreferrer"><Icon name="Ticket" size={18} strokeWidth={2} /> {tourUi[0]}</a>
    </div>
  </div>
</section>


<script>
  import { initStayPlanner } from '@/scripts/stayPlannerClient.js';
  initStayPlanner();
</script>

<style>
.stay-planner {
  position: relative;
  overflow: hidden;
  padding-top: clamp(130px, 16vw, 190px);
  background:
    radial-gradient(circle at 14% 12%, rgba(60,179,113,.16), transparent 32%),
    radial-gradient(circle at 86% 8%, rgba(242,192,120,.15), transparent 34%),
    linear-gradient(180deg, rgba(8,25,16,.95), rgba(239,247,240,.08));
}

.stay-planner__ambient span {
  position: absolute;
  border-radius: 999px;
  filter: blur(22px);
  pointer-events: none;
  animation: plannerFloat 20s ease-in-out infinite;
}

.stay-planner__ambient span:nth-child(1) {
  width: 360px;
  height: 360px;
  left: -120px;
  top: 14%;
  background: rgba(60,179,113,.18);
}

.stay-planner__ambient span:nth-child(2) {
  width: 300px;
  height: 300px;
  right: -90px;
  top: 20%;
  background: rgba(242,192,120,.15);
  animation-delay: -8s;
}

.stay-planner__ambient span:nth-child(3) {
  width: 260px;
  height: 260px;
  right: 28%;
  bottom: 8%;
  background: rgba(143,224,180,.12);
  animation-delay: -13s;
}

.stay-planner__shell {
  position: relative;
  z-index: 1;
}

.stay-planner__head {
  max-width: 980px;
  margin-bottom: clamp(28px, 5vw, 54px);
}

.stay-planner__head h1 {
  max-width: 940px;
  margin: 0 0 18px;
  color: #f7fff9;
  font-size: clamp(2.5rem, 6.6vw, 5.6rem);
  line-height: .94;
  letter-spacing: 0;
}

.stay-planner__head p {
  max-width: 820px;
  margin: 0;
  color: rgba(245,255,248,.76);
  font-size: clamp(1rem, 2vw, 1.18rem);
  line-height: 1.75;
  font-weight: 680;
}

.stay-planner__head small {
  display: inline-flex;
  max-width: 720px;
  margin-top: 18px;
  padding: 10px 14px;
  border: 1px solid rgba(143,224,180,.20);
  border-radius: 999px;
  color: #bff7d7;
  background: rgba(143,224,180,.09);
  font-weight: 850;
}

.stay-planner__quiz,
.stay-planner__panel,
.stay-planner__result,
.stay-planner__today,
.stay-planner__arrival {
  border-radius: 30px;
  border-color: rgba(143,224,180,.18);
  background:
    radial-gradient(circle at 14% 0%, rgba(60,179,113,.18), transparent 38%),
    rgba(9, 28, 19, .74);
  backdrop-filter: blur(22px);
}

.stay-planner__quiz {
  display: grid;
  gap: 22px;
  margin-bottom: 24px;
  padding: clamp(22px, 4vw, 34px);
  color: #fff;
}

.stay-planner__inspiration {
  display: grid;
  gap: 18px;
  margin: 0 0 24px;
}

.stay-planner__inspiration-copy h2 {
  max-width: 760px;
  margin: 8px 0 0;
  color: #f7fff9;
  font-size: clamp(1.45rem, 3vw, 2.4rem);
  line-height: 1.08;
}

.stay-planner__inspiration-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14px;
}

:global(.stay-planner__inspiration-image.photo-frame) {
  min-height: 190px;
  border-radius: 24px;
}

.stay-planner__quiz h2,
.stay-planner__today h2,
.stay-planner__arrival h2 {
  margin: 0 0 8px;
  color: #fff;
  font-size: clamp(1.4rem, 3vw, 2.1rem);
}

.stay-planner__quiz p,
.stay-planner__today p {
  margin: 0;
  color: rgba(245,255,248,.72);
  line-height: 1.65;
}

.stay-planner__scenario-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 12px;
}

.stay-planner__scenario-grid button {
  min-height: 126px;
  display: grid;
  gap: 9px;
  justify-items: start;
  padding: 20px;
  border: 1px solid rgba(143,224,180,.18);
  border-radius: 24px;
  color: #f7fff9;
  background:
    radial-gradient(circle at 20% 0%, rgba(255,255,255,.13), transparent 40%),
    rgba(255,255,255,.07);
  text-align: left;
  transition: transform .22s ease, border-color .22s ease, box-shadow .22s ease, background .22s ease;
}

.stay-planner__scenario-grid button:hover {
  transform: translateY(-3px);
  border-color: rgba(143,224,180,.42);
  background: rgba(143,224,180,.12);
  box-shadow: 0 20px 46px rgba(60,179,113,.18);
}

.stay-planner__scenario-grid svg {
  color: #8fe0b4;
}

.stay-planner__scenario-grid strong {
  font-size: 1.02rem;
  font-weight: 950;
}

.stay-planner__scenario-grid span {
  color: rgba(245,255,248,.70);
  line-height: 1.5;
  font-weight: 760;
}

.stay-planner__layout {
  display: grid;
  gap: 24px;
  align-items: start;
}

.stay-planner__panel {
  display: grid;
  gap: 18px;
  padding: clamp(20px, 4vw, 34px);
}

.stay-planner__control {
  display: grid;
  gap: 12px;
}

.stay-planner__control h2 {
  display: inline-flex;
  align-items: center;
  gap: 9px;
  margin: 0;
  color: #f7fff9;
  font-size: 1rem;
}

.stay-planner__segments,
.stay-planner__attractions {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}

.stay-planner__segments button,
.stay-planner__attractions button {
  min-height: 46px;
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 0 15px;
  border: 1px solid rgba(143,224,180,.20);
  border-radius: 999px;
  color: rgba(245,255,248,.84);
  background: rgba(255,255,255,.07);
  font-weight: 900;
  transition: transform .18s ease, border-color .18s ease, background .18s ease, box-shadow .18s ease;
}

.stay-planner__segments button:hover,
.stay-planner__segments button.is-active,
.stay-planner__attractions button:hover,
.stay-planner__attractions button.is-active {
  transform: translateY(-2px);
  color: #082016;
  border-color: rgba(143,224,180,.58);
  background: linear-gradient(135deg, #a7f2c7, #3CB371);
  box-shadow: 0 16px 34px rgba(60,179,113,.22);
}

.stay-planner__result {
  position: static;
  padding: clamp(22px, 4vw, 32px);
  color: rgba(245,255,248,.84);
}

.stay-planner__result h2 {
  margin: 12px 0;
  color: #fff;
  font-size: clamp(1.45rem, 3vw, 2.2rem);
  line-height: 1.08;
}

.stay-planner__result p {
  color: rgba(245,255,248,.76);
  line-height: 1.65;
}

.stay-planner__result-badge {
  display: inline-flex;
  width: fit-content;
  padding: 7px 11px;
  border-radius: 999px;
  color: #8fe0b4;
  background: rgba(60,179,113,.12);
  font-size: .72rem;
  font-weight: 950;
  letter-spacing: .12em;
  text-transform: uppercase;
}

.stay-planner__result-grid {
  display: grid;
  gap: 12px;
  margin: 20px 0;
}

.stay-planner__result-grid section,
.stay-planner__context,
.stay-planner__plan > div {
  border: 1px solid rgba(143,224,180,.14);
  border-radius: 18px;
  background: rgba(255,255,255,.06);
}

.stay-planner__result-grid section {
  padding: 16px;
}

.stay-planner__result-grid strong,
.stay-planner__plan > strong {
  display: block;
  color: #8fe0b4;
  margin-bottom: 12px;
  font-weight: 950;
}

.stay-planner__result-grid ul,
.stay-planner__arrival ul {
  display: grid;
  gap: 9px;
  margin: 0;
  padding: 0;
  list-style: none;
}

.stay-planner__result-grid li,
.stay-planner__arrival li {
  position: relative;
  padding-left: 22px;
  color: rgba(245,255,248,.78);
  line-height: 1.5;
}

.stay-planner__result-grid li::before,
.stay-planner__arrival li::before {
  content: '';
  position: absolute;
  left: 0;
  top: .58em;
  width: 8px;
  height: 8px;
  border-radius: 999px;
  background: #3CB371;
  box-shadow: 0 0 0 5px rgba(60,179,113,.14);
}

.stay-planner__context {
  display: grid;
  gap: 8px;
  padding: 14px;
}

.stay-planner__context p {
  margin: 0;
}

.stay-planner__plan {
  display: grid;
  gap: 10px;
  margin-top: 18px;
}

.stay-planner__plan > div {
  display: grid;
  grid-template-columns: 34px 1fr;
  gap: 10px;
  align-items: start;
  padding: 12px;
}

.stay-planner__plan span {
  display: grid;
  place-items: center;
  width: 34px;
  height: 34px;
  border-radius: 12px;
  color: #082016;
  background: #8fe0b4;
  font-weight: 950;
}

.stay-planner__plan p {
  margin: 0;
}

.stay-planner__date input {
  min-height: 48px;
  width: 100%;
  padding: 0 14px;
  border: 1px solid rgba(143,224,180,.20);
  border-radius: 15px;
  color: #f7fff9;
  color-scheme: dark;
  background: rgba(255,255,255,.07);
  font: inherit;
  font-weight: 800;
}

.stay-planner__generate {
  grid-column: 1 / -1;
  min-height: 52px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 9px;
  border: 0;
  border-radius: 17px;
  color: #082016;
  background: linear-gradient(135deg,#a7f2c7,#3cb371);
  box-shadow: 0 16px 34px rgba(60,179,113,.2);
  font-weight: 950;
  cursor: pointer;
}

.stay-planner__day-card {
  display: grid;
  gap: 14px;
  padding: 17px;
  border: 1px solid rgba(143,224,180,.15);
  border-radius: 21px;
  background: linear-gradient(145deg,rgba(255,255,255,.075),rgba(255,255,255,.035));
}

.stay-planner__day-card header {
  display: grid;
  grid-template-columns: 42px minmax(0,1fr) auto;
  align-items: center;
  gap: 11px;
}

.stay-planner__day-card header>span {
  width: 42px;
  height: 42px;
  border-radius: 14px;
}

.stay-planner__day-card header small { color:#8fe0b4; font-size:.68rem; font-weight:900; text-transform:uppercase; letter-spacing:.1em; }
.stay-planner__day-card h3 { margin:2px 0 0; color:#fff; font-size:1.08rem; line-height:1.22; }
.stay-planner__day-card header em { padding:6px 9px; border-radius:999px; color:#bff7d7; background:rgba(60,179,113,.12); font-size:.7rem; font-style:normal; font-weight:850; }
.stay-planner__day-weather { width:fit-content!important; height:auto!important; display:inline-flex!important; padding:6px 10px; border-radius:999px!important; color:#dff9e9!important; background:rgba(75,172,223,.13)!important; font-size:.76rem; }
.stay-planner__day-flow { display:grid; grid-template-columns:repeat(3,minmax(0,1fr)); gap:9px; }
.stay-planner__day-flow p,.stay-planner__day-meta span,.stay-planner__rain { display:grid; gap:5px; padding:11px; border-radius:14px; color:rgba(245,255,248,.75); background:rgba(0,0,0,.12); line-height:1.45; font-size:.82rem; }
.stay-planner__day-flow b,.stay-planner__day-meta b,.stay-planner__rain b { color:#bff7d7; font-size:.7rem; letter-spacing:.03em; }
.stay-planner__day-meta { display:grid; grid-template-columns:1fr 1fr; gap:9px; }
.stay-planner__rain { margin:0!important; border:1px solid rgba(91,174,218,.16); background:rgba(45,112,153,.09); }
.stay-planner__day-card.is-rain-first .stay-planner__rain { order:-1; border-color:rgba(143,224,180,.3); }
.stay-planner__upsell { display:grid; grid-template-columns:auto minmax(0,1fr) auto; align-items:center; gap:14px; margin-top:18px; padding:18px; border:1px solid rgba(242,192,120,.24); border-radius:21px; background:linear-gradient(135deg,rgba(242,192,120,.12),rgba(60,179,113,.08)); }
.stay-planner__upsell>span { font-size:1.7rem; }
.stay-planner__upsell h3 { margin:0 0 5px; color:#fff; font-size:1rem; }
.stay-planner__upsell p { margin:0; font-size:.86rem; }
.stay-planner__upsell button { min-height:42px; padding:0 13px; border:0; border-radius:13px; color:#102018; background:#f2c078; font-weight:900; cursor:pointer; }

.stay-planner__extras {
  display: grid;
  gap: 16px;
  margin-top: 24px;
}

.stay-planner__today,
.stay-planner__arrival {
  display: grid;
  grid-template-columns: 42px minmax(0, 1fr);
  gap: 16px;
  padding: clamp(22px, 3vw, 30px);
  color: #fff;
}

.stay-planner__today > svg,
.stay-planner__arrival > svg {
  width: 42px;
  height: 42px;
  padding: 9px;
  border-radius: 16px;
  color: #082016;
  background: linear-gradient(135deg, #a7f2c7, #3CB371);
}

.stay-planner__actions {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  margin-top: 26px;
}

.stay-planner__actions .btn {
  display: inline-flex;
  align-items: center;
  gap: 9px;
}

html[data-theme="light"] .stay-planner {
  background:
    radial-gradient(circle at 14% 12%, rgba(60,179,113,.18), transparent 32%),
    radial-gradient(circle at 86% 8%, rgba(242,192,120,.16), transparent 34%),
    linear-gradient(180deg, #f7fbf5, #edf6ef);
}

html[data-theme="light"] .stay-planner__head h1,
html[data-theme="light"] .stay-planner__inspiration-copy h2,
html[data-theme="light"] .stay-planner__control h2,
html[data-theme="light"] .stay-planner__result h2,
html[data-theme="light"] .stay-planner__quiz h2,
html[data-theme="light"] .stay-planner__today h2,
html[data-theme="light"] .stay-planner__arrival h2 {
  color: #102018;
}

html[data-theme="light"] .stay-planner__head p,
html[data-theme="light"] .stay-planner__result,
html[data-theme="light"] .stay-planner__quiz p,
html[data-theme="light"] .stay-planner__today p {
  color: #52655a;
}

html[data-theme="light"] .stay-planner__head small {
  color: #0f6b3f;
  background: rgba(60,179,113,.10);
}

html[data-theme="light"] .stay-planner__quiz,
html[data-theme="light"] .stay-planner__panel,
html[data-theme="light"] .stay-planner__result,
html[data-theme="light"] .stay-planner__today,
html[data-theme="light"] .stay-planner__arrival {
  background: rgba(255,255,255,.80);
  border-color: rgba(60,179,113,.18);
}

html[data-theme="light"] .stay-planner__scenario-grid button,
html[data-theme="light"] .stay-planner__segments button,
html[data-theme="light"] .stay-planner__attractions button,
html[data-theme="light"] .stay-planner__result-grid section,
html[data-theme="light"] .stay-planner__context,
html[data-theme="light"] .stay-planner__plan > div {
  color: #263a2f;
  background: rgba(255,255,255,.76);
  border-color: rgba(29,83,52,.14);
}

html[data-theme="light"] .stay-planner__date input { color:#173126; color-scheme:light; background:#fff; border-color:#cfe3d6; }
html[data-theme="light"] .stay-planner__day-card { border-color:#d3e6da; background:#f8fcf9; }
html[data-theme="light"] .stay-planner__day-card h3,html[data-theme="light"] .stay-planner__upsell h3 { color:#102018; }
html[data-theme="light"] .stay-planner__day-flow p,html[data-theme="light"] .stay-planner__day-meta span,html[data-theme="light"] .stay-planner__rain { color:#536359; background:#eef7f1; }
html[data-theme="light"] .stay-planner__upsell { background:linear-gradient(135deg,#fff8ed,#f1fbf5); }

html[data-theme="light"] .stay-planner__scenario-grid span,
html[data-theme="light"] .stay-planner__result p,
html[data-theme="light"] .stay-planner__result-grid li,
html[data-theme="light"] .stay-planner__arrival li {
  color: #536359;
}

@media (min-width: 760px) {
  .stay-planner__scenario-grid,
  .stay-planner__extras {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .stay-planner__result-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

@media (min-width: 980px) {
  .stay-planner__layout {
    grid-template-columns: minmax(310px,.72fr) minmax(0,1.28fr);
  }

  .stay-planner__panel {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .stay-planner__control--wide {
    grid-column: 1 / -1;
  }
}

@media (min-width: 1180px) {
  .stay-planner__scenario-grid {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }
}

@media (max-width: 720px) {
  .stay-planner {
    padding-top: 116px;
  }

  .stay-planner__head h1 {
    font-size: clamp(2.25rem, 13vw, 3.5rem);
  }

  .stay-planner__head small {
    border-radius: 18px;
  }

  .stay-planner__result {
    position: static;
  }

  .stay-planner__day-flow,.stay-planner__day-meta { grid-template-columns:1fr; }
  .stay-planner__day-card header { grid-template-columns:38px minmax(0,1fr); }
  .stay-planner__day-card header em { grid-column:2; width:fit-content; }
  .stay-planner__upsell { grid-template-columns:auto minmax(0,1fr); }
  .stay-planner__upsell button { grid-column:1/-1; width:100%; }

  .stay-planner__inspiration-grid {
    grid-template-columns: 1fr;
  }

  :global(.stay-planner__inspiration-image.photo-frame) {
    min-height: 210px;
  }

  .stay-planner__ambient span {
    animation: none;
    filter: blur(14px);
    opacity: .55;
  }

  .stay-planner__today,
  .stay-planner__arrival {
    grid-template-columns: 1fr;
  }

  .stay-planner__actions .btn {
    width: 100%;
    justify-content: center;
  }
}

@media (prefers-reduced-motion: reduce) {
  .stay-planner__ambient span,
  .stay-planner__segments button,
  .stay-planner__attractions button,
  .stay-planner__scenario-grid button {
    animation: none !important;
    transition: none !important;
  }
}

@keyframes plannerFloat {
  0%, 100% { transform: translate3d(0, 0, 0) scale(1); }
  50% { transform: translate3d(22px, -18px, 0) scale(1.06); }
}

/* Planner Premium 3.0 */
.stay-planner__layout > *,
.planner-result-shell,
.stay-planner__day-list,
.planner-day-card,
.planner-day-card__heading {
  min-width: 0;
}

.stay-planner__panel {
  align-content: start;
}

.stay-planner__segments button.is-selecting,
.stay-planner__attractions button.is-selecting,
.stay-planner__scenario-grid button.is-selecting {
  animation: plannerSelectionPulse .36s cubic-bezier(.22,1,.36,1);
}

.stay-planner__result {
  overflow: clip;
  transition:
    height .52s cubic-bezier(.22,1,.36,1),
    opacity .17s ease,
    transform .17s cubic-bezier(.22,1,.36,1),
    filter .17s ease;
  will-change: height, opacity, transform, filter;
}

.stay-planner__result.is-exiting {
  opacity: 0;
  transform: translateY(12px);
  filter: blur(4px);
}

.planner-result-shell {
  display: grid;
  gap: 22px;
}

.planner-result-hero {
  position: relative;
  isolation: isolate;
  overflow: hidden;
  display: grid;
  gap: 13px;
  padding: clamp(20px,3vw,30px);
  border: 1px solid rgba(143,224,180,.22);
  border-radius: 26px;
  background:
    radial-gradient(circle at 92% 10%,rgba(242,192,120,.18),transparent 30%),
    linear-gradient(135deg,rgba(60,179,113,.16),rgba(7,28,19,.72));
  box-shadow: inset 0 1px rgba(255,255,255,.08), 0 24px 60px rgba(2,18,11,.18);
}

.planner-result-hero__glow {
  position: absolute;
  z-index: -1;
  width: 220px;
  height: 220px;
  top: -130px;
  right: 8%;
  border-radius: 50%;
  background: rgba(143,224,180,.24);
  filter: blur(26px);
  transform: translate3d(0,0,0);
}

.planner-result-hero h2 {
  max-width: 19ch;
  margin: 0;
  font-size: clamp(1.75rem,3.5vw,2.85rem);
  letter-spacing: -.035em;
}

.planner-result-hero__subtitle,
.planner-result-hero__summary {
  max-width: 72ch;
  margin: 0;
}

.planner-result-hero__subtitle {
  color: #bff7d7 !important;
  font-size: 1rem;
  font-weight: 850;
}

.planner-result-hero__summary {
  padding-top: 4px;
  font-size: .95rem;
}

.planner-result-hero__chips,
.planner-result-hero__signals {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.planner-result-hero__chips > span,
.planner-result-hero__signals > span {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  max-width: 100%;
  border: 1px solid rgba(143,224,180,.2);
  border-radius: 999px;
  color: #eafff1;
  background: rgba(3,21,13,.4);
  font-size: .76rem;
  font-weight: 850;
  line-height: 1.25;
}

.planner-result-hero__chips > span {
  min-height: 35px;
  padding: 7px 11px;
}

.planner-result-hero__signals > span {
  padding: 8px 11px;
  border-radius: 12px;
  color: rgba(245,255,248,.75);
}

.stay-planner__plan {
  gap: 14px;
  margin-top: 0;
}

.stay-planner__plan-heading {
  display: grid;
  grid-template-columns: 42px minmax(0,1fr) auto;
  align-items: center;
  gap: 12px;
  padding: 4px 2px;
}

.stay-planner__plan-heading > span,
.stay-planner__plan-heading > strong {
  display: grid;
  place-items: center;
  width: 42px;
  height: 42px;
  border-radius: 14px;
  color: #082016;
  background: linear-gradient(135deg,#bff7d7,#3cb371);
  font-size: 1rem;
  font-weight: 950;
}

.stay-planner__plan-heading small {
  color: #8fe0b4;
  font-size: .68rem;
  font-weight: 950;
  letter-spacing: .11em;
  text-transform: uppercase;
}

.stay-planner__plan-heading h3 {
  margin: 3px 0 0;
  color: #fff;
  font-size: clamp(1.08rem,2vw,1.35rem);
}

.stay-planner__day-list {
  display: grid;
  gap: 16px;
}

.planner-day-card.stay-planner__day-card {
  position: relative;
  gap: 18px;
  padding: clamp(17px,2.5vw,24px);
  border-color: rgba(143,224,180,.18);
  border-radius: 25px;
  background:
    linear-gradient(90deg,var(--planner-accent,rgba(60,179,113,.7)) 0 4px,transparent 4px),
    linear-gradient(145deg,rgba(255,255,255,.08),rgba(255,255,255,.025));
  box-shadow: inset 0 1px rgba(255,255,255,.055), 0 18px 42px rgba(0,0,0,.11);
  transition: transform .3s cubic-bezier(.22,1,.36,1), border-color .3s ease, box-shadow .3s ease;
}

.planner-day-card--emerald { --planner-accent:#3cb371; }
.planner-day-card--amber { --planner-accent:#f2c078; }
.planner-day-card--blue { --planner-accent:#65b7e6; }
.planner-day-card--forest { --planner-accent:#65c98f; }
.planner-day-card--mint { --planner-accent:#9ce8bd; }

.planner-day-card.stay-planner__day-card:hover {
  transform: translateY(-3px);
  border-color: rgba(143,224,180,.34);
  box-shadow: inset 0 1px rgba(255,255,255,.08), 0 24px 52px rgba(0,0,0,.18);
}

.planner-day-card__header {
  display: grid !important;
  grid-template-columns: 42px 42px minmax(0,1fr) auto !important;
  align-items: center;
  gap: 11px;
}

.planner-day-card__number,
.planner-day-card__icon {
  display: grid;
  place-items: center;
  width: 42px;
  height: 42px;
  border-radius: 14px;
}

.planner-day-card__number {
  color: #082016;
  background: linear-gradient(135deg,#d0f9e1,#55cf89);
  font-weight: 950;
  box-shadow: 0 9px 22px rgba(60,179,113,.2);
}

.planner-day-card__icon {
  border: 1px solid rgba(143,224,180,.18);
  background: rgba(255,255,255,.06);
  font-size: 1.18rem;
}

.planner-day-card__eyebrow {
  display: block;
  color: #8fe0b4;
  font-size: .67rem;
  font-weight: 950;
  letter-spacing: .1em;
  text-transform: uppercase;
}

.planner-day-card__heading h3 {
  margin: 3px 0 4px;
  overflow-wrap: anywhere;
  color: #fff;
  font-size: clamp(1.08rem,2vw,1.32rem);
  line-height: 1.18;
}

.planner-day-card__heading p {
  margin: 0;
  color: rgba(245,255,248,.66);
  font-size: .82rem;
  line-height: 1.48;
}

.planner-day-card__intensity,
.planner-day-card__weather {
  display: inline-flex;
  align-items: center;
  width: fit-content;
  padding: 7px 10px;
  border-radius: 999px;
  font-size: .7rem;
  font-weight: 900;
  line-height: 1.2;
}

.planner-day-card__intensity {
  color: #bff7d7;
  border: 1px solid rgba(143,224,180,.18);
  background: rgba(60,179,113,.12);
}

.planner-day-card__weather {
  color: #dff6ff;
  border: 1px solid rgba(101,183,230,.2);
  background: rgba(43,118,160,.12);
}

.planner-timeline,
.planner-practical {
  display: grid;
  gap: 10px;
}

.planner-timeline > h4,
.planner-practical > h4 {
  margin: 0;
  color: #bff7d7;
  font-size: .72rem;
  font-weight: 950;
  letter-spacing: .08em;
  text-transform: uppercase;
}

.planner-timeline__rail {
  position: relative;
  display: grid;
  grid-template-columns: repeat(3,minmax(0,1fr));
  gap: 10px;
}

.planner-timeline__rail::before {
  content: '';
  position: absolute;
  top: 20px;
  left: 12%;
  right: 12%;
  height: 1px;
  background: linear-gradient(90deg,transparent,rgba(143,224,180,.25),transparent);
}

.planner-timeline__item {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: 34px minmax(0,1fr);
  gap: 9px;
  align-items: start;
  min-height: 128px;
  padding: 12px;
  border: 1px solid rgba(143,224,180,.13);
  border-radius: 16px;
  background: rgba(1,16,10,.28);
}

.planner-timeline__icon {
  display: grid;
  place-items: center;
  width: 34px;
  height: 34px;
  border-radius: 11px;
  background: rgba(143,224,180,.1);
}

.planner-timeline__label,
.planner-practical__label {
  display: block;
  margin-bottom: 6px;
  color: #8fe0b4;
  font-size: .68rem;
  font-weight: 950;
  letter-spacing: .055em;
  text-transform: uppercase;
}

.planner-timeline__value {
  margin: 0 !important;
  color: rgba(245,255,248,.78) !important;
  font-size: .82rem;
  line-height: 1.5 !important;
