.planner-dialog { inset:0; width:94vw; height:92dvh; max-width:1580px; max-height:1000px; margin:auto!important; padding:0; overflow:hidden; border:1px solid rgba(103,233,159,.31); border-radius:28px; color:#f2fff7; background:#06271b; box-shadow:0 42px 130px rgba(0,0,0,.72); opacity:0; filter:blur(6px); transform:scale(.955) translateY(18px); transition:opacity .22s ease,transform .34s cubic-bezier(.22,1,.36,1),filter .3s ease; }
