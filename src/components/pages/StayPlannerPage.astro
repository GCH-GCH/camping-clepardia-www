<section class="site-section stay-planner reveal-section" data-stay-planner>
  <div class="stay-planner__ambient" aria-hidden="true"><span></span><span></span><span></span></div>
  <div class="container stay-planner__shell">
    <div class="stay-planner__head">
      <span class="section-kicker">{copy.kicker}</span>
      <h1>{copy.title}</h1>
      <p>{copy.lead}</p>
      <small>{copy.micro}</small>
    </div>

    <div class="premium-card stay-planner__quiz">
      <div>
        <h2>{copy.quizTitle}</h2>
        <p>{copy.quizCopy}</p>
      </div>
      <div class="stay-planner__scenario-grid">
        {copy.scenarios.map((scenario) => (
          <button
            type="button"
            data-planner-scenario={scenario.id}
            data-nights={scenario.nights}
            data-pace={scenario.pace}
            data-group={scenario.group}
            data-transport={scenario.transport}
            data-interests={scenario.interests.join(',')}
          >
            <Icon name={scenario.icon} size={22} strokeWidth={2} />
            <strong>{scenario.title}</strong>
            <span>{scenario.copy}</span>
          </button>
        ))}
      </div>
    </div>

    <section class="stay-planner__inspiration" aria-labelledby="stayPlannerInspirationTitle">
      <div class="stay-planner__inspiration-copy">
        <span class="section-kicker">{inspirationCopy.kicker}</span>
        <h2 id="stayPlannerInspirationTitle">{inspirationCopy.title}</h2>
      </div>
      <div class="stay-planner__inspiration-grid">
        {inspirationImages.map((image, index) => (
          <ImageFrame
            src={image.src}
            alt={inspirationCopy.items[index]}
            label={inspirationCopy.items[index]}
            className="stay-planner__inspiration-image"
            width={image.width}
            height={image.height}
            sizes={image.sizes}
          />
        ))}
      </div>
    </section>

    <WeatherCard languageCode={requestedLanguage} compact />
    <SummerCampingNotice languageCode={requestedLanguage} compact />

    <div class="stay-planner__layout">
      <div class="premium-card stay-planner__panel">
        <div class="stay-planner__control">
          <h2><Icon name="CalendarDays" size={21} strokeWidth={2} /> {copy.nights}</h2>
          <div class="stay-planner__segments" data-planner-nights>
            {['1', '2', '3', '4', '5+'].map((value, index) => (
              <button type="button" class:list={[index === 1 && 'is-active']} data-value={value}>{value}</button>
            ))}
          </div>
        </div>

        <label class="stay-planner__control stay-planner__date">
          <h2><Icon name="CalendarClock" size={21} strokeWidth={2} /> {copy.date}</h2>
          <input type="date" data-planner-date />
        </label>

        <div class="stay-planner__control">
          <h2><Icon name="Gauge" size={21} strokeWidth={2} /> {copy.pace}</h2>
          <div class="stay-planner__segments" data-planner-pace>
            {[
              ['calm', copy.options.calm],
              ['normal', copy.options.normal],
              ['intensive', copy.options.intensive],
            ].map(([value, label], index) => (
              <button type="button" class:list={[index === 1 && 'is-active']} data-value={value}>{label}</button>
            ))}
          </div>
        </div>

        <div class="stay-planner__control">
          <h2><Icon name="UsersRound" size={21} strokeWidth={2} /> {copy.group}</h2>
          <div class="stay-planner__segments" data-planner-group>
            {[
              ['pair', copy.options.pair],
              ['family', copy.options.family],
              ['solo', copy.options.solo],
              ['group', copy.options.group],
            ].map(([value, label], index) => (
              <button type="button" class:list={[index === 1 && 'is-active']} data-value={value}>{label}</button>
            ))}
          </div>
        </div>

        <div class="stay-planner__control">
          <h2><Icon name="Baby" size={21} strokeWidth={2} /> {copy.children}</h2>
          <div class="stay-planner__segments" data-planner-children>
            <button type="button" class="is-active" data-value="yes">{copy.options.yes}</button>
            <button type="button" data-value="no">{copy.options.no}</button>
          </div>
        </div>

        <div class="stay-planner__control">
          <h2><Icon name="TramFront" size={21} strokeWidth={2} /> {copy.transport}</h2>
          <div class="stay-planner__segments" data-planner-transport>
            {[
              ['tram', copy.options.tram],
              ['car', copy.options.car],
              ['mixed', copy.options.mixed],
            ].map(([value, label], index) => (
              <button type="button" class:list={[index === 0 && 'is-active']} data-value={value}>{label}</button>
            ))}
          </div>
        </div>

        <div class="stay-planner__control stay-planner__control--wide">
          <h2><Icon name="Sparkles" size={21} strokeWidth={2} /> {copy.interests}</h2>
          <div class="stay-planner__attractions" data-planner-interests>
            {copy.interestsList.map(([value, label], index) => (
              <button type="button" data-value={value} class:list={[index < 2 && 'is-active']}>
                <Icon name={value === 'kids' ? 'HeartHandshake' : value === 'nature' ? 'Leaf' : value === 'tours' ? 'Ticket' : value === 'history' ? 'Landmark' : 'Map'} size={18} strokeWidth={2} />
                <span>{label}</span>
              </button>
            ))}
          </div>
        </div>

        <div class="stay-planner__control stay-planner__control--wide">
          <h2><Icon name="MapPinned" size={21} strokeWidth={2} /> {copy.trips}</h2>
          <div class="stay-planner__attractions" data-planner-trips>
            {copy.tripList.map(([value, label], index) => <button type="button" data-value={value} class:list={[index === 0 && 'is-active']}><Icon name={value === 'none' ? 'Minus' : 'Route'} size={17} /><span>{label}</span></button>)}
          </div>
        </div>

        <div class="stay-planner__control stay-planner__control--wide">
          <h2><Icon name="CloudSun" size={21} strokeWidth={2} /> {copy.weatherPreference}</h2>
          <div class="stay-planner__segments" data-planner-weather>
            <button type="button" class="is-active" data-value="flexible">{copy.options.flexible}</button>
            <button type="button" data-value="sun">{copy.options.sun}</button>
            <button type="button" data-value="indoor">{copy.options.indoor}</button>
          </div>
        </div>

        <button class="stay-planner__generate" type="button" data-planner-generate><Icon name="Sparkles" size={18} /> {copy.generate}</button>
      </div>

      <aside class="premium-card stay-planner__result" data-planner-result aria-live="polite"></aside>
    </div>

    <div class="stay-planner__extras">
      <article class="premium-card stay-planner__today">
        <Icon name="SunMedium" size={24} strokeWidth={2} />
        <div>
          <h2>{copy.todayTitle}</h2>
          <p>{copy.todayCopy}</p>
        </div>
      </article>
      <article class="premium-card stay-planner__arrival">
        <Icon name="BadgeCheck" size={24} strokeWidth={2} />
        <div>
          <h2>{copy.arrivalTitle}</h2>
          <ul>
            {copy.arrivalItems.map((item) => <li>{item}</li>)}
          </ul>
        </div>
      </article>
    </div>

    <div class="stay-planner__actions">
      <a class="btn btn-primary premium-button" href={bookingHref}><Icon name="CalendarCheck" size={18} strokeWidth={2} /> {copy.ctaBooking}</a>
      <button class="btn btn-glass" type="button" data-ask-campy-planner><Icon name="BotMessageSquare" size={18} strokeWidth={2} /> {copy.ctaCampy}</button>
      <a class="btn btn-glass" href={transportHref}><Icon name="TramFront" size={18} strokeWidth={2} /> {copy.ctaTram}</a>
      <a class="btn btn-glass" href={attractionsHref}><Icon name="Map" size={18} strokeWidth={2} /> {copy.ctaAttractions}</a>
      <a class="btn btn-glass" href={tourBookingHref} target="_blank" rel="noopener noreferrer"><Icon name="Ticket" size={18} strokeWidth={2} /> {tourUi[0]}</a>
    </div>
  </div>
</section>

<script define:vars={{ plannerConfigEncoded }}>
  (() => {
    const root = document.querySelector('[data-stay-planner]');
    if (!(root instanceof HTMLElement)) return;

    const decodeConfig = () => {
      try {
        const binary = window.atob(plannerConfigEncoded);
        const bytes = Uint8Array.from(binary, (character) => character.charCodeAt(0));
        return JSON.parse(new TextDecoder().decode(bytes));
      } catch {
        return null;
      }
    };

    const config = decodeConfig();
    if (!config) return;

    const state = {
      nights: '2', pace: 'normal', group: 'family', children: 'yes', transport: 'tram',
      weather: 'flexible', trip: 'none', startDate: '', interests: new Set(['classic', 'history']),
      weatherStatus: 'neutral', weatherDays: [],
    };
    const result = root.querySelector('[data-planner-result]');
    const esc = (value) => String(value ?? '').replace(/[&<>'"]/g, (character) => ({'&':'&amp;','<':'&lt;','>':'&gt;',"'":'&#39;','"':'&quot;'}[character]));
    const track = (eventType, metadata = {}) => window.dispatchEvent(new CustomEvent('cc:analytics', { detail:{ eventType, metadata } }));
    const nightsNumber = () => state.nights === '5+' ? 5 : Math.max(1, Number(state.nights || 1));
    const setActive = (selector, value) => root.querySelectorAll(`${selector} button`).forEach((button) => {
      if (button instanceof HTMLButtonElement) button.classList.toggle('is-active', button.dataset.value === value);
    });
    const tripLabel = () => config.tripList.find(([value]) => value === state.trip)?.[1] || '';
    const routeTransport = (index) => {
      const defaults = [config.routeTransport.city,config.routeTransport.district,config.routeTransport.trip,config.routeTransport.nature,config.routeTransport.relax];
      const fallback = defaults[index] || config.routeTransport.city;
      if (index >= 2 || state.transport === 'tram') return fallback;
      const distance = String(fallback).includes('·') ? String(fallback).split('·').pop().trim() : '';
      const mode = state.transport === 'car' ? config.options.car : config.options.mixed;
      return distance ? `${mode} · ${distance}` : mode;
    };
    const weatherText = () => state.weatherStatus === 'ready' ? config.weatherReady : state.weatherStatus === 'later' ? config.weatherLater : state.weatherStatus === 'unavailable' ? config.weatherUnavailable : config.weatherNeutral;
    const dayWeather = (index) => {
      const day = state.weatherDays[index];
      if (!day) return '';
      const rain = Number.isFinite(Number(day.rainProbability)) ? ` · ${Math.round(day.rainProbability)}% 🌧️` : '';
      return `<span class="stay-planner__day-weather">🌤️ ${Math.round(day.temperatureMinC)}–${Math.round(day.temperatureMaxC)}°C${rain}</span>`;
    };
    const renderDay = (route, index) => {
      const routeIndex = route.routeIndex ?? index;
      const selectedTrip = routeIndex === 2 && state.trip !== 'none' ? ` — ${tripLabel()}` : '';
      const transportIcon = routeIndex >= 2 || state.transport === 'car' ? '🚗' : '🚋';
      return `<article class="stay-planner__day-card ${state.weather === 'indoor' ? 'is-rain-first' : ''}">
        <header><span>${index + 1}</span><div><small>${esc(config.dayPlan)}</small><h3>${esc(route.title)}${esc(selectedTrip)}</h3></div><em>${esc(config.intensity[state.pace] || config.intensity.normal)}</em></header>
        ${dayWeather(index)}
        <div class="stay-planner__day-flow">
          <p><b>🌅 ${esc(config.labels.morning)}</b>${esc(route.morning)}</p>
          <p><b>🏛️ ${esc(config.labels.noon)}</b>${esc(route.noon)}</p>
          <p><b>🌆 ${esc(config.labels.evening)}</b>${esc(route.evening)}</p>
        </div>
        <div class="stay-planner__day-meta"><span>${transportIcon} <b>${esc(config.labels.transport)}</b>${esc(routeTransport(routeIndex))}</span><span>⏱️ <b>${esc(config.labels.duration)}</b>${esc(route.duration)}</span></div>
        <p class="stay-planner__rain"><b>🌧️ ${esc(config.labels.rain)}</b>${esc(route.rain)}</p>
      </article>`;
    };
    const render = () => {
      if (!(result instanceof HTMLElement)) return;
      const preferredIndexes = [];
      if (state.interests.has('classic')) preferredIndexes.push(0);
      if (state.interests.has('history') || state.interests.has('food')) preferredIndexes.push(1);
      if (state.trip !== 'none') preferredIndexes.push(2);
      if (state.interests.has('nature')) preferredIndexes.push(3);
      if (state.interests.has('kids') || state.children === 'yes') preferredIndexes.push(4);
      [0,1,2,3,4].forEach((index) => preferredIndexes.push(index));
      const routes = [...new Set(preferredIndexes)].slice(0, nightsNumber()).map((index) => ({ ...config.routes[index], routeIndex:index }));
      result.innerHTML = `
        <span class="stay-planner__result-badge">${esc(config.resultTitle)}</span>
        <h2>${esc(config.summaryTitle)}</h2>
        <div class="stay-planner__context"><p>${esc(config.paceNotes[state.pace])}</p><p>${esc(config.groupNotes[state.children === 'yes' ? 'family' : state.group])}</p><p>${esc(config.options[state.weather])} · ${esc(weatherText())}</p></div>
        <div class="stay-planner__plan"><strong>${esc(config.dayPlan)}</strong>${routes.map(renderDay).join('')}</div>
        <section class="stay-planner__upsell"><span>🌿</span><div><h3>${esc(config.upsell.title)}</h3><p>${esc(state.nights === '5+' ? config.upsell.max : config.upsell.copy)}</p></div>${state.nights === '5+' ? '' : `<button type="button" data-planner-add-night>${esc(config.upsell.add)}</button>`}</section>`;
      result.querySelector('[data-planner-add-night]')?.addEventListener('click', () => {
        const current = nightsNumber();
        state.nights = current >= 4 ? '5+' : String(current + 1);
        setActive('[data-planner-nights]', state.nights);
        track('planner_add_night', { nights:state.nights });
        track('planner_change_nights', { nights:state.nights, source:'upsell' });
        if (state.startDate) loadWeather(); else render();
      });
    };
    const bindSegment = (selector, key) => {
      const buttons = Array.from(root.querySelectorAll(`${selector} button`));
      buttons.forEach((button) => {
        if (!(button instanceof HTMLButtonElement)) return;
        button.addEventListener('click', () => {
          buttons.forEach((item) => item.classList.toggle('is-active', item === button));
          state[key] = button.dataset.value || state[key];
          if (key === 'nights') {
            track('planner_change_nights', { nights:state.nights, source:'controls' });
            if (state.startDate) { loadWeather(); return; }
          }
          render();
        });
      });
    };
    bindSegment('[data-planner-nights]', 'nights');
    bindSegment('[data-planner-pace]', 'pace');
    bindSegment('[data-planner-group]', 'group');
    bindSegment('[data-planner-children]', 'children');
    bindSegment('[data-planner-transport]', 'transport');
    bindSegment('[data-planner-weather]', 'weather');

    const interestButtons = Array.from(root.querySelectorAll('[data-planner-interests] button'));
    interestButtons.forEach((button) => button.addEventListener('click', () => {
      const value = button.dataset.value || '';
      button.classList.toggle('is-active');
      if (button.classList.contains('is-active')) state.interests.add(value); else state.interests.delete(value);
      render();
    }));
    const tripButtons = Array.from(root.querySelectorAll('[data-planner-trips] button'));
    tripButtons.forEach((button) => button.addEventListener('click', () => {
      tripButtons.forEach((item) => item.classList.toggle('is-active', item === button));
      state.trip = button.dataset.value || 'none';
      render();
    }));

    const addDays = (iso, days) => { const date = new Date(`${iso}T12:00:00`); date.setDate(date.getDate() + days); return date.toISOString().slice(0,10); };
    const loadWeather = async () => {
      state.weatherDays = [];
      if (!state.startDate) { state.weatherStatus = 'neutral'; render(); return; }
      state.weatherStatus = 'loading'; render();
      try {
        const end = addDays(state.startDate, nightsNumber());
        const response = await fetch(`/api/weather?start=${encodeURIComponent(state.startDate)}&end=${encodeURIComponent(end)}`, { headers:{accept:'application/json'} });
        const payload = await response.json();
        if (!payload?.ok) throw new Error('unavailable');
        state.weatherDays = Array.isArray(payload.daily) ? payload.daily : [];
        state.weatherStatus = payload.forecastInRange && state.weatherDays.length ? 'ready' : 'later';
      } catch { state.weatherStatus = 'unavailable'; }
      render();
    };
    const dateInput = root.querySelector('[data-planner-date]');
    if (dateInput instanceof HTMLInputElement) {
      dateInput.min = new Date().toISOString().slice(0,10);
      dateInput.addEventListener('change', () => { state.startDate = dateInput.value; loadWeather(); });
    }
    root.querySelectorAll('[data-planner-scenario]').forEach((button) => {
      if (!(button instanceof HTMLButtonElement)) return;
      button.addEventListener('click', () => {
        state.nights = button.dataset.nights || '2'; state.pace = button.dataset.pace || 'normal'; state.group = button.dataset.group || 'family'; state.transport = button.dataset.transport || 'tram'; state.children = state.group === 'family' ? 'yes' : 'no';
        state.interests = new Set((button.dataset.interests || 'classic').split(',').filter(Boolean));
        setActive('[data-planner-nights]', state.nights); setActive('[data-planner-pace]', state.pace); setActive('[data-planner-group]', state.group); setActive('[data-planner-children]', state.children); setActive('[data-planner-transport]', state.transport);
        interestButtons.forEach((item) => item.classList.toggle('is-active', state.interests.has(item.dataset.value || '')));
        track('planner_generate', { source:'scenario', nights:state.nights, pace:state.pace, group:state.group });
        root.querySelector('.stay-planner__layout')?.scrollIntoView({ behavior:'smooth', block:'start' });
        if (state.startDate) loadWeather(); else render();
      });
    });
    root.querySelector('[data-planner-generate]')?.addEventListener('click', () => {
      track('planner_generate', { source:'button', nights:state.nights, pace:state.pace, group:state.group, transport:state.transport, weather:state.weather, trip:state.trip });
      render(); result?.scrollIntoView({ behavior:'smooth', block:'start' });
    });
    root.querySelector('[data-ask-campy-planner]')?.addEventListener('click', () => {
      const prompt = `${config.campyPlannerPrompt} ${config.nights}: ${state.nights}; ${config.pace}: ${config.options[state.pace]}; ${config.group}: ${config.options[state.group]}; ${config.transport}: ${config.options[state.transport]}; ${config.trips}: ${tripLabel()}.`;
      window.dispatchEvent(new CustomEvent('campy:prompt', { detail:{ prompt, actionKey:'stayLength' } }));
    });
    render();
  })();
</script>

