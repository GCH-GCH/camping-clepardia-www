---
import Icon from '@/components/ui/Icon.astro';
import { siteAssets } from '@/data/assets';
import { resolveContentLanguage } from '@/i18n/config';
import { getStayPlannerPremiumCopy } from '@/i18n/stayPlannerPremium';
import { getWeatherCopy } from '@/i18n/weather';
import { getBookingLocalizedPath, getLocalizedPath, getPathContext } from '@/utils/localizedLinks';
import { tourBookingHref } from '@/i18n/coreUi';
import { getHomeAttractionsToursCopy } from '@/i18n/homeAttractionsTours';

interface Props { languageCode?: string; }
type SupportedLang = 'pl' | 'en' | 'de' | 'it' | 'fr' | 'es' | 'nl' | 'cs' | 'sk' | 'sv';

const { languageCode } = Astro.props as Props;
const pathContext = getPathContext(Astro.url.pathname);
const requestedLanguage = languageCode ?? pathContext.languageCode;
const lang = resolveContentLanguage(requestedLanguage) as SupportedLang;
const explicitLanguage = pathContext.explicitLanguage;
const copy = getStayPlannerPremiumCopy(lang);
const attractionsToursCopy = getHomeAttractionsToursCopy(lang);
const weatherCopy = getWeatherCopy(lang);
const dashboard = { ...copy.dashboard, weatherUnavailable: weatherCopy.unavailable };
const bookingHref = getBookingLocalizedPath(requestedLanguage);
const transportHref = getLocalizedPath(explicitLanguage, 'dojazd');
const attractionsHref = getLocalizedPath(explicitLanguage, 'atrakcje');

const plannerConfigEncoded = Buffer.from(JSON.stringify({
  ...copy,
  dashboard,
  dev: import.meta.env.DEV,
  language: lang,
  locale: lang === 'en' ? 'en-GB' : lang === 'cs' ? 'cs-CZ' : lang === 'sv' ? 'sv-SE' : `${lang}-${lang.toUpperCase()}`,
  weatherConditions: weatherCopy.conditions,
  auschwitzNotice: attractionsToursCopy.auschwitz,
  links: {
    booking: bookingHref,
    transport: transportHref,
    attractions: attractionsHref,
    tours: tourBookingHref,
    auschwitzOfficial: 'https://visit.auschwitz.org/',
    maps: 'https://www.google.com/maps/search/?api=1&query=Camping+Clepardia+Krak%C3%B3w',
  },
  assets: {
    hero: siteAssets.attractions.wawel,
    camp: siteAssets.hero.desktop,
    brand: siteAssets.logo.icon,
    campy: siteAssets.ui.campy.icon,
    days: [
      siteAssets.attractions.wawel,
      siteAssets.attractions.kazimierz,
      siteAssets.attractions.wieliczka,
      siteAssets.attractions.ojcow,
      siteAssets.attractions.waterPark,
    ],
  },
}), 'utf8').toString('base64');

const paceOptions = [
  ['intensive', dashboard.active, 'Gauge'],
  ['normal', dashboard.calm, 'Leaf'],
  ['calm', dashboard.veryCalm, 'Coffee'],
];
const groupOptions = [
  ['pair', copy.options.pair, 'Heart'],
  ['family', copy.options.family, 'UsersRound'],
  ['group', copy.options.group, 'Users'],
  ['solo', copy.options.solo, 'UserRound'],
];
const transportOptions = [
  ['car', copy.options.car, 'CarFront'],
  ['tram', copy.options.tram, 'TramFront'],
  ['mixed', dashboard.walkBike, 'Bike'],
];
const interestIcons: Record<string, string> = { classic:'Landmark', history:'Museum', nature:'Trees', kids:'Sparkles', food:'Utensils' };
---

<section class="stay-planner" data-stay-planner data-planner-config={plannerConfigEncoded}>
  <div class="stay-planner__ambient" aria-hidden="true"></div>
  <section class="stay-planner__intro" aria-labelledby="plannerIntroTitle">
    <img src={siteAssets.attractions.wawel} alt="" width="1600" height="900" loading="eager" decoding="async" />
    <div class="stay-planner__intro-shade" aria-hidden="true"></div>
    <div class="stay-planner__intro-content">
      <span><Icon name="WandSparkles" size={20} /> {copy.kicker}</span>
      <h1 id="plannerIntroTitle">{dashboard.introTitle}</h1>
      <p>{dashboard.introCopy}</p>
      <div class="stay-planner__intro-actions">
        <a href="#stayPlannerDashboard" data-planner-start>{dashboard.introStart} <Icon name="ArrowDown" size={20} /></a>
        <button type="button" data-planner-intro-campy><Icon name="MessageCircleQuestion" size={20} /> {dashboard.introCampy}</button>
      </div>
    </div>
  </section>
  <div class="stay-planner__shell">
    <div class="stay-planner__dashboard" id="stayPlannerDashboard" data-planner-dashboard>
      <aside class="stay-planner__panel" data-planner-panel>
        <header class="stay-planner__panel-head">
          <div>
            <span><Icon name="SlidersHorizontal" size={16} /> {copy.kicker}</span>
            <h2>{dashboard.panelTitle}</h2>
            <p>{dashboard.panelSubtitle}</p>
          </div>
          <button type="button" data-planner-filter-toggle aria-expanded="false" aria-controls="plannerFilters">
            <Icon name="SlidersHorizontal" size={18} />
            <span data-planner-filter-label>{dashboard.filtersOpen}</span>
            <Icon name="ChevronDown" size={17} class="stay-planner__filter-chevron" />
          </button>
        </header>

        <div class="stay-planner__filters" id="plannerFilters" data-planner-filters>
          <div class="stay-planner__control">
            <h3><Icon name="MoonStar" size={17} /> {copy.nights}</h3>
            <div class="stay-planner__stepper" data-planner-nights>
              <button type="button" data-planner-night-step="-1" aria-label="−"><Icon name="Minus" size={17} /></button>
              <strong data-planner-night-value>2 <span>{copy.premium.nightUnits[1]}</span></strong>
              <button type="button" data-planner-night-step="1" aria-label="+"><Icon name="Plus" size={17} /></button>
            </div>
          </div>

          <label class="stay-planner__control stay-planner__date">
            <h3><Icon name="CalendarDays" size={17} /> {copy.date}</h3>
            <span><input type="date" data-planner-date /><Icon name="ChevronDown" size={16} /></span>
          </label>

          <div class="stay-planner__control">
            <h3><Icon name="Gauge" size={17} /> {copy.pace}</h3>
            <div class="stay-planner__chips stay-planner__chips--three" data-planner-pace>
              {paceOptions.map(([value, label, icon]) => (
                <button type="button" data-value={value} class:list={[value === 'normal' && 'is-active']} aria-pressed={value === 'normal'}>
                  <Icon name={icon} size={15} /> <span>{label}</span>
                </button>
              ))}
            </div>
          </div>

          <div class="stay-planner__control">
            <h3><Icon name="UsersRound" size={17} /> {copy.group}</h3>
            <div class="stay-planner__chips stay-planner__chips--four" data-planner-group>
              {groupOptions.map(([value, label, icon]) => (
                <button type="button" data-value={value} class:list={[value === 'family' && 'is-active']} aria-pressed={value === 'family'}>
                  <Icon name={icon} size={15} /> <span>{label}</span>
                </button>
              ))}
            </div>
            <div class="stay-planner__children" data-planner-children-wrap>
              <span>{dashboard.childrenHint}</span>
              <div data-planner-children>
                <button type="button" class="is-active" data-value="yes" aria-pressed="true">{copy.options.yes}</button>
                <button type="button" data-value="no" aria-pressed="false">{copy.options.no}</button>
              </div>
            </div>
          </div>

          <div class="stay-planner__control">
            <h3><Icon name="TramFront" size={17} /> {copy.transport}</h3>
            <div class="stay-planner__chips stay-planner__chips--three" data-planner-transport>
              {transportOptions.map(([value, label, icon]) => (
                <button type="button" data-value={value} class:list={[value === 'tram' && 'is-active']} aria-pressed={value === 'tram'}>
                  <Icon name={icon} size={15} /> <span>{label}</span>
                </button>
              ))}
            </div>
          </div>

          <details class="stay-planner__accordion" data-planner-accordion>
            <summary><span><Icon name="Heart" size={19} /> {copy.interests}</span><Icon name="ChevronDown" size={18} /></summary>
            <div class="stay-planner__accordion-body stay-planner__control">
              <div class="stay-planner__chips stay-planner__chips--wrap" data-planner-interests>
                {copy.interestsList.map(([value, label], index) => (
                  <button type="button" data-value={value} class:list={[index < 2 && 'is-active']} aria-pressed={index < 2}>
                    <Icon name={interestIcons[value] ?? 'Map'} size={17} /> <span>{label}</span>
                  </button>
                ))}
              </div>
            </div>
          </details>

          <details class="stay-planner__accordion" data-planner-accordion>
            <summary><span><Icon name="MountainSnow" size={19} /> {copy.trips}</span><Icon name="ChevronDown" size={18} /></summary>
            <div class="stay-planner__accordion-body stay-planner__control stay-planner__trip">
              <div class="stay-planner__binary" data-planner-trip-choice>
                <button type="button" data-value="yes" aria-pressed="false">{dashboard.tripYes}</button>
                <button type="button" data-value="no" class="is-active" aria-pressed="true">{dashboard.tripNo}</button>
              </div>
              <div class="stay-planner__chips stay-planner__chips--wrap stay-planner__destinations" data-planner-trips hidden>
                {copy.tripList.filter(([value]) => value !== 'none').map(([value, label], index) => (
                  <button type="button" data-value={value} class:list={[index === 0 && 'is-active']} aria-pressed={index === 0}>{label}</button>
                ))}
              </div>
              <aside class="stay-planner__auschwitz" data-planner-auschwitz hidden>
                <strong><Icon name="ShieldAlert" size={18} /> {attractionsToursCopy.auschwitz.title}</strong>
                <p>{attractionsToursCopy.auschwitz.body}</p>
                <div>
                  <a href="https://visit.auschwitz.org/" target="_blank" rel="noopener noreferrer" data-analytics-event="attraction_click" data-analytics-category="auschwitz_official" data-analytics-element="planner_auschwitz_official">{attractionsToursCopy.auschwitz.official}</a>
                  <a href={tourBookingHref} target="_blank" rel="noopener noreferrer" data-analytics-event="tour_click" data-analytics-category="auschwitz" data-analytics-element="planner_auschwitz_tour">{attractionsToursCopy.auschwitz.tour}</a>
                </div>
              </aside>
            </div>
          </details>

          <details class="stay-planner__accordion" data-planner-accordion>
            <summary><span><Icon name="CloudSun" size={19} /> {copy.weatherPreference}</span><Icon name="ChevronDown" size={18} /></summary>
            <div class="stay-planner__accordion-body stay-planner__control">
              <div class="stay-planner__chips stay-planner__chips--weather" data-planner-weather>
                <button type="button" class="is-active" data-value="flexible" aria-pressed="true"><Icon name="Clock3" size={17} /> {copy.options.flexible}</button>
                <button type="button" data-value="sun" aria-pressed="false"><Icon name="Sun" size={17} /> {copy.options.sun}</button>
                <button type="button" data-value="indoor" aria-pressed="false"><Icon name="Umbrella" size={17} /> {copy.options.indoor}</button>
              </div>
            </div>
          </details>

          <button class="stay-planner__generate" type="button" data-planner-generate>
            <Icon name="WandSparkles" size={18} /> <span>{copy.generate}</span><Icon name="ArrowRight" size={17} />
          </button>
          <small class="stay-planner__updated"><span></span>{dashboard.planSavedAt}: <time data-planner-updated-time>—</time></small>
        </div>
      </aside>

      <main class="stay-planner__result" data-planner-result aria-live="polite"></main>
    </div>
    {import.meta.env.DEV && <pre class="stay-planner__debug" data-planner-debug aria-label="Planner runtime state"></pre>}
  </div>
  <div class="stay-planner__toast" data-planner-toast role="status" aria-live="polite"></div>
</section>

<script>
  import { initStayPlanner } from '@/scripts/stayPlannerClient.js';
  initStayPlanner();
</script>

<style is:global>
.stay-planner {
  --planner-green:#55e392;
  --planner-green-2:#20b96a;
  --planner-ink:#041810;
  --planner-card:rgba(8,37,27,.92);
  --planner-line:rgba(102,225,157,.2);
  position:relative;
  isolation:isolate;
  min-height:100vh;
  padding:0 0 54px;
  color:#f3fff7;
  background:
    radial-gradient(circle at 76% 5%,rgba(36,186,110,.14),transparent 32%),
    radial-gradient(circle at 0 45%,rgba(29,145,108,.11),transparent 28%),
    linear-gradient(180deg,#03150f 0%,#041b14 48%,#03130e 100%);
  overflow:clip;
}
.stay-planner__ambient { position:absolute; inset:0; z-index:-1; opacity:.36; background-image:radial-gradient(circle,rgba(119,245,171,.5) 0 1px,transparent 1.5px); background-size:58px 58px; mask-image:linear-gradient(to bottom,#000,transparent 74%); }
.stay-planner__sr-only { position:absolute!important; width:1px!important; height:1px!important; padding:0!important; margin:-1px!important; overflow:hidden!important; clip:rect(0,0,0,0)!important; white-space:nowrap!important; border:0!important; }
.stay-planner__auschwitz{display:grid;gap:9px;margin-top:13px;padding:14px;border:1px solid rgba(242,196,88,.3);border-radius:15px;background:linear-gradient(135deg,rgba(109,77,10,.25),rgba(15,53,35,.72))}.stay-planner__auschwitz[hidden]{display:none}.stay-planner__auschwitz strong{display:flex;align-items:flex-start;gap:8px;color:#ffe9a9;font-size:.83rem;line-height:1.4}.stay-planner__auschwitz p{margin:0;color:rgba(255,248,222,.72);font-size:.76rem;line-height:1.5}.stay-planner__auschwitz>div{display:flex;flex-wrap:wrap;gap:7px}.stay-planner__auschwitz a{min-height:38px;display:inline-flex;align-items:center;padding:0 10px;border:1px solid rgba(255,226,145,.24);border-radius:10px;color:#fff6d8;background:rgba(255,255,255,.07);font-size:.7rem;font-weight:900;text-decoration:none}html[data-theme="light"] .stay-planner__auschwitz{border-color:#e0c878;background:#fff8dd}html[data-theme="light"] .stay-planner__auschwitz strong{color:#66500c}html[data-theme="light"] .stay-planner__auschwitz p{color:#625c45}html[data-theme="light"] .stay-planner__auschwitz a{border-color:#d8c374;color:#57460f;background:#fff}
.stay-planner__intro { position:relative; display:flex; width:min(1840px,calc(100% - 32px)); min-height:clamp(430px,52vh,600px); align-items:flex-end; margin:clamp(78px,8vw,112px) auto 28px; overflow:hidden; border:1px solid rgba(103,232,159,.25); border-radius:30px; background:#06271b; box-shadow:0 30px 90px rgba(0,0,0,.28); }
.stay-planner__intro>img { position:absolute; inset:0; width:100%; height:100%; object-fit:cover; object-position:center 48%; opacity:.82; filter:saturate(.9) contrast(1.04); animation:plannerIntroImage 1.1s both cubic-bezier(.22,1,.36,1); }
.stay-planner__intro-shade { position:absolute; inset:0; background:linear-gradient(90deg,rgba(2,22,15,.95) 0%,rgba(3,27,18,.78) 47%,rgba(3,29,19,.28) 74%),linear-gradient(0deg,rgba(2,19,13,.75),transparent 68%); }
.stay-planner__intro-content { position:relative; z-index:1; width:min(780px,72%); padding:clamp(30px,4.6vw,68px); animation:plannerIntroContent .72s .08s both cubic-bezier(.22,1,.36,1); }
.stay-planner__intro-content>span { display:inline-flex; align-items:center; gap:9px; margin-bottom:15px; color:#9bf4bd; font-size:.82rem; font-weight:900; letter-spacing:.08em; text-transform:uppercase; }
.stay-planner__intro h1 { max-width:760px; margin:0; color:#fff; font-size:clamp(2.4rem,4.2vw,3.7rem); line-height:1.02; letter-spacing:-.045em; text-wrap:balance; }
.stay-planner__intro p { max-width:720px; margin:18px 0 0; color:rgba(241,255,246,.8); font-size:clamp(1rem,1.25vw,1.15rem); line-height:1.62; }
.stay-planner__intro-actions { display:flex; flex-wrap:wrap; gap:12px; margin-top:26px; }
.stay-planner__intro-actions a,.stay-planner__intro-actions button { display:inline-flex; min-height:50px; align-items:center; justify-content:center; gap:9px; padding:0 20px; border:1px solid rgba(111,242,168,.42); border-radius:14px; color:#effff5; background:linear-gradient(135deg,#25a85e,#45cc7c); box-shadow:0 14px 32px rgba(20,160,84,.23); font:inherit; font-size:.95rem; font-weight:900; text-decoration:none; cursor:pointer; transition:transform .25s ease,box-shadow .25s ease,background .25s ease; }
.stay-planner__intro-actions button { background:rgba(4,34,23,.72); backdrop-filter:blur(12px); box-shadow:none; }
.stay-planner__intro-actions a:hover,.stay-planner__intro-actions button:hover { transform:translateY(-2px); box-shadow:0 18px 35px rgba(20,160,84,.28); }
.stay-planner__shell { width:min(1840px,calc(100% - 32px)); margin:0 auto; }
.stay-planner__dashboard { display:grid; grid-template-columns:minmax(340px,390px) minmax(0,1fr); align-items:start; gap:22px; scroll-margin-top:90px; }
.stay-planner__panel { position:relative; top:auto; z-index:5; max-height:none; overflow:visible; padding:22px; border:1px solid var(--planner-line); border-radius:24px; background:linear-gradient(145deg,rgba(13,48,36,.96),rgba(6,31,23,.96)); box-shadow:0 24px 70px rgba(0,0,0,.3),inset 0 1px rgba(255,255,255,.04); }
.stay-planner__panel.can-stick { position:sticky; top:88px; }
.stay-planner__panel-head { margin-bottom:18px; }
.stay-planner__panel-head>div>span { display:flex; align-items:center; gap:8px; margin-bottom:8px; color:#82eeae; font-size:.78rem; font-weight:900; letter-spacing:.09em; text-transform:uppercase; }
.stay-planner__panel-head h2 { margin:0; color:#fff; font-size:clamp(1.45rem,1.8vw,1.8rem); line-height:1.1; letter-spacing:-.035em; }
.stay-planner__panel-head p { margin:8px 0 0; color:rgba(230,249,237,.7); font-size:.94rem; line-height:1.5; }
.stay-planner__panel-head>button { display:none; }
.stay-planner__filters { display:grid; gap:19px; }
.stay-planner__control { display:grid; gap:8px; min-width:0; }
.stay-planner__control h3 { display:flex; align-items:center; gap:8px; margin:0; color:#eafff1; font-size:.9rem; font-weight:850; }
.stay-planner__control h3 svg { color:#83eeb0; }
.stay-planner__stepper { display:grid; grid-template-columns:46px 1fr 46px; align-items:center; min-height:48px; border:1px solid rgba(77,218,139,.25); border-radius:14px; overflow:hidden; background:rgba(22,91,60,.34); }
.stay-planner__stepper button { display:grid; place-items:center; align-self:stretch; border:0; color:#c9ffe0; background:rgba(55,201,121,.13); cursor:pointer; transition:background .22s ease,transform .22s ease; }
.stay-planner__stepper button:hover { background:rgba(55,201,121,.28); }
.stay-planner__stepper button:active { transform:scale(.92); }
.stay-planner__stepper strong { display:flex; justify-content:center; gap:5px; font-size:1rem; }
.stay-planner__stepper strong.is-changing { animation:plannerNumber .34s cubic-bezier(.22,1,.36,1); }
.stay-planner__stepper strong span { color:rgba(235,255,242,.7); font-weight:700; }
.stay-planner__date>span { position:relative; display:block; }
.stay-planner__date input { width:100%; min-height:48px; padding:0 40px 0 14px; border:1px solid rgba(77,218,139,.25); border-radius:14px; color:#f4fff8; color-scheme:dark; background:rgba(5,30,22,.68); font:inherit; font-size:.94rem; font-weight:750; outline:0; transition:border-color .22s ease,box-shadow .22s ease; }
.stay-planner__date input:focus { border-color:#58df91; box-shadow:0 0 0 3px rgba(67,214,132,.13); }
.stay-planner__date>span>svg { position:absolute; top:50%; right:13px; pointer-events:none; color:#73dca0; transform:translateY(-50%); }
.stay-planner__chips { display:grid; gap:7px; }
.stay-planner__chips--three { grid-template-columns:repeat(3,minmax(0,1fr)); }
.stay-planner__chips--four { grid-template-columns:repeat(2,minmax(0,1fr)); }
.stay-planner__chips--wrap { display:flex; flex-wrap:wrap; }
.stay-planner__chips--weather { grid-template-columns:1fr 1fr; }
.stay-planner__chips--weather button:first-child { grid-column:1/-1; }
.stay-planner__chips button,.stay-planner__binary button,.stay-planner__children button { display:inline-flex; min-width:0; min-height:42px; align-items:center; justify-content:center; gap:6px; padding:8px 10px; border:1px solid rgba(129,217,166,.17); border-radius:11px; color:rgba(239,255,245,.8); background:rgba(5,29,21,.58); font:inherit; font-size:.79rem; font-weight:780; line-height:1.2; cursor:pointer; transition:transform .25s cubic-bezier(.22,1,.36,1),border-color .25s ease,color .25s ease,background .25s ease,box-shadow .25s ease; }
.stay-planner__chips--wrap button { flex:1 1 auto; }
.stay-planner__chips button:hover,.stay-planner__binary button:hover,.stay-planner__children button:hover { color:#fff; border-color:rgba(89,227,149,.42); transform:translateY(-1px); }
.stay-planner__chips button.is-active,.stay-planner__binary button.is-active,.stay-planner__children button.is-active { color:#eafff1; border-color:rgba(81,232,148,.68); background:linear-gradient(145deg,rgba(42,185,105,.36),rgba(29,126,78,.28)); box-shadow:0 0 0 1px rgba(73,229,141,.11),0 7px 22px rgba(23,178,92,.13); }
.stay-planner__chips button.is-selecting,.stay-planner__binary button.is-selecting,.stay-planner__children button.is-selecting { animation:plannerChip .36s cubic-bezier(.22,1,.36,1); }
.stay-planner__children { display:flex; align-items:center; justify-content:space-between; gap:8px; padding:9px 10px; border:1px dashed rgba(95,213,145,.2); border-radius:11px; color:rgba(235,255,242,.72); font-size:.76rem; }
.stay-planner__children>div { display:flex; gap:5px; }
.stay-planner__children button { min-height:44px; padding:6px 12px; }
.stay-planner__binary { display:grid; grid-template-columns:1fr 1fr; gap:7px; }
.stay-planner__destinations[hidden] { display:none; }
.stay-planner__generate { display:flex; min-height:52px; align-items:center; justify-content:center; gap:9px; margin-top:2px; border:1px solid rgba(107,244,167,.48); border-radius:14px; color:#eafff1; background:linear-gradient(135deg,#168d50,#2dba70); box-shadow:0 14px 28px rgba(18,148,80,.22),inset 0 1px rgba(255,255,255,.16); font:inherit; font-size:.94rem; font-weight:900; cursor:pointer; transition:transform .3s cubic-bezier(.22,1,.36,1),box-shadow .3s ease; }
.stay-planner__generate:hover { transform:translateY(-2px); box-shadow:0 18px 34px rgba(18,170,88,.3),inset 0 1px rgba(255,255,255,.18); }
.stay-planner__generate svg:last-child { transition:transform .25s ease; }
.stay-planner__generate:hover svg:last-child { transform:translateX(3px); }
.stay-planner__updated { display:flex; align-items:center; justify-content:center; gap:6px; color:rgba(222,247,231,.55); font-size:.7rem; }
.stay-planner__updated>span { width:5px; height:5px; border-radius:50%; background:#50df8c; box-shadow:0 0 9px #50df8c; }
.stay-planner__accordion { overflow:hidden; border:1px solid rgba(91,216,144,.17); border-radius:14px; background:rgba(5,29,21,.4); }
