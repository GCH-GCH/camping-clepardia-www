---
import ImageFrame from '@/components/ImageFrame.astro';
import Icon from '@/components/ui/Icon.astro';
import { attractionImages } from '@/data/attractionsImageRegistry';
import { getBookingLocalizedPath, getLocalizedPath, getPathContext } from '@/utils/localizedLinks';
import { resolveContentLanguage } from '@/i18n/config';

interface Props {
  languageCode?: string;
}

type SupportedLang = 'pl' | 'en' | 'de' | 'it';

const { languageCode } = Astro.props as Props;
const pathContext = getPathContext(Astro.url.pathname);
const lang = resolveContentLanguage(languageCode ?? pathContext.languageCode) as SupportedLang;
const explicitLanguage = pathContext.explicitLanguage;
const bookingHref = getBookingLocalizedPath(lang);
const transportHref = getLocalizedPath(explicitLanguage, 'dojazd');
const attractionsHref = getLocalizedPath(explicitLanguage, 'atrakcje');

const copyByLang = {
  pl: {
    kicker: 'Planer pobytu',
    title: 'Zaplanuj swój pobyt w Krakowie',
    lead:
      'Wybierz liczbę nocy, tempo zwiedzania i atrakcje — podpowiemy, co realnie ma sens, co warto odpuścić i jak połączyć zwiedzanie z odpoczynkiem na campingu.',
    micro: 'To nie jest sztywny program. To szybka podpowiedź, żeby pobyt był przyjemny, a nie goniony.',
    nights: 'Liczba nocy',
    pace: 'Tempo zwiedzania',
    group: 'Z kim jedziesz?',
    transport: 'Jak chcecie się poruszać?',
    interests: 'Co Was najbardziej interesuje?',
    resultTitle: 'Rekomendacja pobytu',
    comfortable: 'Co spokojnie zobaczysz',
    tooMuch: 'Co może być za dużo',
    recommendation: 'Nasza rekomendacja',
    dayPlan: 'Plan dnia',
    quizTitle: 'Nie wiesz, co wybrać?',
    quizCopy: 'Kliknij najbliższy scenariusz, a planer ustawi dobry punkt startu.',
    todayTitle: 'Plan na dziś',
