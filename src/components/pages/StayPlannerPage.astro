      ['history', 'Historia i muzea'],
      ['kids', 'Dzieci i energia'],
      ['nature', 'Natura poza miastem'],
      ['tours', 'Gotowe wycieczki'],
    ],
    scenarios: [
      { id: 'camper', icon: 'Caravan', title: 'Przyjeżdżam kamperem', copy: 'Zacznij od spokojnego Krakowa i tramwaju.', nights: '2', pace: 'normal', group: 'pair', transport: 'tram', interests: ['classic'] },
      { id: 'family', icon: 'UsersRound', title: 'Rodzina z dziećmi', copy: 'Dodaj oddech, Wieliczkę albo Energylandię jako osobny dzień.', nights: '3', pace: 'calm', group: 'family', transport: 'mixed', interests: ['classic', 'kids'] },
      { id: 'krakow', icon: 'Landmark', title: 'Chcę zobaczyć Kraków', copy: 'Stare Miasto, Wawel, Kazimierz i muzea bez auta.', nights: '2', pace: 'normal', group: 'pair', transport: 'tram', interests: ['classic', 'history'] },
      { id: 'cabin', icon: 'House', title: 'Domki i spokojny pobyt', copy: 'Lepszy rytm: miasto + jeden dzień poza Krakowem.', nights: '4', pace: 'calm', group: 'family', transport: 'mixed', interests: ['classic', 'nature'] },
    ],
    recommendations: {
      '1': {
        comfortable: ['Stare Miasto, Rynek i Sukiennice', 'Wawel albo Kazimierz, ale nie wszystko naraz', 'Tramwaj z Górnickiego do Starego Kleparza i spacer do centrum'],
        tooMuch: ['Wieliczka i Auschwitz w tym samym pobycie', 'Zakopane lub Energylandia jako dodatek do jednego dnia', 'Zwiedzanie autem po ścisłym centrum'],
        recommendation: 'Przy 1 nocy zrób city break: Stare Miasto + Wawel, ewentualnie Kazimierz wieczorem. Wieliczkę, Auschwitz i dalsze wycieczki zostaw na dłuższy pobyt.',
