    arrivalTitle: 'Pakiet pierwszego przyjazdu',
    arrivalItems: [
      'Przy rejestracji przygotuj jeden dokument tożsamości.',
      'Jeśli przyjeżdżasz pojazdem, recepcja poprosi o numer rejestracyjny.',
      'Przy przyczepie kempingowej wpisz numer rejestracyjny przyczepy.',
      'Do nawigacji użyj Google Maps, bo dojazd zmienił się w 2022 roku.',
      'Cisza nocna obowiązuje 22:00-07:00.',
    ],
    ctaBooking: 'Zarezerwuj pobyt',
    ctaCampy: 'Zapytaj CAMPY',
    ctaTours: 'Wycieczki z Krakowa',
    ctaTram: 'Dojazd tramwajem',
    ctaAttractions: 'Zobacz atrakcje',
    options: {
      calm: 'Spokojnie',
      normal: 'Normalnie',
      intensive: 'Intensywnie',
      pair: 'Para',
      family: 'Rodzina',
      solo: 'Solo',
      group: 'Grupa',
      tram: 'Tramwaj',
      car: 'Auto',
      mixed: 'Spacer + tramwaj',
