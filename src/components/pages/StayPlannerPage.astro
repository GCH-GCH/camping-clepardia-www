const baseCopy = copyByLang[lang as keyof typeof copyByLang] ?? copyByLang.en;
const coreOverride = plannerCoreOverrides[requestedLanguage as keyof typeof plannerCoreOverrides];
const copy = getStayPlannerPremiumCopy(requestedLanguage);
const plannerConfigEncoded = Buffer.from(JSON.stringify({
  ...copy,
  language:lang,
  links:{ booking:bookingHref, transport:transportHref, attractions:attractionsHref, tours:tourBookingHref },
}), 'utf8').toString('base64');
const inspirationCopy = {
  pl: {
    kicker: 'Inspiracje do planu',
    title: 'Zobacz kierunki, zanim ułożysz tempo pobytu',
    items: ['Kraków i Wawel', 'Wieliczka', 'Rodzinny dzień', 'Park Wodny', 'Bagry', 'Kryspinów'],
  },
