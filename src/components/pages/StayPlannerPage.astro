---
import Icon from '@/components/ui/Icon.astro';
import { siteAssets } from '@/data/assets';
import { resolveContentLanguage } from '@/i18n/config';
import { getStayPlannerPremiumCopy } from '@/i18n/stayPlannerPremium';
import { getWeatherCopy } from '@/i18n/weather';
import { getBookingLocalizedPath, getLocalizedPath, getPathContext } from '@/utils/localizedLinks';
import { tourBookingHref } from '@/i18n/coreUi';

interface Props { languageCode?: string; }
type SupportedLang = 'pl' | 'en' | 'de' | 'it' | 'fr' | 'es' | 'nl' | 'cs' | 'sk' | 'sv';

const { languageCode } = Astro.props as Props;
const pathContext = getPathContext(Astro.url.pathname);
const requestedLanguage = languageCode ?? pathContext.languageCode;
const lang = resolveContentLanguage(requestedLanguage) as SupportedLang;
const explicitLanguage = pathContext.explicitLanguage;
const copy = getStayPlannerPremiumCopy(lang);
const dashboard = copy.dashboard;
const weatherCopy = getWeatherCopy(lang);
const bookingHref = getBookingLocalizedPath(requestedLanguage);
const transportHref = getLocalizedPath(explicitLanguage, 'dojazd');
const attractionsHref = getLocalizedPath(explicitLanguage, 'atrakcje');

const plannerConfigEncoded = Buffer.from(JSON.stringify({
  ...copy,
  language: lang,
  locale: lang === 'en' ? 'en-GB' : lang === 'cs' ? 'cs-CZ' : lang === 'sv' ? 'sv-SE' : `${lang}-${lang.toUpperCase()}`,
  weatherConditions: weatherCopy.conditions,
  links: {
    booking: bookingHref,
    transport: transportHref,
    attractions: attractionsHref,
    tours: tourBookingHref,
    maps: 'https://www.google.com/maps/search/?api=1&query=Camping+Clepardia+Krak%C3%B3w',
  },
  assets: {
    hero: siteAssets.attractions.wawel,
    camp: siteAssets.hero.desktop,
    brand: siteAssets.logo.icon,
    campy: siteAssets.ui.campy.icon,
    days: [
      siteAssets.attractions.wawel,
      siteAssets.attractions.kazimierz,
      siteAssets.attractions.wieliczka,
      siteAssets.attractions.ojcow,
      siteAssets.attractions.waterPark,
    ],
  },
}), 'utf8').toString('base64');

const paceOptions = [
  ['intensive', dashboard.active, 'Gauge'],
  ['normal', dashboard.calm, 'Leaf'],
  ['calm', dashboard.veryCalm, 'Coffee'],
];
const groupOptions = [
  ['pair', copy.options.pair, 'Heart'],
  ['family', copy.options.family, 'UsersRound'],
  ['group', copy.options.group, 'Users'],
  ['solo', copy.options.solo, 'UserRound'],
];
const transportOptions = [
  ['car', copy.options.car, 'CarFront'],
  ['tram', copy.options.tram, 'TramFront'],
  ['mixed', dashboard.walkBike, 'Bike'],
];
const interestIcons: Record<string, string> = { classic:'Landmark', history:'Museum', nature:'Trees', kids:'Sparkles', food:'Utensils' };
---

<section class="stay-planner" data-stay-planner data-planner-config={plannerConfigEncoded}>
  <h1 class="stay-planner__sr-only">{copy.title}</h1>
  <div class="stay-planner__ambient" aria-hidden="true"></div>
  <div class="stay-planner__shell">
    <div class="stay-planner__dashboard">
      <aside class="stay-planner__panel" data-planner-panel>
        <header class="stay-planner__panel-head">
          <div>
            <span><Icon name="SlidersHorizontal" size={16} /> {copy.kicker}</span>
            <h2>{dashboard.panelTitle}</h2>
            <p>{dashboard.panelSubtitle}</p>
          </div>
          <button type="button" data-planner-filter-toggle aria-expanded="false" aria-controls="plannerFilters">
            <Icon name="SlidersHorizontal" size={18} />
            <span data-planner-filter-label>{dashboard.filtersOpen}</span>
            <Icon name="ChevronDown" size={17} class="stay-planner__filter-chevron" />
          </button>
        </header>

        <div class="stay-planner__filters" id="plannerFilters" data-planner-filters>
          <div class="stay-planner__control">
            <h3><Icon name="MoonStar" size={17} /> {copy.nights}</h3>
            <div class="stay-planner__stepper" data-planner-nights>
              <button type="button" data-planner-night-step="-1" aria-label="−"><Icon name="Minus" size={17} /></button>
              <strong data-planner-night-value>2 <span>{copy.premium.nightUnits[1]}</span></strong>
              <button type="button" data-planner-night-step="1" aria-label="+"><Icon name="Plus" size={17} /></button>
            </div>
          </div>

          <label class="stay-planner__control stay-planner__date">
            <h3><Icon name="CalendarDays" size={17} /> {copy.date}</h3>
            <span><input type="date" data-planner-date /><Icon name="ChevronDown" size={16} /></span>
          </label>

          <div class="stay-planner__control">
            <h3><Icon name="Gauge" size={17} /> {copy.pace}</h3>
            <div class="stay-planner__chips stay-planner__chips--three" data-planner-pace>
              {paceOptions.map(([value, label, icon]) => (
                <button type="button" data-value={value} class:list={[value === 'normal' && 'is-active']} aria-pressed={value === 'normal'}>
                  <Icon name={icon} size={15} /> <span>{label}</span>
                </button>
              ))}
            </div>
          </div>

          <div class="stay-planner__control">
            <h3><Icon name="UsersRound" size={17} /> {copy.group}</h3>
            <div class="stay-planner__chips stay-planner__chips--four" data-planner-group>
              {groupOptions.map(([value, label, icon]) => (
                <button type="button" data-value={value} class:list={[value === 'family' && 'is-active']} aria-pressed={value === 'family'}>
                  <Icon name={icon} size={15} /> <span>{label}</span>
                </button>
              ))}
            </div>
            <div class="stay-planner__children" data-planner-children-wrap>
              <span>{dashboard.childrenHint}</span>
              <div data-planner-children>
                <button type="button" class="is-active" data-value="yes" aria-pressed="true">{copy.options.yes}</button>
                <button type="button" data-value="no" aria-pressed="false">{copy.options.no}</button>
              </div>
            </div>
          </div>

          <div class="stay-planner__control">
            <h3><Icon name="TramFront" size={17} /> {copy.transport}</h3>
            <div class="stay-planner__chips stay-planner__chips--three" data-planner-transport>
              {transportOptions.map(([value, label, icon]) => (
                <button type="button" data-value={value} class:list={[value === 'tram' && 'is-active']} aria-pressed={value === 'tram'}>
                  <Icon name={icon} size={15} /> <span>{label}</span>
                </button>
              ))}
            </div>
          </div>

          <div class="stay-planner__control">
            <h3><Icon name="Heart" size={17} /> {copy.interests}</h3>
            <div class="stay-planner__chips stay-planner__chips--wrap" data-planner-interests>
              {copy.interestsList.map(([value, label], index) => (
                <button type="button" data-value={value} class:list={[index < 2 && 'is-active']} aria-pressed={index < 2}>
                  <Icon name={interestIcons[value] ?? 'Map'} size={15} /> <span>{label}</span>
                </button>
              ))}
            </div>
          </div>

          <div class="stay-planner__control stay-planner__trip">
            <h3><Icon name="MountainSnow" size={17} /> {copy.trips}</h3>
            <div class="stay-planner__binary" data-planner-trip-choice>
              <button type="button" data-value="yes" aria-pressed="false">{dashboard.tripYes}</button>
              <button type="button" data-value="no" class="is-active" aria-pressed="true">{dashboard.tripNo}</button>
            </div>
            <div class="stay-planner__chips stay-planner__chips--wrap stay-planner__destinations" data-planner-trips hidden>
              {copy.tripList.filter(([value]) => value !== 'none').map(([value, label], index) => (
                <button type="button" data-value={value} class:list={[index === 0 && 'is-active']} aria-pressed={index === 0}>{label}</button>
              ))}
            </div>
          </div>

          <div class="stay-planner__control">
            <h3><Icon name="CloudSun" size={17} /> {copy.weatherPreference}</h3>
            <div class="stay-planner__chips stay-planner__chips--weather" data-planner-weather>
              <button type="button" class="is-active" data-value="flexible" aria-pressed="true"><Icon name="Clock3" size={15} /> {copy.options.flexible}</button>
              <button type="button" data-value="sun" aria-pressed="false"><Icon name="Sun" size={15} /> {copy.options.sun}</button>
              <button type="button" data-value="indoor" aria-pressed="false"><Icon name="Umbrella" size={15} /> {copy.options.indoor}</button>
            </div>
          </div>

          <button class="stay-planner__generate" type="button" data-planner-generate>
            <Icon name="WandSparkles" size={18} /> <span>{copy.generate}</span><Icon name="ArrowRight" size={17} />
          </button>
          <small class="stay-planner__updated"><span></span>{dashboard.planSavedAt}: <time data-planner-updated-time>—</time></small>
        </div>
      </aside>

      <main class="stay-planner__result" data-planner-result aria-live="polite"></main>
    </div>
  </div>
  <div class="stay-planner__toast" data-planner-toast role="status" aria-live="polite"></div>
</section>

<script>
  import { initStayPlanner } from '@/scripts/stayPlannerClient.js';
  initStayPlanner();
</script>

<style is:global>
.stay-planner {
  --planner-green:#55e392;
  --planner-green-2:#20b96a;
  --planner-ink:#041810;
  --planner-card:rgba(8,37,27,.92);
  --planner-line:rgba(102,225,157,.2);
  position:relative;
  isolation:isolate;
  min-height:100vh;
  padding:clamp(82px,8vw,112px) 0 42px;
  color:#f3fff7;
  background:
    radial-gradient(circle at 76% 5%,rgba(36,186,110,.14),transparent 32%),
    radial-gradient(circle at 0 45%,rgba(29,145,108,.11),transparent 28%),
    linear-gradient(180deg,#03150f 0%,#041b14 48%,#03130e 100%);
  overflow:clip;
}
.stay-planner__ambient { position:absolute; inset:0; z-index:-1; opacity:.36; background-image:radial-gradient(circle,rgba(119,245,171,.5) 0 1px,transparent 1.5px); background-size:58px 58px; mask-image:linear-gradient(to bottom,#000,transparent 74%); }
.stay-planner__sr-only { position:absolute!important; width:1px!important; height:1px!important; padding:0!important; margin:-1px!important; overflow:hidden!important; clip:rect(0,0,0,0)!important; white-space:nowrap!important; border:0!important; }
.stay-planner__shell { width:min(1840px,calc(100% - 32px)); margin:0 auto; }
.stay-planner__dashboard { display:grid; grid-template-columns:minmax(310px,372px) minmax(0,1fr); align-items:start; gap:20px; }
.stay-planner__panel { position:sticky; top:88px; z-index:5; max-height:calc(100vh - 106px); overflow:auto; padding:20px; border:1px solid var(--planner-line); border-radius:24px; background:linear-gradient(145deg,rgba(13,48,36,.96),rgba(6,31,23,.96)); box-shadow:0 24px 70px rgba(0,0,0,.3),inset 0 1px rgba(255,255,255,.04); scrollbar-width:thin; scrollbar-color:rgba(85,227,146,.35) transparent; }
.stay-planner__panel-head { margin-bottom:18px; }
.stay-planner__panel-head>div>span { display:flex; align-items:center; gap:7px; margin-bottom:7px; color:#82eeae; font-size:.67rem; font-weight:900; letter-spacing:.1em; text-transform:uppercase; }
.stay-planner__panel-head h2 { margin:0; color:#fff; font-size:clamp(1.25rem,1.65vw,1.65rem); line-height:1.1; letter-spacing:-.035em; }
.stay-planner__panel-head p { margin:7px 0 0; color:rgba(230,249,237,.65); font-size:.82rem; line-height:1.45; }
.stay-planner__panel-head>button { display:none; }
.stay-planner__filters { display:grid; gap:17px; }
.stay-planner__control { display:grid; gap:8px; min-width:0; }
.stay-planner__control h3 { display:flex; align-items:center; gap:7px; margin:0; color:#eafff1; font-size:.77rem; font-weight:850; }
.stay-planner__control h3 svg { color:#83eeb0; }
.stay-planner__stepper { display:grid; grid-template-columns:42px 1fr 42px; align-items:center; min-height:44px; border:1px solid rgba(77,218,139,.25); border-radius:14px; overflow:hidden; background:rgba(22,91,60,.34); }
.stay-planner__stepper button { display:grid; place-items:center; align-self:stretch; border:0; color:#c9ffe0; background:rgba(55,201,121,.13); cursor:pointer; transition:background .22s ease,transform .22s ease; }
.stay-planner__stepper button:hover { background:rgba(55,201,121,.28); }
.stay-planner__stepper button:active { transform:scale(.92); }
.stay-planner__stepper strong { display:flex; justify-content:center; gap:5px; font-size:.88rem; }
.stay-planner__stepper strong.is-changing { animation:plannerNumber .34s cubic-bezier(.22,1,.36,1); }
.stay-planner__stepper strong span { color:rgba(235,255,242,.7); font-weight:700; }
.stay-planner__date>span { position:relative; display:block; }
.stay-planner__date input { width:100%; min-height:44px; padding:0 38px 0 13px; border:1px solid rgba(77,218,139,.25); border-radius:14px; color:#f4fff8; color-scheme:dark; background:rgba(5,30,22,.68); font:inherit; font-size:.82rem; font-weight:750; outline:0; transition:border-color .22s ease,box-shadow .22s ease; }
.stay-planner__date input:focus { border-color:#58df91; box-shadow:0 0 0 3px rgba(67,214,132,.13); }
.stay-planner__date>span>svg { position:absolute; top:50%; right:13px; pointer-events:none; color:#73dca0; transform:translateY(-50%); }
.stay-planner__chips { display:grid; gap:7px; }
.stay-planner__chips--three { grid-template-columns:repeat(3,minmax(0,1fr)); }
.stay-planner__chips--four { grid-template-columns:repeat(2,minmax(0,1fr)); }
.stay-planner__chips--wrap { display:flex; flex-wrap:wrap; }
.stay-planner__chips--weather { grid-template-columns:1fr 1fr; }
.stay-planner__chips--weather button:first-child { grid-column:1/-1; }
.stay-planner__chips button,.stay-planner__binary button,.stay-planner__children button { display:inline-flex; min-width:0; min-height:36px; align-items:center; justify-content:center; gap:5px; padding:7px 9px; border:1px solid rgba(129,217,166,.17); border-radius:11px; color:rgba(239,255,245,.76); background:rgba(5,29,21,.58); font:inherit; font-size:.68rem; font-weight:780; line-height:1.15; cursor:pointer; transition:transform .25s cubic-bezier(.22,1,.36,1),border-color .25s ease,color .25s ease,background .25s ease,box-shadow .25s ease; }
.stay-planner__chips--wrap button { flex:1 1 auto; }
.stay-planner__chips button:hover,.stay-planner__binary button:hover,.stay-planner__children button:hover { color:#fff; border-color:rgba(89,227,149,.42); transform:translateY(-1px); }
.stay-planner__chips button.is-active,.stay-planner__binary button.is-active,.stay-planner__children button.is-active { color:#eafff1; border-color:rgba(81,232,148,.68); background:linear-gradient(145deg,rgba(42,185,105,.36),rgba(29,126,78,.28)); box-shadow:0 0 0 1px rgba(73,229,141,.11),0 7px 22px rgba(23,178,92,.13); }
.stay-planner__chips button.is-selecting,.stay-planner__binary button.is-selecting,.stay-planner__children button.is-selecting { animation:plannerChip .36s cubic-bezier(.22,1,.36,1); }
.stay-planner__children { display:flex; align-items:center; justify-content:space-between; gap:8px; padding:8px 9px; border:1px dashed rgba(95,213,145,.2); border-radius:11px; color:rgba(235,255,242,.67); font-size:.67rem; }
.stay-planner__children>div { display:flex; gap:5px; }
.stay-planner__children button { min-height:27px; padding:4px 10px; }
.stay-planner__binary { display:grid; grid-template-columns:1fr 1fr; gap:7px; }
.stay-planner__destinations[hidden] { display:none; }
.stay-planner__generate { display:flex; min-height:48px; align-items:center; justify-content:center; gap:8px; margin-top:2px; border:1px solid rgba(107,244,167,.48); border-radius:14px; color:#eafff1; background:linear-gradient(135deg,#168d50,#2dba70); box-shadow:0 14px 28px rgba(18,148,80,.22),inset 0 1px rgba(255,255,255,.16); font:inherit; font-size:.84rem; font-weight:900; cursor:pointer; transition:transform .3s cubic-bezier(.22,1,.36,1),box-shadow .3s ease; }
.stay-planner__generate:hover { transform:translateY(-2px); box-shadow:0 18px 34px rgba(18,170,88,.3),inset 0 1px rgba(255,255,255,.18); }
.stay-planner__generate svg:last-child { transition:transform .25s ease; }
.stay-planner__generate:hover svg:last-child { transform:translateX(3px); }
.stay-planner__updated { display:flex; align-items:center; justify-content:center; gap:5px; color:rgba(222,247,231,.47); font-size:.62rem; }
.stay-planner__updated>span { width:5px; height:5px; border-radius:50%; background:#50df8c; box-shadow:0 0 9px #50df8c; }

.stay-planner__result { min-width:0; transition:height .65s cubic-bezier(.22,1,.36,1),opacity .18s ease,filter .18s ease,transform .18s ease; }
.stay-planner__result.is-exiting { opacity:0; filter:blur(8px); transform:translateY(8px) scale(.992); }
.stay-planner__result.is-loading { overflow:hidden; }
.planner-result-shell { display:grid; gap:12px; min-width:0; }
.planner-hero { position:relative; display:flex; min-height:218px; align-items:flex-end; overflow:hidden; padding:22px 24px; border:1px solid rgba(97,233,158,.27); border-radius:24px; background:#06271b; box-shadow:0 20px 60px rgba(0,0,0,.23); }
.planner-hero__image { position:absolute; inset:0; width:100%; height:100%; object-fit:cover; object-position:center 55%; opacity:.7; filter:saturate(.92) contrast(1.05); }
.planner-hero::after { content:""; position:absolute; inset:0; background:linear-gradient(90deg,rgba(2,20,14,.88) 0%,rgba(4,27,19,.7) 48%,rgba(3,42,25,.83) 77%,rgba(2,34,22,.95) 100%),linear-gradient(0deg,rgba(2,17,12,.82),transparent 62%); }
.planner-hero__content { position:relative; z-index:2; width:min(810px,78%); }
.planner-hero__badge { display:inline-flex; align-items:center; gap:7px; padding:7px 11px; border:1px solid rgba(255,222,141,.3); border-radius:10px; color:#ffe6a7; background:rgba(18,42,31,.58); backdrop-filter:blur(10px); font-size:.65rem; font-weight:900; text-transform:uppercase; letter-spacing:.06em; }
.planner-hero h2 { max-width:750px; margin:10px 0 5px; color:#fff; font-size:clamp(1.65rem,2.55vw,2.75rem); line-height:1.03; letter-spacing:-.045em; text-wrap:balance; }
.planner-hero__subtitle { max-width:720px; margin:0; color:rgba(241,255,246,.77); font-size:.86rem; line-height:1.45; }
.planner-hero__stats { display:grid; grid-template-columns:repeat(4,minmax(0,1fr)); gap:8px; margin-top:15px; }
.planner-hero__stat { display:grid; grid-template-columns:32px minmax(0,1fr); gap:8px; align-items:center; min-height:48px; padding:7px 9px; border:1px solid rgba(112,230,162,.2); border-radius:12px; background:rgba(5,35,24,.64); backdrop-filter:blur(12px); }
.planner-hero__stat>span { display:grid; width:32px; height:32px; place-items:center; border-radius:9px; color:#8df1b6; background:rgba(52,191,112,.17); font-size:1rem; }
.planner-hero__stat small,.planner-hero__stat strong { display:block; min-width:0; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
.planner-hero__stat small { color:rgba(224,249,233,.55); font-size:.54rem; text-transform:uppercase; letter-spacing:.05em; }
.planner-hero__stat strong { margin-top:2px; color:#f7fff9; font-size:.7rem; }
.planner-hero__brand { position:absolute; z-index:2; top:20px; right:22px; display:grid; width:112px; height:112px; place-items:center; color:#85f6b5; filter:drop-shadow(0 0 25px rgba(75,239,145,.34)); opacity:.58; }
.planner-hero__brand img { position:absolute; width:68px; height:68px; opacity:.28; }
.planner-hero__brand span { margin-top:52px; font-size:3.1rem; }

.planner-weather { display:grid; grid-template-columns:auto minmax(0,1fr) auto; align-items:center; gap:14px; min-height:82px; padding:10px 13px 10px 17px; border:1px solid var(--planner-line); border-radius:18px; background:linear-gradient(135deg,rgba(9,45,32,.94),rgba(5,31,23,.94)); }
.planner-weather>h3 { margin:0; color:#f1fff6; font-size:.78rem; white-space:nowrap; }
.planner-weather__days { display:flex; min-width:0; gap:8px; overflow-x:auto; scrollbar-width:none; }
.planner-weather__days::-webkit-scrollbar { display:none; }
.planner-weather__day { display:grid; grid-template-columns:auto auto minmax(74px,1fr); align-items:center; flex:1 0 150px; gap:7px; min-height:57px; padding:7px 10px; border:1px solid rgba(96,220,150,.14); border-radius:12px; background:rgba(18,68,47,.42); }
.planner-weather__day>span { font-size:1.45rem; }
.planner-weather__day strong { color:#fff; font-size:.75rem; white-space:nowrap; }
.planner-weather__day small { display:block; color:rgba(233,252,240,.58); font-size:.58rem; white-space:nowrap; }
.planner-weather__day p { margin:0; overflow:hidden; color:rgba(235,255,242,.72); font-size:.62rem; text-overflow:ellipsis; white-space:nowrap; }
.planner-weather__day em { display:none; color:#8ee7b2; font-size:.56rem; font-style:normal; }
.planner-weather.is-expanded .planner-weather__day em { display:block; }
.planner-weather__empty { margin:0; color:rgba(232,254,240,.65); font-size:.72rem; }
.planner-weather__toggle { display:inline-flex; min-height:36px; align-items:center; gap:7px; padding:0 12px; border:1px solid rgba(88,224,146,.32); border-radius:12px; color:#dfffea; background:rgba(19,84,55,.35); font:inherit; font-size:.66rem; font-weight:800; cursor:pointer; white-space:nowrap; }

.planner-days { position:relative; min-width:0; }
.planner-days__toolbar { display:flex; align-items:center; justify-content:flex-end; gap:7px; min-height:28px; margin-bottom:5px; }
.planner-days__toolbar[hidden] { display:none; }
.planner-days__toolbar button { display:grid; width:30px; height:28px; place-items:center; border:1px solid rgba(90,218,145,.22); border-radius:9px; color:#dfffea; background:rgba(10,47,34,.8); cursor:pointer; }
.planner-days__toolbar button:disabled { opacity:.35; cursor:default; }
.planner-days__indicator { min-width:68px; color:rgba(231,253,239,.65); font-size:.62rem; text-align:center; }
.planner-days__viewport { min-width:0; overflow:hidden; }
.planner-days__track { display:grid; grid-auto-flow:column; grid-auto-columns:calc((100% - (var(--planner-visible,3) - 1)*12px)/var(--planner-visible,3)); gap:12px; transition:transform .5s cubic-bezier(.22,1,.36,1); will-change:transform; }
