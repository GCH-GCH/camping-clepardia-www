      '4': {
        comfortable: ['Kraków bez pośpiechu', 'Kazimierz i muzea', 'Wieliczka jako oddzielna wycieczka', 'Dzień wolniejszy na odpoczynek lub Ojców'],
        tooMuch: ['Codziennie daleka wycieczka poza miasto', 'Zakopane i Energylandia bez dnia regeneracji', 'Plan bez przerwy przy upale'],
        recommendation: '4 noce pozwalają zwiedzać spokojniej: Kraków + Kazimierz + Wieliczka + wolniejszy dzień. To bardzo dobry wariant dla domków i rodzin.',
        days: ['Dzień 1: centrum i Wawel.', 'Dzień 2: Kazimierz + Schindler.', 'Dzień 3: Wieliczka.', 'Dzień 4: Ojców, luźny Kraków albo odpoczynek na campingu.'],
      },
      '5+': {
        comfortable: ['Kraków i Małopolska bez gonienia', 'Wieliczka, Auschwitz albo Ojców', 'Energylandia lub Zakopane jako pełny dzień', 'Dni spokojniejsze między większymi trasami'],
        tooMuch: ['Wszystkie dalekie atrakcje jedna po drugiej', 'Brak dnia buforowego na pogodę', 'Traktowanie campingu tylko jako parkingu'],
        recommendation: '5+ nocy to już pobyt regionalny. Camping Clepardia może być bazą na Kraków, Małopolskę, Energylandię, Ojców lub Zakopane.',
        days: ['Dzień 1: Stare Miasto + Wawel.', 'Dzień 2: Kazimierz + muzea.', 'Dzień 3: Wieliczka albo Auschwitz.', 'Dzień 4: odpoczynek / Ojców.', 'Dzień 5: Energylandia, Zakopane albo własny rytm.'],
      },
    },
  },
  en: {
    kicker: 'Stay planner',
    title: 'Plan Krakow without packing too much into one stay',
    lead:
      'Choose nights, pace, group and transport. The planner suggests what fits from Camping Clepardia, what may be too much and how to shape the day.',
    micro: 'This is a friendly guide, not a fixed programme.',
    nights: 'Nights',
    pace: 'Pace',
    group: 'Travel group',
    transport: 'Transport',
    interests: 'Interests',
    resultTitle: 'Stay recommendation',
    comfortable: 'Comfortably doable',
    tooMuch: 'May be too much',
    recommendation: 'Our recommendation',
    dayPlan: 'Day plan',
    quizTitle: 'Not sure what to choose?',
    quizCopy: 'Pick the closest scenario and the planner will set a good starting point.',
    todayTitle: 'Plan for today',
    todayCopy: 'A safe first day: tram to Stary Kleparz, Old Town walk, Wawel or Kazimierz, then a calm return to the campsite.',
    arrivalTitle: 'First arrival package',
    arrivalItems: [
      'Prepare one identity document for reception registration.',
      'If you arrive with a vehicle, reception will ask for the registration plate.',
      'With a camping trailer, enter the trailer registration plate.',
      'Use Google Maps because access changed in 2022.',
      'Quiet hours: 22:00-07:00.',
    ],
    ctaBooking: 'Book your stay',
    ctaCampy: 'Ask CAMPY',
    ctaTours: 'Tours from Krakow',
    ctaTram: 'Tram directions',
    ctaAttractions: 'See attractions',
    options: {
      calm: 'Calm',
      normal: 'Normal',
      intensive: 'Intensive',
      pair: 'Couple',
      family: 'Family',
      solo: 'Solo',
      group: 'Group',
      tram: 'Tram',
      car: 'Car',
      mixed: 'Walk + tram',
    },
    interestsList: [
      ['classic', 'Old Town + Wawel'],
      ['history', 'History and museums'],
      ['kids', 'Kids and energy'],
      ['nature', 'Nature outside the city'],
      ['tours', 'Organised tours'],
    ],
    scenarios: [
      { id: 'camper', icon: 'Caravan', title: 'Arriving by camper', copy: 'Start with calm Krakow and the tram.', nights: '2', pace: 'normal', group: 'pair', transport: 'tram', interests: ['classic'] },
      { id: 'family', icon: 'UsersRound', title: 'Family with kids', copy: 'Add breathing space and one bigger attraction.', nights: '3', pace: 'calm', group: 'family', transport: 'mixed', interests: ['classic', 'kids'] },
      { id: 'krakow', icon: 'Landmark', title: 'I want Krakow', copy: 'Old Town, Wawel, Kazimierz and museums without the car.', nights: '2', pace: 'normal', group: 'pair', transport: 'tram', interests: ['classic', 'history'] },
      { id: 'cabin', icon: 'House', title: 'Bungalow and slow stay', copy: 'City + one trip outside Krakow.', nights: '4', pace: 'calm', group: 'family', transport: 'mixed', interests: ['classic', 'nature'] },
    ],
    recommendations: {
      '1': { comfortable: ['Old Town and Wawel', 'Kazimierz only if you still have energy', 'Tram route to Stary Kleparz'], tooMuch: ['Wieliczka and Auschwitz', 'Zakopane or Energylandia', 'Driving into the strict centre'], recommendation: 'With 1 night, keep it a city break: Old Town + Wawel. Leave bigger trips for a longer stay.', days: ['Arrival, tram to the centre, Old Town, Wawel or Kazimierz, calm evening.'] },
      '2': { comfortable: ['Old Town, Wawel and Kazimierz', 'Schindler Factory or a calm Kazimierz evening', 'Wieliczka is possible but intense'], tooMuch: ['Wieliczka + Auschwitz + full Krakow', 'Far trips without a full day', 'Late start every day'], recommendation: 'With 2 nights, combine the centre with Kazimierz. Wieliczka is possible if you skip part of the city or add one day.', days: ['Day 1: Old Town + Wawel.', 'Day 2: Kazimierz or Wieliczka.'] },
      '3': { comfortable: ['Classic Krakow', 'Wieliczka or Auschwitz as a separate day', 'A family-friendly slower day'], tooMuch: ['Wieliczka and Auschwitz back to back with small kids', 'Zakopane without an early start', 'No weather buffer'], recommendation: '3 nights gives a good rhythm: two Krakow days and one bigger trip.', days: ['Day 1: Old Town + Wawel.', 'Day 2: Kazimierz + museums.', 'Day 3: Wieliczka / Auschwitz / Energylandia.'] },
      '4': { comfortable: ['Krakow without rush', 'Kazimierz and museums', 'Wieliczka as a separate trip', 'A slower day for Ojców or rest'], tooMuch: ['A long trip every day', 'Zakopane and Energylandia without rest', 'No break in hot weather'], recommendation: '4 nights lets you do Krakow + Kazimierz + Wieliczka + a slower day.', days: ['Day 1: centre and Wawel.', 'Day 2: Kazimierz + Schindler.', 'Day 3: Wieliczka.', 'Day 4: Ojców, slow Krakow or campsite rest.'] },
      '5+': { comfortable: ['Krakow and Lesser Poland', 'Wieliczka, Auschwitz or Ojców', 'Energylandia or Zakopane as a full day', 'Slower days between bigger trips'], tooMuch: ['All long trips one after another', 'No weather buffer', 'Treating the campsite only as parking'], recommendation: '5+ nights makes Clepardia a regional base for Krakow and Lesser Poland.', days: ['Day 1: Old Town + Wawel.', 'Day 2: Kazimierz + museums.', 'Day 3: Wieliczka or Auschwitz.', 'Day 4: rest / Ojców.', 'Day 5: Energylandia, Zakopane or your own rhythm.'] },
    },
  },
};

const copy = copyByLang[lang as keyof typeof copyByLang] ?? copyByLang.en;
const plannerConfigEncoded = Buffer.from(JSON.stringify(copy), 'utf8').toString('base64');
const inspirationCopy = {
  pl: {
    kicker: 'Inspiracje do planu',
    title: 'Zobacz kierunki, zanim ułożysz tempo pobytu',
    items: ['Kraków i Wawel', 'Wieliczka', 'Rodzinny dzień'],
  },
  en: {
    kicker: 'Stay inspiration',
    title: 'See the directions before choosing your pace',
    items: ['Krakow and Wawel', 'Wieliczka', 'Family day'],
  },
  de: {
    kicker: 'Inspiration',
    title: 'Ziele ansehen, bevor Sie das Tempo wählen',
    items: ['Krakau und Wawel', 'Wieliczka', 'Familientag'],
  },
  it: {
    kicker: 'Ispirazioni',
    title: 'Guarda le mete prima di scegliere il ritmo',
    items: ['Cracovia e Wawel', 'Wieliczka', 'Giornata in famiglia'],
  },
}[lang as 'pl' | 'en' | 'de' | 'it'] ?? {
  kicker: 'Stay inspiration',
  title: 'See the directions before choosing your pace',
  items: ['Krakow and Wawel', 'Wieliczka', 'Family day'],
};
const inspirationImages = [
  attractionImages.wawel,
  attractionImages.wieliczka,
  attractionImages.energylandia,
];
---

<section class="site-section stay-planner reveal-section" data-stay-planner>
  <div class="stay-planner__ambient" aria-hidden="true"><span></span><span></span><span></span></div>
  <div class="container stay-planner__shell">
    <div class="stay-planner__head">
      <span class="section-kicker">{copy.kicker}</span>
      <h1>{copy.title}</h1>
      <p>{copy.lead}</p>
      <small>{copy.micro}</small>
    </div>

    <div class="premium-card stay-planner__quiz">
      <div>
        <h2>{copy.quizTitle}</h2>
        <p>{copy.quizCopy}</p>
      </div>
      <div class="stay-planner__scenario-grid">
        {copy.scenarios.map((scenario) => (
          <button
            type="button"
            data-planner-scenario={scenario.id}
            data-nights={scenario.nights}
            data-pace={scenario.pace}
            data-group={scenario.group}
            data-transport={scenario.transport}
            data-interests={scenario.interests.join(',')}
          >
            <Icon name={scenario.icon} size={22} strokeWidth={2} />
            <strong>{scenario.title}</strong>
            <span>{scenario.copy}</span>
          </button>
        ))}
      </div>
    </div>

    <section class="stay-planner__inspiration" aria-labelledby="stayPlannerInspirationTitle">
      <div class="stay-planner__inspiration-copy">
        <span class="section-kicker">{inspirationCopy.kicker}</span>
        <h2 id="stayPlannerInspirationTitle">{inspirationCopy.title}</h2>
      </div>
      <div class="stay-planner__inspiration-grid">
        {inspirationImages.map((image, index) => (
          <ImageFrame
            src={image.src}
            alt={image.altPl}
            label={inspirationCopy.items[index]}
            className="stay-planner__inspiration-image"
            width={image.width}
            height={image.height}
            sizes={image.sizes}
          />
        ))}
      </div>
    </section>

    <div class="stay-planner__layout">
      <div class="premium-card stay-planner__panel">
        <div class="stay-planner__control">
          <h2><Icon name="CalendarDays" size={21} strokeWidth={2} /> {copy.nights}</h2>
          <div class="stay-planner__segments" data-planner-nights>
            {['1', '2', '3', '4', '5+'].map((value, index) => (
              <button type="button" class:list={[index === 1 && 'is-active']} data-value={value}>{value}</button>
            ))}
          </div>
        </div>

        <div class="stay-planner__control">
          <h2><Icon name="Gauge" size={21} strokeWidth={2} /> {copy.pace}</h2>
          <div class="stay-planner__segments" data-planner-pace>
            {[
              ['calm', copy.options.calm],
              ['normal', copy.options.normal],
              ['intensive', copy.options.intensive],
            ].map(([value, label], index) => (
              <button type="button" class:list={[index === 1 && 'is-active']} data-value={value}>{label}</button>
            ))}
          </div>
        </div>

        <div class="stay-planner__control">
          <h2><Icon name="UsersRound" size={21} strokeWidth={2} /> {copy.group}</h2>
          <div class="stay-planner__segments" data-planner-group>
            {[
              ['pair', copy.options.pair],
              ['family', copy.options.family],
              ['solo', copy.options.solo],
              ['group', copy.options.group],
            ].map(([value, label], index) => (
              <button type="button" class:list={[index === 1 && 'is-active']} data-value={value}>{label}</button>
            ))}
          </div>
        </div>

        <div class="stay-planner__control">
          <h2><Icon name="TramFront" size={21} strokeWidth={2} /> {copy.transport}</h2>
          <div class="stay-planner__segments" data-planner-transport>
            {[
              ['tram', copy.options.tram],
              ['car', copy.options.car],
              ['mixed', copy.options.mixed],
            ].map(([value, label], index) => (
              <button type="button" class:list={[index === 0 && 'is-active']} data-value={value}>{label}</button>
            ))}
          </div>
        </div>

        <div class="stay-planner__control stay-planner__control--wide">
          <h2><Icon name="Sparkles" size={21} strokeWidth={2} /> {copy.interests}</h2>
          <div class="stay-planner__attractions" data-planner-interests>
            {copy.interestsList.map(([value, label], index) => (
              <button type="button" data-value={value} class:list={[index < 2 && 'is-active']}>
                <Icon name={value === 'kids' ? 'HeartHandshake' : value === 'nature' ? 'Leaf' : value === 'tours' ? 'Ticket' : value === 'history' ? 'Landmark' : 'Map'} size={18} strokeWidth={2} />
                <span>{label}</span>
              </button>
            ))}
          </div>
        </div>
      </div>

      <aside class="premium-card stay-planner__result" data-planner-result aria-live="polite"></aside>
    </div>

    <div class="stay-planner__extras">
      <article class="premium-card stay-planner__today">
        <Icon name="SunMedium" size={24} strokeWidth={2} />
        <div>
          <h2>{copy.todayTitle}</h2>
          <p>{copy.todayCopy}</p>
        </div>
      </article>
      <article class="premium-card stay-planner__arrival">
        <Icon name="BadgeCheck" size={24} strokeWidth={2} />
        <div>
          <h2>{copy.arrivalTitle}</h2>
          <ul>
            {copy.arrivalItems.map((item) => <li>{item}</li>)}
          </ul>
        </div>
      </article>
    </div>

    <div class="stay-planner__actions">
      <a class="btn btn-primary premium-button" href={bookingHref}><Icon name="CalendarCheck" size={18} strokeWidth={2} /> {copy.ctaBooking}</a>
      <button class="btn btn-glass" type="button" data-ask-campy-planner><Icon name="BotMessageSquare" size={18} strokeWidth={2} /> {copy.ctaCampy}</button>
      <a class="btn btn-glass" href={transportHref}><Icon name="TramFront" size={18} strokeWidth={2} /> {copy.ctaTram}</a>
      <a class="btn btn-glass" href={attractionsHref}><Icon name="Map" size={18} strokeWidth={2} /> {copy.ctaAttractions}</a>
      <a class="btn btn-glass" href={attractionsHref}><Icon name="Ticket" size={18} strokeWidth={2} /> {copy.ctaTours}</a>
    </div>
  </div>
</section>

<script define:vars={{ plannerConfigEncoded }}>
  (() => {
    const root = document.querySelector('[data-stay-planner]');
    if (!(root instanceof HTMLElement)) return;

    const decodeConfig = () => {
      try {
        const binary = window.atob(plannerConfigEncoded);
        const bytes = Uint8Array.from(binary, (character) => character.charCodeAt(0));
        return JSON.parse(new TextDecoder().decode(bytes));
      } catch {
        return null;
      }
    };

    const config = decodeConfig();
    if (!config) return;

    const state = {
      nights: '2',
      pace: 'normal',
      group: 'family',
      transport: 'tram',
      interests: new Set(['classic', 'history']),
    };

    const result = root.querySelector('[data-planner-result]');
    const setActive = (selector, value) => {
      root.querySelectorAll(`${selector} button`).forEach((button) => {
        if (button instanceof HTMLButtonElement) {
          button.classList.toggle('is-active', button.dataset.value === value);
        }
      });
    };

    const paceNote = () => {
      if (state.pace === 'calm') return 'Tempo spokojne: lepiej zostawić bufor na kawę, obiad i powrót na camping.';
      if (state.pace === 'intensive') return 'Tempo intensywne: plan da się zagęścić, ale większe wycieczki traktuj jako osobny dzień.';
      return 'Tempo normalne: dobry balans między zwiedzaniem i odpoczynkiem.';
    };

    const transportNote = () => {
      if (state.transport === 'tram') return 'Najprościej: tramwaj z Górnickiego do Starego Kleparza, potem spacer.';
      if (state.transport === 'car') return 'Auto zostaw raczej na dalsze wycieczki. Do ścisłego centrum wygodniejszy jest tramwaj.';
      return 'Spacer + tramwaj to najlepszy miks na centrum, Kazimierz i Wawel.';
    };

    const groupNote = () => {
      if (state.group === 'family') return 'Dla rodzin najlepiej działa jeden mocniejszy punkt dziennie i przerwa po południu.';
      if (state.group === 'solo') return 'Solo łatwo zmienić plan w biegu: zacznij od centrum i dopiero potem dobieraj muzea.';
      if (state.group === 'group') return 'Dla grupy zaplanuj mniej punktów, ale z większym marginesem na logistykę.';
      return 'Dla pary dobrze sprawdza się centrum + Kazimierz i jeden spokojny wieczór.';
    };

    const renderList = (items = []) => items.map((item) => `<li>${item}</li>`).join('');

    const render = () => {
      if (!(result instanceof HTMLElement)) return;
      const plan = config.recommendations[state.nights] || config.recommendations['5+'];
      result.innerHTML = `
        <span class="stay-planner__result-badge">${config.resultTitle}</span>
        <h2>${config.recommendation}</h2>
        <p>${plan.recommendation}</p>
        <div class="stay-planner__result-grid">
          <section>
            <strong>${config.comfortable}</strong>
            <ul>${renderList(plan.comfortable)}</ul>
          </section>
          <section>
            <strong>${config.tooMuch}</strong>
            <ul>${renderList(plan.tooMuch)}</ul>
          </section>
        </div>
        <div class="stay-planner__context">
          <p>${paceNote()}</p>
          <p>${transportNote()}</p>
          <p>${groupNote()}</p>
        </div>
        <div class="stay-planner__plan">
          <strong>${config.dayPlan}</strong>
          ${plan.days.map((day, index) => `<div><span>${index + 1}</span><p>${day}</p></div>`).join('')}
        </div>
      `;
    };

    const bindSegment = (selector, key) => {
      const buttons = Array.from(root.querySelectorAll(`${selector} button`));
      buttons.forEach((button) => {
        if (!(button instanceof HTMLButtonElement)) return;
        button.addEventListener('click', () => {
          buttons.forEach((item) => item.classList.toggle('is-active', item === button));
          state[key] = button.dataset.value || state[key];
          render();
        });
      });
    };

    bindSegment('[data-planner-nights]', 'nights');
    bindSegment('[data-planner-pace]', 'pace');
    bindSegment('[data-planner-group]', 'group');
    bindSegment('[data-planner-transport]', 'transport');

    const interestButtons = Array.from(root.querySelectorAll('[data-planner-interests] button'));
    interestButtons.forEach((button) => {
      if (!(button instanceof HTMLButtonElement)) return;
      button.addEventListener('click', () => {
        const value = button.dataset.value || '';
        button.classList.toggle('is-active');
        if (button.classList.contains('is-active')) state.interests.add(value);
        else state.interests.delete(value);
        render();
      });
    });

    root.querySelectorAll('[data-planner-scenario]').forEach((button) => {
      if (!(button instanceof HTMLButtonElement)) return;
      button.addEventListener('click', () => {
        state.nights = button.dataset.nights || '2';
        state.pace = button.dataset.pace || 'normal';
        state.group = button.dataset.group || 'family';
        state.transport = button.dataset.transport || 'tram';
        state.interests = new Set((button.dataset.interests || 'classic').split(',').filter(Boolean));
        setActive('[data-planner-nights]', state.nights);
        setActive('[data-planner-pace]', state.pace);
        setActive('[data-planner-group]', state.group);
        setActive('[data-planner-transport]', state.transport);
        interestButtons.forEach((item) => {
          if (item instanceof HTMLButtonElement) item.classList.toggle('is-active', state.interests.has(item.dataset.value || ''));
        });
        root.querySelector('.stay-planner__layout')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
        render();
      });
    });

    root.querySelector('[data-ask-campy-planner]')?.addEventListener('click', () => {
      window.dispatchEvent(new CustomEvent('campy:prompt', {
        detail: { prompt: config.ctaCampy, actionKey: 'stayLength' },
      }));
    });

    render();
  })();
</script>

