    ticketPhoto: 'Tickets on the tram',
    tickets: [
      { title: 'Machine on the tram', copy: 'A ticket can be bought from a machine on the tram.' },
      { title: 'Card payment', copy: 'Card payment is available in many trams.' },
      { title: 'Jakdojade', copy: 'Jakdojade is useful for checking routes and buying tickets.' },
      { title: 'Google Maps', copy: 'Google Maps helps quickly check a walking + tram route.' },
    ],
    carKicker: 'Arriving by car',
    carTitle: 'Arriving by car or motorhome',
    carCopy:
      'Enter Camping Clepardia or the address Henryka Pachońskiego 28A, Krakow in navigation. After arrival, go to reception or follow instructions from staff.',
    mapsNotice:
      'For navigation we recommend Google Maps. The entrance / access route changed in 2022, so older navigation systems may lead incorrectly.',
    arrivalKicker: 'Arrival at the campsite',
    arrivalTitle: 'Stop near reception after arrival',
    arrivalCopy:
      'After arrival, please stop at the parking area near reception. Our reception staff will come to you, show you your place and guide you around the campsite. Registration is completed afterwards.',
    sctKicker: 'Before entering Krakow',
    sctTitle: 'Clean Transport Zone in Krakow',
    sctCopy:
      'Before travelling to Krakow, it is worth checking the current Clean Transport Zone rules. Regulations may change, so please verify the information on the official City of Krakow website before your trip.',
    sctButton: 'Check current CTZ rules',
    maps: 'Open in Google Maps',
    contact: 'Contact reception',
    mapLabel: 'Directions map',
    finalKicker: 'A convenient arrival plan',
    finalTitle: 'Plan your route and confirm the stay with reception',
    finalCopy:
      'If you arrive by motorhome, caravan or a larger vehicle, contact reception before arrival and confirm the details.',
