  de: {
    quickAria: 'Kurzinformationen zur Anfahrt',
    quick: {
      address: 'Adresse',
      tram: 'Straßenbahn',
      center: 'Zentrum',
      base: 'Basis',
    },
    centerKicker: 'Ins Zentrum',
    centerTitle: 'Am bequemsten mit der Straßenbahn',
    centerCopy:
      'Lassen Sie Auto, Wohnmobil oder Wohnwagen auf dem Campingplatz und fahren Sie mit der Straßenbahn ins Zentrum. Die Haltestelle ist ca. 40 m vom Tor entfernt, bis Stary Kleparz / Zentrum sind es ca. 9 Haltestellen, meist rund 14 Minuten.',
    steps: [
      'Gehen Sie zur Haltestelle ca. 40 m vom Tor entfernt.',
      'Steigen Sie in die Straßenbahn Richtung Zentrum.',
      'Nach ca. 9 Haltestellen steigen Sie im Bereich Stary Kleparz / Zentrum aus.',
      'Weiter geht es zu Fuß Richtung Altstadt.',
    ],
    tram: 'Straßenbahn',
    oldTown: 'Altstadt',
    tramPhoto: 'Straßenbahn ins Zentrum',
    ticketsKicker: 'Straßenbahntickets',
    ticketsTitle: 'Tickets und Apps',
    ticketsCopy: 'Prüfen Sie vor der Fahrt die aktuelle Verbindung und wählen Sie die bequemste Ticketoption.',
    ticketPhoto: 'Tickets in der Straßenbahn',
    tickets: [
      { title: 'Automat in der Straßenbahn', copy: 'Ein Ticket kann am Automaten in der Straßenbahn gekauft werden.' },
      { title: 'Kartenzahlung', copy: 'In vielen Straßenbahnen ist Kartenzahlung möglich.' },
      { title: 'Jakdojade', copy: 'Jakdojade hilft bei Routenprüfung und Ticketkauf.' },
      { title: 'Google Maps', copy: 'Google Maps hilft schnell eine Fußweg- und Straßenbahnroute zu prüfen.' },
    ],
    carKicker: 'Anfahrt mit dem Auto',
    carTitle: 'Anfahrt mit Auto oder Wohnmobil',
    carCopy:
      'Geben Sie Camping Clepardia oder Henryka Pachońskiego 28A, Krakau in die Navigation ein. Nach Ankunft gehen Sie zur Rezeption oder folgen den Anweisungen des Personals.',
    mapsNotice:
      'Für die Navigation empfehlen wir Google Maps. Die Einfahrt / Zufahrt wurde 2022 geändert, ältere Navigationssysteme können falsch führen.',
    arrivalKicker: 'Ankunft auf dem Campingplatz',
    arrivalTitle: 'Bitte halten Sie nahe der Rezeption',
    arrivalCopy:
      'Bitte halten Sie bei der Ankunft auf dem Parkplatz in der Nähe der Rezeption. Unser Rezeptionsteam kommt zu Ihnen, zeigt Ihnen den Platz und erklärt Ihnen den Campingplatz. Danach erfolgt die Anmeldung.',
    sctKicker: 'Vor der Einfahrt nach Krakau',
    sctTitle: 'Umweltzone in Krakau',
    sctCopy:
      'Vor der Reise nach Krakau lohnt es sich, die aktuellen Regeln der Umweltzone zu prüfen. Vorschriften können sich ändern, daher prüfen Sie die Informationen bitte vor der Reise auf der offiziellen Website der Stadt Krakau.',
    sctButton: 'Aktuelle Regeln prüfen',
    maps: 'In Google Maps öffnen',
    contact: 'Rezeption kontaktieren',
    mapLabel: 'Anfahrtskarte',
    finalKicker: 'Bequemer Anreiseplan',
    finalTitle: 'Route planen und Aufenthalt mit der Rezeption bestätigen',
    finalCopy:
      'Wenn Sie mit Wohnmobil, Wohnwagen oder größerem Fahrzeug anreisen, kontaktieren Sie die Rezeption vorab und bestätigen Sie die Details.',
  },
  it: {
    quickAria: 'Informazioni rapide su come arrivare',
    quick: {
      address: 'Indirizzo',
      tram: 'Tram',
      center: 'Centro',
      base: 'Base',
    },
    centerKicker: 'Come arrivare in centro',
    centerTitle: 'Il modo più comodo è il tram',
    centerCopy:
      'Lascia auto, camper o roulotte al camping e raggiungi il centro di Cracovia in tram. La fermata è a circa 40 m dal cancello, Stary Kleparz / centro dista circa 9 fermate e il viaggio dura di solito circa 14 minuti.',
    steps: [
      'Esci dal camping verso la fermata a circa 40 m dal cancello.',
      'Prendi il tram in direzione centro.',
      'Dopo circa 9 fermate scendi nella zona di Stary Kleparz / centro.',
      'Prosegui a piedi verso la Città Vecchia.',
    ],
    tram: 'Tram',
    oldTown: 'Città Vecchia',
    tramPhoto: 'Tram per il centro',
    ticketsKicker: 'Biglietti del tram',
    ticketsTitle: 'Biglietti e app',
    ticketsCopy: 'Prima del viaggio controlla il percorso aggiornato e scegli il modo più comodo per acquistare il biglietto.',
    ticketPhoto: 'Biglietti in tram',
    tickets: [
      { title: 'Distributore in tram', copy: 'Il biglietto può essere acquistato al distributore in tram.' },
      { title: 'Pagamento con carta', copy: 'In molti tram è possibile pagare con carta.' },
