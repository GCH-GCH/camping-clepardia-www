const transportText = transportTextByLanguage[contentLanguage];
const registrationTextByLanguage = {
  pl: {
    title: 'Co przygotować do rejestracji?',
    document: 'Przy rejestracji na recepcji poprosimy o jeden dokument tożsamości.',
    plate: 'Jeśli przyjeżdżasz autem, kamperem, vanem lub przyczepą, przygotuj numer rejestracyjny pojazdu.',
    trailer: 'Przy przyjeździe z przyczepą kempingową wpisz numer rejestracyjny przyczepy.',
  },
  en: {
    title: 'What to prepare for registration?',
    document: 'At reception registration we will ask for one identity document.',
    plate: 'If you arrive by car, camper, van or caravan, prepare the vehicle registration plate.',
    trailer: 'When arriving with a camping trailer, enter the trailer registration plate.',
  },
  de: {
    title: 'Was wird für die Anmeldung benötigt?',
    document: 'Bei der Anmeldung an der Rezeption bitten wir um ein Ausweisdokument.',
    plate: 'Wenn Sie mit Auto, Wohnmobil, Van oder Wohnwagen anreisen, bereiten Sie bitte das Kennzeichen vor.',
    trailer: 'Bei Anreise mit Wohnwagen tragen Sie bitte das Kennzeichen des Wohnwagens/Anhängers ein.',
  },
  it: {
    title: 'Cosa preparare per la registrazione?',
    document: 'Alla registrazione in reception chiederemo un documento di identità.',
    plate: 'Se arrivi in auto, camper, van o roulotte, prepara la targa del veicolo.',
    trailer: 'Se arrivi con una roulotte, inserisci la targa della roulotte/rimorchio.',
  },
};
const registrationText = registrationTextByLanguage[contentLanguage as keyof typeof registrationTextByLanguage] ?? registrationTextByLanguage.en;

const quickInfo = [
  { icon: 'map', label: transportText.quick.address, value: page.highlights[0].copy },
  { icon: 'tram', label: transportText.quick.tram, value: page.highlights[1].title },
  { icon: 'route', label: transportText.quick.center, value: page.highlights[2].copy },
  { icon: 'landmark', label: transportText.quick.base, value: page.highlights[3].copy },
];

const centerSteps = transportText.steps;

const ticketCards = transportText.tickets;
const ticketIcons = ['ticket', 'receipt', 'route', 'map'] as const;
---

<section class="site-section transport-page-quick reveal-section" aria-label={transportText.quickAria}>
  <div class="container transport-page-quick__grid">
    {quickInfo.map((item, index) => (
      <article class="premium-card reveal-section transport-page-quick__card" style={`--reveal-delay: ${index * 80}ms`}>
        <span aria-hidden="true">
          <Icon name={item.icon} size={24} strokeWidth={1.8} />
        </span>
        <div>
          <small>{item.label}</small>
          <strong>{item.value}</strong>
        </div>
      </article>
    ))}
  </div>
</section>

<TramCenterGuide languageCode={languageCode} variant="page" />

<section class="site-section transport-center reveal-section">
  <div class="container transport-center__grid">
    <div class="transport-center__content">
      <span class="section-kicker">{transportText.centerKicker}</span>
      <h2 class="section-title">{transportText.centerTitle}</h2>
      <p class="section-copy">
        {transportText.centerCopy}
      </p>

      <ol class="transport-center__steps">
        {centerSteps.map((step, index) => (
          <li class="reveal-section" style={`--reveal-delay: ${index * 70}ms`}>
            <span>{String(index + 1).padStart(2, '0')}</span>
            <p>{step}</p>
          </li>
        ))}
      </ol>
    </div>

    <div class="transport-center__media">
      <ImageFrame
        src={siteAssets.transport.tramToCenter}
        alt={transportText.tramPhoto}
        label={transportText.tramPhoto}
      />
      <div class="transport-center__route premium-card">
        <span>Camping</span><i></i><span>{transportText.tram}</span><i></i><span>{transportText.oldTown}</span>
      </div>
    </div>
  </div>
</section>

<section class="site-section transport-tickets reveal-section">
  <div class="container">
    <div class="transport-tickets__head">
      <span class="section-kicker">{transportText.ticketsKicker}</span>
      <h2 class="section-title">{transportText.ticketsTitle}</h2>
      <p class="section-copy">
        {transportText.ticketsCopy}
      </p>
    </div>

    <div class="transport-tickets__grid">
      <div class="transport-tickets__cards">
        {ticketCards.map((item, index) => (
          <article class="premium-card reveal-section transport-tickets__card" style={`--reveal-delay: ${index * 80}ms`}>
            <span class="transport-tickets__icon" aria-hidden="true">
              <Icon name={ticketIcons[index] ?? 'ticket'} size={20} strokeWidth={1.8} />
            </span>
            <h3>{item.title}</h3>
            <p>{item.copy}</p>
          </article>
        ))}
      </div>

      <div class="transport-tickets__media">
        <ImageFrame src={siteAssets.transport.ticketMachine} alt={transportText.ticketPhoto} label={transportText.ticketPhoto} />
        <ImageFrame src={siteAssets.transport.jakdojade} alt="Podgląd trasy w aplikacji Jakdojade" label="Jakdojade" />
      </div>
    </div>
  </div>
</section>

<section class="site-section transport-car reveal-section">
  <div class="container transport-car__grid">
    <div class="premium-card transport-car__panel">
      <span class="section-kicker">{transportText.carKicker}</span>
      <h2>{transportText.carTitle}</h2>
      <p>
        {transportText.carCopy}
      </p>
      <p class="transport-car__maps-notice">
        {transportText.mapsNotice}
      </p>

      <div class="transport-car__actions">
        <a class="btn btn-primary premium-button" href={googleMapsHref} target="_blank" rel="noopener noreferrer">{transportText.maps}</a>
        <a class="btn btn-glass transport-car__secondary" href={contactHref}>{transportText.contact}</a>
      </div>
    </div>

    <div class="transport-car__media">
      <ImageFrame src={siteAssets.transport.googleMaps} alt={transportText.mapLabel} label={transportText.mapLabel} />
    </div>
  </div>
</section>

<section class="site-section transport-arrival reveal-section">
  <div class="container transport-arrival__grid">
    <article class="premium-card transport-arrival__panel">
      <span aria-hidden="true"><Icon name="info" size={22} strokeWidth={1.8} /></span>
      <div>
        <span class="section-kicker">{transportText.arrivalKicker}</span>
        <h2>{transportText.arrivalTitle}</h2>
        <p>{transportText.arrivalCopy}</p>
        <div class="transport-arrival__docs">
          <strong>{registrationText.title}</strong>
          <ul>
            <li>{registrationText.document}</li>
            <li>{registrationText.plate}</li>
            <li>{registrationText.trailer}</li>
          </ul>
        </div>
      </div>
    </article>

    <article class="premium-card transport-arrival__panel transport-arrival__panel--sct">
      <span aria-hidden="true"><Icon name="leaf" size={22} strokeWidth={1.8} /></span>
      <div>
        <span class="section-kicker">{transportText.sctKicker}</span>
        <h2>{transportText.sctTitle}</h2>
        <p>{transportText.sctCopy}</p>
        <a class="btn btn-glass transport-car__secondary" href={sctHref} target="_blank" rel="noopener noreferrer">{transportText.sctButton}</a>
      </div>
    </article>
  </div>
</section>

<section class="site-section transport-final-cta reveal-section">
  <div class="container">
    <div class="premium-card transport-final-cta__panel">
      <div>
        <span class="section-kicker">{transportText.finalKicker}</span>
        <h2>{transportText.finalTitle}</h2>
        <p>
          {transportText.finalCopy}
        </p>
      </div>
      <div class="transport-final-cta__actions">
        <a class="btn btn-primary premium-button" href={contactHref}>{transportText.contact}</a>
        <a class="btn btn-glass transport-car__secondary" href={googleMapsHref} target="_blank" rel="noopener noreferrer">Google Maps</a>
      </div>
    </div>
  </div>
</section>

<style>
.transport-page-quick {
  padding: clamp(44px, 7vw, 86px) 0;
  background:
    radial-gradient(circle at 86% 12%, rgba(60,179,113,.14), transparent 30%),
    linear-gradient(180deg, #fbfbf7, #f2f7f0);
}

.transport-page-quick__grid,
.transport-tickets__cards {
  display: grid;
  grid-template-columns: 1fr;
  gap: 16px;
}

:global(.transport-page-quick__card) {
  min-height: 170px;
  display: grid;
  gap: 18px;
  align-content: start;
  padding: clamp(24px, 3vw, 32px);
  border-radius: 24px;
  transition: transform .24s ease, box-shadow .24s ease, border-color .24s ease;
}

:global(.transport-page-quick__card:hover),
:global(.transport-tickets__card:hover) {
  transform: translateY(-4px);
  border-color: rgba(60,179,113,.34);
  box-shadow: 0 24px 64px rgba(17,40,28,.14);
}

:global(.transport-page-quick__card > span) {
  width: 48px;
  height: 48px;
  display: grid;
  place-items: center;
  border-radius: 999px;
  background: rgba(60,179,113,.12);
  border: 1px solid rgba(60,179,113,.20);
}

:global(.transport-page-quick__card svg) {
  width: 24px;
  height: 24px;
  fill: none;
  stroke: #2f9d63;
  stroke-width: 1.8;
  stroke-linecap: round;
  stroke-linejoin: round;
}

:global(.transport-page-quick__card small) {
  display: block;
  margin-bottom: 10px;
  color: #3CB371;
  font-size: .74rem;
  font-weight: 950;
  letter-spacing: .14em;
  text-transform: uppercase;
}

:global(.transport-page-quick__card strong) {
  color: #102018;
  font-size: clamp(1.1rem, 2vw, 1.42rem);
  line-height: 1.25;
  font-weight: 950;
}

.transport-center {
  background:
    radial-gradient(circle at 12% 18%, rgba(60,179,113,.14), transparent 32%),
    linear-gradient(180deg, #f2f7f0, #101b14);
}

.transport-center .section-title,
.transport-center .section-copy,
.transport-car__panel h2,
.transport-car__panel p,
.transport-final-cta__panel h2,
.transport-final-cta__panel p {
  color: #fff;
}

.transport-center .section-copy,
.transport-car__panel p,
.transport-final-cta__panel p {
  color: rgba(255,255,255,.76);
}

