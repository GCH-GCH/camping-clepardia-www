    arrivalCopy:
      'Po przyjeździe zatrzymaj się na parkingu w pobliżu recepcji. Personel recepcji podejdzie, wskaże miejsce i oprowadzi po campingu. Następnie odbywa się rejestracja.',
    sctKicker: 'Przed wjazdem do Krakowa',
    sctTitle: 'Strefa Czystego Transportu w Krakowie',
    sctCopy:
      'Przed przyjazdem do Krakowa warto sprawdzić aktualne zasady Strefy Czystego Transportu. Przepisy mogą się zmieniać, dlatego najlepiej zweryfikować informacje na oficjalnej stronie miasta Krakowa przed podróżą.',
    sctButton: 'Sprawdź aktualne zasady SCT',
    maps: 'Otwórz w Google Maps',
    contact: 'Skontaktuj się z recepcją',
    mapLabel: 'Mapa dojazdu',
    finalKicker: 'Wygodny plan przyjazdu',
    finalTitle: 'Zaplanuj trasę i potwierdź pobyt z recepcją',
    finalCopy:
      'Jeśli przyjeżdżasz kamperem, przyczepą lub większym autem, skontaktuj się z recepcją przed przyjazdem i potwierdź szczegóły.',
  },
  en: {
    quickAria: 'Quick directions information',
    quick: {
      address: 'Address',
      tram: 'Tram',
