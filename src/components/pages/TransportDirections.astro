<section class="site-section transport-page-quick" aria-label={transportText.quickAria}>
  <div class="container transport-page-quick__grid">
    {quickInfo.map((item, index) => (
      <article class="premium-card reveal-section transport-page-quick__card" style={`--reveal-delay: ${index * 80}ms`}>
        <span aria-hidden="true">
          <Icon name={item.icon} size={24} strokeWidth={1.8} />
        </span>
        <div>
          <small>{item.label}</small>
          <strong>{item.value}</strong>
        </div>
      </article>
    ))}
  </div>
</section>

<TramCenterGuide languageCode={languageCode} variant="page" />

<ClientGuideTools languageCode={languageCode} variant="transport" />

<section class="site-section transport-route-guide reveal-section">
  <div class="container">
    <div class="transport-route-guide__head">
      <span class="section-kicker">{routeGuideText.kicker}</span>
      <h2 class="section-title">{routeGuideText.title}</h2>
      <p class="section-copy">{routeGuideText.copy}</p>
