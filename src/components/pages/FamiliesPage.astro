---
import ImageFrame from '@/components/ImageFrame.astro';
import Icon from '@/components/ui/Icon.astro';
import { siteAssets } from '@/data/assets';
import { pricingConfig } from '@/data/pricing';
import { getLocalizedPath } from '@/utils/localizedLinks';
import { getTranslations, resolveContentLanguage } from '@/i18n/config';

interface Props {
  languageCode?: string;
}

const { languageCode } = Astro.props as Props;
const contentLanguage = resolveContentLanguage(languageCode);
const t = getTranslations(languageCode);
const page = t.pages['dla-rodzin'];
const pricingHref = getLocalizedPath(languageCode, 'cennik');
const contactHref = getLocalizedPath(languageCode, 'kontakt');
const attractionsHref = getLocalizedPath(languageCode, 'atrakcje');
const currency = pricingConfig.currency;
const formatPrice = (price: number) => `${price} ${currency}`;
const stayTypeLabels = t.pricing.stayTypes as Record<string, string>;
const getStayType = (id: string) => {
  const stayType = pricingConfig.stayTypes.find((item) => item.id === id);
  if (!stayType) throw new Error(`Missing family stay pricing: ${id}`);

  return stayType;
};
const getAddon = (id: string) => {
  const addon = pricingConfig.addons.find((item) => item.id === id);
  if (!addon) throw new Error(`Missing family addon pricing: ${id}`);

  return addon;
};

const bungalow3 = getStayType('bungalow-3');
const bungalow4 = getStayType('bungalow-4');
const dog = getAddon('dog');

const getSeasonalPrices = (stayType: typeof pricingConfig.stayTypes[number]) => {
  if (!('seasonalPrices' in stayType)) throw new Error(`Missing seasonal prices for ${stayType.label}`);

  return stayType.seasonalPrices;
};
const familyTextByLanguage = {
  pl: {
    benefitsKicker: 'Dlaczego rodziny wybierają Clepardię',
    benefitsTitle: 'Kraków blisko, a po zwiedzaniu spokojniejsza zielona baza',
    benefitsLead:
      'To wygodne rozwiązanie dla rodzin, które chcą połączyć zwiedzanie miasta, wycieczki po Małopolsce i odpoczynek w miejscu z campingowym klimatem.',
    stayKicker: 'Domki i camping dla rodzin',
    stayTitle: 'Wybierz wygodną opcję pobytu dla swojej rodziny',
    stayLead:
      'Domki mają osobne ceny sezonowe, a pobyt campingowy sprawdza się dla rodzin podróżujących kamperem, przyczepą, vanem, namiotem albo autem z namiotem dachowym.',
    lowSeason: 'niski sezon',
    highSeason: 'wysoki sezon',
    priceFrom: 'cena od',
    campingOptions: 'Opcje campingowe',
    familyMedia: 'Domki i pobyt rodzinny',
    familyPhoto: 'Miejsce na zdjęcie: domki Camping Clepardia',
    bungalows: 'Domki',
    krakow: 'Kraków',
    attractionsKicker: 'Atrakcje dla dzieci',
    attractionsTitle: 'Pomysły na rodzinne wycieczki z Krakowa',
    attractionsLead:
      'Camping Clepardia może być spokojną bazą noclegową po intensywnym dniu w mieście, parku rozrywki albo na jednodniowej trasie po Małopolsce.',
    infoKicker: 'Praktyczne informacje',
    infoTitle: 'Najważniejsze rzeczy przed rodzinnym przyjazdem',
    pricesKicker: 'Ceny rodzinne',
    pricesTitle: 'Dzieci i pobyt z psem',
    free: 'bezpłatnie',
    toddlers: 'Dzieci do 4 lat',
    children: 'Dzieci 4-14 lat',
    dog: 'Pies',
    nextStep: 'Następny krok',
    stayCopies: [
      'Praktyczna opcja dla mniejszej rodziny albo rodzica z dziećmi.',
      'Więcej miejsca dla rodzin, które chcą zostać blisko centrum Krakowa.',
      'Kamper, przyczepa, van, namiot lub auto z namiotem dachowym według aktualnego cennika campingu.',
    ],
    kidsAttractions: [
      { title: 'Energylandia', copy: 'Popularny park rozrywki na całodniową wycieczkę rodzinną.', label: 'Energylandia' },
      { title: 'Krakowskie Stare Miasto', copy: 'Spacer po Rynku, Sukiennicach i Plantach to dobry plan na rodzinne zwiedzanie.', label: 'Stare Miasto' },
      { title: 'Ojcowski Park Narodowy', copy: 'Dobry kierunek na spokojniejszą wycieczkę z naturą i zamkami.', label: 'Miejsce na zdjęcie: Ojców' },
      { title: 'Wieliczka', copy: 'Jedna z najpopularniejszych atrakcji w okolicy Krakowa.', label: 'Wieliczka' },
    ],
    practicalEnding: 'Finalną dostępność potwierdza recepcja.',
  },
  en: {
    benefitsKicker: 'Why families choose Clepardia',
    benefitsTitle: 'Krakow is close, with a calmer green base after sightseeing',
    benefitsLead:
      'A convenient option for families who want to combine city sightseeing, Małopolska trips and rest in a place with a camping atmosphere.',
    stayKicker: 'Bungalows and camping for families',
    stayTitle: 'Choose a comfortable stay option for your family',
    stayLead:
      'Bungalows have separate seasonal prices, while camping works well for families travelling by motorhome, caravan, van, tent or rooftop tent.',
    lowSeason: 'low season',
    highSeason: 'high season',
    priceFrom: 'from',
    campingOptions: 'Camping options',
    familyMedia: 'Bungalows and family stay',
    familyPhoto: 'Photo space: Camping Clepardia bungalows',
    bungalows: 'Bungalows',
    krakow: 'Krakow',
    attractionsKicker: 'Attractions for children',
    attractionsTitle: 'Ideas for family trips from Krakow',
    attractionsLead:
      'Camping Clepardia can be a calm accommodation base after an intense day in the city, amusement park or on a one-day Małopolska route.',
    infoKicker: 'Practical information',
    infoTitle: 'Key things before a family arrival',
    pricesKicker: 'Family prices',
    pricesTitle: 'Children and staying with a dog',
    free: 'free',
    toddlers: 'Children under 4',
    children: 'Children 4-14',
    dog: 'Dog',
    nextStep: 'Next step',
    stayCopies: [
      'A practical option for a smaller family or a parent with children.',
      'More space for families who want to stay close to Krakow city centre.',
      'Motorhome, caravan, van, tent or car with rooftop tent according to the current camping price list.',
    ],
    kidsAttractions: [
      { title: 'Energylandia', copy: 'A popular amusement park for a full-day family trip.', label: 'Energylandia' },
      { title: 'Krakow Old Town', copy: 'A walk around the Main Square, Cloth Hall and Planty is a good family sightseeing plan.', label: 'Old Town' },
      { title: 'Ojców National Park', copy: 'A good direction for a calmer trip with nature and castles.', label: 'Photo space: Ojców' },
      { title: 'Wieliczka', copy: 'One of the most popular attractions near Krakow.', label: 'Wieliczka' },
    ],
    practicalEnding: 'Final availability is confirmed by reception.',
  },
  de: {
    benefitsKicker: 'Warum Familien Clepardia wählen',
    benefitsTitle: 'Krakau ist nah, danach wartet eine ruhigere grüne Basis',
    benefitsLead:
      'Eine praktische Lösung für Familien, die Stadtbesichtigung, Ausflüge in Małopolska und Erholung an einem Ort mit Campingatmosphäre verbinden möchten.',
    stayKicker: 'Bungalows und Camping für Familien',
    stayTitle: 'Wählen Sie eine bequeme Aufenthaltsoption für Ihre Familie',
    stayLead:
      'Bungalows haben separate Saisonpreise, Camping passt gut für Familien mit Wohnmobil, Wohnwagen, Van, Zelt oder Dachzelt.',
    lowSeason: 'Nebensaison',
    highSeason: 'Hauptsaison',
    priceFrom: 'ab',
    campingOptions: 'Campingoptionen',
    familyMedia: 'Bungalows und Familienaufenthalt',
    familyPhoto: 'Fotoplatz: Bungalows Camping Clepardia',
    bungalows: 'Bungalows',
    krakow: 'Krakau',
    attractionsKicker: 'Attraktionen für Kinder',
    attractionsTitle: 'Ideen für Familienausflüge ab Krakau',
    attractionsLead:
      'Camping Clepardia kann eine ruhige Unterkunftsbasis nach einem intensiven Tag in der Stadt, im Freizeitpark oder auf einer Tagestour durch Małopolska sein.',
    infoKicker: 'Praktische Informationen',
    infoTitle: 'Das Wichtigste vor der Familienanreise',
    pricesKicker: 'Familienpreise',
    pricesTitle: 'Kinder und Aufenthalt mit Hund',
    free: 'kostenlos',
    toddlers: 'Kinder unter 4',
    children: 'Kinder 4-14',
    dog: 'Hund',
    nextStep: 'Nächster Schritt',
    stayCopies: [
      'Praktische Option für eine kleinere Familie oder ein Elternteil mit Kindern.',
      'Mehr Platz für Familien, die nahe am Zentrum von Krakau bleiben möchten.',
      'Wohnmobil, Wohnwagen, Van, Zelt oder Auto mit Dachzelt gemäß aktueller Camping-Preisliste.',
    ],
    kidsAttractions: [
      { title: 'Energylandia', copy: 'Beliebter Freizeitpark für einen ganztägigen Familienausflug.', label: 'Energylandia' },
      { title: 'Krakauer Altstadt', copy: 'Ein Spaziergang über den Hauptmarkt, die Tuchhallen und Planty ist ein guter Familienplan.', label: 'Altstadt' },
      { title: 'Nationalpark Ojców', copy: 'Gute Richtung für einen ruhigeren Ausflug mit Natur und Burgen.', label: 'Fotoplatz: Ojców' },
      { title: 'Wieliczka', copy: 'Eine der beliebtesten Attraktionen in der Nähe von Krakau.', label: 'Wieliczka' },
    ],
    practicalEnding: 'Die endgültige Verfügbarkeit bestätigt die Rezeption.',
  },
  it: {
    benefitsKicker: 'Perché le famiglie scelgono Clepardia',
    benefitsTitle: 'Cracovia è vicina, poi si torna a una base verde più tranquilla',
    benefitsLead:
      'Una soluzione comoda per famiglie che vogliono unire visita della città, gite in Małopolska e riposo in un luogo con atmosfera camping.',
    stayKicker: 'Bungalow e camping per famiglie',
    stayTitle: 'Scegli un’opzione comoda per la tua famiglia',
    stayLead:
      'I bungalow hanno prezzi stagionali separati, mentre il camping è adatto a famiglie con camper, roulotte, van, tenda o tenda da tetto.',
    lowSeason: 'bassa stagione',
    highSeason: 'alta stagione',
    priceFrom: 'da',
    campingOptions: 'Opzioni camping',
    familyMedia: 'Bungalow e soggiorno in famiglia',
    familyPhoto: 'Spazio foto: bungalow Camping Clepardia',
    bungalows: 'Bungalow',
    krakow: 'Cracovia',
    attractionsKicker: 'Attrazioni per bambini',
    attractionsTitle: 'Idee per gite in famiglia da Cracovia',
    attractionsLead:
      'Camping Clepardia può essere una base tranquilla dopo una giornata intensa in città, al parco divertimenti o in un itinerario di un giorno in Małopolska.',
    infoKicker: 'Informazioni pratiche',
    infoTitle: 'Le cose principali prima dell’arrivo in famiglia',
    pricesKicker: 'Prezzi famiglia',
    pricesTitle: 'Bambini e soggiorno con cane',
    free: 'gratuito',
    toddlers: 'Bambini sotto i 4 anni',
    children: 'Bambini 4-14',
    dog: 'Cane',
    nextStep: 'Prossimo passo',
    stayCopies: [
      'Opzione pratica per una famiglia più piccola o un genitore con bambini.',
      'Più spazio per famiglie che vogliono stare vicino al centro di Cracovia.',
      'Camper, roulotte, van, tenda o auto con tenda da tetto secondo il listino camping attuale.',
    ],
    kidsAttractions: [
      { title: 'Energylandia', copy: 'Parco divertimenti popolare per una gita familiare di un’intera giornata.', label: 'Energylandia' },
      { title: 'Città Vecchia di Cracovia', copy: 'Una passeggiata tra Rynek, Sukiennice e Planty è un buon piano per visitare in famiglia.', label: 'Città Vecchia' },
      { title: 'Parco Nazionale di Ojców', copy: 'Una buona meta per una gita più tranquilla tra natura e castelli.', label: 'Spazio foto: Ojców' },
      { title: 'Wieliczka', copy: 'Una delle attrazioni più popolari vicino a Cracovia.', label: 'Wieliczka' },
    ],
    practicalEnding: 'La disponibilità finale è confermata dalla reception.',
  },
};

const familyText = familyTextByLanguage[contentLanguage];
const perNight = t.pricing.perNight;
const freeLabel = familyText.free;

const familyBenefits = [
  {
    title: page.highlights[0].title,
    copy: page.highlights[0].copy,
    icon: 'tram',
  },
  {
    title: page.highlights[1].title,
    copy: page.highlights[1].copy,
    icon: 'leaf',
  },
  {
    title: page.highlights[2].title,
    copy: page.highlights[2].copy,
    icon: 'bungalow',
  },
  {
    title: page.highlights[3].title,
    copy: page.highlights[3].copy,
    icon: 'map',
  },
];

const familyStayOptions = [
  {
    title: stayTypeLabels['bungalow-3'],
    type: 'seasonal',
    low: getSeasonalPrices(bungalow3).low,
    high: getSeasonalPrices(bungalow3).high,
    copy: familyText.stayCopies[0],
  },
  {
    title: stayTypeLabels['bungalow-4'],
    type: 'seasonal',
    low: getSeasonalPrices(bungalow4).low,
    high: getSeasonalPrices(bungalow4).high,
    copy: familyText.stayCopies[1],
  },
  {
    title: 'Camping',
    type: 'camping',
    copy: familyText.stayCopies[2],
  },
];

const kidsAttractions = [
  {
    title: familyText.kidsAttractions[0].title,
    copy: familyText.kidsAttractions[0].copy,
    image: siteAssets.attractions.energylandia,
    label: familyText.kidsAttractions[0].label,
  },
  {
    title: familyText.kidsAttractions[1].title,
    copy: familyText.kidsAttractions[1].copy,
    image: siteAssets.attractions.oldTown,
    label: familyText.kidsAttractions[1].label,
  },
  {
    title: familyText.kidsAttractions[2].title,
    copy: familyText.kidsAttractions[2].copy,
    image: undefined,
    label: familyText.kidsAttractions[2].label,
  },
  {
    title: familyText.kidsAttractions[3].title,
    copy: familyText.kidsAttractions[3].copy,
    image: siteAssets.attractions.wieliczka,
    label: familyText.kidsAttractions[3].label,
  },
];

const practicalInfo = [
  `${familyText.toddlers}: ${pricingConfig.people.toddlers.price === 0 ? freeLabel : `${formatPrice(pricingConfig.people.toddlers.price)} / ${perNight}`}.`,
  `${familyText.children}: ${formatPrice(pricingConfig.people.children.price)} / ${perNight}.`,
  `${familyText.dog}: ${dog.price === 0 ? freeLabel : `${formatPrice(dog.price)} / ${perNight}`}.`,
  'Check-in/check-out camping: 12:00-12:00.',
  contentLanguage === 'pl' ? 'Check-in domki: od 16:00.' : contentLanguage === 'de' ? 'Check-in Bungalows: ab 16:00.' : contentLanguage === 'it' ? 'Check-in bungalow: dalle 16:00.' : 'Bungalow check-in: from 16:00.',
  contentLanguage === 'pl' ? 'Check-out domki: do 11:00.' : contentLanguage === 'de' ? 'Check-out Bungalows: bis 11:00.' : contentLanguage === 'it' ? 'Check-out bungalow: entro le 11:00.' : 'Bungalow check-out: by 11:00.',
  familyText.practicalEnding,
];
---

<section class="site-section families-benefits reveal-section">
  <div class="container families-benefits__grid">
    <div class="families-benefits__intro">
      <span class="section-kicker">{familyText.benefitsKicker}</span>
      <h2 class="section-title">{familyText.benefitsTitle}</h2>
      <p class="section-copy">
        {familyText.benefitsLead}
      </p>
    </div>

    <div class="families-benefits__cards">
      {familyBenefits.map((card, index) => (
        <article class="premium-card reveal-section families-benefits__card" style={`--reveal-delay: ${index * 80}ms`}>
          <span class="families-benefits__icon" aria-hidden="true">
            <Icon name={card.icon} size={27} strokeWidth={1.9} />
          </span>
          <h3>{card.title}</h3>
          <p>{card.copy}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<section class="site-section families-stay reveal-section">
  <div class="container families-stay__grid">
    <div class="families-stay__content">
      <span class="section-kicker">{familyText.stayKicker}</span>
      <h2 class="section-title">{familyText.stayTitle}</h2>
      <p class="section-copy">
        {familyText.stayLead}
      </p>

      <div class="families-stay__options">
        {familyStayOptions.map((option, index) => (
          <article class="premium-card reveal-section families-stay__option" style={`--reveal-delay: ${index * 80}ms`}>
            <span>{String(index + 1).padStart(2, '0')}</span>
            <h3>{option.title}</h3>
            {option.type === 'seasonal' && (
              <div class="families-stay__prices">
                <p><strong>{familyText.lowSeason}</strong>{formatPrice(option.low)} / {perNight}</p>
                <p><strong>{familyText.highSeason}</strong>{formatPrice(option.high)} / {perNight}</p>
              </div>
            )}
            {option.type === 'camping' && (
              <div class="families-stay__tag-list" aria-label={familyText.campingOptions}>
                <em>{stayTypeLabels.camper}</em>
                <em>{stayTypeLabels.caravan}</em>
                <em>van</em>
                <em>{stayTypeLabels['tent-small']}</em>
                <em>{stayTypeLabels['rooftop-tent']}</em>
              </div>
            )}
            <p>{option.copy}</p>
          </article>
        ))}
      </div>
    </div>

    <div class="families-stay__media" aria-label={familyText.familyMedia}>
      <ImageFrame
        src={siteAssets.bungalows.exterior}
        alt={familyText.familyPhoto}
        label={familyText.familyPhoto}
        className="families-stay__main-photo"
      />
      <div class="families-stay__thumbs">
        <ImageFrame src={siteAssets.bungalows.exterior} alt={familyText.bungalows} label={familyText.bungalows} />
        <ImageFrame src={siteAssets.attractions.oldTown} alt={familyText.krakow} label={familyText.krakow} />
      </div>
    </div>
  </div>
</section>

<section class="site-section families-attractions reveal-section">
  <div class="container">
    <div class="families-attractions__head">
      <span class="section-kicker">{familyText.attractionsKicker}</span>
      <h2 class="section-title">{familyText.attractionsTitle}</h2>
      <p class="section-copy">
        {familyText.attractionsLead}
      </p>
    </div>

    <div class="families-attractions__grid">
      {kidsAttractions.map((item, index) => (
        <article class="premium-card reveal-section families-attractions__card" style={`--reveal-delay: ${index * 90}ms`}>
          {item.image ? (
            <ImageFrame src={item.image} alt={item.title} label={item.label} />
          ) : (
            <div class="families-attractions__fallback photo-frame">
              <span aria-hidden="true">
                <Icon name="leaf" size={22} strokeWidth={1.8} />
              </span>
              <strong>{item.label}</strong>
            </div>
          )}
          <div>
            <h3>{item.title}</h3>
            <p>{item.copy}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<section class="site-section families-info reveal-section">
  <div class="container families-info__grid">
    <article class="premium-card families-info__panel">
      <span class="section-kicker">{familyText.infoKicker}</span>
      <h2>{familyText.infoTitle}</h2>
      <div class="families-info__list">
        {practicalInfo.map((item, index) => (
          <div class="families-info__item reveal-section" style={`--reveal-delay: ${index * 60}ms`}>
            <span aria-hidden="true">
              <Icon name="check" size={18} strokeWidth={2} />
            </span>
            <p>{item}</p>
          </div>
        ))}
      </div>
    </article>

    <article class="premium-card families-info__price-card">
      <span class="section-kicker">{familyText.pricesKicker}</span>
      <h2>{familyText.pricesTitle}</h2>
      <div class="families-info__prices">
        <div>
          <span>{familyText.toddlers}</span>
          <strong>{pricingConfig.people.toddlers.price === 0 ? freeLabel : `${formatPrice(pricingConfig.people.toddlers.price)} / ${perNight}`}</strong>
        </div>
        <div>
          <span>{familyText.children}</span>
          <strong>{formatPrice(pricingConfig.people.children.price)} / {perNight}</strong>
        </div>
        <div>
          <span>{familyText.dog}</span>
          <strong>{dog.price === 0 ? freeLabel : `${formatPrice(dog.price)} / ${perNight}`}</strong>
        </div>
      </div>
    </article>
  </div>
</section>

<section class="site-section families-cta reveal-section">
  <div class="container">
    <div class="premium-card families-cta__panel">
      <div>
        <span class="section-kicker">{familyText.nextStep}</span>
        <h2>{page.cta.title}</h2>
        <p>
          {page.cta.copy}
        </p>
      </div>
      <div class="families-cta__actions">
        <a class="btn btn-primary premium-button" href={pricingHref}>{page.cta.primaryLabel}</a>
        <a class="btn btn-glass families-cta__secondary" href={contactHref}>{page.cta.secondaryLabel}</a>
        <a class="btn btn-glass families-cta__secondary" href={attractionsHref}>{t.nav.items.atrakcje}</a>
      </div>
    </div>
  </div>
</section>

<style>
.families-benefits {
  background:
    radial-gradient(circle at 88% 14%, rgba(239,174,99,.18), transparent 32%),
    radial-gradient(circle at 12% 28%, rgba(60,179,113,.12), transparent 34%),
    linear-gradient(180deg, #fbfbf7, #f3f7ee);
}

.families-benefits__grid,
.families-stay__grid,
.families-info__grid {
  display: grid;
  gap: clamp(30px, 5vw, 62px);
}

.families-benefits__intro,
.families-attractions__head {
  max-width: 840px;
}

.families-benefits__cards {
  display: grid;
  grid-template-columns: 1fr;
  gap: 16px;
}

:global(.families-benefits__card) {
  display: grid;
  gap: 16px;
  min-height: 240px;
  padding: clamp(24px, 3vw, 34px);
  border-radius: 24px;
}

.families-benefits__icon {
  width: 54px;
  height: 54px;
  display: grid;
  place-items: center;
  border-radius: 18px;
  color: #3CB371;
  background:
    radial-gradient(circle at 30% 18%, rgba(255,255,255,.94), rgba(255,255,255,.38)),
    rgba(60,179,113,.12);
  border: 1px solid rgba(60,179,113,.22);
  box-shadow: 0 16px 38px rgba(60,179,113,.16);
}

.families-benefits__icon svg {
  width: 27px;
  height: 27px;
  fill: none;
  stroke: currentColor;
  stroke-width: 1.9;
  stroke-linecap: round;
  stroke-linejoin: round;
}

:global(.families-benefits__card h3) {
  margin: 0;
  color: #102018;
  font-size: clamp(1.25rem, 2vw, 1.55rem);
  font-weight: 950;
  line-height: 1.15;
}

:global(.families-benefits__card p) {
  margin: 0;
  color: #536359;
  line-height: 1.7;
}

.families-stay {
  background:
    radial-gradient(circle at 10% 18%, rgba(60,179,113,.13), transparent 32%),
    linear-gradient(180deg, #f3f7ee, #fbfbf7);
}

.families-stay__content {
  align-self: center;
}

.families-stay__options {
  display: grid;
  grid-template-columns: 1fr;
  gap: 14px;
  margin-top: clamp(26px, 4vw, 42px);
}

:global(.families-stay__option) {
  padding: clamp(22px, 3vw, 30px);
  border-radius: 24px;
}

:global(.families-stay__option > span) {
  display: inline-flex;
  margin-bottom: 18px;
  color: #3CB371;
  font-size: .74rem;
  font-weight: 950;
  letter-spacing: .14em;
