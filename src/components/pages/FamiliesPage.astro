const familyText =
  familyTextByLanguage[contentLanguage as keyof typeof familyTextByLanguage]
  ?? familyFallbackTextByLanguage[contentLanguage as keyof typeof familyFallbackTextByLanguage]
  ?? familyTextByLanguage.en;
const familyExtraBenefitTitle = 'extraBenefitTitle' in familyText ? familyText.extraBenefitTitle : familyText.krakow;
const familyExtraBenefitCopy = 'extraBenefitCopy' in familyText ? familyText.extraBenefitCopy : familyText.benefitsLead;
const perNight = t.pricing.perNight;
const freeLabel = familyText.free;

const familyTimeTextByLanguage = {
  pl: { camping: 'Check-in/check-out camping: 12:00-12:00.', bungalowIn: 'Check-in domki: od 16:00.', bungalowOut: 'Check-out domki: do 11:00.' },
  en: { camping: 'Camping check-in/check-out: 12:00-12:00.', bungalowIn: 'Bungalow check-in: from 16:00.', bungalowOut: 'Bungalow check-out: by 11:00.' },
  de: { camping: 'Check-in/Check-out Camping: 12:00-12:00.', bungalowIn: 'Check-in Bungalows: ab 16:00.', bungalowOut: 'Check-out Bungalows: bis 11:00.' },
  it: { camping: 'Check-in/check-out camping: 12:00-12:00.', bungalowIn: 'Check-in bungalow: dalle 16:00.', bungalowOut: 'Check-out bungalow: entro le 11:00.' },
  fr: { camping: 'Arrivée/départ camping : 12h00-12h00.', bungalowIn: 'Arrivée bungalow : à partir de 16h00.', bungalowOut: 'Départ bungalow : jusqu’à 11h00.' },
  es: { camping: 'Check-in/check-out camping: 12:00-12:00.', bungalowIn: 'Entrada bungalow: desde las 16:00.', bungalowOut: 'Salida bungalow: hasta las 11:00.' },
  nl: { camping: 'Camping check-in/check-out: 12.00-12.00 uur.', bungalowIn: 'Bungalow inchecken: vanaf 16.00 uur.', bungalowOut: 'Bungalow uitchecken: tot 11.00 uur.' },
  cs: { camping: 'Příjezd/odjezd camping: 12:00-12:00.', bungalowIn: 'Příjezd do bungalovu: od 16:00.', bungalowOut: 'Odjezd z bungalovu: do 11:00.' },
  sk: { camping: 'Príchod/odchod camping: 12:00-12:00.', bungalowIn: 'Príchod do bungalovu: od 16:00.', bungalowOut: 'Odchod z bungalovu: do 11:00.' },
  sv: { camping: 'Camping in-/utcheckning: 12.00-12.00.', bungalowIn: 'Bungalow incheckning: från 16.00.', bungalowOut: 'Bungalow utcheckning: senast 11.00.' },
};
const familyTimeText =
  familyTimeTextByLanguage[contentLanguage as keyof typeof familyTimeTextByLanguage]
  ?? familyTimeTextByLanguage.en;

const familyBenefits = [
  {
    title: page.highlights[0]?.title ?? familyText.bungalows,
    copy: page.highlights[0]?.copy ?? familyText.stayLead,
    icon: 'tram',
  },
  {
    title: page.highlights[1]?.title ?? familyText.attractionsKicker,
    copy: page.highlights[1]?.copy ?? familyText.attractionsLead,
    icon: 'leaf',
  },
  {
    title: page.highlights[2]?.title ?? familyText.infoKicker,
    copy: page.highlights[2]?.copy ?? familyText.practicalEnding,
    icon: 'bungalow',
  },
  {
    title: page.highlights[3]?.title ?? familyExtraBenefitTitle,
    copy: page.highlights[3]?.copy ?? familyExtraBenefitCopy,
    icon: 'map',
  },
];

const familyStayOptions = [
  {
    title: stayTypeLabels['bungalow-3'],
    type: 'seasonal',
    low: getSeasonalPrices(bungalow3).low,
    high: getSeasonalPrices(bungalow3).high,
    copy: familyText.stayCopies[0],
  },
  {
    title: stayTypeLabels['bungalow-4'],
    type: 'seasonal',
    low: getSeasonalPrices(bungalow4).low,
    high: getSeasonalPrices(bungalow4).high,
    copy: familyText.stayCopies[1],
  },
  {
    title: 'Camping',
    type: 'camping',
    copy: familyText.stayCopies[2],
  },
];

const kidsAttractions = [
  {
    title: familyText.kidsAttractions[0].title,
    copy: familyText.kidsAttractions[0].copy,
    image: siteAssets.attractions.energylandia,
    label: familyText.kidsAttractions[0].label,
  },
  {
    title: familyText.kidsAttractions[1].title,
    copy: familyText.kidsAttractions[1].copy,
    image: siteAssets.attractions.oldTown,
    label: familyText.kidsAttractions[1].label,
  },
  {
    title: familyText.kidsAttractions[2].title,
    copy: familyText.kidsAttractions[2].copy,
    image: undefined,
    label: familyText.kidsAttractions[2].label,
  },
  {
    title: familyText.kidsAttractions[3].title,
    copy: familyText.kidsAttractions[3].copy,
    image: siteAssets.attractions.wieliczka,
    label: familyText.kidsAttractions[3].label,
  },
];

const practicalInfo = [
  `${familyText.toddlers}: ${pricingConfig.people.toddlers.price === 0 ? freeLabel : `${formatPrice(pricingConfig.people.toddlers.price)} / ${perNight}`}.`,
  `${familyText.children}: ${formatPrice(pricingConfig.people.children.price)} / ${perNight}.`,
  `${familyText.dog}: ${dog.price === 0 ? freeLabel : `${formatPrice(dog.price)} / ${perNight}`}.`,
  familyTimeText.camping,
  familyTimeText.bungalowIn,
  familyTimeText.bungalowOut,
  familyText.practicalEnding,
];
---

<section class="site-section families-benefits reveal-section">
  <div class="container families-benefits__grid">
    <div class="families-benefits__intro">
      <span class="section-kicker">{familyText.benefitsKicker}</span>
      <h2 class="section-title">{familyText.benefitsTitle}</h2>
      <p class="section-copy">
        {familyText.benefitsLead}
      </p>
    </div>

    <div class="families-benefits__cards">
      {familyBenefits.map((card, index) => (
        <article class="premium-card reveal-section families-benefits__card" style={`--reveal-delay: ${index * 80}ms`}>
          <span class="families-benefits__icon" aria-hidden="true">
            <Icon name={card.icon} size={27} strokeWidth={1.9} />
          </span>
          <h3>{card.title}</h3>
          <p>{card.copy}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<section class="site-section families-stay reveal-section">
  <div class="container families-stay__grid">
    <div class="families-stay__content">
      <span class="section-kicker">{familyText.stayKicker}</span>
      <h2 class="section-title">{familyText.stayTitle}</h2>
      <p class="section-copy">
        {familyText.stayLead}
      </p>

      <div class="families-stay__options">
        {familyStayOptions.map((option, index) => (
          <article class="premium-card reveal-section families-stay__option" style={`--reveal-delay: ${index * 80}ms`}>
            <span>{String(index + 1).padStart(2, '0')}</span>
            <h3>{option.title}</h3>
            {option.type === 'seasonal' && (
              <div class="families-stay__prices">
                <p><strong>{familyText.lowSeason}</strong>{formatPrice(option.low)} / {perNight}</p>
                <p><strong>{familyText.highSeason}</strong>{formatPrice(option.high)} / {perNight}</p>
              </div>
            )}
            {option.type === 'camping' && (
              <div class="families-stay__tag-list" aria-label={familyText.campingOptions}>
                <em>{stayTypeLabels.camper}</em>
                <em>{stayTypeLabels.caravan}</em>
                <em>van</em>
                <em>{stayTypeLabels['tent-small']}</em>
                <em>{stayTypeLabels['rooftop-tent']}</em>
              </div>
            )}
            <p>{option.copy}</p>
          </article>
        ))}
      </div>
    </div>

    <div class="families-stay__media" aria-label={familyText.familyMedia}>
      <ImageFrame
        src={siteAssets.family.playground}
        alt={familyText.familyPhoto}
        label={familyText.familyPhoto}
        className="families-stay__main-photo"
      />
      <div class="families-stay__thumbs">
        <ImageFrame src={siteAssets.bungalows.exterior} alt={familyText.bungalows} label={familyText.bungalows} />
        <ImageFrame src={siteAssets.attractions.oldTown} alt={familyText.krakow} label={familyText.krakow} />
      </div>
    </div>
  </div>
</section>

<section class="site-section families-attractions reveal-section">
  <div class="container">
    <div class="families-attractions__head">
      <span class="section-kicker">{familyText.attractionsKicker}</span>
      <h2 class="section-title">{familyText.attractionsTitle}</h2>
      <p class="section-copy">
        {familyText.attractionsLead}
      </p>
    </div>

    <div class="families-attractions__grid">
      {kidsAttractions.map((item, index) => (
        <article class="premium-card reveal-section families-attractions__card" style={`--reveal-delay: ${index * 90}ms`}>
          {item.image ? (
            <ImageFrame src={item.image} alt={item.title} label={item.label} />
          ) : (
            <div class="families-attractions__fallback photo-frame">
              <span aria-hidden="true">
                <Icon name="leaf" size={22} strokeWidth={1.8} />
              </span>
              <strong>{item.label}</strong>
            </div>
          )}
          <div>
            <h3>{item.title}</h3>
            <p>{item.copy}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<section class="site-section families-info reveal-section">
  <div class="container families-info__grid">
    <article class="premium-card families-info__panel">
      <span class="section-kicker">{familyText.infoKicker}</span>
      <h2>{familyText.infoTitle}</h2>
      <div class="families-info__list">
        {practicalInfo.map((item, index) => (
          <div class="families-info__item reveal-section" style={`--reveal-delay: ${index * 60}ms`}>
            <span aria-hidden="true">
              <Icon name="check" size={18} strokeWidth={2} />
            </span>
            <p>{item}</p>
          </div>
        ))}
      </div>
    </article>

    <article class="premium-card families-info__price-card">
      <span class="section-kicker">{familyText.pricesKicker}</span>
      <h2>{familyText.pricesTitle}</h2>
      <div class="families-info__prices">
        <div>
          <span>{familyText.toddlers}</span>
          <strong>{pricingConfig.people.toddlers.price === 0 ? freeLabel : `${formatPrice(pricingConfig.people.toddlers.price)} / ${perNight}`}</strong>
        </div>
        <div>
          <span>{familyText.children}</span>
          <strong>{formatPrice(pricingConfig.people.children.price)} / {perNight}</strong>
        </div>
        <div>
          <span>{familyText.dog}</span>
          <strong>{dog.price === 0 ? freeLabel : `${formatPrice(dog.price)} / ${perNight}`}</strong>
        </div>
      </div>
    </article>
  </div>
</section>

<section class="site-section families-cta reveal-section">
  <div class="container">
    <div class="premium-card families-cta__panel">
      <div>
        <span class="section-kicker">{familyText.nextStep}</span>
        <h2>{page.cta.title}</h2>
        <p>
          {page.cta.copy}
        </p>
      </div>
      <div class="families-cta__actions">
        <a class="btn btn-primary premium-button" href={pricingHref}>{page.cta.primaryLabel}</a>
        <a class="btn btn-glass families-cta__secondary" href={contactHref}>{page.cta.secondaryLabel}</a>
        <a class="btn btn-glass families-cta__secondary" href={attractionsHref}>{t.nav.items.atrakcje}</a>
      </div>
    </div>
  </div>
</section>

<style>
.families-benefits {
  background:
    radial-gradient(circle at 88% 14%, rgba(239,174,99,.18), transparent 32%),
    radial-gradient(circle at 12% 28%, rgba(60,179,113,.12), transparent 34%),
    linear-gradient(180deg, #fbfbf7, #f3f7ee);
}

.families-benefits__grid,
.families-stay__grid,
.families-info__grid {
  display: grid;
  gap: clamp(30px, 5vw, 62px);
}

.families-benefits__intro,
.families-attractions__head {
  max-width: 840px;
}

.families-benefits__cards {
  display: grid;
  grid-template-columns: 1fr;
  gap: 16px;
}

:global(.families-benefits__card) {
  display: grid;
  gap: 16px;
  min-height: 240px;
  padding: clamp(24px, 3vw, 34px);
  border-radius: 24px;
}

.families-benefits__icon {
  width: 54px;
  height: 54px;
  display: grid;
  place-items: center;
  border-radius: 18px;
  color: #3CB371;
  background:
    radial-gradient(circle at 30% 18%, rgba(255,255,255,.94), rgba(255,255,255,.38)),
    rgba(60,179,113,.12);
  border: 1px solid rgba(60,179,113,.22);
  box-shadow: 0 16px 38px rgba(60,179,113,.16);
}

.families-benefits__icon svg {
  width: 27px;
  height: 27px;
  fill: none;
  stroke: currentColor;
  stroke-width: 1.9;
  stroke-linecap: round;
  stroke-linejoin: round;
}

:global(.families-benefits__card h3) {
  margin: 0;
  color: #102018;
  font-size: clamp(1.25rem, 2vw, 1.55rem);
  font-weight: 950;
  line-height: 1.15;
}

:global(.families-benefits__card p) {
  margin: 0;
  color: #536359;
  line-height: 1.7;
}

.families-stay {
  background:
    radial-gradient(circle at 10% 18%, rgba(60,179,113,.13), transparent 32%),
    linear-gradient(180deg, #f3f7ee, #fbfbf7);
}

.families-stay__content {
  align-self: center;
}

.families-stay__options {
  display: grid;
  grid-template-columns: 1fr;
  gap: 14px;
  margin-top: clamp(26px, 4vw, 42px);
}

:global(.families-stay__option) {
  padding: clamp(22px, 3vw, 30px);
  border-radius: 24px;
}

:global(.families-stay__option > span) {
  display: inline-flex;
  margin-bottom: 18px;
  color: #3CB371;
  font-size: .74rem;
  font-weight: 950;
  letter-spacing: .14em;
}

:global(.families-stay__option h3) {
  margin: 0 0 14px;
  color: #102018;
  font-size: clamp(1.18rem, 2vw, 1.45rem);
  font-weight: 950;
}

:global(.families-stay__option p) {
  margin: 16px 0 0;
  color: #536359;
  line-height: 1.68;
}

.families-stay__prices {
  display: grid;
  gap: 8px;
}

.families-stay__prices p {
  display: flex;
  justify-content: space-between;
  gap: 16px;
  margin: 0;
  padding: 12px 0;
  border-top: 1px solid rgba(25,70,44,.10);
  color: #102018;
  font-weight: 950;
}

.families-stay__prices strong {
  color: #64736a;
  font-size: .76rem;
  letter-spacing: .08em;
  text-transform: uppercase;
}

.families-stay__tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.families-stay__tag-list em {
  padding: 8px 10px;
  border-radius: 999px;
  color: #276647;
  background: rgba(60,179,113,.11);
  font-size: .78rem;
  font-style: normal;
  font-weight: 900;
}

.families-stay__media {
  display: grid;
  gap: 14px;
}

:global(.families-stay__main-photo) {
  min-height: 430px;
}

.families-stay__thumbs {
  display: grid;
  grid-template-columns: 1fr;
  gap: 12px;
}

.families-stay__thumbs :global(.asset-frame) {
  min-height: 190px;
}

.families-attractions {
  background:
    radial-gradient(circle at 86% 10%, rgba(239,174,99,.16), transparent 34%),
    linear-gradient(180deg, #fbfbf7, #eef6ef);
}

.families-attractions__grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 16px;
  margin-top: clamp(28px, 5vw, 52px);
}

:global(.families-attractions__card) {
  display: grid;
  gap: 20px;
  padding: 12px;
  border-radius: 28px;
}

.families-attractions__card :global(.asset-frame),
.families-attractions__fallback {
  min-height: 220px;
  border-radius: 22px;
}

.families-attractions__fallback {
  position: relative;
  display: grid;
  align-content: end;
  gap: 16px;
  padding: 22px;
  overflow: hidden;
  color: #fff;
  background:
    linear-gradient(135deg, rgba(7,22,15,.22), rgba(7,22,15,.74)),
    radial-gradient(circle at 74% 24%, rgba(232,158,84,.28), transparent 36%),
    linear-gradient(135deg, #25412f, #0c1912);
  box-shadow: 0 26px 76px rgba(17,40,28,.18);
}

.families-attractions__fallback::after {
  content: '';
  position: absolute;
  inset: 0;
  pointer-events: none;
  background: linear-gradient(180deg, transparent 42%, rgba(3,13,9,.58) 100%);
}

.families-attractions__fallback span,
.families-attractions__fallback strong {
  position: relative;
  z-index: 1;
}

.families-attractions__fallback span {
  width: 44px;
  height: 44px;
  display: grid;
  place-items: center;
  border-radius: 999px;
  border: 1px solid rgba(255,255,255,.18);
  background: rgba(255,255,255,.08);
}

.families-attractions__fallback svg {
  width: 22px;
  height: 22px;
  fill: none;
  stroke: #8fe0b4;
  stroke-width: 1.8;
  stroke-linecap: round;
  stroke-linejoin: round;
}

.families-attractions__fallback strong {
  font-size: .76rem;
  font-weight: 900;
  letter-spacing: .12em;
  text-transform: uppercase;
}

:global(.families-attractions__card h3) {
  margin: 0 12px 10px;
  color: #102018;
  font-size: clamp(1.2rem, 2vw, 1.45rem);
  font-weight: 950;
}

:global(.families-attractions__card p) {
  margin: 0 12px 14px;
  color: #536359;
  line-height: 1.68;
}

.families-info {
  background:
    radial-gradient(circle at 16% 18%, rgba(60,179,113,.14), transparent 34%),
    linear-gradient(180deg, #eef6ef, #fbfbf7);
}

:global(.families-info__panel),
:global(.families-info__price-card) {
  padding: clamp(26px, 4vw, 44px);
  border-radius: 28px;
}

.families-info__panel {
  color: #fff;
  background:
    linear-gradient(135deg, rgba(8,24,16,.94), rgba(18,45,29,.86)),
    radial-gradient(circle at 84% 16%, rgba(239,174,99,.20), transparent 34%);
  border-color: rgba(255,255,255,.14);
}

.families-info__panel .section-kicker {
  color: #8fe0b4;
}

.families-info__panel h2,
.families-info__price-card h2 {
  margin: 10px 0 clamp(24px, 4vw, 36px);
  font-size: clamp(1.8rem, 4vw, 3rem);
  line-height: 1.02;
  font-weight: 950;
}

.families-info__panel h2 {
