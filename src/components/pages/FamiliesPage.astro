---
import ImageFrame from '../ImageFrame.astro';
import { siteAssets } from '../../data/assets';
import { pricingConfig } from '../../data/pricing';
import { getLocalizedPath } from '../../utils/localizedLinks';

interface Props {
  languageCode?: string;
}

const { languageCode } = Astro.props as Props;
const pricingHref = getLocalizedPath(languageCode, 'cennik');
const contactHref = getLocalizedPath(languageCode, 'kontakt');
const attractionsHref = getLocalizedPath(languageCode, 'atrakcje');
const currency = pricingConfig.currency;
const formatPrice = (price: number) => `${price} ${currency}`;
const getStayType = (id: string) => {
  const stayType = pricingConfig.stayTypes.find((item) => item.id === id);
  if (!stayType) throw new Error(`Missing family stay pricing: ${id}`);

  return stayType;
};
const getAddon = (id: string) => {
  const addon = pricingConfig.addons.find((item) => item.id === id);
  if (!addon) throw new Error(`Missing family addon pricing: ${id}`);

  return addon;
};

const bungalow3 = getStayType('bungalow-3');
const bungalow4 = getStayType('bungalow-4');
const bungalowFamily = getStayType('bungalow-family');
const dog = getAddon('dog');

const getSeasonalPrices = (stayType: typeof pricingConfig.stayTypes[number]) => {
  if (!('seasonalPrices' in stayType)) throw new Error(`Missing seasonal prices for ${stayType.label}`);

  return stayType.seasonalPrices;
};
const getStartingPrice = (stayType: typeof pricingConfig.stayTypes[number]) => {
  if (!('startingPrice' in stayType)) throw new Error(`Missing starting price for ${stayType.label}`);

  return stayType.startingPrice;
};

const familyBenefits = [
  {
    title: 'Blisko centrum Krakowa',
    copy: 'Możecie łatwo dojechać tramwajem do centrum, bez stresu z parkowaniem przy Starym Mieście.',
    icon: 'M4 6h16M6 6v9a3 3 0 0 0 3 3h6a3 3 0 0 0 3-3V6M8 18l-2 3M16 18l2 3M9 10h6',
  },
  {
    title: 'Zielona przestrzeń',
    copy: 'Po dniu zwiedzania można wrócić w spokojniejsze miejsce i odpocząć poza ścisłym centrum.',
    icon: 'M5 19c8 0 14-6 14-14C11 5 5 11 5 19ZM5 19c0-5 4-9 9-9',
  },
  {
    title: 'Domki dla rodzin',
    copy: 'Domki są praktyczną opcją dla rodzin, które nie podróżują kamperem ani namiotem.',
    icon: 'M4 11l8-7 8 7v8a1 1 0 0 1-1 1h-5v-6H10v6H5a1 1 0 0 1-1-1v-8Z',
  },
  {
    title: 'Baza do wycieczek',
    copy: 'Dobry punkt startowy do Wieliczki, Energylandii, Ojcowa i innych atrakcji Małopolski.',
    icon: 'M9 18l-6 3V6l6-3 6 3 6-3v15l-6 3-6-3ZM9 3v15M15 6v15',
  },
];

const familyStayOptions = [
  {
    title: 'Domek 3-osobowy',
    type: 'seasonal',
    low: getSeasonalPrices(bungalow3).low,
    high: getSeasonalPrices(bungalow3).high,
    copy: 'Praktyczna opcja dla mniejszej rodziny albo rodzica z dziećmi.',
  },
  {
    title: 'Domek 4-osobowy',
    type: 'seasonal',
    low: getSeasonalPrices(bungalow4).low,
    high: getSeasonalPrices(bungalow4).high,
    copy: 'Więcej miejsca dla rodzin, które chcą zostać blisko centrum Krakowa.',
  },
  {
    title: 'Domek rodzinny',
    type: 'confirmation',
    startingPrice: getStartingPrice(bungalowFamily),
    copy: 'Finalna cena i dostępność potwierdzana przez recepcję.',
  },
  {
    title: 'Camping',
    type: 'camping',
    copy: 'Kamper, przyczepa, van, namiot lub auto z namiotem dachowym według aktualnego cennika campingu.',
  },
];

const kidsAttractions = [
  {
    title: 'Energylandia',
    copy: 'Popularny park rozrywki na całodniową wycieczkę rodzinną.',
    image: siteAssets.attractions.energylandia,
    label: 'Energylandia',
  },
  {
    title: 'Krakowskie Stare Miasto',
    copy: 'Spacer po Rynku, Sukiennicach i Plantach to dobry plan na rodzinne zwiedzanie.',
    image: siteAssets.attractions.oldTown,
    label: 'Stare Miasto',
  },
  {
    title: 'Ojcowski Park Narodowy',
    copy: 'Dobry kierunek na spokojniejszą wycieczkę z naturą i zamkami.',
    image: undefined,
    label: 'Miejsce na zdjęcie: Ojców',
  },
  {
    title: 'Wieliczka',
    copy: 'Jedna z najpopularniejszych atrakcji w okolicy Krakowa.',
    image: siteAssets.attractions.wieliczka,
    label: 'Wieliczka',
  },
];

const practicalInfo = [
  `Dzieci do 4 lat: ${pricingConfig.people.toddlers.price === 0 ? 'bezpłatnie' : `${formatPrice(pricingConfig.people.toddlers.price)} / noc`}.`,
  `Dzieci 4-14 lat: ${formatPrice(pricingConfig.people.children.price)} / noc.`,
  `Pies: ${dog.price === 0 ? 'bezpłatnie' : `${formatPrice(dog.price)} / noc`}.`,
  'Check-in/check-out camping: 12:00-12:00.',
  'Check-in domki: od 16:00.',
  'Check-out domki: do 11:00.',
  'Finalną dostępność potwierdza recepcja.',
];
---

<section class="site-section families-benefits reveal-section">
  <div class="container families-benefits__grid">
    <div class="families-benefits__intro">
      <span class="section-kicker">Dlaczego rodziny wybierają Clepardię</span>
      <h2 class="section-title">Kraków blisko, a po zwiedzaniu spokojniejsza zielona baza</h2>
      <p class="section-copy">
        To wygodne rozwiązanie dla rodzin, które chcą połączyć zwiedzanie miasta,
        wycieczki po Małopolsce i odpoczynek w miejscu z campingowym klimatem.
      </p>
    </div>

    <div class="families-benefits__cards">
      {familyBenefits.map((card, index) => (
        <article class="premium-card reveal-section families-benefits__card" style={`--reveal-delay: ${index * 80}ms`}>
          <span class="families-benefits__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24">
              <path d={card.icon}></path>
            </svg>
          </span>
          <h3>{card.title}</h3>
          <p>{card.copy}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<section class="site-section families-stay reveal-section">
  <div class="container families-stay__grid">
    <div class="families-stay__content">
      <span class="section-kicker">Domki i camping dla rodzin</span>
      <h2 class="section-title">Wybierz wygodną opcję pobytu dla swojej rodziny</h2>
      <p class="section-copy">
        Domki mają osobne ceny sezonowe, a pobyt campingowy sprawdza się dla rodzin
        podróżujących kamperem, przyczepą, vanem, namiotem albo autem z namiotem dachowym.
      </p>

      <div class="families-stay__options">
        {familyStayOptions.map((option, index) => (
          <article class="premium-card reveal-section families-stay__option" style={`--reveal-delay: ${index * 80}ms`}>
            <span>{String(index + 1).padStart(2, '0')}</span>
            <h3>{option.title}</h3>
            {option.type === 'seasonal' && (
              <div class="families-stay__prices">
                <p><strong>niski sezon</strong>{formatPrice(option.low)} / noc</p>
                <p><strong>wysoki sezon</strong>{formatPrice(option.high)} / noc</p>
              </div>
            )}
            {option.type === 'confirmation' && (
              <div class="families-stay__prices">
                <p><strong>cena od</strong>{formatPrice(option.startingPrice)} / noc</p>
              </div>
            )}
            {option.type === 'camping' && (
              <div class="families-stay__tag-list" aria-label="Opcje campingowe">
                <em>kamper</em>
                <em>przyczepa</em>
                <em>van</em>
                <em>namiot</em>
                <em>auto + namiot dachowy</em>
              </div>
            )}
            <p>{option.copy}</p>
          </article>
        ))}
      </div>
    </div>

    <div class="families-stay__media" aria-label="Domki i pobyt rodzinny">
      <ImageFrame
        src={siteAssets.bungalows.family}
        alt="Domek rodzinny Camping Clepardia"
        label="Miejsce na zdjęcie: domek rodzinny"
        className="families-stay__main-photo"
      />
      <div class="families-stay__thumbs">
        <ImageFrame src={siteAssets.bungalows.exterior} alt="Domki Camping Clepardia" label="Domki" />
        <ImageFrame src={siteAssets.attractions.oldTown} alt="Stare Miasto w Krakowie" label="Kraków" />
      </div>
    </div>
  </div>
</section>

<section class="site-section families-attractions reveal-section">
  <div class="container">
    <div class="families-attractions__head">
      <span class="section-kicker">Atrakcje dla dzieci</span>
      <h2 class="section-title">Pomysły na rodzinne wycieczki z Krakowa</h2>
      <p class="section-copy">
        Camping Clepardia może być spokojną bazą noclegową po intensywnym dniu w mieście,
        parku rozrywki albo na jednodniowej trasie po Małopolsce.
      </p>
    </div>

    <div class="families-attractions__grid">
      {kidsAttractions.map((item, index) => (
        <article class="premium-card reveal-section families-attractions__card" style={`--reveal-delay: ${index * 90}ms`}>
          {item.image ? (
            <ImageFrame src={item.image} alt={item.title} label={item.label} />
          ) : (
            <div class="families-attractions__fallback photo-frame">
              <span aria-hidden="true">
                <svg viewBox="0 0 24 24">
                  <path d="M5 19c8 0 14-6 14-14C11 5 5 11 5 19ZM5 19c0-5 4-9 9-9"></path>
                </svg>
              </span>
              <strong>{item.label}</strong>
            </div>
          )}
          <div>
            <h3>{item.title}</h3>
            <p>{item.copy}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<section class="site-section families-info reveal-section">
  <div class="container families-info__grid">
    <article class="premium-card families-info__panel">
      <span class="section-kicker">Praktyczne informacje</span>
      <h2>Najważniejsze rzeczy przed rodzinnym przyjazdem</h2>
      <div class="families-info__list">
        {practicalInfo.map((item, index) => (
          <div class="families-info__item reveal-section" style={`--reveal-delay: ${index * 60}ms`}>
            <span aria-hidden="true">
              <svg viewBox="0 0 24 24">
                <path d="M5 13l4 4L19 7"></path>
              </svg>
            </span>
            <p>{item}</p>
          </div>
        ))}
      </div>
    </article>

    <article class="premium-card families-info__price-card">
      <span class="section-kicker">Ceny rodzinne</span>
      <h2>Dzieci i pobyt z psem</h2>
      <div class="families-info__prices">
        <div>
          <span>Dzieci do 4 lat</span>
          <strong>{pricingConfig.people.toddlers.price === 0 ? 'bezpłatnie' : `${formatPrice(pricingConfig.people.toddlers.price)} / noc`}</strong>
        </div>
        <div>
          <span>Dzieci 4-14 lat</span>
          <strong>{formatPrice(pricingConfig.people.children.price)} / noc</strong>
        </div>
        <div>
          <span>Pies</span>
          <strong>{dog.price === 0 ? 'bezpłatnie' : `${formatPrice(dog.price)} / noc`}</strong>
        </div>
      </div>
    </article>
  </div>
</section>

<section class="site-section families-cta reveal-section">
  <div class="container">
    <div class="premium-card families-cta__panel">
      <div>
        <span class="section-kicker">Następny krok</span>
        <h2>Zaplanuj rodzinny pobyt w Krakowie</h2>
        <p>
          Sprawdź orientacyjny cennik, zapytaj recepcję o dostępność albo zobacz,
          które atrakcje możecie łatwo zaplanować z Camping Clepardia.
        </p>
      </div>
      <div class="families-cta__actions">
        <a class="premium-button" href={pricingHref}>Sprawdź cennik</a>
        <a class="families-cta__secondary" href={contactHref}>Zapytaj o dostępność</a>
        <a class="families-cta__secondary" href={attractionsHref}>Zobacz atrakcje</a>
      </div>
    </div>
  </div>
</section>

<style>
.families-benefits {
  background:
    radial-gradient(circle at 88% 14%, rgba(239,174,99,.18), transparent 32%),
    radial-gradient(circle at 12% 28%, rgba(60,179,113,.12), transparent 34%),
    linear-gradient(180deg, #fbfbf7, #f3f7ee);
}

.families-benefits__grid,
.families-stay__grid,
.families-info__grid {
  display: grid;
  gap: clamp(30px, 5vw, 62px);
}

.families-benefits__intro,
.families-attractions__head {
  max-width: 840px;
}

.families-benefits__cards {
  display: grid;
  grid-template-columns: 1fr;
  gap: 16px;
}

:global(.families-benefits__card) {
  display: grid;
  gap: 16px;
  min-height: 240px;
  padding: clamp(24px, 3vw, 34px);
  border-radius: 24px;
}

.families-benefits__icon {
  width: 54px;
  height: 54px;
  display: grid;
  place-items: center;
  border-radius: 18px;
  color: #3CB371;
  background:
    radial-gradient(circle at 30% 18%, rgba(255,255,255,.94), rgba(255,255,255,.38)),
    rgba(60,179,113,.12);
  border: 1px solid rgba(60,179,113,.22);
  box-shadow: 0 16px 38px rgba(60,179,113,.16);
}

.families-benefits__icon svg {
  width: 27px;
  height: 27px;
  fill: none;
  stroke: currentColor;
  stroke-width: 1.9;
  stroke-linecap: round;
  stroke-linejoin: round;
}

:global(.families-benefits__card h3) {
  margin: 0;
  color: #102018;
  font-size: clamp(1.25rem, 2vw, 1.55rem);
  font-weight: 950;
  line-height: 1.15;
}

:global(.families-benefits__card p) {
  margin: 0;
  color: #536359;
  line-height: 1.7;
}

.families-stay {
  background:
    radial-gradient(circle at 10% 18%, rgba(60,179,113,.13), transparent 32%),
    linear-gradient(180deg, #f3f7ee, #fbfbf7);
}

.families-stay__content {
  align-self: center;
}

.families-stay__options {
  display: grid;
  grid-template-columns: 1fr;
  gap: 14px;
  margin-top: clamp(26px, 4vw, 42px);
}

:global(.families-stay__option) {
  padding: clamp(22px, 3vw, 30px);
  border-radius: 24px;
}

:global(.families-stay__option > span) {
  display: inline-flex;
  margin-bottom: 18px;
  color: #3CB371;
  font-size: .74rem;
  font-weight: 950;
  letter-spacing: .14em;
}

:global(.families-stay__option h3) {
  margin: 0 0 14px;
  color: #102018;
  font-size: clamp(1.18rem, 2vw, 1.45rem);
  font-weight: 950;
}

:global(.families-stay__option p) {
  margin: 16px 0 0;
  color: #536359;
  line-height: 1.68;
}

.families-stay__prices {
  display: grid;
  gap: 8px;
}

.families-stay__prices p {
  display: flex;
  justify-content: space-between;
  gap: 16px;
  margin: 0;
  padding: 12px 0;
  border-top: 1px solid rgba(25,70,44,.10);
  color: #102018;
  font-weight: 950;
}

.families-stay__prices strong {
  color: #64736a;
  font-size: .76rem;
  letter-spacing: .08em;
  text-transform: uppercase;
}

.families-stay__tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.families-stay__tag-list em {
  padding: 8px 10px;
  border-radius: 999px;
  color: #276647;
  background: rgba(60,179,113,.11);
  font-size: .78rem;
  font-style: normal;
  font-weight: 900;
}

.families-stay__media {
  display: grid;
  gap: 14px;
}

:global(.families-stay__main-photo) {
  min-height: 430px;
}

.families-stay__thumbs {
  display: grid;
  grid-template-columns: 1fr;
  gap: 12px;
}

.families-stay__thumbs :global(.asset-frame) {
  min-height: 190px;
}

.families-attractions {
  background:
    radial-gradient(circle at 86% 10%, rgba(239,174,99,.16), transparent 34%),
    linear-gradient(180deg, #fbfbf7, #eef6ef);
}

.families-attractions__grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 16px;
  margin-top: clamp(28px, 5vw, 52px);
}

:global(.families-attractions__card) {
  display: grid;
  gap: 20px;
  padding: 12px;
  border-radius: 28px;
}

.families-attractions__card :global(.asset-frame),
.families-attractions__fallback {
  min-height: 220px;
  border-radius: 22px;
}

.families-attractions__fallback {
  position: relative;
  display: grid;
  align-content: end;
  gap: 16px;
  padding: 22px;
  overflow: hidden;
  color: #fff;
  background:
    linear-gradient(135deg, rgba(7,22,15,.22), rgba(7,22,15,.74)),
    radial-gradient(circle at 74% 24%, rgba(232,158,84,.28), transparent 36%),
    linear-gradient(135deg, #25412f, #0c1912);
  box-shadow: 0 26px 76px rgba(17,40,28,.18);
}

.families-attractions__fallback::after {
  content: '';
  position: absolute;
  inset: 0;
  pointer-events: none;
  background: linear-gradient(180deg, transparent 42%, rgba(3,13,9,.58) 100%);
}

.families-attractions__fallback span,
.families-attractions__fallback strong {
  position: relative;
  z-index: 1;
}

.families-attractions__fallback span {
  width: 44px;
  height: 44px;
  display: grid;
  place-items: center;
  border-radius: 999px;
  border: 1px solid rgba(255,255,255,.18);
  background: rgba(255,255,255,.08);
}

.families-attractions__fallback svg {
  width: 22px;
  height: 22px;
  fill: none;
  stroke: #8fe0b4;
  stroke-width: 1.8;
  stroke-linecap: round;
  stroke-linejoin: round;
}

.families-attractions__fallback strong {
  font-size: .76rem;
  font-weight: 900;
  letter-spacing: .12em;
  text-transform: uppercase;
}

:global(.families-attractions__card h3) {
  margin: 0 12px 10px;
  color: #102018;
  font-size: clamp(1.2rem, 2vw, 1.45rem);
  font-weight: 950;
}

:global(.families-attractions__card p) {
  margin: 0 12px 14px;
  color: #536359;
  line-height: 1.68;
}

.families-info {
  background:
    radial-gradient(circle at 16% 18%, rgba(60,179,113,.14), transparent 34%),
    linear-gradient(180deg, #eef6ef, #fbfbf7);
}

:global(.families-info__panel),
:global(.families-info__price-card) {
  padding: clamp(26px, 4vw, 44px);
  border-radius: 28px;
}

.families-info__panel {
  color: #fff;
  background:
    linear-gradient(135deg, rgba(8,24,16,.94), rgba(18,45,29,.86)),
    radial-gradient(circle at 84% 16%, rgba(239,174,99,.20), transparent 34%);
  border-color: rgba(255,255,255,.14);
}

.families-info__panel .section-kicker {
  color: #8fe0b4;
}

.families-info__panel h2,
.families-info__price-card h2 {
  margin: 10px 0 clamp(24px, 4vw, 36px);
  font-size: clamp(1.8rem, 4vw, 3rem);
  line-height: 1.02;
  font-weight: 950;
}

.families-info__panel h2 {
  color: #fff;
}

.families-info__price-card h2 {
  color: #102018;
}

.families-info__list {
  display: grid;
  gap: 12px;
}

.families-info__item {
  display: grid;
  grid-template-columns: auto 1fr;
  gap: 12px;
  align-items: start;
  padding: 14px;
  border-radius: 18px;
  background: rgba(255,255,255,.075);
  border: 1px solid rgba(255,255,255,.10);
}

.families-info__item span {
  width: 30px;
  height: 30px;
  display: grid;
  place-items: center;
  border-radius: 999px;
  color: #8fe0b4;
  background: rgba(143,224,180,.12);
}

.families-info__item svg {
  width: 17px;
  height: 17px;
  fill: none;
  stroke: currentColor;
  stroke-width: 2.3;
  stroke-linecap: round;
  stroke-linejoin: round;
}

.families-info__item p {
  margin: 0;
  color: rgba(255,255,255,.80);
  line-height: 1.62;
  font-weight: 760;
}

.families-info__price-card {
  align-self: start;
  background:
    radial-gradient(circle at 86% 8%, rgba(60,179,113,.16), transparent 34%),
    rgba(255,255,255,.82);
}

.families-info__prices {
  display: grid;
  gap: 12px;
}

.families-info__prices div {
  display: grid;
  gap: 8px;
  padding: 18px;
  border-radius: 20px;
  background: rgba(255,255,255,.72);
  border: 1px solid rgba(25,70,44,.10);
  box-shadow: 0 16px 42px rgba(17,40,28,.07);
}

.families-info__prices span {
  color: #536359;
  font-size: .78rem;
  font-weight: 950;
  letter-spacing: .10em;
  text-transform: uppercase;
}

.families-info__prices strong {
  color: #102018;
  font-size: clamp(1.15rem, 2vw, 1.45rem);
  font-weight: 950;
}

.families-cta {
  background:
    radial-gradient(circle at 18% 20%, rgba(60,179,113,.18), transparent 34%),
    linear-gradient(180deg, #fbfbf7, #101b14);
}

.families-cta__panel {
  display: grid;
  gap: 28px;
  padding: clamp(28px, 5vw, 54px);
  border-radius: 28px;
  color: #fff;
  background:
    linear-gradient(135deg, rgba(10,28,18,.92), rgba(17,39,27,.82)),
    radial-gradient(circle at 86% 18%, rgba(239,174,99,.18), transparent 36%);
  border-color: rgba(255,255,255,.14);
}

.families-cta__panel h2 {
  max-width: 820px;
  margin: 0 0 14px;
  color: #fff;
  font-size: clamp(2rem, 5vw, 4rem);
  line-height: .98;
  font-weight: 950;
}

.families-cta__panel p {
  max-width: 720px;
  margin: 0;
  color: rgba(255,255,255,.76);
  line-height: 1.75;
}

.families-cta__actions {
  display: flex;
  flex-wrap: wrap;
