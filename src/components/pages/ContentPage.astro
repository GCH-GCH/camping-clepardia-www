---
import PricingCalculator from '../pricing/PricingCalculator.astro';
import ReservationInquiryForm from '../forms/ReservationInquiryForm.astro';
import TransportDirections from './TransportDirections.astro';
import AttractionsPage from './AttractionsPage.astro';
import FaqPage from './FaqPage.astro';
import GalleryPage from './GalleryPage.astro';
import CampersPage from './CampersPage.astro';
import { pricingConfig } from '../../data/pricing';
import type { SitePage } from '../../data/sitePages';
import { getLocalizedPath } from '../../utils/localizedLinks';

interface Props {
  page: SitePage;
  languageCode?: string;
  languageName?: string;
}

const { page, languageCode, languageName } = Astro.props as Props;
const localizeHref = (href: string) => href.startsWith('/') ? getLocalizedPath(languageCode, href) : href;
const homeHref = getLocalizedPath(languageCode, '');
const breadcrumbHome = languageName ? `Camping Clepardia ${languageName}` : 'Camping Clepardia';
const formatPrice = (price: number) => `${price} ${pricingConfig.currency}`;
const formatSeasonDate = (value: string) => {
  const [month, day] = value.split('-');
  return `${day}.${month}`;
};
const bungalowNames = {
  'bungalow-2': 'Domek 2-osobowy',
  'bungalow-3': 'Domek 3-osobowy',
  'bungalow-4': 'Domek 4-osobowy',
  'bungalow-family': 'Domek rodzinny',
} as const;
const bungalowCards = pricingConfig.stayTypes
  .filter((type) => type.category === 'bungalow')
  .map((type) => ({
    id: type.id,
    title: bungalowNames[type.id as keyof typeof bungalowNames] ?? type.label,
    lowSeasonPrice: 'seasonalPrices' in type ? formatPrice(type.seasonalPrices.low) : undefined,
    highSeasonPrice: 'seasonalPrices' in type ? formatPrice(type.seasonalPrices.high) : undefined,
    startingPrice: 'startingPrice' in type ? formatPrice(type.startingPrice) : undefined,
    note: 'note' in type ? type.note : undefined,
    requiresConfirmation: 'requiresConfirmation' in type ? type.requiresConfirmation : false,
  }));
const highSeasonRange = `${formatSeasonDate(pricingConfig.seasons.high.start)}–${formatSeasonDate(pricingConfig.seasons.high.end)}`;
const dogAddon = pricingConfig.addons.find((addon) => addon.id === 'dog');
const electricityAddon = pricingConfig.addons.find((addon) => addon.id === 'electricity');
const pricingInfoBarItems = [
  { label: 'Wysoki sezon', value: highSeasonRange },
  { label: 'Niski sezon', value: 'pozostałe terminy' },
  { label: 'Pies', value: dogAddon?.price === 0 ? 'bezpłatnie' : dogAddon ? `${formatPrice(dogAddon.price)} / noc` : 'do potwierdzenia' },
  { label: 'Prąd', value: electricityAddon ? `${formatPrice(electricityAddon.price)} / noc` : 'do potwierdzenia' },
];
const contactCards = [
  { label: 'Telefon', value: '+48 795 294 486', href: 'tel:+48795294486' },
  { label: 'Email', value: 'clepardia@gmail.com', href: 'mailto:clepardia@gmail.com' },
  { label: 'Adres', value: 'Henryka Pachońskiego 28A, 31-322 Kraków' },
  { label: 'Godziny recepcji', value: '9:00–20:00' },
];
---

<section class="page-mini-hero reveal-section">
  <div class="container page-mini-hero__inner">
    <nav class="breadcrumbs" aria-label="Breadcrumb">
      <a href={homeHref}>{breadcrumbHome}</a>
      <span aria-hidden="true">/</span>
      <span>{page.title}</span>
    </nav>

    <span class="section-kicker">{page.overline}</span>
    <h1>{page.title}</h1>
    <p>{page.lead}</p>
  </div>
</section>

{page.slug !== 'cennik' && page.slug !== 'kontakt' && page.slug !== 'dojazd' && page.slug !== 'atrakcje' && page.slug !== 'faq' && page.slug !== 'galeria' && page.slug !== 'dla-kamperow' && (
<section class="site-section page-detail reveal-section">
  <div class="container page-detail__grid">
    <div class="page-detail__intro">
      <span class="section-kicker">Informacje</span>
      <h2 class="section-title">Najważniejsze informacje przed przyjazdem</h2>
      <p class="section-copy">{page.seoDescription}</p>
    </div>

    <div class="page-detail__cards">
      {page.highlights.map((item, index) => (
        <article class="premium-card reveal-section page-detail__card" style={`--reveal-delay: ${index * 80}ms`}>
          <span>{String(index + 1).padStart(2, '0')}</span>
          <h3>{item.title}</h3>
          <p>{item.copy}</p>
        </article>
      ))}
    </div>
  </div>
</section>
)}

{page.slug === 'cennik' && (
  <section class="pricing-quick-info reveal-section" aria-label="Najważniejsze informacje o cenniku">
    <div class="container pricing-quick-info__grid">
      {pricingInfoBarItems.map((item) => (
        <div class="pricing-quick-info__item">
          <span>{item.label}</span>
          <strong>{item.value}</strong>
        </div>
      ))}
    </div>
  </section>
)}

{page.slug === 'kontakt' && (
  <section class="site-section contact-cards reveal-section" aria-label="Dane kontaktowe Camping Clepardia">
    <div class="container contact-cards__grid">
      {contactCards.map((item, index) => (
        <article class="premium-card reveal-section contact-cards__card" style={`--reveal-delay: ${index * 80}ms`}>
          <span>{item.label}</span>
          {item.href ? (
            <a href={item.href}>{item.value}</a>
          ) : (
            <strong>{item.value}</strong>
          )}
        </article>
      ))}
    </div>
  </section>
)}

{page.slug === 'domki' && (
  <section class="site-section bungalow-types reveal-section">
    <div class="container">
      <div class="bungalow-types__head">
        <span class="section-kicker">Cennik domków</span>
        <h2 class="section-title">Rodzaje domków</h2>
        <p class="section-copy">
          Ceny domków zależą od sezonu i konfiguracji pobytu. Domek rodzinny wymaga potwierdzenia dostępności oraz finalnej ceny przez recepcję.
        </p>
      </div>

      <div class="bungalow-types__grid">
        {bungalowCards.map((bungalow, index) => (
          <article class="premium-card reveal-section bungalow-types__card" style={`--reveal-delay: ${index * 90}ms`}>
            <span>{String(index + 1).padStart(2, '0')}</span>
            <h3>{bungalow.title}</h3>
            {bungalow.lowSeasonPrice && bungalow.highSeasonPrice ? (
              <div class="bungalow-types__prices">
                <p><strong>niski sezon</strong>{bungalow.lowSeasonPrice} / noc</p>
                <p><strong>wysoki sezon</strong>{bungalow.highSeasonPrice} / noc</p>
              </div>
            ) : (
              <div class="bungalow-types__prices">
                <p><strong>cena od</strong>{bungalow.startingPrice} / noc</p>
              </div>
            )}
            {bungalow.note && <p class="bungalow-types__note">{bungalow.note}</p>}
            {bungalow.requiresConfirmation && <small>Dostępność i finalna cena potwierdzana przez recepcję.</small>}
          </article>
        ))}
      </div>

      <p class="bungalow-types__season-note">
        Wysoki sezon: {highSeasonRange}. Niski sezon: pozostałe terminy sezonu.
      </p>
    </div>
  </section>
)}

{page.slug === 'cennik' && <PricingCalculator />}

{page.slug === 'kontakt' && <ReservationInquiryForm languageCode={languageCode} />}

{page.slug === 'dojazd' && <TransportDirections languageCode={languageCode} />}

{page.slug === 'atrakcje' && <AttractionsPage languageCode={languageCode} />}

{page.slug === 'faq' && <FaqPage languageCode={languageCode} />}

{page.slug === 'galeria' && <GalleryPage languageCode={languageCode} />}

{page.slug === 'dla-kamperow' && <CampersPage languageCode={languageCode} />}

{page.slug === 'cennik' && (
  <section class="site-section page-detail pricing-guidance reveal-section">
    <div class="container page-detail__grid">
      <div class="page-detail__intro">
        <span class="section-kicker">Ważne przed rezerwacją</span>
        <h2 class="section-title">Najważniejsze informacje</h2>
        <p class="section-copy">{page.seoDescription}</p>
      </div>

      <div class="page-detail__cards pricing-guidance__cards">
        {page.highlights.map((item, index) => (
          <article class="premium-card reveal-section page-detail__card" style={`--reveal-delay: ${index * 80}ms`}>
            <span>{String(index + 1).padStart(2, '0')}</span>
            <h3>{item.title}</h3>
            <p>{item.copy}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
)}

{page.slug === 'kontakt' && (
  <section class="site-section page-detail contact-guidance reveal-section">
    <div class="container page-detail__grid">
      <div class="page-detail__intro">
        <span class="section-kicker">Przed wysłaniem zapytania</span>
        <h2 class="section-title">Co warto wiedzieć?</h2>
        <p class="section-copy">{page.seoDescription}</p>
      </div>

      <div class="page-detail__cards contact-guidance__cards">
        {page.highlights.map((item, index) => (
          <article class="premium-card reveal-section page-detail__card" style={`--reveal-delay: ${index * 80}ms`}>
            <span>{String(index + 1).padStart(2, '0')}</span>
            <h3>{item.title}</h3>
            <p>{item.copy}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
)}

{page.slug !== 'kontakt' && page.slug !== 'dojazd' && page.slug !== 'atrakcje' && page.slug !== 'faq' && page.slug !== 'galeria' && page.slug !== 'dla-kamperow' && (
<section class="site-section page-cta reveal-section">
  <div class="container">
    <div class="page-cta__panel premium-card">
      <div>
        <span class="section-kicker">Następny krok</span>
        <h2>{page.cta.title}</h2>
        <p>{page.cta.copy}</p>
      </div>
      <div class="page-cta__actions">
        <a class="premium-button" href={localizeHref(page.cta.primaryHref)}>{page.cta.primaryLabel}</a>
        {page.cta.secondaryHref && page.cta.secondaryLabel && (
          <a class="page-cta__secondary" href={localizeHref(page.cta.secondaryHref)}>{page.cta.secondaryLabel}</a>
        )}
      </div>
    </div>
  </div>
</section>
)}

<style>
.page-mini-hero {
  min-height: 58svh;
  display: grid;
  align-items: end;
  padding: 128px 0 78px;
  color: #fff;
  background:
    linear-gradient(90deg, rgba(3,13,9,.88), rgba(8,28,18,.68) 52%, rgba(11,24,17,.36)),
    radial-gradient(circle at 78% 24%, rgba(239,174,99,.20), transparent 34%),
    radial-gradient(circle at 14% 68%, rgba(60,179,113,.20), transparent 32%),
    linear-gradient(135deg, #07120d, #10281b 54%, #26190c);
  overflow: hidden;
}

.page-mini-hero__inner {
  display: grid;
  gap: 20px;
}

.breadcrumbs {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  align-items: center;
  color: rgba(255,255,255,.68);
  font-size: .84rem;
  font-weight: 800;
}

.breadcrumbs a {
  color: rgba(255,255,255,.86);
}

.breadcrumbs a:hover {
  color: #8fe0b4;
}

.page-mini-hero .section-kicker {
  color: #8fe0b4;
}

.page-mini-hero h1 {
  max-width: 960px;
  margin: 0;
  color: #fff;
  font-size: clamp(2.7rem, 7vw, 6.2rem);
  line-height: .92;
  font-weight: 950;
  letter-spacing: 0;
  text-shadow: 0 8px 34px rgba(0,0,0,.36);
}

.page-mini-hero p {
  max-width: 760px;
  margin: 0;
  color: rgba(255,255,255,.84);
  font-size: clamp(1.02rem, 2vw, 1.24rem);
  line-height: 1.72;
}

.page-detail {
  background:
    radial-gradient(circle at 88% 8%, rgba(60,179,113,.12), transparent 30%),
    linear-gradient(180deg, #fbfbf7, #f2f7f0);
}

.pricing-quick-info {
  padding: 0 0 clamp(36px, 6vw, 70px);
  margin-top: -34px;
  position: relative;
  z-index: 2;
}

.pricing-quick-info__grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 10px;
  padding: clamp(14px, 2vw, 18px);
  border: 1px solid rgba(255,255,255,.14);
  border-radius: 28px;
  background: rgba(8, 25, 16, .82);
  box-shadow: 0 24px 70px rgba(0,0,0,.22), inset 0 1px 0 rgba(255,255,255,.10);
  backdrop-filter: blur(22px) saturate(140%);
  -webkit-backdrop-filter: blur(22px) saturate(140%);
}

.pricing-quick-info__item {
  min-height: 86px;
  display: grid;
  align-content: center;
  gap: 8px;
  padding: 18px;
  border-radius: 22px;
  background: rgba(255,255,255,.075);
  border: 1px solid rgba(255,255,255,.10);
}

.pricing-quick-info__item span {
  color: #8fe0b4;
  font-size: .74rem;
  font-weight: 950;
  letter-spacing: .12em;
  text-transform: uppercase;
}

.pricing-quick-info__item strong {
  color: #fff;
  font-size: clamp(1.08rem, 2vw, 1.35rem);
  line-height: 1.15;
  font-weight: 950;
}

.pricing-guidance {
  background:
    radial-gradient(circle at 14% 12%, rgba(60,179,113,.16), transparent 34%),
    linear-gradient(180deg, #fbfbf7, #edf6ef);
}

.contact-cards {
  padding: clamp(44px, 7vw, 86px) 0;
  background:
    radial-gradient(circle at 86% 12%, rgba(60,179,113,.14), transparent 30%),
    linear-gradient(180deg, #fbfbf7, #f2f7f0);
}

.contact-cards__grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 16px;
}

:global(.contact-cards__card) {
  display: grid;
  gap: 12px;
  min-height: 154px;
  padding: clamp(24px, 3vw, 32px);
  border-radius: 24px;
}

:global(.contact-cards__card span) {
  color: #3CB371;
  font-size: .74rem;
  font-weight: 950;
  letter-spacing: .14em;
  text-transform: uppercase;
}

:global(.contact-cards__card a),
:global(.contact-cards__card strong) {
  color: #102018;
  font-size: clamp(1.12rem, 2vw, 1.42rem);
  line-height: 1.25;
  font-weight: 950;
}

:global(.contact-cards__card a:hover) {
  color: #2f9d63;
}

.contact-guidance {
  background:
    radial-gradient(circle at 14% 12%, rgba(60,179,113,.15), transparent 34%),
    linear-gradient(180deg, #eef6ef, #fbfbf7);
}

.page-detail__grid {
  display: grid;
  gap: clamp(30px, 5vw, 62px);
}

.page-detail__cards {
  display: grid;
  grid-template-columns: 1fr;
  gap: 16px;
}

:global(.page-detail__card) {
  padding: clamp(24px, 3vw, 32px);
  border-radius: 24px;
}

:global(.page-detail__card span) {
  display: inline-flex;
  margin-bottom: 28px;
  color: #3CB371;
  font-size: .74rem;
  font-weight: 950;
  letter-spacing: .14em;
}

:global(.page-detail__card h3) {
  margin: 0 0 12px;
  color: #102018;
  font-size: 1.2rem;
  font-weight: 900;
  line-height: 1.2;
}

:global(.page-detail__card p) {
  margin: 0;
  color: #536359;
  line-height: 1.7;
}

.page-cta {
  background:
    radial-gradient(circle at 18% 20%, rgba(60,179,113,.18), transparent 34%),
    linear-gradient(180deg, #f2f7f0, #101b14);
}

.bungalow-types {
  background:
    radial-gradient(circle at 12% 18%, rgba(60,179,113,.14), transparent 32%),
    linear-gradient(180deg, #f8fbf5, #edf6ef);
}

.bungalow-types__head {
  max-width: 820px;
  margin-bottom: clamp(30px, 5vw, 52px);
}

.bungalow-types__grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 16px;
}

:global(.bungalow-types__card) {
  padding: clamp(24px, 3vw, 34px);
  border-radius: 24px;
}

:global(.bungalow-types__card > span) {
  display: inline-flex;
  margin-bottom: 24px;
  color: #3CB371;
  font-size: .74rem;
  font-weight: 950;
  letter-spacing: .14em;
}

:global(.bungalow-types__card h3) {
  margin: 0 0 18px;
  color: #102018;
  font-size: clamp(1.25rem, 2vw, 1.55rem);
  font-weight: 950;
}

.bungalow-types__prices {
  display: grid;
  gap: 10px;
}

.bungalow-types__prices p {
  display: flex;
  justify-content: space-between;
  gap: 16px;
  margin: 0;
  padding: 14px 0;
  border-top: 1px solid rgba(25,70,44,.10);
  color: #102018;
  font-weight: 900;
}

.bungalow-types__prices strong {
  color: #64736a;
  font-size: .78rem;
  letter-spacing: .08em;
  text-transform: uppercase;
}

.bungalow-types__note {
  margin: 18px 0 0;
  color: #536359;
  line-height: 1.65;
  font-weight: 760;
}

:global(.bungalow-types__card small) {
  display: block;
  margin-top: 12px;
  color: #2c6b48;
  font-weight: 900;
  line-height: 1.5;
}

.bungalow-types__season-note {
  margin: 22px 0 0;
  color: #536359;
  font-weight: 850;
  line-height: 1.65;
}

.page-cta__panel {
  display: grid;
  gap: 28px;
  padding: clamp(28px, 5vw, 54px);
  border-radius: 28px;
  color: #fff;
  background:
    linear-gradient(135deg, rgba(10,28,18,.92), rgba(17,39,27,.82)),
    radial-gradient(circle at 86% 18%, rgba(239,174,99,.18), transparent 36%);
  border-color: rgba(255,255,255,.14);
}

.page-cta__panel h2 {
  max-width: 780px;
  margin: 0 0 14px;
  color: #fff;
  font-size: clamp(2rem, 5vw, 4rem);
  line-height: .98;
  font-weight: 950;
}

.page-cta__panel p {
  max-width: 720px;
  margin: 0;
  color: rgba(255,255,255,.76);
  line-height: 1.75;
}

.page-cta__actions {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
}

.page-cta__secondary {
  display: inline-flex;
  min-height: 50px;
  align-items: center;
  justify-content: center;
  padding: 14px 24px;
  border-radius: 999px;
  border: 1px solid rgba(255,255,255,.18);
  color: #fff;
  background: rgba(255,255,255,.08);
  font-weight: 900;
  letter-spacing: .06em;
}

.page-cta__secondary:hover {
  color: #fff;
  border-color: rgba(143,224,180,.42);
  background: rgba(255,255,255,.14);
}

@media (min-width: 900px) {
  .page-detail__grid {
    grid-template-columns: .75fr 1.25fr;
  }

  .page-detail__intro {
    position: sticky;
    top: 104px;
    align-self: start;
  }

  .page-detail__cards {
    grid-template-columns: repeat(3, 1fr);
  }

  .pricing-quick-info__grid {
    grid-template-columns: repeat(4, 1fr);
  }

  .contact-cards__grid {
    grid-template-columns: repeat(4, 1fr);
  }

  .bungalow-types__grid {
    grid-template-columns: repeat(3, 1fr);
  }

  .page-cta__panel {
    grid-template-columns: 1fr auto;
    align-items: end;
  }
}

@media (min-width: 1120px) {
  .bungalow-types__grid {
    grid-template-columns: repeat(4, 1fr);
  }

  .pricing-guidance__cards {
    grid-template-columns: repeat(4, 1fr);
  }

  .contact-guidance__cards {
    grid-template-columns: repeat(4, 1fr);
  }
}

@media (max-width: 640px) {
  .page-mini-hero {
    min-height: 62svh;
    padding: 116px 0 58px;
  }

  .page-cta__actions {
    display: grid;
  }

  .page-cta__actions a {
    width: 100%;
  }
}
</style>
