---
import PremiumPricingApp from '@/components/pricing/PremiumPricingApp.astro';
import Icon from '@/components/ui/Icon.astro';
import TransportDirections from './TransportDirections.astro';
import AttractionsPage from './AttractionsPage.astro';
import FaqPage from './FaqPage.astro';
import GalleryPage from './GalleryPage.astro';
import CampersPage from './CampersPage.astro';
import FamiliesPage from './FamiliesPage.astro';
import LegalPage from './LegalPage.astro';
import ArrivalFlowSection from '@/components/home/ArrivalFlowSection.astro';
import { publicAssetExists, siteAssets } from '@/data/assets';
import { pricingConfig } from '@/data/pricing';
import type { SitePage } from '@/data/sitePages';
import { getBookingLocalizedPath, getLocalizedPath, getPathContext } from '@/utils/localizedLinks';
import { getTranslations, resolveContentLanguage } from '@/i18n/config';
import { getCurrentYear } from '@/utils/currentYear';

interface Props {
  page: SitePage;
  languageCode?: string;
  languageName?: string;
}

const { page, languageCode, languageName } = Astro.props as Props;
const pathContext = getPathContext(Astro.url.pathname);
const contentLanguage = languageCode ?? pathContext.languageCode;
const resolvedContentLanguage = resolveContentLanguage(contentLanguage);
const linkLanguage = pathContext.explicitLanguage;
const t = getTranslations(contentLanguage);
const currentYear = getCurrentYear();
const pricingOverlineByLanguage = {
  pl: `Cennik Camping Clepardia ${currentYear}`,
  en: `Camping Clepardia prices ${currentYear}`,
  de: `Camping Clepardia Preisliste ${currentYear}`,
  it: `Prezzi Camping Clepardia ${currentYear}`,
};
const contactHeroTextByLanguage = {
  pl: {
    overline: 'Kontakt',
    title: 'Kontakt z Camping Clepardia',
    lead: 'Telefon, email, adres, Google Maps i szybki dostęp do rezerwacji pobytu.',
  },
  en: {
    overline: 'Contact',
    title: 'Contact Camping Clepardia',
    lead: 'Phone, email, address, Google Maps and a fast path to the booking flow.',
  },
  de: {
    overline: 'Kontakt',
    title: 'Kontakt zu Camping Clepardia',
    lead: 'Telefon, E-Mail, Adresse, Google Maps und schneller Zugang zur Buchung.',
  },
  it: {
    overline: 'Contatto',
    title: 'Contatta Camping Clepardia',
    lead: 'Telefono, email, indirizzo, Google Maps e accesso rapido alla prenotazione.',
  },
};
const pricingHeroTextByLanguage = {
  pl: {
    overline: `Cennik Camping Clepardia ${currentYear}`,
    title: 'Cennik Camping Clepardia',
    lead: 'Sprawdź orientacyjny koszt pobytu i wybierz najlepszy wariant dla siebie.',
    primary: 'Oblicz koszt',
    secondary: 'Zarezerwuj pobyt',
    notes: ['Cena jest orientacyjna', 'Dostępność potwierdza recepcja', 'Camping 12:00-12:00', 'Domki 16:00-11:00'],
  },
  en: {
    overline: `Camping Clepardia prices ${currentYear}`,
    title: 'Camping Clepardia prices',
    lead: 'Check the indicative stay cost and choose the best option for you.',
    primary: 'Calculate cost',
    secondary: 'Book your stay',
    notes: ['Indicative price', 'Reception confirms availability', 'Camping 12:00-12:00', 'Bungalows 16:00-11:00'],
  },
  de: {
    overline: `Camping Clepardia Preisliste ${currentYear}`,
    title: 'Preise Camping Clepardia',
    lead: 'Prüfen Sie die ungefähren Aufenthaltskosten und wählen Sie die passende Option.',
    primary: 'Kosten berechnen',
    secondary: 'Aufenthalt buchen',
    notes: ['Richtpreis', 'Rezeption bestätigt Verfügbarkeit', 'Camping 12:00-12:00', 'Bungalows 16:00-11:00'],
  },
  it: {
    overline: `Prezzi Camping Clepardia ${currentYear}`,
    title: 'Prezzi Camping Clepardia',
    lead: 'Controlla il costo indicativo del soggiorno e scegli la soluzione migliore.',
    primary: 'Calcola costo',
    secondary: 'Prenota soggiorno',
    notes: ['Prezzo indicativo', 'La reception conferma disponibilità', 'Camping 12:00-12:00', 'Bungalow 16:00-11:00'],
  },
};
const contactHeroText = contactHeroTextByLanguage[resolvedContentLanguage];
const pricingHeroText = pricingHeroTextByLanguage[resolvedContentLanguage];
const displayOverline = page.slug === 'kontakt'
  ? contactHeroText.overline
  : page.slug === 'cennik'
    ? pricingHeroText.overline
    : page.overline;
const displayTitle = page.slug === 'kontakt'
  ? contactHeroText.title
  : page.slug === 'cennik'
    ? pricingHeroText.title
    : page.title;
const displayLead = page.slug === 'kontakt'
  ? contactHeroText.lead
  : page.slug === 'cennik'
    ? pricingHeroText.lead
    : page.lead;
const localizeHref = (href: string) => href.startsWith('/') ? getLocalizedPath(linkLanguage, href) : href;
const homeHref = getLocalizedPath(linkLanguage, '');
const breadcrumbHome = languageName ? `Camping Clepardia ${languageName}` : 'Camping Clepardia';
const formatPrice = (price: number) => `${price} ${pricingConfig.currency}`;
const formatSeasonDate = (value: string) => {
  const [month, day] = value.split('-');
  return `${day}.${month}`;
};
const bungalowNames = {
  'bungalow-2': t.pricing.stayTypes['bungalow-2'],
  'bungalow-3': t.pricing.stayTypes['bungalow-3'],
  'bungalow-4': t.pricing.stayTypes['bungalow-4'],
} as const;
const bungalowCards = pricingConfig.stayTypes
  .filter((type) => type.category === 'bungalow')
  .map((type) => ({
    id: type.id,
    title: bungalowNames[type.id as keyof typeof bungalowNames] ?? type.label,
    lowSeasonPrice: 'seasonalPrices' in type ? formatPrice(type.seasonalPrices.low) : undefined,
    highSeasonPrice: 'seasonalPrices' in type ? formatPrice(type.seasonalPrices.high) : undefined,
  }));
const highSeasonRange = `${formatSeasonDate(pricingConfig.seasons.high.start)}–${formatSeasonDate(pricingConfig.seasons.high.end)}`;
const dogAddon = pricingConfig.addons.find((addon) => addon.id === 'dog');
const electricityAddon = pricingConfig.addons.find((addon) => addon.id === 'electricity');
const googleMapsHref = 'https://www.google.com/maps/search/?api=1&query=Camping+Clepardia+Henryka+Pacho%C5%84skiego+28A+Krak%C3%B3w';
const bookingHref = getBookingLocalizedPath(contentLanguage);
const flatPricingStayPrice = (id: string) => {
  const item = pricingConfig.stayTypes.find((type) => type.id === id);
  return item && 'price' in item ? item.price : 0;
};
const pricingAddonPrice = (id: string) => pricingConfig.addons.find((addon) => addon.id === id)?.price ?? 0;
const pricingHeroStats = [
  {
    icon: 'camper',
    value: formatPrice((pricingConfig.people.adults.price * 2) + flatPricingStayPrice('camper') + pricingAddonPrice('electricity')),
    label: '2 osoby + kamper + prąd',
  },
  {
    icon: 'dog',
    value: formatPrice(pricingAddonPrice('dog')),
    label: 'Pies',
  },
  {
    icon: 'electricity',
    value: formatPrice(pricingAddonPrice('electricity')),
    label: 'Prąd 10A',
  },
  {
    icon: 'clock',
    value: '12:00-12:00',
    label: 'Doba campingowa',
  },
];
const pricingInfoBarItems = [
  { label: t.content.highSeason, value: highSeasonRange },
  { label: t.content.lowSeason, value: t.content.remainingDates },
  { label: t.content.dog, value: dogAddon?.price === 0 ? t.content.free : dogAddon ? `${formatPrice(dogAddon.price)} / ${t.pricing.perNight}` : t.content.confirm },
  { label: t.content.electricity, value: electricityAddon ? `${formatPrice(electricityAddon.price)} / ${t.pricing.perNight}` : t.content.confirm },
];
const contactCards = [
  { label: t.content.contactCards.phone, value: '+48 795 294 486', href: 'tel:+48795294486' },
  { label: t.content.contactCards.email, value: 'clepardia@gmail.com', href: 'mailto:clepardia@gmail.com' },
  { label: t.content.contactCards.address, value: 'Henryka Pachońskiego 28A, 31-322 Kraków' },
  { label: t.content.contactCards.receptionHours, value: '9:00–20:00' },
];
const contactActionTextByLanguage = {
  pl: {
    kicker: 'Kontakt i rezerwacja',
    title: 'Potrzebujesz konkretnej odpowiedzi?',
    copy: 'Najprościej: zadzwoń, napisz maila albo przejdź do dedykowanego flow rezerwacji. Formularz pobytu przenieśliśmy na osobną podstronę, żeby /kontakt był szybki i czytelny.',
    booking: 'Zarezerwuj pobyt',
    call: 'Zadzwoń',
    maps: 'Google Maps',
    email: 'Email',
  },
  en: {
    kicker: 'Contact and booking',
    title: 'Need a clear next step?',
    copy: 'Call, email or open the dedicated booking flow. The stay enquiry form now lives on a separate page so contact stays fast and readable.',
    booking: 'Book your stay',
    call: 'Call',
    maps: 'Google Maps',
    email: 'Email',
  },
  de: {
    kicker: 'Kontakt und Buchung',
    title: 'Brauchen Sie den nächsten Schritt?',
    copy: 'Rufen Sie an, schreiben Sie eine E-Mail oder öffnen Sie den Buchungsflow. Die Aufenthaltsanfrage ist jetzt auf einer eigenen Seite.',
    booking: 'Aufenthalt buchen',
    call: 'Anrufen',
    maps: 'Google Maps',
    email: 'E-Mail',
  },
  it: {
    kicker: 'Contatto e prenotazione',
    title: 'Hai bisogno del passo successivo?',
    copy: 'Chiama, scrivi una email o apri il flow di prenotazione dedicato. La richiesta di soggiorno ora è in una pagina separata.',
    booking: 'Prenota soggiorno',
    call: 'Chiama',
    maps: 'Google Maps',
    email: 'Email',
  },
};
const contactActionText = contactActionTextByLanguage[resolvedContentLanguage];
const campingGuideExists = publicAssetExists(siteAssets.documents.campingGuidePdf);
const operationalTextByLanguage = {
  pl: {
    arrivalKicker: 'Przyjazd na camping',
    arrivalTitle: 'Po przyjeździe zatrzymaj się przy recepcji',
    arrivalCopy:
      'Po przyjeździe zatrzymaj się na parkingu w pobliżu recepcji. Personel recepcji podejdzie, wskaże miejsce i oprowadzi po campingu. Następnie odbywa się rejestracja.',
    mapsCopy:
      'Do nawigacji zalecamy używać Google Maps. Wjazd / trasa dojazdu zmieniła się w 2022 roku, dlatego starsze nawigacje mogą prowadzić nieprawidłowo.',
    practicalKicker: 'Praktyczne informacje na miejscu',
    practicalTitle: 'Najważniejsze rzeczy dla gości',
    guideReady: 'Pobierz Camping Guide PDF',
    guidePending: 'Camping Guide PDF — w przygotowaniu.',
    cards: [
      { icon: 'phone', title: 'Telefon do recepcji', copy: '+48 795 294 486' },
      { icon: 'warning', title: 'Lodówka', copy: 'Prosimy pilnować swoich rzeczy i podpisywać produkty.' },
      { icon: 'utensils', title: 'Kuchnia turystyczna', copy: 'Na miejscu dostępna jest podstawowa przestrzeń do przygotowania posiłku.' },
      { icon: 'shower', title: 'Toalety i sanitariaty', copy: 'Sanitariaty są dostępne dla gości campingu.' },
      { icon: 'laundry', title: 'Suszarnia', copy: 'Suszarnia pomaga wygodnie ogarnąć rzeczy po podróży lub praniu.' },
    ],
  },
  en: {
    arrivalKicker: 'Arrival at the campsite',
    arrivalTitle: 'After arrival, please stop near reception',
    arrivalCopy:
      'After arrival, please stop at the parking area near reception. Our reception staff will come to you, show you your place and guide you around the campsite. Registration is completed afterwards.',
    mapsCopy:
      'For navigation we recommend Google Maps. The entrance / access route changed in 2022, so older navigation systems may lead incorrectly.',
    practicalKicker: 'Practical information on site',
    practicalTitle: 'Useful things for guests',
    guideReady: 'Download Camping Guide PDF',
    guidePending: 'Camping Guide PDF — coming soon.',
    cards: [
      { icon: 'phone', title: 'Reception phone', copy: '+48 795 294 486' },
      { icon: 'warning', title: 'Fridge', copy: 'Please keep an eye on your belongings and label your food.' },
      { icon: 'utensils', title: 'Tourist kitchen', copy: 'Basic space for preparing a meal is available on site.' },
      { icon: 'shower', title: 'Toilets and sanitary facilities', copy: 'Sanitary facilities are available for campsite guests.' },
      { icon: 'laundry', title: 'Drying room', copy: 'The drying room is useful after travel, rain or laundry.' },
    ],
  },
  de: {
    arrivalKicker: 'Ankunft auf dem Campingplatz',
    arrivalTitle: 'Bitte halten Sie nach der Ankunft nahe der Rezeption',
    arrivalCopy:
      'Bitte halten Sie bei der Ankunft auf dem Parkplatz in der Nähe der Rezeption. Unser Rezeptionsteam kommt zu Ihnen, zeigt Ihnen den Platz und erklärt Ihnen den Campingplatz. Danach erfolgt die Anmeldung.',
    mapsCopy:
      'Für die Navigation empfehlen wir Google Maps. Die Einfahrt / Zufahrt wurde 2022 geändert, ältere Navigationssysteme können falsch führen.',
    practicalKicker: 'Praktische Informationen vor Ort',
    practicalTitle: 'Nützliche Hinweise für Gäste',
    guideReady: 'Camping Guide PDF herunterladen',
    guidePending: 'Camping Guide PDF — in Vorbereitung.',
    cards: [
      { icon: 'phone', title: 'Telefon der Rezeption', copy: '+48 795 294 486' },
      { icon: 'warning', title: 'Kühlschrank', copy: 'Bitte achten Sie auf Ihre Sachen und beschriften Sie Lebensmittel.' },
      { icon: 'utensils', title: 'Touristische Küche', copy: 'Vor Ort gibt es eine einfache Möglichkeit zur Essenszubereitung.' },
      { icon: 'shower', title: 'Toiletten und Sanitäranlagen', copy: 'Sanitäranlagen stehen den Campinggästen zur Verfügung.' },
      { icon: 'laundry', title: 'Trockenraum', copy: 'Der Trockenraum ist nach Reise, Regen oder Wäsche hilfreich.' },
    ],
  },
  it: {
    arrivalKicker: 'Arrivo al camping',
    arrivalTitle: 'All’arrivo fermati vicino alla reception',
    arrivalCopy:
      'All’arrivo, fermati nell’area di parcheggio vicino alla reception. Il personale della reception verrà da te, ti indicherà la piazzola e ti accompagnerà nel campeggio. La registrazione verrà completata dopo.',
    mapsCopy:
      'Per la navigazione consigliamo Google Maps. L’ingresso / percorso di accesso è cambiato nel 2022, quindi i navigatori più vecchi possono indicare una strada sbagliata.',
    practicalKicker: 'Informazioni pratiche sul posto',
    practicalTitle: 'Cose utili per gli ospiti',
    guideReady: 'Scarica Camping Guide PDF',
    guidePending: 'Camping Guide PDF — in preparazione.',
    cards: [
      { icon: 'phone', title: 'Telefono reception', copy: '+48 795 294 486' },
      { icon: 'warning', title: 'Frigorifero', copy: 'Ti chiediamo di controllare le tue cose e firmare i prodotti.' },
      { icon: 'utensils', title: 'Cucina turistica', copy: 'Sul posto è disponibile uno spazio base per preparare un pasto.' },
      { icon: 'shower', title: 'Bagni e servizi igienici', copy: 'I servizi igienici sono disponibili per gli ospiti del camping.' },
      { icon: 'laundry', title: 'Stenditoio', copy: 'Lo stenditoio è utile dopo il viaggio, la pioggia o il bucato.' },
    ],
  },
};
const operationalText = operationalTextByLanguage[resolvedContentLanguage];
---

<section class:list={['page-mini-hero', page.slug !== 'cennik' && 'reveal-section', page.slug === 'cennik' && 'page-mini-hero--pricing']}>
  <div class="container page-mini-hero__inner">
    <nav class="breadcrumbs" aria-label="Breadcrumb">
      <a href={homeHref}>{breadcrumbHome}</a>
      <span aria-hidden="true">/</span>
      <span>{displayTitle}</span>
    </nav>

    <span class="section-kicker">{displayOverline}</span>
    <h1>{displayTitle}</h1>
    <p>{displayLead}</p>
    {page.slug === 'cennik' && (
      <div class="pricing-hero-actions" aria-label="Szybkie akcje cennika">
        <div class="pricing-hero-actions__buttons">
          <a class="btn btn-primary premium-button" href="#oblicz-koszt">
            <Icon name="pricing" size={18} strokeWidth={2} />
            {pricingHeroText.primary}
          </a>
          <a class="btn btn-glass pricing-hero-actions__secondary" href={bookingHref}>
            <Icon name="booking" size={18} strokeWidth={2} />
            {pricingHeroText.secondary}
          </a>
        </div>
        <div class="pricing-hero-actions__notes">
          {pricingHeroText.notes.map((note) => (
            <span><Icon name="check" size={15} strokeWidth={2.2} /> {note}</span>
          ))}
        </div>
        <div class="pricing-hero-actions__stats" aria-label="Przykładowe ceny">
          {pricingHeroStats.map((item) => (
            <span>
              <Icon name={item.icon} size={20} strokeWidth={2.35} />
              <strong>{item.value}</strong>
              <small>{item.label}</small>
            </span>
          ))}
        </div>
      </div>
    )}
  </div>
</section>

{(page.slug === 'kontakt' || page.slug === 'dojazd') && <ArrivalFlowSection languageCode={contentLanguage} />}

{page.slug !== 'cennik' && page.slug !== 'kontakt' && page.slug !== 'dojazd' && page.slug !== 'atrakcje' && page.slug !== 'faq' && page.slug !== 'galeria' && page.slug !== 'dla-kamperow' && page.slug !== 'dla-rodzin' && page.slug !== 'regulamin' && page.slug !== 'polityka-prywatnosci' && (
<section class="site-section page-detail reveal-section">
  <div class="container page-detail__grid">
    <div class="page-detail__intro">
      <span class="section-kicker">{t.content.infoKicker}</span>
      <h2 class="section-title">{t.content.infoTitle}</h2>
      <p class="section-copy">{page.seoDescription}</p>
    </div>

    <div class="page-detail__cards">
      {page.highlights.map((item, index) => (
        <article class="premium-card reveal-section page-detail__card" style={`--reveal-delay: ${index * 80}ms`}>
          <span>{String(index + 1).padStart(2, '0')}</span>
          <h3>{item.title}</h3>
          <p>{item.copy}</p>
        </article>
      ))}
    </div>
  </div>
</section>
)}

{false && page.slug === 'cennik' && (
  <section class="pricing-quick-info reveal-section" aria-label={t.content.pricingQuickAria}>
    <div class="container pricing-quick-info__grid">
      {pricingInfoBarItems.map((item) => (
        <div class="pricing-quick-info__item">
          <span>{item.label}</span>
          <strong>{item.value}</strong>
        </div>
      ))}
    </div>
  </section>
)}

{page.slug === 'kontakt' && (
  <section class="site-section contact-cards reveal-section" aria-label={t.content.contactAria}>
    <div class="container contact-cards__grid">
      {contactCards.map((item, index) => (
        index === 2 ? (
          <a
            class="premium-card reveal-section contact-cards__card contact-cards__card--link"
            href={googleMapsHref}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Otwórz Camping Clepardia w Google Maps"
            style={`--reveal-delay: ${index * 80}ms`}
          >
            <span>{item.label}</span>
            <strong>{item.value}</strong>
            <small><Icon name="map" size={16} /> Google Maps <Icon name="ArrowUpRight" size={14} /></small>
          </a>
        ) : (
          <article class="premium-card reveal-section contact-cards__card" style={`--reveal-delay: ${index * 80}ms`}>
            <span>{item.label}</span>
            {item.href ? (
              <a href={item.href}>{item.value}</a>
            ) : (
              <strong>{item.value}</strong>
            )}
          </article>
        )
      ))}
    </div>
  </section>
)}

{page.slug === 'kontakt' && (
  <section class="site-section contact-action-hub reveal-section">
    <div class="container">
      <div class="contact-action-hub__panel premium-card">
        <div>
          <span class="section-kicker">{contactActionText.kicker}</span>
          <h2>{contactActionText.title}</h2>
          <p>{contactActionText.copy}</p>
        </div>
        <div class="contact-action-hub__actions">
          <a class="contact-action-hub__button contact-action-hub__button--primary" href={bookingHref}>
            <Icon name="CalendarCheck" size={19} />
            {contactActionText.booking}
          </a>
          <a class="contact-action-hub__button" href="tel:+48795294486">
            <Icon name="phone" size={18} />
            {contactActionText.call}
          </a>
          <a class="contact-action-hub__button" href={googleMapsHref} target="_blank" rel="noopener noreferrer">
            <Icon name="map" size={18} />
            {contactActionText.maps}
          </a>
          <a class="contact-action-hub__button" href="mailto:clepardia@gmail.com">
            <Icon name="mail" size={18} />
            {contactActionText.email}
          </a>
        </div>
      </div>
    </div>
  </section>
)}

{page.slug === 'kontakt' && (
  <section class="site-section operational-info reveal-section">
    <div class="container operational-info__grid">
      <article class="premium-card operational-info__arrival">
        <span class="section-kicker">{operationalText.arrivalKicker}</span>
        <h2>{operationalText.arrivalTitle}</h2>
        <p>{operationalText.arrivalCopy}</p>
        <p class="operational-info__maps-note">{operationalText.mapsCopy}</p>
        {campingGuideExists ? (
          <a class="btn btn-glass operational-info__guide" href={siteAssets.documents.campingGuidePdf} target="_blank" rel="noopener noreferrer">
            {operationalText.guideReady}
          </a>
        ) : (
          <small>{operationalText.guidePending}</small>
        )}
      </article>

      <div class="operational-info__practical">
        <div class="operational-info__head">
          <span class="section-kicker">{operationalText.practicalKicker}</span>
          <h2 class="section-title">{operationalText.practicalTitle}</h2>
        </div>
        <div class="operational-info__cards">
          {operationalText.cards.map((item, index) => (
            <article class="premium-card reveal-section operational-info__card" style={`--reveal-delay: ${index * 70}ms`}>
              <span aria-hidden="true"><Icon name={item.icon} size={22} strokeWidth={1.8} /></span>
              <h3>{item.title}</h3>
              <p>{item.copy}</p>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>
)}

{page.slug === 'domki' && (
  <section class="site-section bungalow-types reveal-section">
    <div class="container">
      <div class="bungalow-types__head">
        <span class="section-kicker">{t.content.bungalowKicker}</span>
        <h2 class="section-title">{t.content.bungalowTitle}</h2>
        <p class="section-copy">
          {t.content.bungalowCopy}
        </p>
      </div>

      <div class="bungalow-types__grid">
        {bungalowCards.map((bungalow, index) => (
          <article class="premium-card reveal-section bungalow-types__card" style={`--reveal-delay: ${index * 90}ms`}>
            <span>{String(index + 1).padStart(2, '0')}</span>
            <h3>{bungalow.title}</h3>
            {bungalow.lowSeasonPrice && bungalow.highSeasonPrice ? (
              <div class="bungalow-types__prices">
                <p><strong>{t.content.lowSeasonLabel}</strong>{bungalow.lowSeasonPrice} / {t.pricing.perNight}</p>
                <p><strong>{t.content.highSeasonLabel}</strong>{bungalow.highSeasonPrice} / {t.pricing.perNight}</p>
              </div>
            ) : null}
          </article>
        ))}
      </div>

      <p class="bungalow-types__season-note">
        {t.content.seasonNote.replace('{range}', highSeasonRange)}
      </p>
    </div>
  </section>
)}

{page.slug === 'cennik' && <PremiumPricingApp languageCode={contentLanguage} />}

