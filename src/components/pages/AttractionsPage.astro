---
import ImageFrame from '@/components/ImageFrame.astro';
import { siteAssets } from '@/data/assets';
import { getLocalizedPath } from '@/utils/localizedLinks';
import { getTranslations, resolveContentLanguage } from '@/i18n/config';

interface Props {
  languageCode?: string;
}

const { languageCode } = Astro.props as Props;
const contentLanguage = resolveContentLanguage(languageCode);
const t = getTranslations(languageCode);
const page = t.pages.atrakcje;
const pricingHref = getLocalizedPath(languageCode, 'cennik');
const contactHref = getLocalizedPath(languageCode, 'kontakt');
const transportHref = getLocalizedPath(languageCode, 'dojazd');

const attractionsTextByLanguage = {
  pl: {
    localKicker: 'Kraków blisko campingu',
    localTitle: 'Kraków bez stresu z parkowaniem',
    localCopy:
      'Z Camping Clepardia możesz zostawić auto, kampera lub przyczepę na miejscu i dojechać do centrum tramwajem. To wygodne rozwiązanie dla gości, którzy chcą zwiedzać miasto bez szukania parkingu przy Starym Mieście.',
    localAria: 'Miejsca w Krakowie blisko Camping Clepardia',
    routeCamping: 'Camping Clepardia',
    routeTram: 'Tramwaj',
    routeCenter: 'Centrum Krakowa',
    listKicker: 'Najpopularniejsze atrakcje',
    listTitle: 'Kraków, Małopolska i rodzinne wyjazdy',
    listCopy: 'Wybierz klasyczne zwiedzanie miasta, jednodniową trasę poza Kraków albo spokojniejszy dzień wśród zieleni.',
    itineraryKicker: 'Pomysł na pobyt',
    itineraryTitle: 'Zaplanuj zwiedzanie bez przepakowywania auta',
    itineraryCopy:
      'Camping Clepardia może być jedną bazą na krótki city break, rodzinny weekend albo dłuższy pobyt z wycieczkami po regionie.',
    ctaKicker: 'Baza wypadowa w Krakowie',
    cards: ['Stare Miasto', 'Rynek Główny', 'Kazimierz', 'Wawel', 'Planty'],
    attractions: [
      { title: 'Stare Miasto w Krakowie', copy: 'Spacer po Rynku Głównym, Sukiennicach, ulicy Floriańskiej i okolicach Plant.', label: 'Stare Miasto' },
      { title: 'Kazimierz', copy: 'Historyczna dzielnica z klimatycznymi uliczkami, restauracjami i kawiarniami.', label: 'Kazimierz' },
      { title: 'Wawel', copy: 'Jedno z najważniejszych miejsc w Krakowie, dobre na spacer i klasyczne zwiedzanie.', label: 'Wawel' },
      { title: 'Kopalnia Soli Wieliczka', copy: 'Jedna z najpopularniejszych atrakcji w okolicy Krakowa.', label: 'Wieliczka' },
      { title: 'Fabryka Schindlera', copy: 'Miejsce dla osób zainteresowanych historią Krakowa i II wojną światową.', label: 'Fabryka Schindlera' },
      { title: 'Auschwitz-Birkenau', copy: 'Ważne miejsce pamięci, często odwiedzane podczas pobytu w Małopolsce.', label: 'Auschwitz-Birkenau' },
      { title: 'Energylandia', copy: 'Duży park rozrywki, popularny szczególnie wśród rodzin z dziećmi.', label: 'Energylandia' },
      { title: 'Ojców i Ojcowski Park Narodowy', copy: 'Dobry pomysł na spokojniejszy wyjazd poza miasto, z naturą i zamkami.', label: 'Ojców' },
      { title: 'Zakopane', copy: 'Popularny kierunek jednodniowej wycieczki w Tatry.', label: 'Zakopane' },
    ],
    plans: [
      { title: '1 dzień', items: ['Stare Miasto', 'Wawel', 'Kazimierz'] },
      { title: '2-3 dni', items: ['Kraków', 'Wieliczka', 'Fabryka Schindlera'] },
      { title: 'Dłuższy pobyt', items: ['Kraków', 'Wieliczka', 'Ojców', 'Energylandia', 'Zakopane'] },
    ],
  },
  en: {
    localKicker: 'Krakow close to the campsite',
    localTitle: 'Krakow without parking stress',
    localCopy:
      'From Camping Clepardia you can leave your car, camper or caravan on site and reach the centre by tram. It is a convenient solution for guests who want to explore the city without searching for parking near the Old Town.',
    localAria: 'Places in Krakow close to Camping Clepardia',
    routeCamping: 'Camping Clepardia',
    routeTram: 'Tram',
    routeCenter: 'Krakow centre',
    listKicker: 'Most popular attractions',
    listTitle: 'Krakow, Małopolska and family trips',
    listCopy: 'Choose classic city sightseeing, a one-day route outside Krakow or a calmer day surrounded by greenery.',
    itineraryKicker: 'Stay idea',
    itineraryTitle: 'Plan sightseeing without repacking the car',
    itineraryCopy:
      'Camping Clepardia can be one base for a short city break, family weekend or a longer stay with trips around the region.',
    ctaKicker: 'A trip base in Krakow',
    cards: ['Old Town', 'Main Square', 'Kazimierz', 'Wawel', 'Planty'],
    attractions: [
      { title: 'Krakow Old Town', copy: 'A walk around the Main Square, Cloth Hall, Floriańska Street and Planty.', label: 'Old Town' },
      { title: 'Kazimierz', copy: 'A historic district with atmospheric streets, restaurants and cafes.', label: 'Kazimierz' },
      { title: 'Wawel', copy: 'One of the most important places in Krakow, good for a walk and classic sightseeing.', label: 'Wawel' },
      { title: 'Wieliczka Salt Mine', copy: 'One of the most popular attractions near Krakow.', label: 'Wieliczka' },
      { title: 'Schindler’s Factory', copy: 'A place for visitors interested in Krakow history and World War II.', label: 'Schindler’s Factory' },
      { title: 'Auschwitz-Birkenau', copy: 'An important memorial site often visited during stays in Małopolska.', label: 'Auschwitz-Birkenau' },
      { title: 'Energylandia', copy: 'A large amusement park, especially popular with families with children.', label: 'Energylandia' },
      { title: 'Ojców National Park', copy: 'A good idea for a calmer trip outside the city with nature and castles.', label: 'Ojców' },
      { title: 'Zakopane', copy: 'A popular direction for a one-day trip to the Tatra Mountains.', label: 'Zakopane' },
    ],
    plans: [
      { title: '1 day', items: ['Old Town', 'Wawel', 'Kazimierz'] },
      { title: '2-3 days', items: ['Krakow', 'Wieliczka', 'Schindler’s Factory'] },
      { title: 'Longer stay', items: ['Krakow', 'Wieliczka', 'Ojców', 'Energylandia', 'Zakopane'] },
    ],
  },
  de: {
    localKicker: 'Krakau nahe dem Campingplatz',
    localTitle: 'Krakau ohne Parkplatzstress',
    localCopy:
      'Vom Camping Clepardia aus können Sie Auto, Camper oder Wohnwagen vor Ort lassen und mit der Straßenbahn ins Zentrum fahren. Das ist bequem für Gäste, die die Stadt ohne Parkplatzsuche bei der Altstadt entdecken möchten.',
    localAria: 'Orte in Krakau nahe Camping Clepardia',
    routeCamping: 'Camping Clepardia',
    routeTram: 'Straßenbahn',
    routeCenter: 'Zentrum von Krakau',
    listKicker: 'Beliebteste Attraktionen',
    listTitle: 'Krakau, Małopolska und Familienausflüge',
    listCopy: 'Wählen Sie klassische Stadtbesichtigung, eine Tagestour außerhalb Krakaus oder einen ruhigeren Tag im Grünen.',
    itineraryKicker: 'Idee für den Aufenthalt',
    itineraryTitle: 'Sightseeing planen, ohne das Auto umzupacken',
    itineraryCopy:
      'Camping Clepardia kann eine Basis für City Break, Familienwochenende oder längeren Aufenthalt mit Ausflügen in der Region sein.',
    ctaKicker: 'Ausflugsbasis in Krakau',
    cards: ['Altstadt', 'Hauptmarkt', 'Kazimierz', 'Wawel', 'Planty'],
    attractions: [
      { title: 'Krakauer Altstadt', copy: 'Spaziergang über den Hauptmarkt, die Tuchhallen, die Floriańska-Straße und Planty.', label: 'Altstadt' },
      { title: 'Kazimierz', copy: 'Historisches Viertel mit stimmungsvollen Straßen, Restaurants und Cafés.', label: 'Kazimierz' },
      { title: 'Wawel', copy: 'Einer der wichtigsten Orte Krakaus, gut für Spaziergang und klassische Besichtigung.', label: 'Wawel' },
      { title: 'Salzbergwerk Wieliczka', copy: 'Eine der beliebtesten Attraktionen in der Umgebung von Krakau.', label: 'Wieliczka' },
      { title: 'Schindlers Fabrik', copy: 'Ein Ort für Gäste, die sich für Krakauer Geschichte und den Zweiten Weltkrieg interessieren.', label: 'Schindlers Fabrik' },
      { title: 'Auschwitz-Birkenau', copy: 'Wichtige Gedenkstätte, oft während eines Aufenthalts in Małopolska besucht.', label: 'Auschwitz-Birkenau' },
      { title: 'Energylandia', copy: 'Großer Freizeitpark, besonders beliebt bei Familien mit Kindern.', label: 'Energylandia' },
      { title: 'Ojców-Nationalpark', copy: 'Gute Idee für einen ruhigeren Ausflug außerhalb der Stadt mit Natur und Burgen.', label: 'Ojców' },
      { title: 'Zakopane', copy: 'Beliebtes Ziel für einen Tagesausflug in die Tatra.', label: 'Zakopane' },
    ],
    plans: [
      { title: '1 Tag', items: ['Altstadt', 'Wawel', 'Kazimierz'] },
      { title: '2-3 Tage', items: ['Krakau', 'Wieliczka', 'Schindlers Fabrik'] },
      { title: 'Längerer Aufenthalt', items: ['Krakau', 'Wieliczka', 'Ojców', 'Energylandia', 'Zakopane'] },
    ],
  },
  it: {
    localKicker: 'Cracovia vicino al camping',
    localTitle: 'Cracovia senza stress da parcheggio',
    localCopy:
      'Da Camping Clepardia puoi lasciare auto, camper o roulotte sul posto e raggiungere il centro in tram. È una soluzione comoda per visitare la città senza cercare parcheggio vicino alla Città Vecchia.',
    localAria: 'Luoghi di Cracovia vicino a Camping Clepardia',
    routeCamping: 'Camping Clepardia',
    routeTram: 'Tram',
    routeCenter: 'Centro di Cracovia',
    listKicker: 'Attrazioni più popolari',
    listTitle: 'Cracovia, Małopolska e gite in famiglia',
    listCopy: 'Scegli una visita classica della città, un itinerario di un giorno fuori Cracovia o una giornata più tranquilla nel verde.',
    itineraryKicker: 'Idea di soggiorno',
    itineraryTitle: 'Pianifica le visite senza risistemare l’auto',
    itineraryCopy:
      'Camping Clepardia può essere un’unica base per un city break, un weekend in famiglia o un soggiorno più lungo con gite nella regione.',
    ctaKicker: 'Base per escursioni a Cracovia',
    cards: ['Città Vecchia', 'Piazza del Mercato', 'Kazimierz', 'Wawel', 'Planty'],
    attractions: [
      { title: 'Città Vecchia di Cracovia', copy: 'Passeggiata tra Rynek, Sukiennice, via Floriańska e Planty.', label: 'Città Vecchia' },
      { title: 'Kazimierz', copy: 'Quartiere storico con strade suggestive, ristoranti e caffè.', label: 'Kazimierz' },
      { title: 'Wawel', copy: 'Uno dei luoghi più importanti di Cracovia, adatto a una passeggiata e visita classica.', label: 'Wawel' },
      { title: 'Miniera di Sale Wieliczka', copy: 'Una delle attrazioni più popolari vicino a Cracovia.', label: 'Wieliczka' },
      { title: 'Fabbrica di Schindler', copy: 'Luogo per chi è interessato alla storia di Cracovia e alla Seconda guerra mondiale.', label: 'Fabbrica di Schindler' },
      { title: 'Auschwitz-Birkenau', copy: 'Importante luogo della memoria, spesso visitato durante un soggiorno in Małopolska.', label: 'Auschwitz-Birkenau' },
      { title: 'Energylandia', copy: 'Grande parco divertimenti, molto popolare tra le famiglie con bambini.', label: 'Energylandia' },
      { title: 'Parco Nazionale di Ojców', copy: 'Buona idea per una gita più tranquilla fuori città, tra natura e castelli.', label: 'Ojców' },
      { title: 'Zakopane', copy: 'Meta popolare per una gita di un giorno verso i Tatra.', label: 'Zakopane' },
    ],
    plans: [
      { title: '1 giorno', items: ['Città Vecchia', 'Wawel', 'Kazimierz'] },
      { title: '2-3 giorni', items: ['Cracovia', 'Wieliczka', 'Fabbrica di Schindler'] },
      { title: 'Soggiorno più lungo', items: ['Cracovia', 'Wieliczka', 'Ojców', 'Energylandia', 'Zakopane'] },
    ],
  },
};

const attractionsText = attractionsTextByLanguage[contentLanguage];

const krakowCards = attractionsText.cards;

const attractions = [
  {
    title: attractionsText.attractions[0].title,
    copy: attractionsText.attractions[0].copy,
    image: siteAssets.attractions.oldTown,
    label: attractionsText.attractions[0].label,
  },
  {
    title: attractionsText.attractions[1].title,
    copy: attractionsText.attractions[1].copy,
    image: '/images/attractions/krakow-kazimierz.webp',
    label: attractionsText.attractions[1].label,
  },
  {
    title: attractionsText.attractions[2].title,
    copy: attractionsText.attractions[2].copy,
    image: '/images/attractions/wawel-castle.webp',
    label: attractionsText.attractions[2].label,
  },
  {
    title: attractionsText.attractions[3].title,
    copy: attractionsText.attractions[3].copy,
    image: siteAssets.attractions.wieliczka,
    label: attractionsText.attractions[3].label,
  },
  {
    title: attractionsText.attractions[4].title,
    copy: attractionsText.attractions[4].copy,
    image: siteAssets.attractions.schindler,
    label: attractionsText.attractions[4].label,
  },
  {
    title: attractionsText.attractions[5].title,
    copy: attractionsText.attractions[5].copy,
    image: siteAssets.attractions.auschwitz,
    label: attractionsText.attractions[5].label,
  },
  {
    title: attractionsText.attractions[6].title,
    copy: attractionsText.attractions[6].copy,
    image: siteAssets.attractions.energylandia,
    label: attractionsText.attractions[6].label,
  },
  {
    title: attractionsText.attractions[7].title,
    copy: attractionsText.attractions[7].copy,
    image: '/images/attractions/ojcow-national-park.webp',
    label: attractionsText.attractions[7].label,
  },
  {
    title: attractionsText.attractions[8].title,
    copy: attractionsText.attractions[8].copy,
    image: siteAssets.attractions.zakopane,
    label: attractionsText.attractions[8].label,
  },
];

const stayPlans = attractionsText.plans;
---

<section class="site-section attractions-local reveal-section">
  <div class="container attractions-local__grid">
    <div class="attractions-local__content">
      <span class="section-kicker">{attractionsText.localKicker}</span>
      <h2 class="section-title">{attractionsText.localTitle}</h2>
      <p class="section-copy">
        {attractionsText.localCopy}
      </p>

      <div class="attractions-local__cards" aria-label={attractionsText.localAria}>
        {krakowCards.map((item, index) => (
          <article class="premium-card reveal-section attractions-local__card" style={`--reveal-delay: ${index * 70}ms`}>
            <span>{String(index + 1).padStart(2, '0')}</span>
            <strong>{item}</strong>
          </article>
        ))}
      </div>
    </div>

    <div class="attractions-local__media">
      <ImageFrame
        src={siteAssets.attractions.oldTown}
        alt={attractionsText.localTitle}
        label={attractionsText.localKicker}
        className="attractions-local__image"
      />
      <div class="premium-card attractions-local__route">
        <span>{attractionsText.routeCamping}</span><i></i><span>{attractionsText.routeTram}</span><i></i><span>{attractionsText.routeCenter}</span>
      </div>
    </div>
  </div>
</section>

<section class="site-section attractions-list reveal-section">
  <div class="container">
    <div class="attractions-list__head">
      <span class="section-kicker">{attractionsText.listKicker}</span>
      <h2 class="section-title">{attractionsText.listTitle}</h2>
      <p class="section-copy">
        {attractionsText.listCopy}
      </p>
    </div>

    <div class="attractions-list__grid">
      {attractions.map((item, index) => (
        <article class="premium-card reveal-section attractions-list__card" style={`--reveal-delay: ${index * 65}ms`}>
          <ImageFrame
            src={item.image}
            alt={item.title}
            label={item.label}
            className="attractions-list__image"
          />
          <div class="attractions-list__body">
            <span>{String(index + 1).padStart(2, '0')}</span>
            <h3>{item.title}</h3>
            <p>{item.copy}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<section class="site-section attractions-itinerary reveal-section">
  <div class="container attractions-itinerary__grid">
    <div class="attractions-itinerary__intro">
      <span class="section-kicker">{attractionsText.itineraryKicker}</span>
      <h2 class="section-title">{attractionsText.itineraryTitle}</h2>
      <p class="section-copy">
        {attractionsText.itineraryCopy}
      </p>
    </div>

    <div class="attractions-itinerary__cards">
      {stayPlans.map((plan, index) => (
        <article class="premium-card reveal-section attractions-itinerary__card" style={`--reveal-delay: ${index * 90}ms`}>
          <span>{plan.title}</span>
          <ul>
            {plan.items.map((item) => <li>{item}</li>)}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>

<section class="site-section attractions-final-cta reveal-section">
  <div class="container">
    <div class="premium-card attractions-final-cta__panel">
      <div>
        <span class="section-kicker">{attractionsText.ctaKicker}</span>
        <h2>{page.cta.title}</h2>
        <p>
          {page.cta.copy}
        </p>
      </div>
      <div class="attractions-final-cta__actions">
        <a class="btn btn-primary premium-button" href={pricingHref}>{page.cta.primaryLabel}</a>
        <a class="btn btn-glass attractions-final-cta__secondary" href={contactHref}>{t.cta.availability}</a>
        <a class="btn btn-glass attractions-final-cta__secondary" href={transportHref}>{t.cta.directions}</a>
      </div>
    </div>
  </div>
</section>

<style>
.attractions-local {
  padding: clamp(44px, 7vw, 86px) 0;
  background:
    radial-gradient(circle at 88% 12%, rgba(60,179,113,.16), transparent 30%),
    linear-gradient(180deg, #fbfbf7, #f2f7f0);
}

.attractions-local__grid,
.attractions-itinerary__grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: clamp(28px, 5vw, 64px);
  align-items: center;
}

.attractions-local__cards {
  display: grid;
  grid-template-columns: 1fr;
  gap: 14px;
  margin-top: clamp(28px, 4vw, 42px);
}

.attractions-local__card {
  display: grid;
  grid-template-columns: 48px 1fr;
  gap: 14px;
  align-items: center;
  min-height: 86px;
  padding: 16px;
  border-radius: 22px;
  transition: transform .24s ease, box-shadow .24s ease, border-color .24s ease;
}

.attractions-local__card:hover,
.attractions-list__card:hover,
.attractions-itinerary__card:hover {
  transform: translateY(-4px);
  border-color: rgba(60,179,113,.34);
  box-shadow: 0 24px 64px rgba(17,40,28,.14);
}

.attractions-local__card span {
  width: 42px;
  height: 42px;
  display: grid;
  place-items: center;
  border-radius: 999px;
  color: #07120d;
  background: rgba(60,179,113,.18);
  border: 1px solid rgba(60,179,113,.22);
  font-size: .76rem;
  font-weight: 950;
}

.attractions-local__card strong {
  color: #102018;
  font-size: clamp(1.02rem, 2vw, 1.22rem);
  line-height: 1.25;
  font-weight: 950;
}

.attractions-local__media {
  display: grid;
  gap: 14px;
}

.attractions-local__route {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  align-items: center;
  justify-content: center;
  padding: 20px;
  border-radius: 24px;
  color: #fff;
  background:
    linear-gradient(135deg, rgba(10,28,18,.90), rgba(17,39,27,.78)),
    radial-gradient(circle at 86% 18%, rgba(239,174,99,.18), transparent 36%);
  border-color: rgba(255,255,255,.14);
}

.attractions-local__route span {
  padding: 12px 15px;
  border-radius: 999px;
  background: rgba(255,255,255,.10);
  border: 1px solid rgba(255,255,255,.13);
  font-weight: 900;
}

.attractions-local__route i {
  width: 28px;
  height: 2px;
  background: rgba(143,224,180,.72);
}

.attractions-list {
  background:
    radial-gradient(circle at 12% 18%, rgba(60,179,113,.13), transparent 32%),
    linear-gradient(180deg, #f2f7f0, #f8fbf5);
}

.attractions-list__head {
  max-width: 880px;
  margin-bottom: clamp(30px, 5vw, 54px);
}

.attractions-list__grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 18px;
}

.attractions-list__card {
  overflow: hidden;
  border-radius: 28px;
  transition: transform .24s ease, box-shadow .24s ease, border-color .24s ease;
}

:global(.attractions-list__image.photo-frame) {
  border-radius: 28px 28px 0 0;
  border: 0;
  box-shadow: none;
}

.attractions-list__body {
  padding: clamp(22px, 3vw, 30px);
}

.attractions-list__body span {
  display: inline-flex;
  margin-bottom: 22px;
  color: #3CB371;
  font-size: .74rem;
  font-weight: 950;
  letter-spacing: .14em;
}

.attractions-list__body h3 {
  margin: 0 0 12px;
  color: #102018;
  font-size: clamp(1.16rem, 2vw, 1.42rem);
  line-height: 1.18;
  font-weight: 950;
}

.attractions-list__body p {
  margin: 0;
  color: #536359;
  line-height: 1.7;
}

.attractions-itinerary {
  background:
    radial-gradient(circle at 16% 18%, rgba(60,179,113,.18), transparent 34%),
    linear-gradient(180deg, #f8fbf5, #101b14);
}

.attractions-itinerary .section-title,
.attractions-itinerary .section-copy {
  color: #fff;
}

.attractions-itinerary .section-copy {
  color: rgba(255,255,255,.76);
}

.attractions-itinerary .section-kicker {
  color: #8fe0b4;
}

.attractions-itinerary__cards {
  display: grid;
  grid-template-columns: 1fr;
  gap: 16px;
}

.attractions-itinerary__card {
  padding: clamp(24px, 3vw, 34px);
  border-radius: 24px;
  color: #fff;
  background: rgba(255,255,255,.09);
  border-color: rgba(255,255,255,.13);
  transition: transform .24s ease, box-shadow .24s ease, border-color .24s ease;
}

.attractions-itinerary__card span {
  display: inline-flex;
  margin-bottom: 24px;
  color: #8fe0b4;
  font-size: .86rem;
  font-weight: 950;
  letter-spacing: .12em;
  text-transform: uppercase;
}

.attractions-itinerary__card ul {
  display: grid;
  gap: 12px;
  margin: 0;
  padding: 0;
  list-style: none;
}

.attractions-itinerary__card li {
  position: relative;
  padding-left: 26px;
  color: rgba(255,255,255,.84);
  font-weight: 850;
  line-height: 1.55;
}

.attractions-itinerary__card li::before {
  content: '';
  position: absolute;
  left: 0;
