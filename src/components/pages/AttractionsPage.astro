---
import ImageFrame from '@/components/ImageFrame.astro';
import { siteAssets } from '@/data/assets';
import { getLocalizedPath } from '@/utils/localizedLinks';

interface Props {
  languageCode?: string;
}

const { languageCode } = Astro.props as Props;
const pricingHref = getLocalizedPath(languageCode, 'cennik');
const contactHref = getLocalizedPath(languageCode, 'kontakt');
const transportHref = getLocalizedPath(languageCode, 'dojazd');

const krakowCards = [
  'Stare Miasto',
  'Rynek Główny',
  'Kazimierz',
  'Wawel',
  'Planty',
];

const attractions = [
  {
    title: 'Stare Miasto w Krakowie',
    copy: 'Spacer po Rynku Głównym, Sukiennicach, ulicy Floriańskiej i okolicach Plant.',
    image: siteAssets.attractions.oldTown,
    label: 'Stare Miasto',
  },
  {
    title: 'Kazimierz',
    copy: 'Historyczna dzielnica z klimatycznymi uliczkami, restauracjami i kawiarniami.',
    image: '/images/attractions/krakow-kazimierz.webp',
    label: 'Kazimierz',
  },
  {
    title: 'Wawel',
    copy: 'Jedno z najważniejszych miejsc w Krakowie, dobre na spacer i klasyczne zwiedzanie.',
    image: '/images/attractions/wawel-castle.webp',
    label: 'Wawel',
  },
  {
    title: 'Kopalnia Soli Wieliczka',
    copy: 'Jedna z najpopularniejszych atrakcji w okolicy Krakowa.',
    image: siteAssets.attractions.wieliczka,
    label: 'Wieliczka',
  },
  {
    title: 'Fabryka Schindlera',
    copy: 'Miejsce dla osób zainteresowanych historią Krakowa i II wojną światową.',
    image: siteAssets.attractions.schindler,
    label: 'Fabryka Schindlera',
  },
  {
    title: 'Auschwitz-Birkenau',
    copy: 'Ważne miejsce pamięci, często odwiedzane podczas pobytu w Małopolsce.',
    image: siteAssets.attractions.auschwitz,
    label: 'Auschwitz-Birkenau',
  },
  {
    title: 'Energylandia',
    copy: 'Duży park rozrywki, popularny szczególnie wśród rodzin z dziećmi.',
    image: siteAssets.attractions.energylandia,
    label: 'Energylandia',
  },
  {
    title: 'Ojców i Ojcowski Park Narodowy',
    copy: 'Dobry pomysł na spokojniejszy wyjazd poza miasto, z naturą i zamkami.',
    image: '/images/attractions/ojcow-national-park.webp',
    label: 'Ojców',
  },
  {
    title: 'Zakopane',
    copy: 'Popularny kierunek jednodniowej wycieczki w Tatry.',
    image: siteAssets.attractions.zakopane,
    label: 'Zakopane',
  },
];

const stayPlans = [
  {
    title: '1 dzień',
    items: ['Stare Miasto', 'Wawel', 'Kazimierz'],
  },
  {
    title: '2-3 dni',
    items: ['Kraków', 'Wieliczka', 'Fabryka Schindlera'],
  },
  {
    title: 'Dłuższy pobyt',
    items: ['Kraków', 'Wieliczka', 'Ojców', 'Energylandia', 'Zakopane'],
  },
];
---

<section class="site-section attractions-local reveal-section">
  <div class="container attractions-local__grid">
    <div class="attractions-local__content">
      <span class="section-kicker">Kraków blisko campingu</span>
      <h2 class="section-title">Kraków bez stresu z parkowaniem</h2>
      <p class="section-copy">
        Z Camping Clepardia możesz zostawić auto, kampera lub przyczepę na miejscu i dojechać do centrum tramwajem.
        To wygodne rozwiązanie dla gości, którzy chcą zwiedzać miasto bez szukania parkingu przy Starym Mieście.
      </p>

      <div class="attractions-local__cards" aria-label="Miejsca w Krakowie blisko Camping Clepardia">
        {krakowCards.map((item, index) => (
          <article class="premium-card reveal-section attractions-local__card" style={`--reveal-delay: ${index * 70}ms`}>
            <span>{String(index + 1).padStart(2, '0')}</span>
            <strong>{item}</strong>
          </article>
        ))}
      </div>
    </div>

    <div class="attractions-local__media">
      <ImageFrame
        src={siteAssets.attractions.oldTown}
        alt="Stare Miasto w Krakowie blisko Camping Clepardia"
        label="Kraków blisko campingu"
        className="attractions-local__image"
      />
      <div class="premium-card attractions-local__route">
        <span>Camping Clepardia</span><i></i><span>Tramwaj</span><i></i><span>Centrum Krakowa</span>
      </div>
    </div>
  </div>
</section>

<section class="site-section attractions-list reveal-section">
  <div class="container">
    <div class="attractions-list__head">
      <span class="section-kicker">Najpopularniejsze atrakcje</span>
      <h2 class="section-title">Kraków, Małopolska i rodzinne wyjazdy</h2>
      <p class="section-copy">
        Wybierz klasyczne zwiedzanie miasta, jednodniową trasę poza Kraków albo spokojniejszy dzień wśród zieleni.
      </p>
    </div>

    <div class="attractions-list__grid">
      {attractions.map((item, index) => (
        <article class="premium-card reveal-section attractions-list__card" style={`--reveal-delay: ${index * 65}ms`}>
          <ImageFrame
            src={item.image}
            alt={item.title}
            label={item.label}
            className="attractions-list__image"
          />
          <div class="attractions-list__body">
            <span>{String(index + 1).padStart(2, '0')}</span>
            <h3>{item.title}</h3>
            <p>{item.copy}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<section class="site-section attractions-itinerary reveal-section">
  <div class="container attractions-itinerary__grid">
    <div class="attractions-itinerary__intro">
      <span class="section-kicker">Pomysł na pobyt</span>
      <h2 class="section-title">Zaplanuj zwiedzanie bez przepakowywania auta</h2>
      <p class="section-copy">
        Camping Clepardia może być jedną bazą na krótki city break, rodzinny weekend albo dłuższy pobyt z wycieczkami po regionie.
      </p>
    </div>

    <div class="attractions-itinerary__cards">
      {stayPlans.map((plan, index) => (
        <article class="premium-card reveal-section attractions-itinerary__card" style={`--reveal-delay: ${index * 90}ms`}>
          <span>{plan.title}</span>
          <ul>
            {plan.items.map((item) => <li>{item}</li>)}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>

<section class="site-section attractions-final-cta reveal-section">
  <div class="container">
    <div class="premium-card attractions-final-cta__panel">
      <div>
        <span class="section-kicker">Baza wypadowa w Krakowie</span>
        <h2>Zaplanuj pobyt w Krakowie z Camping Clepardia</h2>
        <p>
          Połącz spokojniejszy nocleg na campingu z wygodnym dojazdem do centrum i jednodniowymi trasami po Małopolsce.
        </p>
      </div>
      <div class="attractions-final-cta__actions">
        <a class="premium-button" href={pricingHref}>Sprawdź cennik</a>
        <a class="attractions-final-cta__secondary" href={contactHref}>Zapytaj o dostępność</a>
        <a class="attractions-final-cta__secondary" href={transportHref}>Jak dojechać</a>
      </div>
    </div>
  </div>
</section>

<style>
.attractions-local {
  padding: clamp(44px, 7vw, 86px) 0;
  background:
    radial-gradient(circle at 88% 12%, rgba(60,179,113,.16), transparent 30%),
    linear-gradient(180deg, #fbfbf7, #f2f7f0);
}

.attractions-local__grid,
.attractions-itinerary__grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: clamp(28px, 5vw, 64px);
  align-items: center;
}

.attractions-local__cards {
  display: grid;
  grid-template-columns: 1fr;
  gap: 14px;
  margin-top: clamp(28px, 4vw, 42px);
}

.attractions-local__card {
  display: grid;
  grid-template-columns: 48px 1fr;
  gap: 14px;
  align-items: center;
  min-height: 86px;
  padding: 16px;
  border-radius: 22px;
  transition: transform .24s ease, box-shadow .24s ease, border-color .24s ease;
}

.attractions-local__card:hover,
.attractions-list__card:hover,
.attractions-itinerary__card:hover {
  transform: translateY(-4px);
  border-color: rgba(60,179,113,.34);
  box-shadow: 0 24px 64px rgba(17,40,28,.14);
}

.attractions-local__card span {
  width: 42px;
  height: 42px;
  display: grid;
  place-items: center;
  border-radius: 999px;
  color: #07120d;
  background: rgba(60,179,113,.18);
  border: 1px solid rgba(60,179,113,.22);
  font-size: .76rem;
  font-weight: 950;
}

.attractions-local__card strong {
  color: #102018;
  font-size: clamp(1.02rem, 2vw, 1.22rem);
  line-height: 1.25;
  font-weight: 950;
}

.attractions-local__media {
  display: grid;
  gap: 14px;
}

.attractions-local__route {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  align-items: center;
  justify-content: center;
  padding: 20px;
  border-radius: 24px;
  color: #fff;
  background:
    linear-gradient(135deg, rgba(10,28,18,.90), rgba(17,39,27,.78)),
    radial-gradient(circle at 86% 18%, rgba(239,174,99,.18), transparent 36%);
  border-color: rgba(255,255,255,.14);
}

.attractions-local__route span {
  padding: 12px 15px;
  border-radius: 999px;
  background: rgba(255,255,255,.10);
  border: 1px solid rgba(255,255,255,.13);
  font-weight: 900;
}

.attractions-local__route i {
  width: 28px;
  height: 2px;
  background: rgba(143,224,180,.72);
}

.attractions-list {
  background:
    radial-gradient(circle at 12% 18%, rgba(60,179,113,.13), transparent 32%),
    linear-gradient(180deg, #f2f7f0, #f8fbf5);
}

.attractions-list__head {
  max-width: 880px;
  margin-bottom: clamp(30px, 5vw, 54px);
}

.attractions-list__grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 18px;
}

.attractions-list__card {
  overflow: hidden;
  border-radius: 28px;
  transition: transform .24s ease, box-shadow .24s ease, border-color .24s ease;
}

:global(.attractions-list__image.photo-frame) {
  border-radius: 28px 28px 0 0;
  border: 0;
  box-shadow: none;
}

.attractions-list__body {
  padding: clamp(22px, 3vw, 30px);
}

.attractions-list__body span {
  display: inline-flex;
  margin-bottom: 22px;
  color: #3CB371;
  font-size: .74rem;
  font-weight: 950;
  letter-spacing: .14em;
}

.attractions-list__body h3 {
  margin: 0 0 12px;
  color: #102018;
  font-size: clamp(1.16rem, 2vw, 1.42rem);
  line-height: 1.18;
  font-weight: 950;
}

.attractions-list__body p {
  margin: 0;
  color: #536359;
  line-height: 1.7;
}

.attractions-itinerary {
  background:
    radial-gradient(circle at 16% 18%, rgba(60,179,113,.18), transparent 34%),
    linear-gradient(180deg, #f8fbf5, #101b14);
}

.attractions-itinerary .section-title,
.attractions-itinerary .section-copy {
  color: #fff;
}

.attractions-itinerary .section-copy {
  color: rgba(255,255,255,.76);
}

.attractions-itinerary .section-kicker {
  color: #8fe0b4;
}

.attractions-itinerary__cards {
  display: grid;
  grid-template-columns: 1fr;
  gap: 16px;
}

.attractions-itinerary__card {
  padding: clamp(24px, 3vw, 34px);
  border-radius: 24px;
  color: #fff;
  background: rgba(255,255,255,.09);
  border-color: rgba(255,255,255,.13);
  transition: transform .24s ease, box-shadow .24s ease, border-color .24s ease;
}

.attractions-itinerary__card span {
  display: inline-flex;
  margin-bottom: 24px;
  color: #8fe0b4;
  font-size: .86rem;
  font-weight: 950;
  letter-spacing: .12em;
  text-transform: uppercase;
}

.attractions-itinerary__card ul {
  display: grid;
  gap: 12px;
  margin: 0;
  padding: 0;
  list-style: none;
}

.attractions-itinerary__card li {
  position: relative;
  padding-left: 26px;
  color: rgba(255,255,255,.84);
  font-weight: 850;
  line-height: 1.55;
}

.attractions-itinerary__card li::before {
  content: '';
  position: absolute;
  left: 0;
  top: .62em;
  width: 8px;
  height: 8px;
  border-radius: 999px;
  background: #3CB371;
  box-shadow: 0 0 0 6px rgba(60,179,113,.14);
}

.attractions-final-cta {
  padding-top: 0;
  background:
    radial-gradient(circle at 18% 20%, rgba(60,179,113,.18), transparent 34%),
    linear-gradient(180deg, #101b14, #0b140f);
}

.attractions-final-cta__panel {
  display: grid;
  gap: 28px;
  padding: clamp(28px, 5vw, 54px);
  border-radius: 28px;
  color: #fff;
  background:
    linear-gradient(135deg, rgba(10,28,18,.92), rgba(17,39,27,.82)),
    radial-gradient(circle at 86% 18%, rgba(239,174,99,.18), transparent 36%);
  border-color: rgba(255,255,255,.14);
}

.attractions-final-cta__panel h2 {
  max-width: 820px;
  margin: 10px 0 16px;
  color: #fff;
  font-size: clamp(2rem, 5vw, 4rem);
  line-height: .98;
  font-weight: 950;
}

.attractions-final-cta__panel p {
  max-width: 760px;
  margin: 0;
  color: rgba(255,255,255,.76);
  line-height: 1.75;
}

.attractions-final-cta__panel .section-kicker {
  color: #8fe0b4;
}

.attractions-final-cta__actions {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
}

.attractions-final-cta__secondary {
  display: inline-flex;
  min-height: 50px;
  align-items: center;
  justify-content: center;
  padding: 14px 24px;
  border-radius: 999px;
  border: 1px solid rgba(255,255,255,.18);
  color: #fff;
  background: rgba(255,255,255,.08);
  font-weight: 900;
  letter-spacing: .06em;
}

.attractions-final-cta__secondary:hover {
  color: #fff;
  border-color: rgba(143,224,180,.42);
  background: rgba(255,255,255,.14);
}

@media (min-width: 760px) {
  .attractions-local__cards {
    grid-template-columns: repeat(2, 1fr);
  }

  .attractions-list__grid {
    grid-template-columns: repeat(2, 1fr);
  }

  .attractions-itinerary__cards {
    grid-template-columns: repeat(3, 1fr);
  }
}

@media (min-width: 980px) {
  .attractions-local__grid,
  .attractions-itinerary__grid {
    grid-template-columns: .95fr 1.05fr;
  }

  .attractions-list__grid {
    grid-template-columns: repeat(3, 1fr);
  }

  .attractions-final-cta__panel {
    grid-template-columns: 1fr auto;
    align-items: end;
  }
}

@media (max-width: 640px) {
  .attractions-local__card {
    grid-template-columns: 44px 1fr;
  }

  .attractions-local__route {
    justify-content: start;
  }

  .attractions-final-cta__actions {
    display: grid;
  }

  .attractions-final-cta__actions a {
    width: 100%;
  }
}
</style>
