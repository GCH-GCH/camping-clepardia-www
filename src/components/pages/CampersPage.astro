  ?? camperFallbackTextByLanguage[contentLanguage as keyof typeof camperFallbackTextByLanguage]
  ?? camperTextByLanguage.en;
const camperExtraValueTitle = 'extraValueTitle' in camperText ? camperText.extraValueTitle : camperText.tram;
const camperExtraValueCopy = 'extraValueCopy' in camperText ? camperText.extraValueCopy : camperText.whyLead;

const valueCards = [
  {
    title: page.highlights[0]?.title ?? camperText.pitches,
    copy: page.highlights[0]?.copy ?? camperText.whyLead,
    icon: 'map',
  },
  {
    title: page.highlights[1]?.title ?? camperText.electricity,
    copy: page.highlights[1]?.copy ?? camperText.notes[1],
    icon: 'camper',
  },
  {
    title: page.highlights[2]?.title ?? camperText.tram,
    copy: page.highlights[2]?.copy ?? camperText.notes[2],
    icon: 'electricity',
  },
  {
    title: page.highlights[3]?.title ?? camperExtraValueTitle,
    copy: page.highlights[3]?.copy ?? camperExtraValueCopy,
    icon: 'tram',
  },
