import { pricingConfig } from '@/data/pricing';
import { getLocalizedPath } from '@/utils/localizedLinks';
import { getTranslations, resolveContentLanguage } from '@/i18n/config';

interface Props {
  languageCode?: string;
}

const { languageCode } = Astro.props as Props;
const contentLanguage = resolveContentLanguage(languageCode);
const t = getTranslations(languageCode);
const page = t.pages['dla-kamperow'];
const pricingHref = getLocalizedPath(languageCode, 'cennik');
const contactHref = getLocalizedPath(languageCode, 'kontakt');
const currency = pricingConfig.currency;
const formatPrice = (price: number) => `${price} ${currency}`;
const stayTypeLabels = t.pricing.stayTypes as Record<string, string>;
const addonLabels = t.pricing.addons as Record<string, string>;
const getStayPrice = (id: string) => {
  const stayType = pricingConfig.stayTypes.find((item) => item.id === id);
  if (!stayType || !('price' in stayType)) throw new Error(`Missing camper pricing: ${id}`);

  return {
    label: stayTypeLabels[id] ?? stayType.label,
    price: stayType.price,
  };
};
const getAddonPrice = (id: string) => {
  const addon = pricingConfig.addons.find((item) => item.id === id);
  if (!addon) throw new Error(`Missing addon pricing: ${id}`);

  return {
    label: addonLabels[id] ?? addon.label,
    price: addon.price,
  };
};

