        <a class="btn btn-primary premium-button" href={pricingHref}>{page.cta.primaryLabel}</a>
        <a class="btn btn-glass faq-final-cta__secondary" href={contactHref}>{page.cta.secondaryLabel}</a>
        <a class="btn btn-glass faq-final-cta__secondary" href={tourBookingHref} target="_blank" rel="noopener noreferrer">{tourUi[0]}</a>
      </div>
    </div>
  </div>
</section>

<script>
  const faqRoot = document.querySelector('[data-faq-page]');

  if (faqRoot instanceof HTMLElement) {
    const searchInput = faqRoot.querySelector('[data-faq-search]') as HTMLInputElement | null;
    const categoryButtons = Array.from(faqRoot.querySelectorAll('[data-faq-category]')) as HTMLButtonElement[];
    const items = Array.from(faqRoot.querySelectorAll('[data-faq-item]')) as HTMLElement[];
    const emptyState = faqRoot.querySelector('[data-faq-empty]') as HTMLElement | null;
    let activeCategory = 'all';

    const normalize = (value: string) => value
      .toLowerCase()
      .normalize('NFD')
      .replace(/\p{Diacritic}/gu, '');

    const closeItem = (item: HTMLElement) => {
      const button = item.querySelector('[data-faq-toggle]') as HTMLButtonElement | null;
      const panel = item.querySelector('[data-faq-panel]') as HTMLElement | null;

      if (!button || !panel) return;
      item.classList.remove('is-open');
      button.setAttribute('aria-expanded', 'false');
      panel.setAttribute('aria-hidden', 'true');
      panel.style.maxHeight = '0px';
    };

    const openItem = (item: HTMLElement) => {
      const button = item.querySelector('[data-faq-toggle]') as HTMLButtonElement | null;
      const panel = item.querySelector('[data-faq-panel]') as HTMLElement | null;

      if (!button || !panel) return;
      item.classList.add('is-open');
      button.setAttribute('aria-expanded', 'true');
      panel.setAttribute('aria-hidden', 'false');
      panel.style.maxHeight = `${panel.scrollHeight}px`;
    };

    const filterItems = () => {
      const query = normalize(searchInput?.value ?? '').trim();
      let visibleCount = 0;

      items.forEach((item) => {
        const categoryMatch = activeCategory === 'all' || item.dataset.category === activeCategory;
        const searchMatch = !query || normalize(item.dataset.search ?? '').includes(query);
        const isVisible = categoryMatch && searchMatch;

        item.hidden = !isVisible;
        if (isVisible) {
          visibleCount += 1;
          const panel = item.querySelector('[data-faq-panel]') as HTMLElement | null;
          if (item.classList.contains('is-open') && panel) {
            panel.style.maxHeight = `${panel.scrollHeight}px`;
          }
        } else {
          closeItem(item);
        }
      });

      if (emptyState) emptyState.hidden = visibleCount > 0;
    };

    const setCategory = (category: string) => {
      activeCategory = category;
      categoryButtons.forEach((button) => {
        const active = button.dataset.faqCategory === category;
        button.classList.toggle('is-active', active);
        button.setAttribute('aria-pressed', String(active));
      });
      filterItems();
    };

    items.forEach((item) => {
      const button = item.querySelector('[data-faq-toggle]') as HTMLButtonElement | null;
      if (!button) return;

      button.addEventListener('click', () => {
        if (item.classList.contains('is-open')) closeItem(item);
        else openItem(item);
      });
    });

    categoryButtons.forEach((button) => {
      button.addEventListener('click', () => setCategory(button.dataset.faqCategory ?? 'all'));
    });

    searchInput?.addEventListener('input', filterItems);
    window.addEventListener('resize', () => {
      items.forEach((item) => {
        if (!item.classList.contains('is-open')) return;
        const panel = item.querySelector('[data-faq-panel]') as HTMLElement | null;
        if (panel) panel.style.maxHeight = `${panel.scrollHeight}px`;
      });
    }, { passive: true });

    filterItems();
  }
</script>

