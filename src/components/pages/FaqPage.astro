const faqText =
  faqTextByLanguage[contentLanguage as keyof typeof faqTextByLanguage]
  ?? faqFallbackTextByLanguage[contentLanguage as keyof typeof faqFallbackTextByLanguage]
  ?? faqTextByLanguage.en;
const extraFaqText =
  extraFaqTextByLanguage[contentLanguage as keyof typeof extraFaqTextByLanguage]
  ?? extraFaqTextByLanguage.en;

const getSeasonalAnswer = (stayType: typeof pricingConfig.stayTypes[number] | undefined) => {
  if (!stayType || !('seasonalPrices' in stayType)) return faqText.toConfirm;
  return faqText.seasonalAnswer(formatPrice(stayType.seasonalPrices.low), formatPrice(stayType.seasonalPrices.high));
};

