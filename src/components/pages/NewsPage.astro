---
import ImageFrame from '@/components/ImageFrame.astro';
import Icon from '@/components/ui/Icon.astro';
import { getNoticeCopy, siteNoticeCategories, siteNotices } from '@/data/siteNotices';

const activeFirst = [...siteNotices].sort((a, b) => {
  const rank = { high: 3, medium: 2, low: 1 };
  return Number(b.isActive) - Number(a.isActive) || rank[b.priority] - rank[a.priority];
});
const featured = activeFirst.find((notice) => notice.id === 'season-open-2026') ?? activeFirst[0];
const categoryLabel = (category: string) =>
  siteNoticeCategories.find((item) => item.id === category)?.label ?? category;
const statusLabel = (notice: (typeof siteNotices)[number]) =>
  notice.isActive ? 'Aktywne' : new Date(notice.startDate) > new Date() ? 'Nadchodzące' : 'Archiwum';
---

<section class="site-section news-page reveal-section" data-news-page>
  <div class="container news-page__inner">
    <header class="news-page__hero">
      <span class="section-kicker">Aktualności</span>
      <h1>Aktualnie na campingu i w Krakowie</h1>
      <p>Komunikaty sezonowe, dojazd, wydarzenia, podpowiedzi dla rodzin i rzeczy, które warto sprawdzić przed przyjazdem.</p>
    </header>

    {featured && (
      <article class="premium-card news-page__featured" data-news-card data-news-id={featured.id} data-category={featured.category} data-search={`${featured.title} ${featured.shortDescription} ${featured.description} ${(featured.tags ?? []).join(' ')}`}>
        <ImageFrame
          src={featured.image ?? ''}
          alt={featured.imageAlt ?? featured.title}
          label={featured.badge ?? categoryLabel(featured.category)}
          className="news-page__featured-image"
        />
        <div class="news-page__featured-copy">
          <span class="news-page__status">{statusLabel(featured)}</span>
          <h2>{getNoticeCopy(featured).title}</h2>
          <p>{getNoticeCopy(featured).description}</p>
          {featured.ctaHref && (
            <a href={featured.ctaHref}>
              <span>{getNoticeCopy(featured).ctaLabel ?? 'Zobacz szczegóły'}</span>
              <Icon name="ArrowUpRight" size={18} strokeWidth={2.2} />
            </a>
          )}
        </div>
      </article>
    )}

    <div class="premium-card news-page__tools">
      <div class="news-page__search">
        <Icon name="Search" size={18} strokeWidth={2} />
        <input type="search" data-news-search placeholder="Szukaj: sezon, tramwaj, dokument, pies, Wieliczka..." />
      </div>
      <div class="news-page__filters" aria-label="Kategorie aktualności">
        {siteNoticeCategories.map((category) => (
          <button type="button" class:list={[category.id === 'all' && 'is-active']} data-news-filter={category.id} aria-pressed={category.id === 'all' ? 'true' : 'false'}>
            <Icon name={category.icon} size={15} strokeWidth={2} />
            <span>{category.label}</span>
          </button>
        ))}
      </div>
    </div>

    <div class="news-page__grid">
      {siteNotices.map((notice) => {
        const copy = getNoticeCopy(notice);
        return (
          <article
            class:list={['premium-card news-page__card', !notice.isActive && 'is-inactive']}
            data-news-card
            data-news-id={notice.id}
            data-category={notice.category}
            data-search={`${copy.title} ${copy.shortDescription} ${copy.description} ${(notice.tags ?? []).join(' ')}`}
          >
            <ImageFrame src={notice.image ?? ''} alt={copy.imageAlt ?? copy.title} label={copy.badge ?? categoryLabel(notice.category)} className="news-page__image" />
            <div class="news-page__card-body">
              <div class="news-page__meta">
                <span>{categoryLabel(notice.category)}</span>
                <small>{statusLabel(notice)}</small>
              </div>
              <h3>{copy.title}</h3>
              <p>{copy.shortDescription ?? copy.description}</p>
              <div class="news-page__tags">
                {(notice.tags ?? []).slice(0, 4).map((tag) => <em>{tag}</em>)}
              </div>
              {notice.ctaHref && notice.isActive && (
                <a href={notice.ctaHref}>
                  <span>{copy.ctaLabel ?? 'Zobacz szczegóły'}</span>
                  <Icon name="ArrowUpRight" size={16} strokeWidth={2.2} />
                </a>
              )}
            </div>
          </article>
        );
      })}
    </div>
  </div>
</section>

<script>
  (() => {
    const root = document.querySelector('[data-news-page]');
    if (!(root instanceof HTMLElement)) return;
    const buttons = Array.from(root.querySelectorAll('[data-news-filter]'));
    const cards = Array.from(root.querySelectorAll('[data-news-card]'));
    const search = root.querySelector('[data-news-search]');
    let activeFilter = 'all';
    const normalize = (value: string) => value.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '');
    const apply = () => {
      const query = search instanceof HTMLInputElement ? normalize(search.value.trim()) : '';
      cards.forEach((card) => {
        if (!(card instanceof HTMLElement)) return;
        const categoryMatch = activeFilter === 'all' || card.dataset.category === activeFilter;
        const searchMatch = !query || normalize(card.dataset.search || '').includes(query);
        card.hidden = !(categoryMatch && searchMatch);
      });
    };
    buttons.forEach((button) => {
      if (!(button instanceof HTMLButtonElement)) return;
      button.addEventListener('click', () => {
        activeFilter = button.dataset.newsFilter || 'all';
        buttons.forEach((item) => {
          const active = item === button;
          item.classList.toggle('is-active', active);
          item.setAttribute('aria-pressed', String(active));
        });
        apply();
      });
    });
    search?.addEventListener('input', apply);
  })();
</script>

<style>
.news-page {
  min-height: 100vh;
  background:
    radial-gradient(circle at 12% 0%, rgba(60,179,113,.18), transparent 34%),
    radial-gradient(circle at 88% 10%, rgba(242,192,120,.13), transparent 32%),
    linear-gradient(180deg, #f7f8f3, #edf5ec);
}

.news-page__inner {
  display: grid;
  gap: clamp(22px, 4vw, 38px);
}

.news-page__hero {
  max-width: 900px;
  padding-top: clamp(32px, 6vw, 74px);
}

.news-page__hero h1 {
  margin: 0;
  color: #102018;
  font-size: clamp(2.5rem, 7vw, 5.6rem);
  line-height: .94;
  letter-spacing: 0;
  font-weight: 950;
}

.news-page__hero p {
  max-width: 720px;
  color: #52645a;
  font-size: clamp(1rem, 2vw, 1.18rem);
  line-height: 1.7;
  font-weight: 760;
}

.news-page__featured {
  display: grid;
  grid-template-columns: minmax(0, .95fr) minmax(0, 1.05fr);
  gap: clamp(18px, 4vw, 38px);
  padding: clamp(16px, 3vw, 24px);
  border-radius: 34px;
  background: rgba(255,255,255,.76);
}

:global(.news-page__featured-image) {
  min-height: clamp(280px, 32vw, 420px);
  border-radius: 26px;
}

.news-page__featured-copy {
  align-self: center;
  display: grid;
  gap: 14px;
}

.news-page__status,
.news-page__meta span,
.news-page__meta small,
.news-page__tags em {
  width: fit-content;
  padding: 7px 10px;
  border-radius: 999px;
  color: #0f6b3f;
  background: rgba(60,179,113,.13);
  font-size: .72rem;
  font-style: normal;
  font-weight: 950;
  letter-spacing: .06em;
  text-transform: uppercase;
}

.news-page__featured-copy h2,
.news-page__card h3 {
  margin: 0;
  color: #102018;
  font-weight: 950;
  line-height: 1.12;
}

.news-page__featured-copy h2 {
  font-size: clamp(1.8rem, 4vw, 3.2rem);
}

.news-page__featured-copy p,
.news-page__card p {
  margin: 0;
  color: #52645a;
  line-height: 1.65;
  font-weight: 760;
}

.news-page__featured-copy a,
.news-page__card a {
  width: fit-content;
  min-height: 42px;
  display: inline-flex;
  align-items: center;
  gap: 9px;
  padding: 0 14px;
  border-radius: 999px;
  color: #082016;
  background: linear-gradient(135deg, #a8f0c7, #3CB371 62%, #2f9d63);
  font-size: .86rem;
  font-weight: 950;
  text-decoration: none;
  box-shadow: 0 16px 34px rgba(60,179,113,.20);
}

.news-page__tools {
  display: grid;
  gap: 14px;
  padding: 16px;
  border-radius: 28px;
  background: rgba(255,255,255,.74);
}

.news-page__search {
  display: grid;
  grid-template-columns: auto minmax(0, 1fr);
  gap: 10px;
  align-items: center;
  padding: 12px 14px;
  border: 1px solid rgba(60,179,113,.20);
  border-radius: 20px;
  background: rgba(255,255,255,.70);
}

.news-page__search input {
  width: 100%;
  border: 0;
  outline: 0;
  background: transparent;
  color: #102018;
  font: inherit;
  font-weight: 850;
}

.news-page__filters {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.news-page__filters button {
  min-height: 38px;
  display: inline-flex;
  align-items: center;
  gap: 7px;
  padding: 0 12px;
  border: 1px solid rgba(60,179,113,.15);
  border-radius: 999px;
  color: #173624;
  background: rgba(255,255,255,.74);
  cursor: pointer;
  font-size: .78rem;
  font-weight: 900;
}

.news-page__filters button.is-active {
  color: #082016;
  background: linear-gradient(135deg, #a8f0c7, #3CB371);
}

.news-page__grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 16px;
}

.news-page__card {
  display: grid;
  gap: 14px;
  padding: 14px;
  border-radius: 28px;
  background: rgba(255,255,255,.76);
}

.news-page__card.is-inactive {
  opacity: .62;
}

:global(.news-page__image) {
  min-height: 210px;
  border-radius: 22px;
}

.news-page__card-body {
  display: grid;
  gap: 10px;
  padding: 0 6px 8px;
}

.news-page__meta,
.news-page__tags {
  display: flex;
  flex-wrap: wrap;
  gap: 7px;
}

.news-page__meta small {
  color: #6c4c18;
  background: rgba(242,192,120,.20);
}

html[data-theme="dark"] .news-page {
  background:
    radial-gradient(circle at 12% 0%, rgba(60,179,113,.20), transparent 34%),
    radial-gradient(circle at 88% 10%, rgba(242,192,120,.10), transparent 32%),
    linear-gradient(180deg, #0f1d14, #13261a);
}

html[data-theme="dark"] .news-page__hero h1,
html[data-theme="dark"] .news-page__featured-copy h2,
html[data-theme="dark"] .news-page__card h3 {
  color: #fff;
}

html[data-theme="dark"] .news-page__hero p,
html[data-theme="dark"] .news-page__featured-copy p,
html[data-theme="dark"] .news-page__card p {
  color: rgba(255,255,255,.72);
}

html[data-theme="dark"] .news-page__featured,
html[data-theme="dark"] .news-page__tools,
html[data-theme="dark"] .news-page__card {
  border-color: rgba(255,255,255,.13);
  background: rgba(255,255,255,.08);
}

html[data-theme="dark"] .news-page__search,
html[data-theme="dark"] .news-page__filters button {
  color: #fff;
  border-color: rgba(255,255,255,.13);
  background: rgba(255,255,255,.08);
}

html[data-theme="dark"] .news-page__search input {
  color: #fff;
}

@media (max-width: 980px) {
  .news-page__featured,
  .news-page__grid {
    grid-template-columns: 1fr;
  }
}
</style>
