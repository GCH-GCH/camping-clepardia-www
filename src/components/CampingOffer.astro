---
// LEGACY — nieużywany komponent, zostawiony tymczasowo po przebudowie homepage.
import ImageFrame from '@/components/ImageFrame.astro';
import { siteAssets } from '@/data/assets';

const features = ['Kampery', 'Przyczepy', 'Namioty', 'Prąd', 'Sanitariaty', 'Parking', 'Szybka rejestracja'];
---

<section class="site-section camping reveal-section" id="camping">
  <div class="container section-grid section-grid--2">
    <div>
      <span class="section-kicker">Camping</span>
      <h2 class="section-title">Miejsca campingowe dla podróżujących po Krakowie i Europie.</h2>
      <p class="section-copy">
        Przyjedź kamperem, z przyczepą albo namiotem. Clepardia daje wygodną bazę blisko komunikacji miejskiej, z praktyczną infrastrukturą potrzebną do spokojnego pobytu.
      </p>
      <div class="camping__features">
        {features.map((feature) => <span>{feature}</span>)}
      </div>
      <a class="premium-button" href="#rezerwacja">Zobacz ofertę campingu</a>
    </div>
    <div class="camping__media">
      <ImageFrame
        src={siteAssets.camping.pitches}
        alt="Pole campingowe Camping Clepardia"
        label="Miejsce na zdjęcie: pole campingowe i kampery"
        className="camping__photo"
      />
      <div class="camping__thumbs">
        <ImageFrame src={siteAssets.camping.camperArea} alt="Strefa dla kamperów" label="Kampery" />
        <ImageFrame src={siteAssets.camping.tents} alt="Strefa namiotowa" label="Namioty" />
        <ImageFrame src={siteAssets.camping.electricity} alt="Przyłącza prądu na campingu" label="Prąd" />
      </div>
    </div>
  </div>
</section>

<style>
.camping { background: #f7faf4; }
.camping__features { display: flex; flex-wrap: wrap; gap: 10px; margin: 30px 0 32px; }
.camping__features span { padding: 10px 14px; border-radius: 999px; background: rgba(60,179,113,.10); color: #246947; font-weight: 850; }
.camping__media { display: grid; gap: 14px; }
:global(.camping__photo) { min-height: 420px; background: linear-gradient(135deg, rgba(10,25,17,.18), rgba(6,18,12,.78)), radial-gradient(circle at 72% 22%, rgba(246,177,96,.25), transparent 32%), linear-gradient(135deg, #31543b, #0b1a12); }
.camping__thumbs { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; }
.camping__thumbs :global(.asset-frame) { min-height: 150px; }
@media (max-width: 680px) { .camping__thumbs { grid-template-columns: 1fr; } }
</style>
