const attractionCopy = attractionCopyByLanguage[activeLanguage as keyof typeof attractionCopyByLanguage] ?? attractionCopyByLanguage.en;
const ctaLabel = attractionCopy.cta;
const attractions = [
  { key: 'oldTown', meta: attractionCopy.tramWalk, metaIcon: 'tram', image: attractionImages.mainSquare, icon: 'landmark', variant: 'old-town' },
  { key: 'wieliczka', meta: attractionCopy.dayTrip, metaIcon: 'route', image: attractionImages.wieliczka, icon: 'map', variant: 'wieliczka' },
  { key: 'auschwitz', meta: attractionCopy.carBus, metaIcon: 'bus', image: attractionImages.auschwitz, icon: 'shield', variant: 'auschwitz' },
  { key: 'schindler', meta: attractionCopy.cityMuseum, metaIcon: 'ticket', image: attractionImages.schindler, icon: 'info', variant: 'schindler' },
  { key: 'energylandia', meta: attractionCopy.fullDay, metaIcon: 'car', image: attractionImages.energylandia, icon: 'sparkle', variant: 'energylandia' },
  { key: 'nature', meta: attractionCopy.nature, metaIcon: 'leaf', image: attractionImages.zakopane, icon: 'leaf', variant: 'nature' },
].map((item) => {
  const [name, description, alt] = attractionCopy.items[item.key as keyof typeof attractionCopy.items];
  return { ...item, name, description, alt };
});

const featured = attractions[0];
const secondary = attractions.slice(1);
---

<section class="site-section attractions reveal-section" id="atrakcje">
  <div class="container">
    <div class="attractions__head">
      <span class="section-kicker">{page.overline}</span>
      <h2 class="section-title">{page.title}</h2>
    </div>

    <div class="attractions__layout">
      <article class="attractions__feature reveal-section">
        <ImageFrame
          src={featured.image.src}
          alt={featured.image.altPl || featured.alt}
          label={featured.name}
          className={`attractions__media attractions__media--feature attractions__media--${featured.variant}`}
          width={featured.image.width}
          height={featured.image.height}
          sizes={featured.image.sizes}
        />
        <div class="attractions__feature-copy">
          <span class="attractions__feature-icon" aria-hidden="true">
            <Icon name={featured.icon} size={28} strokeWidth={1.8} />
          </span>
          <span class="attractions__trip-label">
            <Icon name={featured.metaIcon} size={14} strokeWidth={2} />
            {featured.meta}
          </span>
          <p>{attractionCopy.closest}</p>
          <h3>{featured.name}</h3>
          <span>{featured.description}</span>
        </div>
      </article>

      <div class="attractions__stack">
        {secondary.map((attraction, index) => (
          <article class:list={['attractions__mini', `attractions__mini--${index + 1}`, 'reveal-section']} style={`--reveal-delay: ${(index + 1) * 80}ms`}>
            <ImageFrame
              src={attraction.image.src}
              alt={attraction.image.altPl || attraction.alt}
              label={attraction.name}
              className={`attractions__media attractions__media--mini attractions__media--${attraction.variant}`}
              width={attraction.image.width}
              height={attraction.image.height}
              sizes={attraction.image.sizes}
            />
            <div class="attractions__mini-copy">
              <span aria-hidden="true">
                <Icon name={attraction.icon} size={18} strokeWidth={1.9} />
              </span>
              <small class="attractions__trip-label">
                <Icon name={attraction.metaIcon} size={13} strokeWidth={2} />
                {attraction.meta}
              </small>
              <h3>{attraction.name}</h3>
              <p>{attraction.description}</p>
            </div>
          </article>
        ))}
      </div>
    </div>

    <a class="btn btn-primary premium-button attractions__cta" href={getLocalizedPath(explicitLanguage, 'atrakcje')}>
      {ctaLabel}
    </a>
  </div>
</section>

<style>
.attractions {
  position: relative;
  overflow: hidden;
  background:
    radial-gradient(circle at 10% 0%, rgba(60,179,113,.12), transparent 30%),
    radial-gradient(circle at 88% 8%, rgba(242,192,120,.12), transparent 32%),
    linear-gradient(180deg, #f7f8f1 0%, #eef5eb 100%);
}

.attractions::before {
  content: '';
  position: absolute;
  inset: 0;
  opacity: .18;
  pointer-events: none;
  background-image:
    radial-gradient(circle at 22% 26%, rgba(60,179,113,.26) 0 1px, transparent 1px 8px),
    radial-gradient(circle at 78% 40%, rgba(242,192,120,.22) 0 1px, transparent 1px 12px);
  background-size: 16px 16px, 24px 24px;
}

.attractions__head {
  position: relative;
  z-index: 1;
  max-width: 920px;
}

.attractions__layout {
  position: relative;
  z-index: 1;
  margin-top: clamp(34px, 5vw, 62px);
  display: grid;
  grid-template-columns: 1fr;
  gap: clamp(22px, 3vw, 34px);
}

.attractions__feature {
  position: relative;
  display: grid;
  min-width: 0;
  border-radius: 34px;
  overflow: hidden;
  box-shadow: 0 30px 84px rgba(17,40,28,.15), 0 0 38px rgba(60,179,113,.10);
}

:global(.attractions__media) {
  min-height: 260px;
}

:global(.attractions__media--feature) {
  aspect-ratio: 16 / 10;
  min-height: clamp(360px, 46vw, 560px);
  border-radius: 34px;
}

.attractions__feature-copy {
  position: absolute;
  left: clamp(20px, 4vw, 42px);
  right: clamp(20px, 4vw, 42px);
  bottom: clamp(20px, 4vw, 42px);
  z-index: 3;
  max-width: 560px;
  display: grid;
  gap: 12px;
  color: #fff;
}

.attractions__feature-icon,
.attractions__mini-copy > span {
  display: grid;
  place-items: center;
  border: 1px solid rgba(143,224,180,.34);
  color: #f4fff8;
  background:
    radial-gradient(circle at 32% 18%, rgba(255,255,255,.28), transparent 36%),
    linear-gradient(135deg, rgba(60,179,113,.50), rgba(60,179,113,.18));
  box-shadow: 0 18px 44px rgba(60,179,113,.22), inset 0 1px 0 rgba(255,255,255,.16);
}

.attractions__feature-icon {
  width: 62px;
  height: 62px;
  border-radius: 24px;
}

.attractions__feature-copy p {
  margin: 0;
  color: #8fe0b4;
  font-size: .78rem;
  font-weight: 950;
  letter-spacing: .15em;
  text-transform: uppercase;
}

.attractions__feature-copy h3 {
  margin: 0;
  color: #fff;
  font-size: clamp(2.2rem, 5vw, 4.5rem);
  line-height: .96;
  letter-spacing: 0;
  text-shadow: 0 18px 42px rgba(0,0,0,.32);
}

.attractions__feature-copy > span:last-child {
  max-width: 520px;
  color: rgba(255,255,255,.78);
  font-size: clamp(1rem, 1.4vw, 1.14rem);
  line-height: 1.65;
}

.attractions__stack {
  display: grid;
  grid-template-columns: 1fr;
  gap: 18px;
}

.attractions__mini {
  position: relative;
  min-width: 0;
  display: grid;
  grid-template-rows: auto 1fr;
  gap: 0;
  padding: 12px;
  border-radius: 28px;
  overflow: hidden;
  background:
    radial-gradient(circle at 16% 0%, rgba(60,179,113,.13), transparent 36%),
    linear-gradient(145deg, rgba(255,255,255,.78), rgba(255,255,255,.52));
  box-shadow: 0 22px 62px rgba(17,40,28,.12), inset 0 1px 0 rgba(255,255,255,.48);
  transition: transform .28s cubic-bezier(.22, 1, .36, 1), box-shadow .28s ease, border-color .28s ease;
}

.attractions__mini:hover {
  transform: translateY(-6px);
  box-shadow: 0 30px 78px rgba(17,40,28,.17), 0 0 30px rgba(60,179,113,.13);
}

:global(.attractions__media--mini) {
  aspect-ratio: 16 / 10;
  min-height: 200px;
  border-radius: 22px;
}

.attractions__mini-copy {
  position: relative;
  z-index: 3;
  display: grid;
  grid-template-columns: auto minmax(0, 1fr);
  grid-template-areas:
    "icon meta"
    "title title"
    "text text";
  align-content: start;
  gap: 10px 12px;
  min-height: 176px;
  margin-top: 10px;
  padding: clamp(18px, 2.2vw, 22px);
  border: 1px solid rgba(60,179,113,.18);
  border-radius: 22px;
  color: var(--color-text, #102116);
  background:
    radial-gradient(circle at 100% 0%, rgba(60,179,113,.12), transparent 34%),
    rgba(255,255,255,.72);
  box-shadow: inset 0 1px 0 rgba(255,255,255,.38);
}

html[data-theme="dark"] .attractions__mini {
  background:
    radial-gradient(circle at 16% 0%, rgba(60,179,113,.16), transparent 38%),
    linear-gradient(145deg, rgba(255,255,255,.075), rgba(255,255,255,.045));
  box-shadow: 0 24px 66px rgba(0,0,0,.24), inset 0 1px 0 rgba(255,255,255,.09);
}

html[data-theme="dark"] .attractions__mini-copy {
  color: #f4fbf6;
  border-color: rgba(143,224,180,.20);
  background:
    radial-gradient(circle at 100% 0%, rgba(60,179,113,.16), transparent 36%),
    rgba(255,255,255,.055);
  box-shadow: inset 0 1px 0 rgba(255,255,255,.08);
}

.attractions__mini-copy > span {
  grid-area: icon;
  width: 38px;
  height: 38px;
  border-radius: 15px;
}

.attractions__mini-copy .attractions__trip-label {
  grid-area: meta;
  align-self: center;
}

.attractions__mini-copy h3 {
  grid-area: title;
  margin: 0;
  color: var(--color-text, #102116);
  font-size: 1.08rem;
  line-height: 1.15;
}

html[data-theme="dark"] .attractions__mini-copy h3 {
  color: #fff;
}

.attractions__mini-copy p {
  grid-area: text;
  margin: 0;
  color: var(--color-muted, rgba(16,33,22,.68));
  font-size: .9rem;
  line-height: 1.56;
}

html[data-theme="dark"] .attractions__mini-copy p {
  color: rgba(255,255,255,.72);
}

.attractions__trip-label {
  width: fit-content;
  display: inline-flex;
  align-items: center;
  gap: 7px;
  padding: 7px 11px;
  border: 1px solid rgba(143,224,180,.26);
