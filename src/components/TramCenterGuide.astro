const copy = copyByLang[lang as keyof typeof copyByLang] ?? copyByLang.en;
---

<section class:list={['site-section tram-center-guide reveal-section', `tram-center-guide--${variant}`]} aria-labelledby={`tramCenterTitle-${variant}`}>
  <div class="container tram-center-guide__inner">
    <div class="tram-center-guide__head">
      <span class="section-kicker">{copy.kicker}</span>
      <h2 class="section-title" id={`tramCenterTitle-${variant}`}>{copy.title}</h2>
      <p class="section-copy">{copy.lead}</p>
    </div>

    <div class="tram-center-guide__layout">
      <article class="premium-card tram-center-guide__route">
        <span class="tram-center-guide__route-icon" aria-hidden="true">
          <Icon name="TramFront" size={28} strokeWidth={2} />
        </span>
        <div class="tram-center-guide__route-line" aria-label={copy.route.join(' -> ')}>
          {copy.route.map((step, index) => (
            <>
              <span class:list={[index === 0 && 'is-start', index === copy.route.length - 1 && 'is-end']}>{step}</span>
              {index < copy.route.length - 1 && <i aria-hidden="true"></i>}
            </>
          ))}
        </div>
        <ImageFrame
          src={siteAssets.transport.tramToCenter}
          alt={copy.routeImage}
          label={copy.routeImage}
          className="tram-center-guide__image"
        />
        <p class="tram-center-guide__note">
          <Icon name="Info" size={17} strokeWidth={2} />
          <span>{copy.note}</span>
        </p>
        <div class="tram-center-guide__actions">
          <a href={mapsHref} target="_blank" rel="noopener noreferrer">
            <Icon name="Navigation" size={18} strokeWidth={2} />
            <span>{copy.maps}</span>
          </a>
          <a href={jakdojadeHref} target="_blank" rel="noopener noreferrer">
            <Icon name="TramFront" size={18} strokeWidth={2} />
            <span>{copy.jakdojade}</span>
          </a>
          <button type="button" data-tram-campy data-prompt={copy.campyPrompt}>
            <Icon name="BotMessageSquare" size={18} strokeWidth={2} />
            <span>{copy.campy}</span>
          </button>
          <a href={attractionsHref}>
            <Icon name="Landmark" size={18} strokeWidth={2} />
            <span>{copy.attractions}</span>
          </a>
        </div>
      </article>

      <div class="tram-center-guide__facts">
        {copy.facts.map((fact, index) => (
          <article class="premium-card tram-center-guide__fact" style={`--fact-delay: ${index * 70}ms`}>
            <span aria-hidden="true">
              <Icon name={fact.icon} size={21} strokeWidth={2} />
            </span>
            <h3>{fact.title}</h3>
            <p>{fact.copy}</p>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  (() => {
    document.querySelectorAll('[data-tram-campy]').forEach((button) => {
      if (!(button instanceof HTMLButtonElement)) return;
      button.addEventListener('click', () => {
        window.dispatchEvent(new CustomEvent('campy:prompt', {
          detail: {
            prompt: button.dataset.prompt || 'Jak dojadę do centrum?',
            actionKey: 'centerTransit',
          },
        }));
      });
    });
  })();
</script>

<style>
.tram-center-guide {
  position: relative;
  overflow: hidden;
  padding: clamp(54px, 8vw, 104px) 0;
  background:
    radial-gradient(circle at 12% 10%, rgba(60,179,113,.20), transparent 34%),
    radial-gradient(circle at 88% 16%, rgba(242,192,120,.14), transparent 30%),
    linear-gradient(180deg, #f7f8f3, #edf5ec);
}

.tram-center-guide--page {
  background:
    radial-gradient(circle at 12% 10%, rgba(60,179,113,.20), transparent 34%),
    radial-gradient(circle at 88% 16%, rgba(242,192,120,.14), transparent 30%),
    linear-gradient(180deg, #101b14, #14261a);
}

.tram-center-guide::before {
  content: '';
  position: absolute;
  inset: 0;
  opacity: .14;
  pointer-events: none;
  background:
    repeating-linear-gradient(135deg, rgba(255,255,255,.18) 0 1px, transparent 1px 28px),
    linear-gradient(90deg, transparent, rgba(60,179,113,.16), transparent);
  mask-image: radial-gradient(circle at 58% 20%, #000, transparent 72%);
}

.tram-center-guide__inner {
  position: relative;
  z-index: 1;
  display: grid;
  gap: clamp(24px, 4vw, 40px);
}

.tram-center-guide__head {
  max-width: 860px;
}

.tram-center-guide--page .section-title,
.tram-center-guide--page .section-copy {
  color: #fff;
}

.tram-center-guide--page .section-copy {
  color: rgba(255,255,255,.75);
}

.tram-center-guide--page .section-kicker {
  color: #8fe0b4;
}

.tram-center-guide__layout {
  display: grid;
  grid-template-columns: minmax(0, 1.06fr) minmax(320px, .94fr);
  gap: clamp(18px, 3vw, 28px);
  align-items: start;
}

.tram-center-guide__route {
  position: sticky;
  top: 102px;
  display: grid;
  gap: 22px;
  padding: clamp(24px, 3vw, 34px);
  border-radius: 30px;
