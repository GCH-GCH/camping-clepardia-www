---
import { getTranslations } from '@/i18n/config';
import { getLocalizedPath, getPathContext } from '@/utils/localizedLinks';
import Icon from '@/components/ui/Icon.astro';

interface Props {
  languageCode?: string;
}

const { languageCode } = Astro.props as Props;
const pathContext = getPathContext(Astro.url.pathname);
const t = getTranslations(languageCode ?? pathContext.languageCode);
const contactHref = getLocalizedPath(pathContext.explicitLanguage, 'kontakt');
const lang = languageCode ?? pathContext.languageCode;
const hints = {
  pl: {
    date: 'Wybierz w pełnym formularzu',
    stay: 'Kamper, namiot, przyczepa lub domek',
  },
  en: {
    date: 'Choose in the full form',
    stay: 'Camper, tent, caravan or bungalow',
  },
  de: {
    date: 'Im vollständigen Formular wählen',
    stay: 'Camper, Zelt, Wohnwagen oder Bungalow',
  },
  it: {
    date: 'Scegli nel modulo completo',
    stay: 'Camper, tenda, roulotte o bungalow',
  },
}[lang] ?? {
  date: 'Choose in the full form',
  stay: 'Camper, tent, caravan or bungalow',
};
---

<section class="site-section booking reveal-section" id="rezerwacja">
  <div class="container">
    <div class="booking__panel">
      <div>
        <span class="section-kicker">{t.form.kicker}</span>
        <h2 class="section-title">{t.pages.kontakt.title}</h2>
        <p class="section-copy">{t.pages.kontakt.lead}</p>
      </div>
      <div class="home-inquiry-card" aria-label={t.form.kicker}>
        <div class="home-inquiry-grid" role="group" aria-label={t.form.kicker}>
          <div class="home-inquiry-field">
            <span class="home-inquiry-field__label">
              <Icon name="calendar" size={16} />
              <span>{t.form.arrival}</span>
            </span>
            <strong>{hints.date}</strong>
          </div>
          <div class="home-inquiry-field">
            <span class="home-inquiry-field__label">
              <Icon name="calendar" size={16} />
              <span>{t.form.departure}</span>
            </span>
            <strong>{hints.date}</strong>
          </div>
          <div class="home-inquiry-field">
            <span class="home-inquiry-field__label">
              <Icon name="camping" size={16} />
              <span>{t.form.stayType}</span>
            </span>
            <strong>{hints.stay}</strong>
          </div>
          <div class="home-inquiry-action">
            <a class="btn btn-primary premium-button home-inquiry-submit" href={contactHref}>
              <span>{t.form.homeCtaButton}</span>
              <Icon name="ArrowUpRight" size={17} />
            </a>
          </div>
        </div>
        <p class="booking__note">{t.form.homeMiniNote}</p>
      </div>
    </div>
  </div>
</section>

<style>
.booking { background: #fffaf2; }
.booking__panel { width: 100%; min-width: 0; display: grid; gap: 34px; padding: clamp(28px, 5vw, 56px); border-radius: 36px; background: linear-gradient(135deg, rgba(14,34,23,.96), rgba(30,70,47,.94)), radial-gradient(circle at 80% 10%, rgba(244,176,97,.24), transparent 34%); color: #fff; box-shadow: 0 34px 100px rgba(13,34,23,.24); }
.booking__panel > div:first-child { max-width: 780px; }
.booking .section-title { color: #fff; }
.booking .section-copy { color: rgba(255,255,255,.78); }
.booking .section-kicker { color: #8fe0b4; }
.home-inquiry-card { width: 100%; max-width: 100%; min-width: 0; display: grid; gap: 16px; padding: clamp(18px, 3vw, 24px); border-radius: 28px; border: 1px solid rgba(143,224,180,.22); background: radial-gradient(circle at 12% 0%, rgba(60,179,113,.18), transparent 36%), linear-gradient(145deg, rgba(255,255,255,.115), rgba(255,255,255,.065)); box-shadow: inset 0 1px 0 rgba(255,255,255,.12), 0 20px 58px rgba(0,0,0,.14), 0 0 28px rgba(60,179,113,.10); box-sizing: border-box; }
.home-inquiry-grid { width: 100%; max-width: 100%; min-width: 0; display: grid; grid-template-columns: 1fr; gap: 14px; align-items: end; }
.home-inquiry-field { display: flex; flex-direction: column; gap: 10px; min-width: 0; width: 100%; margin: 0; padding: 16px; border: 1px solid rgba(255,255,255,.12); border-radius: 22px; background: rgba(255,255,255,.075); box-shadow: inset 0 1px 0 rgba(255,255,255,.08); }
.home-inquiry-field__label { display: inline-flex; align-items: center; gap: 8px; color: rgba(255,255,255,.84); font-size: .74rem; font-weight: 950; line-height: 1.2; text-transform: uppercase; letter-spacing: .09em; }
.home-inquiry-field strong { display: block; color: #fff; font-size: clamp(.98rem, 1.2vw, 1.08rem); font-weight: 900; line-height: 1.22; letter-spacing: 0; }
.home-inquiry-action { display: flex; min-width: 0; width: 100%; align-self: stretch; }
.home-inquiry-submit { min-height: 74px; height: 100%; align-self: stretch; width: 100%; gap: 9px; border-radius: 24px; background: linear-gradient(135deg, #63d99c, #3CB371 48%, #24794e); color: #fff; font-weight: 950; letter-spacing: .04em; text-transform: none; box-shadow: 0 18px 48px rgba(60,179,113,.32); white-space: normal; }
.booking__note { grid-column: 1 / -1; margin: 0; color: rgba(255,255,255,.68); font-size: .92rem; line-height: 1.55; }
@media (min-width: 760px) { .home-inquiry-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); } .home-inquiry-action { grid-column: 1 / -1; } }
@media (min-width: 1120px) { .home-inquiry-grid { grid-template-columns: repeat(3, minmax(0, 1fr)) minmax(220px, auto); } .home-inquiry-action { grid-column: auto; } .home-inquiry-submit { min-width: 220px; padding-inline: 28px; } }
@media (max-width: 899px) { .booking__panel { padding: 24px; border-radius: 30px; } .home-inquiry-card { border-radius: 24px; } }
@media (max-width: 520px) { .booking__panel { padding: 20px; } .home-inquiry-submit { min-height: 58px; white-space: normal; } }
</style>
