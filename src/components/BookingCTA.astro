---
import { getTranslations } from '@/i18n/config';
import { getLocalizedPath, getPathContext } from '@/utils/localizedLinks';
import Icon from '@/components/ui/Icon.astro';

interface Props {
  languageCode?: string;
}

const { languageCode } = Astro.props as Props;
const pathContext = getPathContext(Astro.url.pathname);
const t = getTranslations(languageCode ?? pathContext.languageCode);
const contactHref = getLocalizedPath(pathContext.explicitLanguage, 'kontakt');
const lang = languageCode ?? pathContext.languageCode;
const bookingCopy = {
  pl: {
    title: 'Zapytaj o dostępność pobytu',
    copy: 'Wybierz termin i typ pobytu w formularzu kontaktowym. Recepcja Camping Clepardia potwierdzi dostępność, cenę i szczegóły przyjazdu.',
    steps: [
      { icon: 'calendar', label: 'Wybierz termin' },
      { icon: 'camping', label: 'Podaj typ pobytu' },
      { icon: 'message', label: 'Otrzymaj potwierdzenie' },
    ],
    button: 'Przejdź do formularza',
  },
  en: {
    title: 'Ask about availability',
    copy: 'Choose your dates and stay type in the contact form. Camping Clepardia reception will confirm availability, price and arrival details.',
    steps: [
      { icon: 'calendar', label: 'Choose dates' },
      { icon: 'camping', label: 'Add stay type' },
      { icon: 'message', label: 'Receive confirmation' },
    ],
    button: 'Go to the form',
  },
  de: {
    title: 'Verfügbarkeit anfragen',
    copy: 'Wählen Sie Termin und Aufenthaltsart im Kontaktformular. Die Rezeption von Camping Clepardia bestätigt Verfügbarkeit, Preis und Anreiseinformationen.',
    steps: [
      { icon: 'calendar', label: 'Termin wählen' },
      { icon: 'camping', label: 'Aufenthalt angeben' },
      { icon: 'message', label: 'Bestätigung erhalten' },
    ],
    button: 'Zum Formular',
  },
  it: {
    title: 'Richiedi disponibilità',
    copy: 'Scegli date e tipo di soggiorno nel modulo contatti. La reception di Camping Clepardia confermerà disponibilità, prezzo e dettagli di arrivo.',
    steps: [
      { icon: 'calendar', label: 'Scegli le date' },
      { icon: 'camping', label: 'Indica il soggiorno' },
      { icon: 'message', label: 'Ricevi conferma' },
    ],
    button: 'Vai al modulo',
  },
}[lang] ?? {
  title: 'Ask about availability',
  copy: 'Choose your dates and stay type in the contact form. Camping Clepardia reception will confirm availability, price and arrival details.',
  steps: [
    { icon: 'calendar', label: 'Choose dates' },
    { icon: 'camping', label: 'Add stay type' },
    { icon: 'message', label: 'Receive confirmation' },
  ],
  button: 'Go to the form',
};
---

<section class="site-section booking reveal-section" id="rezerwacja">
  <div class="container">
    <div class="booking__panel">
      <div class="booking__content">
        <span class="section-kicker">{t.form.kicker}</span>
        <h2 class="section-title">{bookingCopy.title}</h2>
        <p class="section-copy">{bookingCopy.copy}</p>
      </div>

      <div class="home-inquiry-card" aria-label={t.form.kicker}>
        <div class="home-inquiry-grid" role="list" aria-label={t.form.kicker}>
          {bookingCopy.steps.map((step, index) => (
            <div class="home-inquiry-field" role="listitem">
              <span class="home-inquiry-field__icon" aria-hidden="true">
                <Icon name={step.icon} size={21} strokeWidth={1.9} />
              </span>
              <span class="home-inquiry-field__number">{String(index + 1).padStart(2, '0')}</span>
              <strong>{step.label}</strong>
            </div>
          ))}
        </div>
        <a class="btn btn-primary premium-button home-inquiry-submit" href={contactHref}>
          <span>{bookingCopy.button}</span>
          <Icon name="ArrowUpRight" size={17} />
        </a>
      </div>
    </div>
  </div>
</section>

<style>
.booking { background: #fffaf2; }
.booking__panel { position: relative; width: 100%; min-width: 0; display: grid; gap: clamp(28px, 4vw, 46px); padding: clamp(28px, 5vw, 60px); border-radius: 38px; overflow: hidden; background: radial-gradient(circle at 84% 12%, rgba(242,192,120,.22), transparent 34%), radial-gradient(circle at 14% 80%, rgba(60,179,113,.22), transparent 34%), linear-gradient(135deg, rgba(10,29,19,.97), rgba(22,62,40,.94)); color: #fff; box-shadow: 0 34px 100px rgba(13,34,23,.24), 0 0 54px rgba(60,179,113,.14); }
.booking__panel::before { content: ''; position: absolute; inset: 1px; border-radius: inherit; pointer-events: none; background: linear-gradient(115deg, rgba(255,255,255,.14), transparent 28%, transparent 72%, rgba(143,224,180,.12)); mask-image: linear-gradient(#000, transparent 64%); }
.booking__content,
.home-inquiry-card { position: relative; z-index: 1; }
.booking__content { max-width: 720px; }
.booking .section-title { color: #fff; }
.booking .section-copy { color: rgba(255,255,255,.78); }
.booking .section-kicker { color: #8fe0b4; }
.home-inquiry-card { width: 100%; max-width: 100%; min-width: 0; display: grid; gap: 18px; padding: clamp(18px, 3vw, 26px); border-radius: 30px; border: 1px solid rgba(143,224,180,.24); background: radial-gradient(circle at 12% 0%, rgba(60,179,113,.20), transparent 36%), linear-gradient(145deg, rgba(255,255,255,.125), rgba(255,255,255,.065)); box-shadow: inset 0 1px 0 rgba(255,255,255,.13), 0 20px 58px rgba(0,0,0,.14), 0 0 28px rgba(60,179,113,.10); box-sizing: border-box; }
.home-inquiry-grid { width: 100%; max-width: 100%; min-width: 0; display: grid; grid-template-columns: 1fr; gap: 14px; }
.home-inquiry-field { position: relative; display: grid; grid-template-columns: auto minmax(0, 1fr); grid-template-areas: "icon number" "icon label"; gap: 5px 14px; min-width: 0; width: 100%; margin: 0; padding: 17px; border: 1px solid rgba(255,255,255,.13); border-radius: 22px; background: rgba(255,255,255,.075); box-shadow: inset 0 1px 0 rgba(255,255,255,.08); transition: transform .28s cubic-bezier(.22,1,.36,1), border-color .28s ease, background .28s ease; }
.home-inquiry-field:hover { transform: translateY(-3px); border-color: rgba(143,224,180,.34); background: rgba(255,255,255,.105); }
.home-inquiry-field__icon { grid-area: icon; display: grid; width: 48px; height: 48px; place-items: center; border: 1px solid rgba(143,224,180,.34); border-radius: 18px; color: #fff; background: linear-gradient(135deg, rgba(60,179,113,.92), rgba(35,119,73,.70)); box-shadow: 0 14px 34px rgba(60,179,113,.24); }
.home-inquiry-field__number { grid-area: number; color: rgba(143,224,180,.86); font-size: .68rem; font-weight: 950; letter-spacing: .14em; }
.home-inquiry-field strong { grid-area: label; display: block; color: #fff; font-size: clamp(1rem, 1.3vw, 1.14rem); font-weight: 950; line-height: 1.18; letter-spacing: 0; }
.home-inquiry-submit { min-height: 62px; justify-self: start; gap: 9px; border-radius: 999px; background: linear-gradient(135deg, #63d99c, #3CB371 48%, #24794e); color: #fff; font-weight: 950; letter-spacing: .04em; text-transform: none; box-shadow: 0 18px 48px rgba(60,179,113,.32); white-space: normal; }
@media (min-width: 760px) { .home-inquiry-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); } }
@media (min-width: 1080px) { .booking__panel { grid-template-columns: minmax(0, .82fr) minmax(470px, 1fr); align-items: center; } }
@media (max-width: 899px) { .booking__panel { padding: 24px; border-radius: 30px; } .home-inquiry-card { border-radius: 24px; } }
@media (max-width: 520px) { .booking__panel { padding: 20px; } .home-inquiry-submit { width: 100%; min-height: 58px; white-space: normal; } }
</style>
