---
import { getTranslations } from '@/i18n/config';
import { getLocalizedPath, getPathContext } from '@/utils/localizedLinks';

interface Props {
  languageCode?: string;
}

const { languageCode } = Astro.props as Props;
const pathContext = getPathContext(Astro.url.pathname);
const t = getTranslations(languageCode ?? pathContext.languageCode);
const contactHref = getLocalizedPath(pathContext.explicitLanguage, 'kontakt');
---

<section class="site-section booking reveal-section" id="rezerwacja">
  <div class="container">
    <div class="booking__panel">
      <div>
        <span class="section-kicker">{t.form.kicker}</span>
        <h2 class="section-title">{t.pages.kontakt.title}</h2>
        <p class="section-copy">{t.pages.kontakt.lead}</p>
      </div>
      <div class="home-inquiry-card" aria-label={t.form.kicker}>
        <div class="home-inquiry-grid">
          <label class="home-inquiry-field">
            <span>{t.form.arrival}</span>
            <input type="date" />
          </label>
          <label class="home-inquiry-field">
            <span>{t.form.departure}</span>
            <input type="date" />
          </label>
          <label class="home-inquiry-field">
            <span>{t.form.stayType}</span>
            <select>
              <option>{t.pricing.stayTypes.camper}</option>
              <option>{t.pricing.stayTypes['tent-small']}</option>
              <option>{t.pricing.stayTypes.caravan}</option>
              <option>{t.pricing.stayTypes['bungalow-2']}</option>
            </select>
          </label>
          <a class="btn btn-primary premium-button home-inquiry-submit" href={contactHref}>{t.form.homeCtaButton}</a>
        </div>
        <p class="booking__note">{t.form.homeMiniNote}</p>
      </div>
    </div>
  </div>
</section>

<style>
.booking { background: #fffaf2; }
.booking__panel { display: grid; gap: 34px; padding: clamp(28px, 5vw, 56px); border-radius: 36px; background: linear-gradient(135deg, rgba(14,34,23,.96), rgba(30,70,47,.94)), radial-gradient(circle at 80% 10%, rgba(244,176,97,.24), transparent 34%); color: #fff; box-shadow: 0 34px 100px rgba(13,34,23,.24); }
.booking .section-title { color: #fff; }
.booking .section-copy { color: rgba(255,255,255,.78); }
.booking .section-kicker { color: #8fe0b4; }
.home-inquiry-card { width: 100%; display: grid; gap: 14px; padding: clamp(18px, 3vw, 24px); border-radius: 28px; border: 1px solid rgba(143,224,180,.22); background: radial-gradient(circle at 12% 0%, rgba(60,179,113,.18), transparent 36%), linear-gradient(145deg, rgba(255,255,255,.115), rgba(255,255,255,.065)); box-shadow: inset 0 1px 0 rgba(255,255,255,.12), 0 20px 58px rgba(0,0,0,.14), 0 0 28px rgba(60,179,113,.10); }
.home-inquiry-grid { width: 100%; display: grid; grid-template-columns: 1fr; gap: 14px; align-items: end; }
.home-inquiry-field { display: grid; gap: 9px; min-width: 0; width: 100%; }
.home-inquiry-field span { display: block; color: rgba(255,255,255,.78); font-size: .74rem; font-weight: 950; line-height: 1.2; text-transform: uppercase; letter-spacing: .09em; }
.home-inquiry-field input, .home-inquiry-field select { display: block; width: 100%; min-width: 0; min-height: 56px; border: 1px solid rgba(255,255,255,.18); border-radius: 18px; background: rgba(255,255,255,.12); color: #fff; padding: 0 16px; font: inherit; font-size: .96rem; font-weight: 800; letter-spacing: 0; text-transform: none; appearance: none; }
.home-inquiry-field input:focus-visible, .home-inquiry-field select:focus-visible { outline: 0; border-color: rgba(143,224,180,.62); box-shadow: 0 0 0 4px rgba(60,179,113,.18); background: rgba(255,255,255,.16); }
.home-inquiry-field option { color: #102018; }
.home-inquiry-submit { min-height: 56px; align-self: end; width: 100%; border-radius: 999px; background: linear-gradient(135deg, #63d99c, #3CB371 48%, #24794e); color: #fff; font-weight: 950; letter-spacing: .04em; text-transform: none; box-shadow: 0 18px 48px rgba(60,179,113,.32); white-space: nowrap; }
.booking__note { grid-column: 1 / -1; margin: 0; color: rgba(255,255,255,.68); font-size: .92rem; line-height: 1.55; }
@media (min-width: 900px) { .booking__panel { grid-template-columns: .88fr 1.12fr; align-items: center; } .home-inquiry-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); } .home-inquiry-submit { grid-column: 1 / -1; } }
@media (min-width: 1120px) { .home-inquiry-grid { grid-template-columns: minmax(0, 1fr) minmax(0, 1fr) minmax(190px, 1fr) auto; } .home-inquiry-submit { grid-column: auto; min-width: 210px; padding-inline: 28px; } }
@media (max-width: 520px) { .home-inquiry-submit { min-height: 58px; white-space: normal; } }
</style>
