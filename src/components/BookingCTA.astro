---
import { getLocalizedPath, getPathContext } from '@/utils/localizedLinks';
import { resolveContentLanguage } from '@/i18n/config';
import Icon from '@/components/ui/Icon.astro';

interface Props {
  languageCode?: string;
}

const { languageCode } = Astro.props as Props;
const pathContext = getPathContext(Astro.url.pathname);
const explicitLanguage = pathContext.explicitLanguage ?? (languageCode && languageCode !== 'pl' ? languageCode : undefined);
const lang = resolveContentLanguage(languageCode ?? pathContext.languageCode);
const contactHref = getLocalizedPath(explicitLanguage, 'kontakt');

const copy = {
  pl: {
    kicker: 'Szybkie zapytanie',
    title: 'Zapytaj o dostępność pobytu',
    lead: 'Wybierz ścieżkę pobytu. Pełny formularz otworzy się już z dopasowanymi polami, a recepcja potwierdzi dostępność, cenę i szczegóły przyjazdu.',
    button: 'Przejdź do formularza',
    choices: {
      camping: { title: 'Camping', text: 'Kamper, przyczepa, namiot, van albo auto z namiotem dachowym.', icon: 'camping' },
      bungalow: { title: 'Domki', text: 'Domki 2-, 3- i 4-osobowe. Bez domku rodzinnego i bez tarasów.', icon: 'bungalow' },
      combined: { title: 'Razem', text: 'Domek oraz miejsce campingowe w jednym zapytaniu.', icon: 'UsersRound' },
    },
  },
  en: {
    kicker: 'Quick enquiry',
    title: 'Ask about stay availability',
    lead: 'Choose your stay path. The full form opens with the right fields, and reception confirms availability, price and arrival details.',
    button: 'Go to the form',
    choices: {
      camping: { title: 'Camping', text: 'Motorhome, caravan, tent, van or car with rooftop tent.', icon: 'camping' },
      bungalow: { title: 'Bungalows', text: '2-, 3- and 4-person bungalows only.', icon: 'bungalow' },
      combined: { title: 'Combined', text: 'A bungalow and a camping pitch in one enquiry.', icon: 'UsersRound' },
    },
  },
  de: {
    kicker: 'Schnelle Anfrage',
    title: 'Verfügbarkeit anfragen',
    lead: 'Wählen Sie die passende Aufenthaltsart. Das vollständige Formular öffnet mit passenden Feldern, die Rezeption bestätigt Verfügbarkeit, Preis und Anreise.',
    button: 'Zum Formular',
    choices: {
      camping: { title: 'Camping', text: 'Wohnmobil, Wohnwagen, Zelt, Van oder Auto mit Dachzelt.', icon: 'camping' },
      bungalow: { title: 'Bungalows', text: 'Nur Bungalows für 2, 3 und 4 Personen.', icon: 'bungalow' },
      combined: { title: 'Kombiniert', text: 'Bungalow und Campingplatz in einer Anfrage.', icon: 'UsersRound' },
    },
  },
  it: {
    kicker: 'Richiesta rapida',
    title: 'Richiedi disponibilità',
    lead: 'Scegli il tipo di soggiorno. Il modulo completo si apre con i campi giusti e la reception conferma disponibilità, prezzo e arrivo.',
    button: 'Vai al modulo',
    choices: {
      camping: { title: 'Camping', text: 'Camper, roulotte, tenda, van o auto con tenda da tetto.', icon: 'camping' },
      bungalow: { title: 'Bungalow', text: 'Solo bungalow da 2, 3 e 4 persone.', icon: 'bungalow' },
      combined: { title: 'Combinato', text: 'Bungalow e piazzola camping in una richiesta.', icon: 'UsersRound' },
    },
  },
}[lang];

const choices = [
  ['camping', copy.choices.camping],
  ['bungalow', copy.choices.bungalow],
  ['combined', copy.choices.combined],
] as const;
---

<section class="site-section booking reveal-section" id="rezerwacja">
  <div class="container">
    <div class="booking__panel">
      <div class="booking__content">
        <span class="section-kicker">{copy.kicker}</span>
        <h2 class="section-title">{copy.title}</h2>
        <p class="section-copy">{copy.lead}</p>
      </div>

      <div class="home-inquiry-card" aria-label={copy.title}>
        {choices.map(([stay, item]) => (
          <a class="home-inquiry-choice" href={`${contactHref}?stay=${stay}`}>
            <span class="home-inquiry-choice__icon" aria-hidden="true">
              <Icon name={item.icon} size={24} strokeWidth={1.9} />
            </span>
            <strong>{item.title}</strong>
            <small>{item.text}</small>
            <em>{copy.button}<Icon name="ArrowUpRight" size={16} /></em>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
.booking {
  background:
    radial-gradient(circle at 16% 0%, rgba(60,179,113,.13), transparent 32%),
    radial-gradient(circle at 82% 12%, rgba(242,192,120,.13), transparent 30%),
    #fffaf2;
}

.booking__panel {
  position: relative;
  display: grid;
  gap: clamp(26px, 4vw, 46px);
  padding: clamp(24px, 5vw, 58px);
  border-radius: 38px;
  overflow: hidden;
  background:
    radial-gradient(circle at 84% 12%, rgba(242,192,120,.22), transparent 34%),
    radial-gradient(circle at 14% 80%, rgba(60,179,113,.22), transparent 34%),
    linear-gradient(135deg, rgba(10,29,19,.97), rgba(22,62,40,.94));
  color: #fff;
  box-shadow: 0 34px 100px rgba(13,34,23,.24), 0 0 54px rgba(60,179,113,.14);
}

.booking__content,
.home-inquiry-card {
  position: relative;
  z-index: 1;
}

.booking__content {
  max-width: 720px;
}

.booking .section-title { color: #fff; }
.booking .section-copy { color: rgba(255,255,255,.78); }
.booking .section-kicker { color: #8fe0b4; }

.home-inquiry-card {
  display: grid;
  grid-template-columns: 1fr;
  gap: 14px;
  padding: clamp(18px, 3vw, 26px);
  border: 1px solid rgba(143,224,180,.24);
  border-radius: 30px;
  background:
    radial-gradient(circle at 12% 0%, rgba(60,179,113,.20), transparent 36%),
    linear-gradient(145deg, rgba(255,255,255,.125), rgba(255,255,255,.065));
  box-shadow: inset 0 1px 0 rgba(255,255,255,.13), 0 20px 58px rgba(0,0,0,.14);
}

.home-inquiry-choice {
  position: relative;
  display: grid;
  grid-template-columns: auto minmax(0, 1fr);
  gap: 5px 14px;
  min-height: 168px;
  padding: clamp(18px, 3vw, 24px);
  border: 1px solid rgba(255,255,255,.14);
  border-radius: 26px;
  background:
    radial-gradient(circle at 96% 0%, rgba(60,179,113,.16), transparent 34%),
    rgba(255,255,255,.075);
  color: #fff;
  text-decoration: none;
  transition: transform .24s ease, border-color .24s ease, background .24s ease, box-shadow .24s ease;
}

.home-inquiry-choice__icon {
  grid-row: span 2;
  display: grid;
  width: 54px;
  height: 54px;
  place-items: center;
  border-radius: 20px;
  background: linear-gradient(135deg, rgba(99,217,156,.96), rgba(60,179,113,.86) 52%, rgba(36,121,78,.82));
  box-shadow: 0 16px 38px rgba(60,179,113,.26);
}

.home-inquiry-choice strong {
  align-self: end;
  color: #fff;
  font-size: 1.18rem;
  font-weight: 950;
}

.home-inquiry-choice small {
  color: rgba(255,255,255,.72);
  line-height: 1.48;
  font-weight: 760;
}

.home-inquiry-choice em {
  grid-column: 1 / -1;
  display: inline-flex;
  align-items: center;
  gap: 8px;
  width: fit-content;
  margin-top: 12px;
  padding: 10px 14px;
  border-radius: 999px;
  background: rgba(60,179,113,.18);
  color: #9af0bf;
  font-style: normal;
  font-weight: 950;
}

.home-inquiry-choice:hover {
  transform: translateY(-4px);
  border-color: rgba(143,224,180,.44);
  background: rgba(255,255,255,.12);
  box-shadow: 0 22px 64px rgba(60,179,113,.20);
}

@media (min-width: 760px) {
  .home-inquiry-card {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }
}

@media (min-width: 1080px) {
  .booking__panel {
    grid-template-columns: minmax(0, .78fr) minmax(560px, 1fr);
    align-items: center;
  }
}

@media (max-width: 620px) {
  .booking__panel {
    padding: 20px;
    border-radius: 30px;
  }

  .home-inquiry-card {
    border-radius: 24px;
  }

  .home-inquiry-choice {
    min-height: 146px;
  }
}
</style>
