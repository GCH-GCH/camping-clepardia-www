---
const cards = [
  ['Mister Camping 2024', 'Wyróżnienie budujące zaufanie wśród gości planujących pobyt.'],
  ['Wysoka ocena gości', 'Goście doceniają lokalizację, atmosferę i wygodę pobytu.'],
  ['Rodzinna atmosfera', 'Campingowy rytm, bez anonimowego hotelowego dystansu.'],
  ['Wiele lat doświadczenia', 'Sprawdzone miejsce dla turystów odwiedzających Kraków.'],
];
---

<section class="site-section trust reveal-section">
  <div class="container">
    <span class="section-kicker">Zaufanie</span>
    <h2 class="section-title">Miejsce wybierane przez gości, którzy chcą zwiedzać Kraków po swojemu.</h2>
    <div class="trust__grid">
      {cards.map(([title, copy]) => (
        <article class="premium-card trust__card">
          <h3>{title}</h3>
          <p>{copy}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
.trust { background: linear-gradient(180deg, #f6f8f2, #fffaf2); }
.trust__grid { margin-top: 42px; display: grid; grid-template-columns: 1fr; gap: 16px; }
.trust__card { padding: 28px; }
.trust__card h3 { font-size: 1.25rem; font-weight: 900; margin-bottom: 12px; }
.trust__card p { color: #5c685f; line-height: 1.72; }
@media (min-width: 760px) { .trust__grid { grid-template-columns: repeat(2, 1fr); } }
@media (min-width: 1120px) { .trust__grid { grid-template-columns: repeat(4, 1fr); } }
</style>
