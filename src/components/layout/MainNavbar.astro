---
import { logoMain, logoMainPng } from '@/data/assets';
import { getLanguageSwitchLinks, getLocalizedPath, getPathContext } from '@/utils/localizedLinks';
import { getTranslations } from '@/i18n/config';
import Icon from '@/components/ui/Icon.astro';

const pathContext = getPathContext(Astro.url.pathname);
const t = getTranslations(pathContext.languageCode);
const navItems = [
  { slug: '', label: t.nav.items.start },
  { slug: 'camping', label: t.nav.items.camping },
  { slug: 'domki', label: t.nav.items.domki },
  { slug: 'cennik', label: t.nav.items.cennik },
  { slug: 'dojazd', label: t.nav.items.dojazd },
  { slug: 'atrakcje', label: t.nav.items.atrakcje },
  { slug: 'galeria', label: t.nav.items.galeria },
  { slug: 'kontakt', label: t.nav.items.kontakt },
];

const currentLanguage = pathContext.currentLanguage;
const currentSlug = pathContext.slug;
const activeLanguagePrefix = pathContext.explicitLanguage;

const homeHref = getLocalizedPath(activeLanguagePrefix, '');
const contactHref = getLocalizedPath(activeLanguagePrefix, 'kontakt');
const localizedNavItems = navItems.map((item) => ({
  ...item,
  href: getLocalizedPath(activeLanguagePrefix, item.slug),
  active: item.slug === currentSlug,
}));
const languageLinks = getLanguageSwitchLinks(Astro.url.pathname);
const navMessages = {
  openMenu: t.nav.openMenu,
  closeMenu: t.nav.closeMenu,
  enableLight: t.nav.enableLight,
  enableDark: t.nav.enableDark,
  lightMode: t.nav.lightMode,
  darkMode: t.nav.darkMode,
};
---

<header class="main-navbar-shell" id="mainNavbarShell">
  <nav class="main-navbar" id="mainNavbar" aria-label={t.nav.aria}>
    <a href={homeHref} class="main-navbar__brand" aria-label={t.nav.homeAria}>
      <img class="main-navbar__logo" src={logoMain} alt="Camping Clepardia" width="180" height="46" onerror={`this.onerror=null;this.src='${logoMainPng}'`} />
    </a>

    <ul class="main-navbar__links" id="mainNavbarLinks">
      {localizedNavItems.map((item) => (
        <li>
          <a
            href={item.href}
            class:list={['main-navbar__link', item.active && 'is-active']}
            aria-current={item.active ? 'page' : undefined}
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>

    <div class="main-navbar__actions">
      <div class="main-navbar-lang" id="mainNavbarLang">
        <button
          class="main-navbar-lang__toggle"
          id="mainNavbarLangToggle"
          type="button"
          aria-label={t.nav.changeLanguage}
          aria-haspopup="menu"
          aria-expanded="false"
          aria-controls="mainNavbarLangMenu"
        >
          <img src={currentLanguage.flag} alt="" width="22" height="22" loading="eager" decoding="async" />
          <span>{currentLanguage.code.toUpperCase()}</span>
          <Icon name="chevronDown" size={15} strokeWidth={2.4} />
        </button>

        <div class="main-navbar-lang__menu" id="mainNavbarLangMenu" role="menu" aria-label={t.nav.languageList}>
          {languageLinks.map((language) => (
            <a
              href={language.href}
              class:list={['main-navbar-lang__item', language.active && 'is-active']}
              role="menuitem"
              aria-current={language.active ? 'page' : undefined}
            >
              <img src={language.flag} alt="" width="24" height="24" loading="lazy" decoding="async" />
              <span>{language.name}</span>
              <strong>{language.code.toUpperCase()}</strong>
            </a>
          ))}
        </div>
      </div>

      <button
        class="main-navbar-theme"
        type="button"
        data-theme-toggle
        aria-label={t.nav.changeTheme}
        aria-pressed="false"
      >
        <span class="main-navbar-theme__icon main-navbar-theme__icon--sun" aria-hidden="true">
          <Icon name="sun" size={19} strokeWidth={2} />
        </span>
        <span class="main-navbar-theme__icon main-navbar-theme__icon--moon" aria-hidden="true">
          <Icon name="moon" size={19} strokeWidth={2} />
        </span>
      </button>

      <a href={contactHref} class="main-navbar__cta">{t.nav.cta}</a>
    </div>

    <button
      class="main-navbar__hamburger"
      id="mainNavbarToggle"
      type="button"
      data-mobile-toggle
      aria-label={t.nav.openMenu}
      aria-expanded="false"
      aria-controls="mainNavbarMobile"
    >
      <span></span>
      <span></span>
      <span></span>
    </button>
  </nav>

  <div class="main-navbar-mobile" id="mainNavbarMobile" aria-hidden="true">
    <div class="main-navbar-mobile__panel" role="dialog" aria-modal="true" aria-label={t.nav.mobileMenu}>
      <div class="main-navbar-mobile__top">
        <a href={homeHref} class="main-navbar-mobile__brand" aria-label={t.nav.homeAria}>
          <img src={logoMain} alt="Camping Clepardia" width="164" height="42" onerror={`this.onerror=null;this.src='${logoMainPng}'`} />
        </a>
      </div>

      <ul class="main-navbar-mobile__links">
        {localizedNavItems.map((item) => (
          <li>
            <a
              href={item.href}
              class:list={['main-navbar-mobile__link', item.active && 'is-active']}
              aria-current={item.active ? 'page' : undefined}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>

      <div class="main-navbar-mobile__bottom">
        <button
          class="main-navbar-theme main-navbar-theme--mobile"
          type="button"
          data-theme-toggle
          aria-label={t.nav.changeTheme}
          aria-pressed="false"
        >
          <span class="main-navbar-theme__icon main-navbar-theme__icon--sun" aria-hidden="true">
            <Icon name="sun" size={19} strokeWidth={2} />
          </span>
          <span class="main-navbar-theme__icon main-navbar-theme__icon--moon" aria-hidden="true">
            <Icon name="moon" size={19} strokeWidth={2} />
          </span>
          <span data-theme-label>{t.nav.lightMode}</span>
        </button>

        <div class="main-navbar-mobile__languages" aria-label={t.nav.chooseLanguage}>
          {languageLinks.map((language) => (
            <a
              href={language.href}
              class:list={['main-navbar-mobile__language', language.active && 'is-active']}
              aria-label={`${language.name} ${language.code.toUpperCase()}`}
              aria-current={language.active ? 'page' : undefined}
            >
              <img src={language.flag} alt="" width="26" height="26" loading="lazy" decoding="async" />
              <span>{language.code.toUpperCase()}</span>
            </a>
          ))}
        </div>
        <a href={contactHref} class="main-navbar__cta main-navbar__cta--mobile">{t.nav.cta}</a>
      </div>
    </div>
  </div>
</header>

<script define:vars={{ navMessages }}>
  (() => {
    const shell = document.getElementById('mainNavbarShell');
    const toggle = document.getElementById('mainNavbarToggle');
    const mobile = document.getElementById('mainNavbarMobile');
    const panel = mobile?.querySelector('.main-navbar-mobile__panel');
    const lang = document.getElementById('mainNavbarLang');
    const langToggle = document.getElementById('mainNavbarLangToggle');
    const langMenu = document.getElementById('mainNavbarLangMenu');
    const mobileLinks = document.querySelectorAll('.main-navbar-mobile a, .main-navbar__cta--mobile');
    const themeToggles = document.querySelectorAll('[data-theme-toggle]');

    let mobileOpen = false;
    let langOpen = false;
    const themeWindow = window;

    const setLangOpen = (open) => {
      langOpen = open;
      lang?.classList.toggle('is-open', open);
      langToggle?.setAttribute('aria-expanded', String(open));
    };

    const setMobileOpen = (open) => {
      mobileOpen = open;
      mobile?.classList.toggle('is-open', open);
      toggle?.classList.toggle('is-open', open);
      shell?.classList.toggle('has-mobile-open', open);
      mobile?.setAttribute('aria-hidden', String(!open));
      toggle?.setAttribute('aria-expanded', String(open));
      toggle?.setAttribute('aria-label', open ? navMessages.closeMenu : navMessages.openMenu);
      document.body.classList.toggle('has-main-navbar-open', open);

      if (open) {
        setLangOpen(false);
        window.setTimeout(() => {
          const firstLink = mobile?.querySelector('a');
          if (firstLink instanceof HTMLElement) firstLink.focus({ preventScroll: true });
        }, 120);
      }
    };

    const updateScrolled = () => {
      shell?.classList.toggle('is-scrolled', window.scrollY > 24);
    };

    const syncThemeToggles = () => {
      const activeTheme = document.documentElement.dataset.theme === 'light' ? 'light' : 'dark';
      const nextTheme = activeTheme === 'dark' ? 'light' : 'dark';
      themeToggles.forEach((button) => {
        if (!(button instanceof HTMLButtonElement)) return;
        button.setAttribute('aria-pressed', String(activeTheme === 'light'));
        button.setAttribute('aria-label', nextTheme === 'light' ? navMessages.enableLight : navMessages.enableDark);
        button.dataset.currentTheme = activeTheme;
        const label = button.querySelector('[data-theme-label]');
        if (label) label.textContent = nextTheme === 'light' ? navMessages.lightMode : navMessages.darkMode;
      });
    };

    themeToggles.forEach((button) => {
      button.addEventListener('click', () => {
        const activeTheme = document.documentElement.dataset.theme === 'light' ? 'light' : 'dark';
        const nextTheme = activeTheme === 'dark' ? 'light' : 'dark';

        if (typeof themeWindow.__ccSetTheme === 'function') {
          themeWindow.__ccSetTheme(nextTheme, true);
        } else {
          document.documentElement.dataset.theme = nextTheme;
          try {
            window.localStorage.setItem('cc-theme', nextTheme);
          } catch {}
        }

        syncThemeToggles();
      });
    });

    toggle?.addEventListener('click', () => setMobileOpen(!mobileOpen));

    mobile?.addEventListener('click', (event) => {
      if (event.target === mobile) setMobileOpen(false);
    });

    panel?.addEventListener('click', (event) => {
      event.stopPropagation();
    });

    mobileLinks.forEach((link) => {
      link.addEventListener('click', () => setMobileOpen(false));
    });

    langToggle?.addEventListener('click', (event) => {
      event.stopPropagation();
      setLangOpen(!langOpen);
    });

    langMenu?.addEventListener('click', (event) => {
      event.stopPropagation();
      setLangOpen(false);
    });

    document.addEventListener('click', (event) => {
      const target = event.target;
      if (!(target instanceof Node) || !lang?.contains(target)) setLangOpen(false);
    });

    window.addEventListener('keydown', (event) => {
      if (event.key !== 'Escape') return;
      setLangOpen(false);
      if (mobileOpen) setMobileOpen(false);
    });

    window.addEventListener('scroll', updateScrolled, { passive: true });
    window.addEventListener('cc-theme-change', syncThemeToggles);
    window.addEventListener('resize', () => {
      if (window.innerWidth > 920 && mobileOpen) setMobileOpen(false);
    });

    updateScrolled();
    syncThemeToggles();
  })();
</script>

<style is:global>
body.has-main-navbar-open {
  overflow: hidden;
  touch-action: none;
}

.main-navbar-shell {
  position: fixed;
  inset: 0 0 auto;
  z-index: 1000;
  width: 100%;
  pointer-events: none;
}

.main-navbar-shell.has-mobile-open {
  z-index: 1200;
}

.main-navbar {
  position: relative;
  z-index: 2;
  width: min(1240px, calc(100% - 32px));
  height: 78px;
  margin: 16px auto 0;
  padding: 0 18px;
  display: grid;
  grid-template-columns: minmax(150px, auto) minmax(0, 1fr) auto;
  align-items: center;
  gap: 18px;
  border: 1px solid rgba(255,255,255,.10);
  border-radius: 999px;
  background: rgba(7, 23, 16, .76);
  box-shadow: 0 18px 54px rgba(0,0,0,.18), inset 0 1px 0 rgba(255,255,255,.11);
  backdrop-filter: blur(22px) saturate(140%);
  -webkit-backdrop-filter: blur(22px) saturate(140%);
  pointer-events: auto;
  transition: height .28s ease, margin .28s ease, background .28s ease, box-shadow .28s ease, border-color .28s ease;
}

.main-navbar-shell.is-scrolled .main-navbar {
  height: 64px;
  margin-top: 10px;
  background: rgba(8, 27, 18, .88);
  border-color: rgba(255,255,255,.14);
  box-shadow: 0 16px 46px rgba(0,0,0,.22), inset 0 1px 0 rgba(255,255,255,.12);
}

.main-navbar__brand,
.main-navbar-mobile__brand {
  display: inline-flex;
  align-items: center;
  min-width: 0;
}

.main-navbar__logo {
  display: block;
  height: 46px;
  max-width: 180px;
  width: auto;
  object-fit: contain;
  image-rendering: auto;
  filter: drop-shadow(0 12px 28px rgba(0,0,0,.22));
  transition: height .28s ease;
}

.main-navbar-shell.is-scrolled .main-navbar__logo {
  height: 40px;
}

.main-navbar__links {
  justify-self: center;
  display: flex;
  align-items: center;
  gap: 3px;
  margin: 0;
  padding: 0;
  list-style: none;
}

.main-navbar__link {
  display: inline-flex;
  min-height: 40px;
  align-items: center;
  justify-content: center;
  padding: 0 12px;
  border: 1px solid transparent;
  border-radius: 999px;
  color: rgba(255,255,255,.82);
  font-size: 14px;
  font-weight: 700;
  letter-spacing: -.01em;
  white-space: nowrap;
  transition: color .22s ease, background .22s ease, border-color .22s ease, box-shadow .22s ease, transform .22s ease;
}

.main-navbar__link:hover {
  color: #fff;
  background: rgba(255,255,255,.08);
  box-shadow: 0 0 28px rgba(60,179,113,.13);
  transform: translateY(-1px);
}

.main-navbar__link.is-active {
  color: #fff;
  background: rgba(60,179,113,.18);
  border-color: rgba(60,179,113,.35);
  box-shadow: 0 0 30px rgba(60,179,113,.18), inset 0 1px 0 rgba(255,255,255,.08);
}

.main-navbar__actions {
  justify-self: end;
  display: flex;
  align-items: center;
  gap: 10px;
}

.main-navbar-lang {
  position: relative;
}

.main-navbar-lang__toggle {
  min-height: 42px;
  display: inline-flex;
  align-items: center;
  gap: 7px;
  padding: 7px 11px;
  border: 1px solid rgba(255,255,255,.12);
  border-radius: 999px;
  background:
    linear-gradient(145deg, rgba(255,255,255,.095), rgba(255,255,255,.055)),
    rgba(255,255,255,.06);
  color: #fff;
  box-shadow: inset 0 1px 0 rgba(255,255,255,.08);
  font-size: 13px;
  font-weight: 800;
  letter-spacing: .03em;
  transition: background .22s ease, border-color .22s ease, transform .22s ease;
}

.main-navbar-lang__toggle:hover,
.main-navbar-lang.is-open .main-navbar-lang__toggle {
  background: rgba(60,179,113,.14);
  border-color: rgba(143,224,180,.42);
  transform: translateY(-1px);
}

.main-navbar-lang__toggle img,
.main-navbar-lang__item img,
.main-navbar-mobile__language img {
  display: block;
  border-radius: 999px;
  object-fit: cover;
  border: 1px solid rgba(143,224,180,.30);
  background: rgba(255,255,255,.12);
  box-shadow: 0 5px 14px rgba(0,0,0,.22), 0 0 0 3px rgba(60,179,113,.06);
}

.main-navbar-lang__toggle svg {
  width: 15px;
  height: 15px;
  fill: none;
  stroke: currentColor;
  stroke-width: 2.4;
  stroke-linecap: round;
  stroke-linejoin: round;
  opacity: .78;
  transition: transform .22s ease;
}

.main-navbar-lang.is-open .main-navbar-lang__toggle svg {
  transform: rotate(180deg);
}

.main-navbar-lang__menu {
  position: absolute;
  top: calc(100% + 14px);
  right: 0;
  width: 270px;
  padding: 10px;
  border: 1px solid rgba(255,255,255,.13);
  border-radius: 24px;
  background:
    radial-gradient(circle at 20% 0%, rgba(60,179,113,.10), transparent 34%),
    rgba(9, 28, 19, .94);
  box-shadow: 0 24px 70px rgba(0,0,0,.28), inset 0 1px 0 rgba(255,255,255,.11);
  backdrop-filter: blur(24px) saturate(140%);
  -webkit-backdrop-filter: blur(24px) saturate(140%);
  opacity: 0;
  visibility: hidden;
  transform: translateY(-8px) scale(.98);
  transform-origin: top right;
  transition: opacity .22s ease, visibility .22s ease, transform .22s ease;
}

.main-navbar-lang.is-open .main-navbar-lang__menu {
  opacity: 1;
  visibility: visible;
  transform: translateY(0) scale(1);
}

.main-navbar-lang__item {
  display: grid;
  grid-template-columns: 24px 1fr auto;
  align-items: center;
  gap: 10px;
  padding: 11px 12px;
  border: 1px solid transparent;
  border-radius: 16px;
  color: rgba(255,255,255,.84);
  font-size: 14px;
  font-weight: 750;
  transition: color .2s ease, background .2s ease, transform .2s ease, border-color .2s ease;
}

.main-navbar-lang__item strong {
  color: #8fe0b4;
  font-size: 12px;
  letter-spacing: .06em;
}

.main-navbar-lang__item:hover,
.main-navbar-lang__item.is-active {
  color: #fff;
  border-color: rgba(60,179,113,.24);
  background: rgba(60,179,113,.16);
  transform: translateX(2px);
}

.main-navbar-theme {
  width: 44px;
  height: 44px;
  display: inline-grid;
  place-items: center;
  border: 1px solid rgba(255,255,255,.12);
  border-radius: 999px;
  color: #fff;
  background: rgba(255,255,255,.075);
  box-shadow: inset 0 1px 0 rgba(255,255,255,.08);
  transition: transform .22s ease, border-color .22s ease, background .22s ease, box-shadow .22s ease, color .22s ease;
}

.main-navbar-theme:hover {
  color: #fff;
  transform: translateY(-1px);
  border-color: rgba(143,224,180,.42);
  background: rgba(255,255,255,.13);
  box-shadow: 0 0 28px rgba(60,179,113,.16), inset 0 1px 0 rgba(255,255,255,.12);
}

.main-navbar-theme__icon {
  grid-area: 1 / 1;
  display: grid;
  place-items: center;
  transition: opacity .24s ease, transform .24s ease;
}

.main-navbar-theme svg {
  width: 19px;
  height: 19px;
  fill: none;
  stroke: currentColor;
  stroke-width: 2;
  stroke-linecap: round;
  stroke-linejoin: round;
}

html[data-theme="dark"] .main-navbar-theme__icon--moon,
html[data-theme="light"] .main-navbar-theme__icon--sun {
  opacity: 0;
  transform: scale(.72) rotate(-24deg);
}

html[data-theme="dark"] .main-navbar-theme__icon--sun,
html[data-theme="light"] .main-navbar-theme__icon--moon {
  opacity: 1;
  transform: scale(1) rotate(0deg);
}

.main-navbar-theme--mobile {
  width: 100%;
  height: 56px;
  grid-template-columns: auto auto 1fr;
  justify-content: start;
  gap: 10px;
  padding: 0 16px;
  border-radius: 18px;
  color: rgba(255,255,255,.92);
  font-weight: 850;
  letter-spacing: .02em;
}

.main-navbar-theme--mobile .main-navbar-theme__icon {
  position: relative;
  grid-area: auto;
}

.main-navbar-theme--mobile .main-navbar-theme__icon--moon {
  margin-left: -29px;
}

.main-navbar-theme--mobile [data-theme-label] {
  margin-left: 4px;
  text-align: left;
}

.main-navbar__cta {
  position: relative;
  overflow: hidden;
  display: inline-flex;
  min-height: 44px;
  align-items: center;
  justify-content: center;
  padding: 0 20px;
  border-radius: 999px;
  color: #fff;
  background: linear-gradient(135deg, #3CB371, #2f9d63);
  box-shadow: 0 16px 38px rgba(60,179,113,.34), inset 0 1px 0 rgba(255,255,255,.22);
  font-size: 13px;
  font-weight: 850;
  letter-spacing: .01em;
  white-space: nowrap;
  transition: transform .22s ease, box-shadow .22s ease;
}

.main-navbar__cta::before {
  content: '';
  position: absolute;
  inset: -80% auto -80% -35%;
  width: 34%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,.48), transparent);
  transform: translateX(-140%) rotate(18deg);
  transition: transform .72s ease;
}

.main-navbar__cta:hover {
  color: #fff;
  transform: translateY(-2px);
  box-shadow: 0 22px 58px rgba(60,179,113,.48), inset 0 1px 0 rgba(255,255,255,.26);
}

.main-navbar__cta:hover::before {
  transform: translateX(430%) rotate(18deg);
}

.main-navbar__hamburger {
  display: none;
  width: 48px;
  height: 48px;
  justify-self: end;
  place-content: center;
  gap: 5px;
  border: 1px solid rgba(255,255,255,.12);
  border-radius: 16px;
  background: rgba(255,255,255,.08);
  transition: background .22s ease, border-color .22s ease;
}

.main-navbar__hamburger span {
  display: block;
  width: 23px;
  height: 2px;
  border-radius: 99px;
  background: #fff;
  transition: transform .25s ease, opacity .2s ease;
}

.main-navbar__hamburger.is-open {
  background: rgba(255,255,255,.14);
  border-color: rgba(143,224,180,.38);
}

.main-navbar__hamburger.is-open span:first-child {
  transform: translateY(7px) rotate(45deg);
}

.main-navbar__hamburger.is-open span:nth-child(2) {
  opacity: 0;
}

.main-navbar__hamburger.is-open span:last-child {
  transform: translateY(-7px) rotate(-45deg);
}

.main-navbar-mobile {
  position: fixed;
  inset: 0;
  z-index: 1200;
  pointer-events: auto;
  opacity: 0;
  visibility: hidden;
  background:
    radial-gradient(circle at 14% 12%, rgba(60,179,113,.20), transparent 34%),
    radial-gradient(circle at 82% 78%, rgba(242,192,120,.16), transparent 38%),
    rgba(7, 20, 15, .86);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  transition: opacity .28s ease, visibility .28s ease;
}

.main-navbar-mobile.is-open {
  opacity: 1;
  visibility: visible;
}

.main-navbar-mobile__panel {
  min-height: 100svh;
  display: flex;
  flex-direction: column;
  padding: 104px 24px max(28px, env(safe-area-inset-bottom));
  opacity: 0;
  transform: translateY(20px);
  transition: opacity .34s ease .04s, transform .34s ease .04s;
}

.main-navbar-mobile.is-open .main-navbar-mobile__panel {
  opacity: 1;
  transform: translateY(0);
}

.main-navbar-mobile__top {
  display: flex;
  justify-content: center;
  margin-bottom: 26px;
}

.main-navbar-mobile__brand img {
  height: 42px;
  width: auto;
  object-fit: contain;
  image-rendering: auto;
  filter: drop-shadow(0 18px 38px rgba(60,179,113,.24));
}

.main-navbar-mobile__links {
  display: grid;
  gap: 0;
  margin: 0;
  padding: 0;
  list-style: none;
}

.main-navbar-mobile__link {
  display: flex;
  min-height: 58px;
  align-items: center;
  border-bottom: 1px solid rgba(255,255,255,.10);
  color: #fff;
  font-size: 28px;
  font-weight: 800;
  line-height: 1;
  letter-spacing: -.02em;
}

.main-navbar-mobile__link.is-active {
  color: #8fe0b4;
