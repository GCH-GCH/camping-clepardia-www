    <section class="pricing-faq reveal-section" aria-labelledby="pricingFaqTitle">
      <div class="pricing-app__section-head">
        <span class="section-kicker">FAQ cennika</span>
        <h2 id="pricingFaqTitle">Najczęstsze pytania o ceny</h2>
      </div>
      <div class="pricing-faq__list">
        {faqItems.map(([question, answer]) => (
          <details class="premium-card pricing-faq__item">
            <summary>
              <span><Icon name="faq" size={20} strokeWidth={2.25} />{question}</span>
              <Icon name="chevronDown" size={18} strokeWidth={2.35} />
            </summary>
            <p>{answer}</p>
          </details>
        ))}
      </div>
