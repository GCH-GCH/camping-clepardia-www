                          <div>
                            <strong>{item.label}</strong>
                            <small>{item.note}</small>
                          </div>
                          <em>{priceLabel} / noc</em>
                          <div class="pricing-stepper pricing-stepper--service">
                            <button type="button" data-stepper-target={item.id} data-stepper-delta="-1" aria-label={`Zmniejsz ${item.label}`}>
                              <Icon name="minus" size={17} strokeWidth={2.6} />
                            </button>
                            <input type="number" min="0" value="0" inputmode="numeric" data-service-input={item.id} />
                            <button type="button" data-stepper-target={item.id} data-stepper-delta="1" aria-label={`Zwiększ ${item.label}`}>
                              <Icon name="plus" size={17} strokeWidth={2.6} />
                            </button>
                          </div>
                        </article>
                      );
                    })}
                  </div>
                </section>
              ))}
            </section>
          </div>
        </div>

        <aside class="pricing-app-summary premium-card" aria-live="polite">
          <div class="pricing-app-summary__top">
            <span class="pricing-app-summary__badge"><Icon name="receipt" size={16} strokeWidth={2.4} /> Orientacyjna cena</span>
            <small>Status: do potwierdzenia przez recepcję</small>
          </div>
          <h3 data-summary-total>{formatPrice(popularPrice.camperElectricity - electricity.price)}</h3>
          <p data-summary-hint>Wybrano domyślnie: 2 osoby + kamper. Dodaj prąd albo wybierz popularny zestaw.</p>
          <div class="pricing-app-summary__meta">
            <p><span><Icon name="camping" size={15} strokeWidth={2.3} /> Typ pobytu</span><strong data-summary-mode>Camping</strong></p>
            <p><span><Icon name="calendar" size={15} strokeWidth={2.3} /> Liczba nocy</span><strong data-summary-nights>1</strong></p>
            <p><span><Icon name="pricing" size={15} strokeWidth={2.3} /> Cena / noc</span><strong data-summary-nightly>{formatPrice(popularPrice.camperElectricity - electricity.price)}</strong></p>
          </div>
          <div class="pricing-app-summary__lines" data-summary-lines></div>
          <div class="pricing-app-summary__actions">
            <a class="pricing-app-summary__cta" href={bookingHref}>
              <Icon name="booking" size={18} strokeWidth={2.3} />
