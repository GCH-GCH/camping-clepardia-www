<script define:vars={{ pricingAppConfig }}>
  (() => {
    const root = document.querySelector('[data-pricing-app]');
    if (!(root instanceof HTMLElement)) return;

    const config = pricingAppConfig;
    const modeButtons = Array.from(root.querySelectorAll('[data-pricing-mode]'));
    const seasonButtons = Array.from(root.querySelectorAll('[data-pricing-season]'));
    const serviceGroups = Array.from(root.querySelectorAll('[data-service-group]'));
    const summaryTotals = Array.from(root.querySelectorAll('[data-summary-total]'));
    const summaryHint = root.querySelector('[data-summary-hint]');
    const summaryTitle = root.querySelector('[data-summary-title]');
    const summaryMode = root.querySelector('[data-summary-mode]');
    const summaryNights = root.querySelector('[data-summary-nights]');
    const summaryNightlyItems = Array.from(root.querySelectorAll('[data-summary-nightly]'));
    const summaryLines = root.querySelector('[data-summary-lines]');
    const summaryCard = root.querySelector('.pricing-app-summary');
    const suggestionBox = root.querySelector('[data-pricing-hints]');
    const toast = root.querySelector('[data-pricing-toast]');
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const state = { mode: 'camping', season: 'low' };
    let summaryPulseTimer = 0;
    let toastTimer = 0;

    const formatMoney = (value) => `${Math.round(Math.max(0, value)).toLocaleString('pl-PL')} ${config.currency}`;
    const numberInput = (id) => root.querySelector(`[data-pricing-input="${id}"], [data-service-input="${id}"]`);
    const getValue = (id) => {
      const input = numberInput(id);
      const min = Number(input?.getAttribute('min') ?? 0);
      const value = Number(input?.value ?? 0);
      return Number.isFinite(value) ? Math.max(min, value) : min;
    };
    const setValue = (id, value) => {
      const input = numberInput(id);
      if (input) input.value = String(Math.max(Number(input.getAttribute('min') ?? 0), value));
    };
    const resetServices = () => {
      root.querySelectorAll('[data-service-input]').forEach((input) => {
        input.value = '0';
      });
    };
    const getServicePrice = (id) => {
      const service = config.services[id];
      if (!service) return 0;
      if (service.seasonalPrices) return service.seasonalPrices[state.season] ?? service.seasonalPrices.low ?? 0;
      return service.price ?? 0;
    };
    const getRelevantGroupNames = () => {
      if (state.mode === 'camping') return ['camping'];
      if (state.mode === 'bungalow') return ['bungalow'];
      return ['camping', 'bungalow'];
    };
    const updateGroups = () => {
      const groups = getRelevantGroupNames();
      serviceGroups.forEach((group) => {
        const groupName = group.getAttribute('data-service-group');
        group.hidden = !groups.includes(groupName);
      });
    };
    const setMode = (mode, reset = true) => {
      state.mode = mode;
      modeButtons.forEach((button) => button.classList.toggle('is-active', button.dataset.pricingMode === mode));
      if (reset) {
        resetServices();
        if (mode === 'camping') {
          setValue('camper', 1);
          setValue('electricity', 1);
        }
        if (mode === 'bungalow') setValue('bungalow-2', 1);
        if (mode === 'combined') {
          setValue('camper', 1);
          setValue('bungalow-2', 1);
          setValue('electricity', 1);
        }
      }
      updateGroups();
      update();
    };
    const setSeason = (season) => {
      state.season = season;
      seasonButtons.forEach((button) => button.classList.toggle('is-active', button.dataset.pricingSeason === season));
      update();
    };
    const visibleServiceInputs = () => {
      const groups = getRelevantGroupNames();
      return Array.from(root.querySelectorAll('[data-service-input]')).filter((input) => {
        const card = input.closest('[data-service-card]');
        const group = card?.closest('[data-service-group]')?.getAttribute('data-service-group');
        return groups.includes(group);
      });
    };
    const collectServices = () => visibleServiceInputs()
      .map((input) => {
        const id = input.dataset.serviceInput;
        const qty = Math.max(0, Number(input.value || 0));
        const service = config.services[id];
        if (!id || !service || qty <= 0) return null;
        return { id, qty, label: service.label, price: getServicePrice(id), total: getServicePrice(id) * qty };
      })
      .filter(Boolean);
    const calculate = () => {
      const nights = getValue('nights');
      const adults = getValue('adults');
      const children = getValue('children');
      const toddlers = getValue('toddlers');
      const services = collectServices();
      const chargePeople = state.mode !== 'bungalow';
      const peoplePerNight = chargePeople
        ? adults * config.people.adults + children * config.people.children + toddlers * config.people.toddlers
        : 0;
      const servicesPerNight = services.reduce((sum, service) => sum + service.total, 0);
      const nightly = peoplePerNight + servicesPerNight;
      return { nights, adults, children, toddlers, services, peoplePerNight, servicesPerNight, nightly, total: nightly * nights };
    };
    const animateTextMoney = (element, value) => {
      if (!element) return;
      if (reduceMotion) {
        element.textContent = formatMoney(value);
        element.dataset.value = String(value);
        return;
      }
      const start = Number(element.dataset.value || 0);
      const end = Math.round(value);
      const startTime = performance.now();
      const duration = 280;
      const tick = (now) => {
        const progress = Math.min(1, (now - startTime) / duration);
        const eased = 1 - Math.pow(1 - progress, 3);
        const current = start + (end - start) * eased;
        element.textContent = formatMoney(current);
        if (progress < 1) requestAnimationFrame(tick);
        else element.dataset.value = String(end);
      };
      requestAnimationFrame(tick);
    };
    const updateCardStates = () => {
      root.querySelectorAll('[data-service-card]').forEach((card) => {
        const input = card.querySelector('[data-service-input]');
        const active = Number(input?.value || 0) > 0;
        card.classList.toggle('is-active', active);
      });
      root.querySelectorAll('[data-counter-card]').forEach((card) => {
        const input = card.querySelector('[data-pricing-input]');
        const active = Number(input?.value || 0) > 0;
        card.classList.toggle('is-active', active);
      });
      root.querySelectorAll('[data-stepper-target][data-stepper-delta="-1"]').forEach((button) => {
        const id = button.dataset.stepperTarget;
        const input = numberInput(id);
        const min = Number(input?.getAttribute('min') ?? 0);
        const value = Number(input?.value ?? 0);
        if (button instanceof HTMLButtonElement) button.disabled = value <= min;
      });
    };
    const updateSuggestions = () => {
      if (!suggestionBox) return;
      const suggestions = [];
      if (getValue('camper') > 0 && getValue('electricity') === 0) {
        suggestions.push(`
          <article class="pricing-smart-hint">
            <span>Goście z kamperem najczęściej wybierają także prąd 10A.</span>
            <button type="button" data-suggestion-service="electricity">Dodaj prąd</button>
          </article>
        `);
      }
      if (getValue('caravan') > 0 && getValue('parking') === 0) {
        suggestions.push(`
          <article class="pricing-smart-hint">
            <span>Przy przyczepie zwykle potrzebne jest też miejsce dla auta.</span>
            <button type="button" data-suggestion-service="parking">Dodaj samochód</button>
          </article>
        `);
      }
      if (getValue('dog') > 0 || getValue('bungalow-dog') > 0) {
        suggestions.push(`
          <article class="pricing-smart-hint pricing-smart-hint--quiet">
            <span>Pies jest bezpłatny — prosimy tylko o opiekę i sprzątanie.</span>
          </article>
        `);
      }
      suggestionBox.innerHTML = suggestions.join('');
      suggestionBox.hidden = suggestions.length === 0;
    };
    const update = () => {
      const result = calculate();
      summaryTotals.forEach((element) => animateTextMoney(element, result.total));
      if (summaryMode) summaryMode.textContent = config.modeLabels[state.mode] || state.mode;
      if (summaryNights) summaryNights.textContent = `${result.nights} ${result.nights === 1 ? 'noc' : 'noce'}`;
      summaryNightlyItems.forEach((element) => {
        element.textContent = `${formatMoney(result.nightly)} / noc`;
      });
      if (summaryTitle) {
        const peopleLabel = state.mode === 'bungalow'
          ? 'Pobyt w domku'
          : `${result.adults + result.children + result.toddlers || 0} os.`;
        const servicesLabel = result.services.length
          ? result.services.slice(0, 3).map((service) => service.label).join(' + ')
          : 'wybierz elementy pobytu';
        summaryTitle.textContent = `${peopleLabel} + ${servicesLabel}`;
      }
      if (summaryHint) {
        summaryHint.textContent = result.services.length
          ? 'Cena obejmuje wybrane elementy, liczbę nocy i aktualny wariant. To nadal koszt orientacyjny.'
          : 'Wybierz usługi, a tutaj zobaczysz orientacyjny koszt.';
      }
      if (summaryLines) {
        const lines = [];
        if (state.mode !== 'bungalow') {
          if (result.adults > 0) lines.push(`<p><span>Dorośli x ${result.adults}</span><strong>${formatMoney(result.adults * config.people.adults)} / noc</strong></p>`);
          if (result.children > 0) lines.push(`<p><span>Dzieci 4-14 x ${result.children}</span><strong>${formatMoney(result.children * config.people.children)} / noc</strong></p>`);
          if (result.toddlers > 0) lines.push(`<p><span>Dzieci do 4 x ${result.toddlers}</span><strong>0 PLN</strong></p>`);
        } else {
          lines.push('<p><span>Osoby w domku</span><strong>W cenie domku</strong></p>');
        }
        result.services.forEach((service) => {
          lines.push(`<p><span>${service.label} x ${service.qty}</span><strong>${formatMoney(service.total)} / noc</strong></p>`);
        });
        summaryLines.innerHTML = lines.length ? lines.join('') : '<p><span>Wybrane elementy</span><strong>Do wyboru</strong></p>';
      }
      summaryCard?.classList.add('is-pulsing');
      window.clearTimeout(summaryPulseTimer);
      summaryPulseTimer = window.setTimeout(() => summaryCard?.classList.remove('is-pulsing'), 180);
      updateCardStates();
      updateSuggestions();
    };
    const applyPreset = (presetId) => {
      const preset = config.presets[presetId];
      if (!preset) return;
      setMode(preset.mode, true);
      resetServices();
      Object.entries(preset.values || {}).forEach(([id, value]) => setValue(id, value));
      Object.entries(preset.services || {}).forEach(([id, value]) => setValue(id, value));
      updateGroups();
      update();
      if (toast) {
        window.clearTimeout(toastTimer);
        toast.classList.add('is-visible');
        toastTimer = window.setTimeout(() => toast.classList.remove('is-visible'), 2100);
      }
      const calculator = root.querySelector('#oblicz-koszt');
      calculator?.classList.add('is-highlighted');
      window.setTimeout(() => calculator?.classList.remove('is-highlighted'), 950);
      calculator?.scrollIntoView({ behavior: reduceMotion ? 'auto' : 'smooth', block: 'start' });
    };

    modeButtons.forEach((button) => button.addEventListener('click', () => setMode(button.dataset.pricingMode || 'camping')));
    seasonButtons.forEach((button) => button.addEventListener('click', () => setSeason(button.dataset.pricingSeason || 'low')));
    root.querySelectorAll('[data-stepper-target]').forEach((button) => {
      button.addEventListener('click', () => {
        const id = button.dataset.stepperTarget;
        const delta = Number(button.dataset.stepperDelta || 0);
        const input = numberInput(id);
        if (!input) return;
        const min = Number(input.getAttribute('min') || 0);
        input.value = String(Math.max(min, Number(input.value || 0) + delta));
        const feedbackCard = button.closest('.pricing-live-card, .pricing-counter-row, .pricing-service-card, .pricing-addon-row');
        feedbackCard?.classList.add('is-bumped');
        window.setTimeout(() => feedbackCard?.classList.remove('is-bumped'), 180);
        update();
      });
    });
    root.querySelectorAll('input[type="number"]').forEach((input) => input.addEventListener('input', () => {
      const min = Number(input.getAttribute('min') || 0);
      input.value = String(Math.max(min, Number(input.value || 0)));
      update();
    }));
    root.querySelectorAll('[data-pricing-preset]').forEach((button) => button.addEventListener('click', () => applyPreset(button.dataset.pricingPreset)));
    suggestionBox?.addEventListener('click', (event) => {
      const button = event.target instanceof Element ? event.target.closest('[data-suggestion-service]') : null;
      const id = button?.getAttribute('data-suggestion-service');
      if (!id) return;
      setValue(id, Math.max(1, getValue(id)));
      update();
    });
    root.querySelectorAll('[data-pricing-ask-campy]').forEach((button) => {
      button.addEventListener('click', () => {
        window.dispatchEvent(new CustomEvent('campy:prompt', {
          detail: {
            prompt: 'Pomóż mi wybrać najlepszy wariant pobytu i policzyć orientacyjny koszt na Camping Clepardia.',
            actionKey: 'campingPricing',
          },
        }));
      });
    });

    updateGroups();
    update();
  })();
</script>

