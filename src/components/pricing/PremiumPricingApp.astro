---
import { pricingConfig } from '@/data/pricing';
import Icon from '@/components/ui/Icon.astro';
import { getBookingLocalizedPath, getPathContext } from '@/utils/localizedLinks';

interface Props {
  languageCode?: string;
}

const { languageCode } = Astro.props as Props;
const pathContext = getPathContext(Astro.url.pathname);
const activeLanguage = languageCode ?? pathContext.languageCode;
const bookingHref = getBookingLocalizedPath(activeLanguage);
const currency = pricingConfig.currency;
const formatPrice = (price: number) => `${price} ${currency}`;
const findStayType = (id: string) => pricingConfig.stayTypes.find((item) => item.id === id);
const findAddon = (id: string) => pricingConfig.addons.find((item) => item.id === id);
const flatStay = (id: string) => {
  const item = findStayType(id);
  if (!item || !('price' in item)) throw new Error(`Missing flat stay pricing: ${id}`);
  return item;
};
const seasonalStay = (id: string) => {
  const item = findStayType(id);
  if (!item || !('seasonalPrices' in item)) throw new Error(`Missing seasonal stay pricing: ${id}`);
  return item;
};
const addon = (id: string) => {
  const item = findAddon(id);
  if (!item) throw new Error(`Missing addon pricing: ${id}`);
  return item;
};

const adult = pricingConfig.people.adults;
const child = pricingConfig.people.children;
const toddler = pricingConfig.people.toddlers;
const camper = flatStay('camper');
const van = flatStay('van');
const caravan = flatStay('caravan');
const tentSmall = flatStay('tent-small');
const tentLarge = flatStay('tent-large');
const rooftopTent = flatStay('rooftop-tent');
const bungalow2 = seasonalStay('bungalow-2');
const bungalow3 = seasonalStay('bungalow-3');
const bungalow4 = seasonalStay('bungalow-4');
const electricity = addon('electricity');
const dog = addon('dog');
const parking = addon('parking');
const motorcycle = addon('motorcycle');
const cargoTrailer = addon('cargo-trailer');
const bus = addon('bus');

const highSeasonRange = `${pricingConfig.seasons.high.start.slice(3)}.${pricingConfig.seasons.high.start.slice(0, 2)}-${pricingConfig.seasons.high.end.slice(3)}.${pricingConfig.seasons.high.end.slice(0, 2)}`;
const popularPrice = {
  camperElectricity: adult.price * 2 + camper.price + electricity.price,
  van: adult.price * 2 + van.price,
  caravanElectricityCar: adult.price * 2 + caravan.price + electricity.price + parking.price,
  tentSmall: adult.price * 2 + tentSmall.price,
  bungalow2: bungalow2.seasonalPrices.low,
  bungalow4: bungalow4.seasonalPrices.low,
};

const modeCards = [
  {
    mode: 'camping',
    icon: 'camper',
    title: 'Camping',
    copy: 'Kamper, van, namiot, przyczepa, auto + namiot dachowy.',
    chips: ['Kamper', 'Namiot', 'Prąd 10A'],
  },
  {
    mode: 'bungalow',
    icon: 'house',
    title: 'Domki',
    copy: 'Domki 2-, 3- i 4-osobowe.',
    chips: ['2-os.', '3-os.', '4-os.'],
  },
  {
    mode: 'combined',
    icon: 'users',
    title: 'Camping + domek',
    copy: 'Dla rodzin i grup, gdy część osób śpi w domku, a część przyjeżdża kamperem lub przyczepą.',
    chips: ['Domek', 'Kamper', 'Grupa'],
  },
];

const counters = [
  { id: 'nights', label: 'Liczba nocy', value: 1, min: 1, price: null, icon: 'calendar' },
  { id: 'adults', label: 'Dorośli', value: 2, min: 0, price: adult.price, icon: 'users' },
  { id: 'children', label: 'Dzieci 4-14', value: 0, min: 0, price: child.price, icon: 'baby' },
  { id: 'toddlers', label: 'Dzieci do 4', value: 0, min: 0, price: toddler.price, icon: 'baby' },
];

const personCounters = counters.filter((counter) => counter.id !== 'nights');

const counterGroups = [
  {
    icon: 'calendar',
    title: 'Liczba nocy',
    copy: 'Ustaw długość pobytu. Suma mnoży się przez liczbę nocy.',
    counters: counters.filter((counter) => counter.id === 'nights'),
  },
  {
    icon: 'users',
    title: 'Goście',
    copy: 'Osoby doliczane są do wariantów campingowych. W domkach cena bazuje na typie domku.',
    counters: counters.filter((counter) => counter.id !== 'nights'),
  },
];

const campingServices = [
  { id: 'camper', label: camper.label, price: camper.price, icon: 'camper', note: 'Najczęstszy wybór' },
  { id: 'van', label: van.label, price: van.price, icon: 'busFront', note: 'Kompaktowy pobyt' },
  { id: 'caravan', label: caravan.label, price: caravan.price, icon: 'caravan', note: 'Przyczepa kempingowa' },
  { id: 'tent-small', label: tentSmall.label, price: tentSmall.price, icon: 'tent', note: 'Namiot 1-2 os.' },
  { id: 'tent-large', label: tentLarge.label, price: tentLarge.price, icon: 'tent', note: 'Namiot 3-4 os.' },
  { id: 'rooftop-tent', label: rooftopTent.label, price: rooftopTent.price, icon: 'tent', note: 'Auto + namiot' },
  { id: 'parking', label: 'Samochód / parking', price: parking.price, icon: 'car', note: 'Auto przy zestawie' },
  { id: 'motorcycle', label: motorcycle.label, price: motorcycle.price, icon: 'motorcycle', note: 'Motocykl' },
  { id: 'cargo-trailer', label: cargoTrailer.label, price: cargoTrailer.price, icon: 'caravan', note: 'Dodatkowy bagaż' },
  { id: 'bus', label: bus.label, price: bus.price, icon: 'truck', note: 'Cięższy pojazd' },
  { id: 'electricity', label: 'Prąd 10A', price: electricity.price, icon: 'electricity', note: 'Bez ładowania EV' },
  { id: 'dog', label: dog.label, price: dog.price, icon: 'dog', note: 'Pies bezpłatnie' },
];

const campingServiceGroups = [
  {
    title: 'Pojazd / nocleg',
    copy: 'Wybierz główny sposób pobytu na campingu.',
    icon: 'camper',
    items: campingServices.filter((item) => ['camper', 'van', 'caravan', 'tent-small', 'tent-large', 'rooftop-tent', 'bus'].includes(item.id)),
  },
  {
    title: 'Dodatki',
    copy: 'Dodatkowe elementy liczone za noc pobytu.',
    icon: 'plug',
    items: campingServices.filter((item) => ['parking', 'motorcycle', 'cargo-trailer', 'electricity', 'dog'].includes(item.id)),
  },
];

const bungalowServices = [
  { id: 'bungalow-2', label: bungalow2.label, seasonalPrices: bungalow2.seasonalPrices, icon: 'house', note: '2 osoby' },
  { id: 'bungalow-3', label: bungalow3.label, seasonalPrices: bungalow3.seasonalPrices, icon: 'house', note: '2 lub 3 osoby' },
  { id: 'bungalow-4', label: bungalow4.label, seasonalPrices: bungalow4.seasonalPrices, icon: 'house', note: 'Dla rodziny' },
  { id: 'bungalow-parking', label: 'Samochód / parking', price: parking.price, icon: 'car', note: 'Auto przy domku' },
  { id: 'bungalow-dog', label: dog.label, price: dog.price, icon: 'dog', note: 'Pies bezpłatnie' },
];

const bungalowServiceGroups = [
  {
    title: 'Domki',
    copy: 'Ceny domków zależą od sezonu. Osoby pomagają dobrać wariant, ale nie są doliczane osobno.',
    icon: 'house',
    items: bungalowServices.filter((item) => ['bungalow-2', 'bungalow-3', 'bungalow-4'].includes(item.id)),
  },
  {
    title: 'Dodatki do domku',
    copy: 'Opcje praktyczne przy pobycie w domku.',
    icon: 'car',
    items: bungalowServices.filter((item) => ['bungalow-parking', 'bungalow-dog'].includes(item.id)),
  },
];

const serviceConfigEntries = [...campingServices, ...bungalowServices].map((item) => [
  item.id,
  {
    label: item.label,
    price: 'price' in item ? item.price : undefined,
    seasonalPrices: 'seasonalPrices' in item ? item.seasonalPrices : undefined,
  },
]);

const presets = [
  {
    id: 'camper-electricity',
    mode: 'camping',
    icon: 'camper',
    title: '2 osoby + kamper + prąd',
    price: popularPrice.camperElectricity,
    href: `${bookingHref}?stay=camping&preset=camper-electricity`,
    values: { adults: 2, children: 0, toddlers: 0 },
    services: { camper: 1, electricity: 1 },
  },
  {
    id: 'van',
    mode: 'camping',
    icon: 'busFront',
    title: '2 osoby + van',
    price: popularPrice.van,
    href: `${bookingHref}?stay=camping&preset=van`,
    values: { adults: 2, children: 0, toddlers: 0 },
    services: { van: 1 },
  },
  {
    id: 'caravan-electricity-car',
    mode: 'camping',
    icon: 'caravan',
    title: '2 osoby + auto + przyczepa + prąd',
    price: popularPrice.caravanElectricityCar,
    href: `${bookingHref}?stay=camping&preset=caravan-electricity`,
    values: { adults: 2, children: 0, toddlers: 0 },
    services: { caravan: 1, parking: 1, electricity: 1 },
  },
  {
    id: 'tent-small',
    mode: 'camping',
    icon: 'tent',
    title: '2 osoby + namiot 1-2 os.',
    price: popularPrice.tentSmall,
    href: `${bookingHref}?stay=camping&preset=tent-small`,
    values: { adults: 2, children: 0, toddlers: 0 },
    services: { 'tent-small': 1 },
  },
  {
    id: 'bungalow-2',
    mode: 'bungalow',
    icon: 'house',
    title: 'Domek 2-os.',
    price: popularPrice.bungalow2,
    href: `${bookingHref}?stay=bungalow&preset=bungalow-2`,
    values: { adults: 2, children: 0, toddlers: 0 },
    services: { 'bungalow-2': 1 },
  },
  {
    id: 'bungalow-4',
    mode: 'bungalow',
    icon: 'house',
    title: 'Domek 4-os.',
    price: popularPrice.bungalow4,
    href: `${bookingHref}?stay=bungalow&preset=bungalow-4`,
    values: { adults: 2, children: 2, toddlers: 0 },
    services: { 'bungalow-4': 1 },
  },
];

const popularSpotlightCards = [
  {
    presetId: 'camper-electricity',
    icon: 'camper',
    label: 'Najczęściej wybierany camping',
    title: '2 osoby + kamper + prąd',
    price: popularPrice.camperElectricity,
    composition: '2 dorosłych, kamper, prąd 10A',
    copy: 'Pełny campingowy klasyk z szybkim podłączeniem do prądu.',
    href: `${bookingHref}?stay=camping&preset=camper-electricity`,
  },
  {
    presetId: 'van',
    icon: 'busFront',
    label: 'Lekki city break',
    title: '2 osoby + van',
    price: popularPrice.van,
    composition: '2 dorosłych, van',
    copy: 'Prosty wariant dla krótszego pobytu blisko centrum.',
    href: `${bookingHref}?stay=camping&preset=van`,
  },
  {
    presetId: 'caravan-electricity-car',
    icon: 'caravan',
    label: 'Przyczepa z autem',
    title: '2 osoby + auto + przyczepa + prąd',
    price: popularPrice.caravanElectricityCar,
    composition: '2 dorosłych, auto, przyczepa, prąd 10A',
    copy: 'Czytelny zestaw dla pary podróżującej z przyczepą.',
    href: `${bookingHref}?stay=camping&preset=caravan-electricity`,
  },
  {
    presetId: 'tent-small',
    icon: 'tent',
    label: 'Najprostszy namiot',
    title: '2 osoby + namiot 1-2 os.',
    price: popularPrice.tentSmall,
    composition: '2 dorosłych, namiot 1-2 os.',
    copy: 'Budżetowy wariant z pełnym dostępem do campingu.',
    href: `${bookingHref}?stay=camping&preset=tent-small`,
  },
  {
    presetId: 'bungalow-2',
    icon: 'house',
    label: 'Domek dla pary',
    title: 'Domek 2-os.',
    price: popularPrice.bungalow2,
    prefix: 'od ',
    composition: 'Domek 2-osobowy, niski sezon',
    copy: 'Najprostszy wariant domku dla dwóch osób.',
    href: `${bookingHref}?stay=bungalow&preset=bungalow-2`,
  },
  {
    presetId: 'bungalow-4',
    icon: 'house',
    label: 'Domek rodzinny',
    title: 'Domek 4-os.',
    price: popularPrice.bungalow4,
    prefix: 'od ',
    composition: 'Domek 4-osobowy, niski sezon',
    copy: 'Dla rodziny lub małej grupy, z rezerwacją domku.',
    href: `${bookingHref}?stay=bungalow&preset=bungalow-4`,
  },
];

const fullPriceGroups = [
  {
    icon: 'users',
    title: 'Camping - osoby',
    copy: 'Osoby doliczane są do pojazdu, namiotu albo zestawu campingowego.',
    rows: [
      { label: 'Osoba dorosła', price: adult.price, note: 'Podstawowa opłata osobowa za noc.' },
      { label: 'Dziecko 4-14 lat', price: child.price, note: 'Cena dla dzieci w wieku 4-14 lat.' },
      { label: 'Dziecko do 4 lat', price: toddler.price, note: 'Najmłodsze dzieci bez opłaty.' },
    ],
  },
  {
    icon: 'camper',
    title: 'Camping - pojazdy i nocleg',
    copy: 'Wybierz główny typ pobytu campingowego.',
    rows: [
      { label: camper.label, price: camper.price, note: 'Najczęstszy wariant dla kamperów.' },
      { label: 'Van / minibus', price: van.price, note: 'Kompaktowy pojazd turystyczny.' },
      { label: caravan.label, price: caravan.price, note: 'Przyczepa kempingowa, auto doliczane osobno.' },
      { label: tentSmall.label, price: tentSmall.price, note: 'Mały namiot dla 1-2 osób.' },
      { label: tentLarge.label, price: tentLarge.price, note: 'Większy namiot dla 3-4 osób.' },
      { label: rooftopTent.label, price: rooftopTent.price, note: 'Auto z namiotem dachowym.' },
      { label: bus.label, price: bus.price, note: 'Cięższe pojazdy ustawiamy na asfalcie.' },
    ],
  },
  {
    icon: 'plug',
    title: 'Camping - dodatki',
    copy: 'Dodatki liczone za noc pobytu.',
    rows: [
      { label: 'Prąd 10A', price: electricity.price, note: 'Standardowe przyłącze campingowe. Bez ładowania aut EV.' },
      { label: 'Samochód / parking', price: parking.price, note: 'Auto przy zestawie campingowym.' },
      { label: motorcycle.label, price: motorcycle.price, note: 'Miejsce dla motocykla.' },
      { label: cargoTrailer.label, price: cargoTrailer.price, note: 'Dodatkowa przyczepa bagażowa.' },
      { label: dog.label, price: dog.price, note: 'Pies jest bezpłatny. Prosimy o opiekę i sprzątanie.' },
    ],
  },
  {
    icon: 'house',
    title: 'Domki - niski sezon',
    copy: 'Ceny domków poza wysokim sezonem wakacyjnym.',
    rows: [
      { label: bungalow2.label, price: bungalow2.seasonalPrices.low, note: 'Dla 2 osób.' },
      { label: bungalow3.label, price: bungalow3.seasonalPrices.low, note: 'Dla 2 lub 3 osób.' },
      { label: bungalow4.label, price: bungalow4.seasonalPrices.low, note: 'Dla rodziny lub małej grupy.' },
    ],
  },
  {
    icon: 'wallet',
    title: 'Domki - wysoki sezon',
    copy: `Wysoki sezon: ${highSeasonRange}. Dostępność i ewentualną zaliczkę potwierdza recepcja.`,
    rows: [
      { label: bungalow2.label, price: bungalow2.seasonalPrices.high, note: 'Wakacyjna cena domku 2-os.' },
      { label: bungalow3.label, price: bungalow3.seasonalPrices.high, note: 'Wakacyjna cena domku 3-os.' },
      { label: bungalow4.label, price: bungalow4.seasonalPrices.high, note: 'Wakacyjna cena domku 4-os.' },
    ],
  },
];

const infoCards = [
  { icon: 'clock', title: 'Camping 12:00-12:00', copy: 'Doba campingowa trwa od 12:00 do 12:00.' },
  { icon: 'house', title: 'Domki 16:00-11:00', copy: 'Check-in od 16:00, check-out do 11:00.' },
  { icon: 'moon', title: 'Cisza nocna 22:00-07:00', copy: 'Camping Clepardia nie jest miejscem imprezowym.' },
  { icon: 'plug', title: 'Prąd 10A', copy: 'Standardowe przyłącze campingowe. Bez ładowania aut EV.' },
  { icon: 'calendar', title: 'Lipiec i sierpień', copy: 'Miejsca campingowe są dostępne według kolejności przyjazdu. Domki można rezerwować.' },
  { icon: 'map', title: 'Google Maps', copy: 'Dojazd zmienił się w 2022 roku, dlatego polecamy Google Maps.' },
];

const faqItems = [
  ['Czy cena z kalkulatora jest ostateczna?', 'Nie, kalkulator pokazuje koszt orientacyjny. Dostępność i finalne warunki potwierdza recepcja.'],
  ['Czy pies jest płatny?', 'Nie, pies jest bezpłatny. Prosimy tylko o opiekę i sprzątanie po pupilu.'],
  ['Czy prąd jest w cenie?', `Prąd 10A jest płatny według cennika - ${electricity.price} PLN / noc.`],
  ['Czy można rezerwować miejsca campingowe w lipcu i sierpniu?', 'W wysokim sezonie miejsca campingowe są dostępne według kolejności przyjazdu. Najlepiej przyjechać krótko po 12:00. Rezerwacje online dotyczą głównie domków.'],
  ['Czy domki wymagają zaliczki?', 'Dla domków może być wymagana zaliczka. Szczegóły recepcja przesyła po potwierdzeniu dostępności.'],
  ['Czy można przyjechać cięższym pojazdem?', 'Tak, ale cięższe pojazdy ustawiamy na asfalcie, aby uniknąć zakopania się na trawie.'],
];

const pricingAppConfig = {
  currency,
  people: {
    adults: adult.price,
    children: child.price,
    toddlers: toddler.price,
  },
  services: Object.fromEntries(serviceConfigEntries),
  presets: Object.fromEntries(presets.map((preset) => [preset.id, preset])),
  seasonLabels: {
    low: 'Niski sezon',
    high: 'Wysoki sezon',
  },
  modeLabels: {
    camping: 'Camping',
    bungalow: 'Domki',
    combined: 'Camping + domek',
  },
};
---

<section class="pricing-app" data-pricing-app>
  <div class="container pricing-app__container">
    <section class="pricing-spotlight reveal-section" aria-labelledby="pricingSpotlightTitle">
      <div class="pricing-app__section-head pricing-app__section-head--wide">
        <span class="section-kicker">Najpopularniejsze ceny</span>
        <h2 id="pricingSpotlightTitle">Szybki podgląd najczęstszych pobytów</h2>
        <p>Najpierw zobacz realne przykłady, potem dopasuj szczegóły w kalkulatorze.</p>
      </div>
      <div class="pricing-spotlight__grid">
        {popularSpotlightCards.map((card, index) => (
          <article
            class:list={['pricing-spotlight-card', 'premium-card', index < 2 && 'pricing-spotlight-card--featured']}
            style={`--delay: ${index * 70}ms`}
          >
            {index === 0 && <span class="pricing-spotlight-card__ribbon">Najczęściej wybierane</span>}
            <span class="pricing-spotlight-card__icon"><Icon name={card.icon} size={32} strokeWidth={2.35} /></span>
            <div class="pricing-spotlight-card__body">
              <small>{card.label}</small>
              <h3>{card.title}</h3>
              <p>{card.copy}</p>
              <em>{card.composition}</em>
            </div>
            <strong>{card.prefix ?? ''}{formatPrice(card.price)} <small>/ noc</small></strong>
            <div class="pricing-spotlight-card__actions">
              <button type="button" data-pricing-preset={card.presetId}>Użyj w kalkulatorze</button>
              <a href={card.href}>Zarezerwuj</a>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="pricing-app__choice reveal-section" aria-labelledby="pricingStayTypeTitle">
      <div class="pricing-app__section-head">
        <span class="section-kicker">Wybierz typ pobytu</span>
        <h2 id="pricingStayTypeTitle">Najpierw wybierz, co chcesz policzyć</h2>
        <p>Aktywny wariant dopasuje kalkulator, podsumowanie i najważniejsze opcje.</p>
      </div>

      <div class="pricing-mode-grid" role="group" aria-label="Typ pobytu w cenniku">
        {modeCards.map((card, index) => (
          <button
            type="button"
            class:list={['pricing-mode-card', index === 0 && 'is-active']}
            data-pricing-mode={card.mode}
            style={`--delay: ${index * 90}ms`}
          >
            <span class="pricing-mode-card__icon"><Icon name={card.icon} size={30} strokeWidth={1.9} /></span>
            <strong>{card.title}</strong>
            <small>{card.copy}</small>
            <span class="pricing-mode-card__chips">
              {card.chips.map((chip) => <em>{chip}</em>)}
            </span>
          </button>
        ))}
      </div>
    </section>

    <section class="pricing-app__calculator reveal-section" id="oblicz-koszt" aria-labelledby="pricingCalculatorTitle">
      <div class="pricing-app__section-head pricing-app__section-head--wide">
        <span class="section-kicker">Kalkulator orientacyjny</span>
        <h2 id="pricingCalculatorTitle">Kalkulator w 3 prostych krokach</h2>
        <p>Najpierw ustaw gości i noce, potem wybierz sposób pobytu oraz dodatki. Bez danych klienta i bez zgód.</p>
      </div>

      <div class="pricing-app__layout">
        <div class="pricing-app__panel premium-card">
          <div class="pricing-app__toolbar pricing-app__toolbar--simple">
            <div class="pricing-season-toggle" role="group" aria-label="Sezon dla domków">
              <button type="button" class="is-active" data-pricing-season="low">Niski sezon</button>
              <button type="button" data-pricing-season="high">Wysoki sezon</button>
            </div>
            <p><Icon name="info" size={16} /> Domki zmieniają cenę w sezonie wysokim. Camping ma stałą cenę za noc.</p>
          </div>

          <div class="pricing-live-strip" aria-label="Szybkie podsumowanie kosztu">
            <article class="pricing-live-card pricing-live-card--nights">
              <span><Icon name="calendar" size={22} strokeWidth={2.25} /> Liczba nocy</span>
              <div class="pricing-stepper pricing-stepper--live">
                <button type="button" data-stepper-target="nights" data-stepper-delta="-1" aria-label="Zmniejsz liczbę nocy">
                  <Icon name="minus" size={20} strokeWidth={2.8} />
                </button>
                <input id="pricing-nights" type="number" min="1" value="1" inputmode="numeric" data-pricing-input="nights" aria-label="Liczba nocy" />
                <button type="button" data-stepper-target="nights" data-stepper-delta="1" aria-label="Zwiększ liczbę nocy">
                  <Icon name="plus" size={20} strokeWidth={2.8} />
