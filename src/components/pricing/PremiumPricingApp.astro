    </section>

    <section class="pricing-full reveal-section" aria-labelledby="pricingFullTitle">
      <div class="pricing-app__section-head pricing-app__section-head--wide">
        <span class="section-kicker">Pełny cennik</span>
        <h2 id="pricingFullTitle">Ceny w czytelnych grupach</h2>
        <p>Wszystkie kwoty pochodzą z konfiguracji cenowej strony. Kalkulator i rezerwacja korzystają z tej samej logiki.</p>
      </div>
      <div class="pricing-full__grid">
        {fullPriceGroups.map((group) => (
          <article class="pricing-price-group premium-card">
            <span class="pricing-price-group__icon"><Icon name={group.icon} size={24} /></span>
            <h3>{group.title}</h3>
            <p>{group.copy}</p>
            <div class="pricing-price-group__rows">
              {group.rows.map((row) => (
                <div class="pricing-price-row">
                  <span>
                    <strong>{row.label}</strong>
                    {'note' in row && <small>{row.note}</small>}
                  </span>
                  {'price' in row ? (
                    <em>{row.price === 0 ? '0 PLN' : `${formatPrice(row.price)} / noc`}</em>
                  ) : (
                    <em>{formatPrice(row.low)} niski / {formatPrice(row.high)} wysoki</em>
                  )}
                </div>
              ))}
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="pricing-info reveal-section" aria-labelledby="pricingInfoTitle">
      <div class="pricing-app__section-head">
        <span class="section-kicker">Przed przyjazdem</span>
        <h2 id="pricingInfoTitle">Ważne informacje przed przyjazdem</h2>
      </div>
      <div class="pricing-info__grid">
        {infoCards.map((item) => (
          <article class="pricing-info-card premium-card">
            <span><Icon name={item.icon} size={22} /></span>
            <h3>{item.title}</h3>
            <p>{item.copy}</p>
          </article>
