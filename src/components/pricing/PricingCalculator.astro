---
import { pricingConfig } from '@/data/pricing';
import { getTranslations } from '@/i18n/config';
import { getPathContext } from '@/utils/localizedLinks';
import Icon from '@/components/ui/Icon.astro';

interface Props {
  languageCode?: string;
}

const { languageCode } = Astro.props as Props;
const pathContext = getPathContext(Astro.url.pathname);
const t = getTranslations(languageCode ?? pathContext.languageCode);
const pricingText = t.pricing;

const formatPrice = (price: number) => `${price} ${pricingConfig.currency}`;
const getStayTypeLabel = (id: string, fallback: string) => pricingText.stayTypes[id as keyof typeof pricingText.stayTypes] ?? fallback;
const getAddonLabel = (id: string, fallback: string) => pricingText.addons[id as keyof typeof pricingText.addons] ?? fallback;
const localizedPricingConfig = {
  ...pricingConfig,
  seasons: {
    ...pricingConfig.seasons,
    high: {
      ...pricingConfig.seasons.high,
      label: pricingText.highSeason,
    },
    low: {
      ...pricingConfig.seasons.low,
      label: pricingText.lowSeason,
    },
  },
  people: {
    adults: { ...pricingConfig.people.adults, label: pricingText.adults },
    children: { ...pricingConfig.people.children, label: pricingText.children },
    toddlers: { ...pricingConfig.people.toddlers, label: pricingText.toddlers },
  },
  stayTypes: pricingConfig.stayTypes.map((type) => ({
    ...type,
    label: getStayTypeLabel(type.id, type.label),
    ...('note' in type ? { note: pricingText.familyNotice } : {}),
  })),
  addons: pricingConfig.addons.map((addon) => ({
    ...addon,
    label: getAddonLabel(addon.id, addon.label),
  })),
};
const defaultStayType = localizedPricingConfig.stayTypes[0];
const defaultAdults = 2;
const defaultNights = 1;
const defaultAccommodationPerNight = 'seasonalPrices' in defaultStayType
  ? defaultStayType.seasonalPrices.low
  : 'startingPrice' in defaultStayType
    ? defaultStayType.startingPrice
    : defaultStayType.price;
const defaultPeoplePerNight = defaultStayType.category === 'bungalow'
  ? 0
  : defaultAdults * localizedPricingConfig.people.adults.price;
const defaultTotal = (defaultAccommodationPerNight + defaultPeoplePerNight) * defaultNights;
const defaultTotalLabel = formatPrice(defaultTotal);
const defaultRateLabel = `${defaultTotalLabel} / ${pricingText.perNight}`;
const stayTypeIcons: Record<string, string> = {
  camper: 'camper',
  caravan: 'caravan',
  'tent-small': 'tent',
  'tent-large': 'tent',
  van: 'busFront',
  'rooftop-tent': 'tent',
  'bungalow-2': 'bungalow',
  'bungalow-3': 'bungalow',
  'bungalow-4': 'bungalow',
  'bungalow-family': 'family',
};
const addonIcons: Record<string, string> = {
  electricity: 'electricity',
  dog: 'dog',
  motorcycle: 'motorcycle',
  'cargo-trailer': 'caravan',
  bus: 'truck',
  parking: 'parking',
  'extra-car': 'car',
};
---

<section class="site-section pricing-calculator reveal-section" id="kalkulator">
  <div class="container">
    <div class="pricing-calculator__header">
      <span class="section-kicker">{pricingText.kicker}</span>
      <h2 class="section-title">{pricingText.title}</h2>
      <p class="section-copy">
        {pricingText.lead}
      </p>
    </div>

    <div class="pricing-calculator__layout" data-pricing-calculator>
      <form class="premium-card pricing-calculator__form" aria-label={pricingText.formAria}>
        <fieldset class="pricing-calculator__group reveal-section" style="--reveal-delay: 0ms">
          <legend>{pricingText.dates}</legend>
          <div class="pricing-calculator__fields">
            <label>
              <span>{pricingText.arrival}</span>
              <input type="date" name="arrival" data-arrival aria-label={pricingText.arrival} />
            </label>
            <label>
              <span>{pricingText.departure}</span>
              <input type="date" name="departure" data-departure aria-label={pricingText.departure} />
            </label>
          </div>
          <p class="pricing-calculator__hint">
            {pricingText.nightsLabel}: <strong data-nights-label>{pricingText.night.one}</strong>
          </p>
        </fieldset>

        <fieldset class="pricing-calculator__group reveal-section" style="--reveal-delay: 80ms">
          <legend>{pricingText.stayType}</legend>
          <div class="pricing-calculator__options">
            {pricingConfig.stayTypes.map((type, index) => {
              const price = 'seasonalPrices' in type
                ? `${pricingText.from} ${type.seasonalPrices.low} PLN`
                : 'startingPrice' in type
                  ? `${pricingText.from} ${type.startingPrice} PLN`
                  : formatPrice(type.price);
              return (
                <label class="pricing-calculator__option">
                  <input type="radio" name="stayType" value={type.id} checked={index === 0} />
                  <span>
                    <i class="pricing-calculator__option-icon" aria-hidden="true">
                      <Icon name={stayTypeIcons[type.id] ?? 'pricing'} size={22} strokeWidth={1.85} />
                    </i>
                    <span class="pricing-calculator__option-copy">
                      <strong>{getStayTypeLabel(type.id, type.label)}</strong>
                      <small>{price} / {pricingText.perNight}</small>
                      {'note' in type && <em>{pricingText.familyNotice}</em>}
                    </span>
                  </span>
                </label>
              );
            })}
          </div>
          <div class="pricing-calculator__notice" data-summer-notice hidden>
            {pricingText.summerNotice}
          </div>
          <div class="pricing-calculator__notice pricing-calculator__notice--confirmation" data-family-notice hidden>
            {pricingText.familyNotice}
          </div>
        </fieldset>

        <fieldset class="pricing-calculator__group reveal-section" style="--reveal-delay: 160ms">
          <legend>{pricingText.people}</legend>
          <div class="pricing-calculator__counters">
            <div class="pricing-counter">
              <label for="adults">{pricingText.adults}</label>
              <div>
                <button type="button" data-counter="adults" data-delta="-1" aria-label={`${pricingText.decrement} ${pricingText.adults}`}>-</button>
                <input id="adults" type="number" min="0" value="2" inputmode="numeric" data-counter-input="adults" />
                <button type="button" data-counter="adults" data-delta="1" aria-label={`${pricingText.increment} ${pricingText.adults}`}>+</button>
              </div>
              <small>{formatPrice(pricingConfig.people.adults.price)} / {pricingText.perNight}</small>
            </div>

            <div class="pricing-counter">
              <label for="children">{pricingText.children}</label>
              <div>
                <button type="button" data-counter="children" data-delta="-1" aria-label={`${pricingText.decrement} ${pricingText.children}`}>-</button>
                <input id="children" type="number" min="0" value="0" inputmode="numeric" data-counter-input="children" />
                <button type="button" data-counter="children" data-delta="1" aria-label={`${pricingText.increment} ${pricingText.children}`}>+</button>
              </div>
              <small>{formatPrice(pricingConfig.people.children.price)} / {pricingText.perNight}</small>
            </div>

            <div class="pricing-counter">
              <label for="toddlers">{pricingText.toddlers}</label>
              <div>
                <button type="button" data-counter="toddlers" data-delta="-1" aria-label={`${pricingText.decrement} ${pricingText.toddlers}`}>-</button>
                <input id="toddlers" type="number" min="0" value="0" inputmode="numeric" data-counter-input="toddlers" />
                <button type="button" data-counter="toddlers" data-delta="1" aria-label={`${pricingText.increment} ${pricingText.toddlers}`}>+</button>
              </div>
              <small>{formatPrice(pricingConfig.people.toddlers.price)} / {pricingText.perNight}</small>
            </div>
          </div>
        </fieldset>

        <fieldset class="pricing-calculator__group reveal-section" style="--reveal-delay: 240ms">
          <legend>{pricingText.extras}</legend>
          <div class="pricing-calculator__addons">
            {pricingConfig.addons.map((addon) => (
              <label class="pricing-calculator__addon">
                <input type="checkbox" name="addons" value={addon.id} />
                <span>
                  <i class="pricing-calculator__option-icon" aria-hidden="true">
                    <Icon name={addonIcons[addon.id] ?? 'check'} size={21} strokeWidth={1.9} />
                  </i>
                  <span class="pricing-calculator__option-copy">
                    <strong>{getAddonLabel(addon.id, addon.label)}</strong>
                    <small>{formatPrice(addon.price)} / {pricingText.perNight}</small>
                  </span>
                </span>
              </label>
            ))}
          </div>
        </fieldset>
      </form>

      <aside class="premium-card pricing-summary" aria-label={pricingText.summary} aria-live="polite">
        <div class="pricing-summary__head">
          <div>
            <span>{pricingText.summary}</span>
            <small>{pricingText.total}</small>
          </div>
          <strong data-total data-value={defaultTotal}>{defaultTotalLabel}</strong>
        </div>
        <dl class="pricing-summary__details">
          <div>
            <dt>{pricingText.term}</dt>
            <dd data-summary-dates>{pricingText.toComplete}</dd>
          </div>
          <div>
            <dt>{pricingText.nightsLabel}</dt>
            <dd data-summary-nights>{pricingText.night.one}</dd>
          </div>
          <div>
            <dt>{pricingText.stayType}</dt>
            <dd data-summary-stay>{pricingText.stayTypes.camper}</dd>
          </div>
          <div>
            <dt>{pricingText.season}</dt>
            <dd data-summary-season>{pricingText.lowSeason}</dd>
          </div>
          <div>
            <dt>{pricingText.people}</dt>
            <dd data-summary-people>2 {pricingText.adults}</dd>
          </div>
          <div>
            <dt>{pricingText.extras}</dt>
            <dd data-summary-addons>{pricingText.noAddons}</dd>
          </div>
          <div>
            <dt>{pricingText.pricePerNight}</dt>
            <dd data-nightly-rate>{defaultRateLabel}</dd>
          </div>
        </dl>
        <div class="pricing-summary__breakdown" data-breakdown></div>
        <p class="pricing-summary__footnote" data-summary-footnote>
          {pricingText.summaryFootnote}
        </p>
      </aside>
    </div>
  </div>

  <div class="pricing-mobile-summary" data-mobile-summary>
    <button type="button" data-mobile-toggle aria-expanded="false" aria-controls="pricingMobilePanel">
      <span>{pricingText.mobileTotal}</span>
      <strong data-mobile-total data-value={defaultTotal}>{defaultTotalLabel}</strong>
    </button>
    <div id="pricingMobilePanel" class="pricing-mobile-summary__panel" data-mobile-panel hidden>
      <div class="pricing-mobile-summary__row">
        <span>{pricingText.term}</span>
        <strong data-mobile-dates>{pricingText.toComplete}</strong>
      </div>
      <div class="pricing-mobile-summary__row">
        <span>{pricingText.nightsLabel}</span>
        <strong data-mobile-nights>{pricingText.night.one}</strong>
      </div>
      <div class="pricing-mobile-summary__row">
        <span>{pricingText.stayType}</span>
        <strong data-mobile-stay>{pricingText.stayTypes.camper}</strong>
      </div>
      <div class="pricing-mobile-summary__row">
        <span>{pricingText.season}</span>
        <strong data-mobile-season>{pricingText.lowSeason}</strong>
      </div>
      <div class="pricing-mobile-summary__row">
        <span>{pricingText.people}</span>
        <strong data-mobile-people>2 {pricingText.adults}</strong>
      </div>
      <div class="pricing-mobile-summary__row">
        <span>{pricingText.extras}</span>
        <strong data-mobile-addons>{pricingText.noAddons}</strong>
      </div>
      <div class="pricing-mobile-summary__row">
        <span>{pricingText.pricePerNight}</span>
        <strong data-mobile-rate>{defaultRateLabel}</strong>
      </div>
      <div class="pricing-mobile-summary__breakdown" data-mobile-breakdown></div>
    </div>
  </div>
</section>

<script define:vars={{ pricingConfig: localizedPricingConfig, pricingText }}>
  (() => {
    const root = document.querySelector('[data-pricing-calculator]');
    if (!root) return;

    const config = pricingConfig;
    const DAY = 24 * 60 * 60 * 1000;
    const currency = config.currency;
    const arrivalInput = root.querySelector('[data-arrival]');
    const departureInput = root.querySelector('[data-departure]');
    const nightsLabel = root.querySelector('[data-nights-label]');
    const notice = root.querySelector('[data-summer-notice]');
    const familyNotice = root.querySelector('[data-family-notice]');
    const totalEl = root.querySelector('[data-total]');
    const summaryDates = root.querySelector('[data-summary-dates]');
    const summaryNights = root.querySelector('[data-summary-nights]');
    const summaryStay = root.querySelector('[data-summary-stay]');
    const summarySeason = root.querySelector('[data-summary-season]');
    const summaryPeople = root.querySelector('[data-summary-people]');
    const summaryAddons = root.querySelector('[data-summary-addons]');
    const nightlyRate = root.querySelector('[data-nightly-rate]');
    const breakdownEl = root.querySelector('[data-breakdown]');
    const summaryFootnote = root.querySelector('[data-summary-footnote]');
    const mobileSummary = document.querySelector('[data-mobile-summary]');
    const mobileToggle = document.querySelector('[data-mobile-toggle]');
    const mobilePanel = document.querySelector('[data-mobile-panel]');
    const mobileTotal = document.querySelector('[data-mobile-total]');
    const mobileDates = document.querySelector('[data-mobile-dates]');
    const mobileNights = document.querySelector('[data-mobile-nights]');
    const mobileStay = document.querySelector('[data-mobile-stay]');
    const mobileSeason = document.querySelector('[data-mobile-season]');
    const mobilePeople = document.querySelector('[data-mobile-people]');
    const mobileAddons = document.querySelector('[data-mobile-addons]');
    const mobileRate = document.querySelector('[data-mobile-rate]');
    const mobileBreakdown = document.querySelector('[data-mobile-breakdown]');
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const formatMoney = (value) => `${Math.round(value).toLocaleString('pl-PL')} ${currency}`;
    const formatDisplayMoney = (value, approximate = false) => `${approximate ? `${pricingText.from} ` : ''}${formatMoney(value)}`;
    const setText = (element, value) => {
      if (element) element.textContent = value;
    };
    const formatDateDisplay = (date) => {
      const day = String(date.getUTCDate()).padStart(2, '0');
      const month = String(date.getUTCMonth() + 1).padStart(2, '0');
      const year = date.getUTCFullYear();
      return `${day}.${month}.${year}`;
    };
    const formatNightsText = (nights) => {
      const mod10 = nights % 10;
      const mod100 = nights % 100;
      if (pricingText.night?.other) return nights === 1 ? pricingText.night.one : pricingText.night.other.replace('{count}', String(nights));
      if (nights === 1) return '1 night';
      return `${nights} nights`;
    };
    const toDateValue = (date) => {
      const year = date.getFullYear();
      const month = String(date.getMonth() + 1).padStart(2, '0');
      const day = String(date.getDate()).padStart(2, '0');
      return `${year}-${month}-${day}`;
    };
    const parseDate = (value) => {
      if (!value) return null;
      const parts = value.split('-').map(Number);
      if (parts.length !== 3 || parts.some((part) => !Number.isFinite(part))) return null;
      return new Date(Date.UTC(parts[0], parts[1] - 1, parts[2]));
    };
    const addDays = (date, days) => new Date(date.getTime() + days * DAY);
    const getMonthDay = (date) => {
      const month = date.getUTCMonth() + 1;
      const day = date.getUTCDate();
      return { month, day };
    };
    const isHighSeason = (date) => {
      const { month, day } = getMonthDay(date);
      return (month === 7 && day >= 1) || month === 8;
    };
    const isSummerNoticeMonth = (date) => config.seasons.summerNoticeMonths.includes(date.getUTCMonth() + 1);
    const getSelectedStayType = () => {
      const selected = root.querySelector('input[name="stayType"]:checked');
      const selectedId = selected?.value ?? config.stayTypes[0].id;
      return config.stayTypes.find((type) => type.id === selectedId) ?? config.stayTypes[0];
    };
    const normalizeCounterValue = (value) => {
      const numericValue = Number(value);
      return Number.isFinite(numericValue) ? Math.max(0, numericValue) : 0;
    };
    const getCounterValue = (name) => {
      const input = root.querySelector(`[data-counter-input="${name}"]`);
      return normalizeCounterValue(input?.value ?? 0);
    };
    const getNights = () => {
      const arrival = parseDate(arrivalInput?.value);
      const departure = parseDate(departureInput?.value);
      if (!arrival || !departure) return 1;
      return Math.max(1, Math.round((departure.getTime() - arrival.getTime()) / DAY));
    };
    const getNightDates = () => {
      const arrival = parseDate(arrivalInput?.value);
      const nights = getNights();
      const start = arrival ?? new Date();
      return Array.from({ length: nights }, (_, index) => addDays(start, index));
    };
    const getStayRate = (type, date) => {
      if ('seasonalPrices' in type) {
        return isHighSeason(date) ? type.seasonalPrices.high : type.seasonalPrices.low;
      }
      if ('startingPrice' in type) {
        return type.startingPrice;
      }
      return type.price;
    };
    const getSeasonSummary = (nightDates) => {
      if (!nightDates.length) return pricingText.lowSeason;
      const highSeasonNights = nightDates.filter(isHighSeason).length;
      if (highSeasonNights === 0) return pricingText.lowSeason;
      if (highSeasonNights === nightDates.length) return pricingText.highSeason;
      return pricingText.mixedSeason;
    };
    const getRateSummary = (type, nightDates) => {
      if ('startingPrice' in type) return `${pricingText.from} ${formatMoney(type.startingPrice)} / ${pricingText.perNight}`;

      const rates = nightDates.map((date) => getStayRate(type, date));
      const uniqueRates = Array.from(new Set(rates)).sort((a, b) => a - b);
      if (!uniqueRates.length) return `${formatMoney(getStayRate(type, new Date()))} / ${pricingText.perNight}`;
      if (uniqueRates.length === 1) return `${formatMoney(uniqueRates[0])} / ${pricingText.perNight}`;
      return `${formatMoney(uniqueRates[0])}-${formatMoney(uniqueRates[uniqueRates.length - 1])} / ${pricingText.perNight}`;
    };
    const getPeopleSummary = ({ adults, children, toddlers }) => {
      const parts = [];
      if (adults > 0) parts.push(`${adults} ${pricingText.adults}`);
      if (children > 0) parts.push(`${children} ${pricingText.children}`);
      if (toddlers > 0) parts.push(`${toddlers} ${pricingText.toddlers}`);
      return parts.length ? parts.join(', ') : pricingText.noPeople;
    };
    const getTranslatedStayLabel = (type) => pricingText.stayTypes?.[type.id] ?? type.label;
    const getTranslatedAddonLabel = (addon) => pricingText.addons?.[addon.id] ?? addon.label;
    const getAddonsSummary = (addons) => addons.length ? addons.map(getTranslatedAddonLabel).join(', ') : pricingText.noAddons;
    const isConfirmationStay = (type) => Boolean(type.requiresConfirmation);
    const animateMoney = (element, nextValue, approximate = false) => {
      if (!element) return;
      if (reduceMotion) {
        element.textContent = formatDisplayMoney(nextValue, approximate);
        element.dataset.value = String(nextValue);
        return;
      }
      const previousValue = Number(element.dataset.value ?? 0);
      const start = performance.now();
      const duration = 420;
      element.classList.add('is-updating');
      const tick = (now) => {
        const progress = Math.min(1, (now - start) / duration);
        const eased = 1 - Math.pow(1 - progress, 3);
        const value = previousValue + (nextValue - previousValue) * eased;
        element.textContent = formatDisplayMoney(value, approximate);
        if (progress < 1) {
          requestAnimationFrame(tick);
        } else {
          element.classList.remove('is-updating');
        }
      };
      element.dataset.value = String(nextValue);
      requestAnimationFrame(tick);
    };
    const renderBreakdown = (items) => {
      const html = items.map((item) => `
        <div class="pricing-summary__line">
        <span>${item.label}${item.note ? `<small>${item.note}</small>` : ''}</span>
        <strong>${item.confirmation ? pricingText.confirmPrice : `${item.approximate ? `${pricingText.from} ` : ''}${formatMoney(item.amount)}`}</strong>
        </div>
      `).join('');
      if (breakdownEl) breakdownEl.innerHTML = html;
      if (mobileBreakdown) mobileBreakdown.innerHTML = html;
    };
    const syncDates = () => {
      const today = new Date();
      const tomorrow = new Date(today.getTime() + DAY);

      if (!arrivalInput.value) arrivalInput.value = toDateValue(today);
      if (!departureInput.value) departureInput.value = toDateValue(tomorrow);

      const arrival = parseDate(arrivalInput.value);
      const departure = parseDate(departureInput.value);
      if (arrival && departure && departure <= arrival) {
        departureInput.value = toDateValue(new Date(arrival.getTime() + DAY));
      }

      if (arrivalInput && departureInput) {
        arrivalInput.min = toDateValue(today);
        const minDeparture = parseDate(arrivalInput.value);
        departureInput.min = minDeparture ? toDateValue(new Date(minDeparture.getTime() + DAY)) : toDateValue(tomorrow);
      }
    };
    const update = () => {
      syncDates();

      const type = getSelectedStayType();
      const nights = getNights();
      const nightDates = getNightDates();
      const arrival = parseDate(arrivalInput?.value);
      const departure = parseDate(departureInput?.value);
      const adults = getCounterValue('adults');
      const children = getCounterValue('children');
      const toddlers = getCounterValue('toddlers');
      const selectedAddons = Array.from(root.querySelectorAll('input[name="addons"]:checked')).map((input) => input.value);
      const chargePeople = type.category !== 'bungalow';
      const accommodationTotal = nightDates.length
        ? nightDates.reduce((sum, date) => sum + getStayRate(type, date), 0)
        : getStayRate(type, new Date()) * nights;
      const peoplePerNight =
        chargePeople
          ? adults * config.people.adults.price +
            children * config.people.children.price +
            toddlers * config.people.toddlers.price
          : 0;
      const selectedAddonItems = config.addons.filter((addon) => selectedAddons.includes(addon.id));
      const addonsPerNight = selectedAddonItems.reduce((sum, addon) => sum + addon.price, 0);
      const peopleTotal = peoplePerNight * nights;
      const addonsTotal = addonsPerNight * nights;
      const total = accommodationTotal + peopleTotal + addonsTotal;
      const nightlyTotal = nights > 0 ? total / nights : total;
      const hasSummerCamping = type.category === 'camping' && nightDates.some(isSummerNoticeMonth);
      const requiresConfirmation = isConfirmationStay(type);
      const datesSummary = arrival && departure ? `${formatDateDisplay(arrival)} - ${formatDateDisplay(departure)}` : pricingText.toComplete;
      const nightsSummary = formatNightsText(nights);
      const seasonSummary = getSeasonSummary(nightDates);
      const peopleSummary = getPeopleSummary({ adults, children, toddlers });
      const addonsSummary = getAddonsSummary(selectedAddonItems);
      const rateSummary = `${requiresConfirmation ? `${pricingText.from} ` : ''}${formatMoney(nightlyTotal)} / ${pricingText.perNight}`;

      const breakdown = [
        {
          label: `${getTranslatedStayLabel(type)} x ${nightsSummary}`,
          amount: accommodationTotal,
          approximate: requiresConfirmation,
          note: requiresConfirmation ? pricingText.familyNotice : '',
        },
      ];

      if (chargePeople && adults > 0) breakdown.push({ label: `${pricingText.adults} x ${adults} x ${nightsSummary}`, amount: adults * config.people.adults.price * nights });
      if (chargePeople && children > 0) breakdown.push({ label: `${pricingText.children} x ${children} x ${nightsSummary}`, amount: children * config.people.children.price * nights });
      if (chargePeople && toddlers > 0) breakdown.push({ label: `${pricingText.toddlers} x ${toddlers} x ${nightsSummary}`, amount: 0 });
      selectedAddonItems.forEach((addon) => breakdown.push({ label: `${getTranslatedAddonLabel(addon)} x ${nightsSummary}`, amount: addon.price * nights }));

      setText(nightsLabel, nightsSummary);
      setText(summaryDates, datesSummary);
      setText(summaryNights, nightsSummary);
      setText(summaryStay, getTranslatedStayLabel(type));
      setText(summarySeason, seasonSummary);
      setText(summaryPeople, peopleSummary);
      setText(summaryAddons, addonsSummary);
      setText(nightlyRate, rateSummary);
      setText(mobileDates, datesSummary);
      setText(mobileNights, nightsSummary);
      setText(mobileStay, getTranslatedStayLabel(type));
      setText(mobileSeason, seasonSummary);
      setText(mobilePeople, peopleSummary);
      setText(mobileAddons, addonsSummary);
      setText(mobileRate, rateSummary);
      if (notice) notice.hidden = !hasSummerCamping;
      if (familyNotice) familyNotice.hidden = !requiresConfirmation;
      if (summaryFootnote) {
        summaryFootnote.textContent = requiresConfirmation
          ? pricingText.familyFootnote
          : pricingText.summaryFootnote;
      }
      animateMoney(totalEl, total, requiresConfirmation);
      animateMoney(mobileTotal, total, requiresConfirmation);
      renderBreakdown(breakdown);
    };

    root.querySelectorAll('input').forEach((input) => input.addEventListener('change', update));
    arrivalInput?.addEventListener('input', update);
    departureInput?.addEventListener('input', update);
    root.querySelectorAll('[data-counter]').forEach((button) => {
      button.addEventListener('click', () => {
        const name = button.dataset.counter;
        const delta = Number(button.dataset.delta ?? 0);
        const input = root.querySelector(`[data-counter-input="${name}"]`);
        const value = Math.max(0, normalizeCounterValue(input?.value ?? 0) + delta);
        if (input) input.value = String(value);
        update();
      });
    });
    root.querySelectorAll('[data-counter-input]').forEach((input) => {
      input.addEventListener('input', () => {
        input.value = String(normalizeCounterValue(input.value || 0));
        update();
      });
    });
    mobileToggle?.addEventListener('click', () => {
      const expanded = mobileToggle.getAttribute('aria-expanded') === 'true';
      mobileToggle.setAttribute('aria-expanded', String(!expanded));
      if (mobilePanel) mobilePanel.hidden = expanded;
      mobileSummary?.classList.toggle('is-open', !expanded);
    });

    syncDates();
    update();
  })();
</script>

