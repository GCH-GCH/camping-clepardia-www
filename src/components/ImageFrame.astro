---
import { publicAssetExists } from '@/data/assets';
import Icon from '@/components/ui/Icon.astro';

interface Props {
  src: string;
  alt: string;
  label: string;
  className?: string;
  portrait?: boolean;
}

const { src, alt, label, className = '', portrait = false } = Astro.props as Props;
const imageExists = publicAssetExists(src);
const fallbackScope = `${src} ${label} ${alt}`.toLowerCase();
const fallbackIcon = fallbackScope.includes('tram') || fallbackScope.includes('transport')
  ? 'tram'
  : fallbackScope.includes('bungalow') || fallbackScope.includes('domek')
    ? 'bungalow'
    : fallbackScope.includes('electric') || fallbackScope.includes('prąd') || fallbackScope.includes('prad')
      ? 'electricity'
      : fallbackScope.includes('camper') || fallbackScope.includes('kamper') || fallbackScope.includes('van')
        ? 'camper'
        : fallbackScope.includes('attraction') || fallbackScope.includes('krak') || fallbackScope.includes('wieliczka')
          ? 'attractions'
          : 'tent';
---

<figure
  class:list={[
    'photo-frame',
    'asset-frame',
    imageExists ? 'asset-frame--image' : 'asset-frame--fallback',
    !imageExists && `asset-frame--fallback-${fallbackIcon}`,
    portrait && 'asset-frame--portrait',
    className,
  ]}
>
  {imageExists ? (
    <>
      <img src={src} alt={alt} loading="lazy" decoding="async" />
      <figcaption>{label}</figcaption>
    </>
  ) : (
    <>
      <div class="asset-frame__fallback-scene" aria-hidden="true">
        <span class="asset-frame__sun"></span>
        <span class="asset-frame__hill asset-frame__hill--back"></span>
        <span class="asset-frame__hill asset-frame__hill--front"></span>
        <span class="asset-frame__tent"></span>
      </div>
      <span class="asset-frame__fallback-icon" aria-hidden="true">
        <Icon name={fallbackIcon} size={28} strokeWidth={1.75} />
      </span>
      <div class="asset-frame__fallback-content">
        <span>{label}</span>
      </div>
    </>
  )}
</figure>

<style is:global>
.asset-frame.photo-frame {
  position: relative;
  display: block;
  min-height: auto;
  aspect-ratio: 16 / 10;
  padding: 0;
  border-radius: 24px;
  border: 1px solid rgba(143,224,180,.30);
  overflow: hidden;
  box-shadow: 0 28px 82px rgba(17, 40, 28, .20), 0 0 30px rgba(60,179,113,.10);
  background:
    linear-gradient(135deg, rgba(14, 44, 29, .16), rgba(16, 45, 31, .62)),
    radial-gradient(circle at 74% 24%, rgba(242, 192, 120, .36), transparent 36%),
    radial-gradient(circle at 18% 86%, rgba(60,179,113,.44), transparent 42%),
    linear-gradient(135deg, #477b59, #163a27 58%, #0e271a);
}

.asset-frame--portrait.photo-frame {
  aspect-ratio: 4 / 5;
}

.asset-frame img {
  width: 100%;
  height: 100%;
  display: block;
  object-fit: cover;
  transform: scale(1.001);
  transition: transform .8s cubic-bezier(.2, .8, .2, 1), filter .8s ease;
}

.asset-frame::after {
  content: '';
  position: absolute;
  inset: 0;
  pointer-events: none;
  background:
    linear-gradient(180deg, rgba(3, 12, 8, .02) 0%, transparent 46%, rgba(3, 13, 9, .46) 100%),
    radial-gradient(circle at 80% 18%, rgba(255, 196, 121, .16), transparent 34%),
    radial-gradient(circle at 16% 86%, rgba(60,179,113,.16), transparent 34%);
}

.asset-frame:hover img {
  transform: scale(1.055);
  filter: saturate(1.06) contrast(1.03);
}

.asset-frame figcaption,
.asset-frame__fallback-content {
  position: absolute;
  left: 22px;
  bottom: 22px;
  z-index: 2;
  color: rgba(255,255,255,.88);
}

.asset-frame figcaption {
  right: 22px;
}

.asset-frame figcaption,
.asset-frame__fallback-content span:last-child {
  font-size: .76rem;
  font-weight: 900;
  letter-spacing: .12em;
  line-height: 1.35;
  text-transform: uppercase;
}

.asset-frame__fallback-content {
  display: grid;
  max-width: calc(100% - 120px);
  width: fit-content;
  gap: 8px;
  padding: 10px 13px;
  border: 1px solid rgba(143,224,180,.18);
  border-radius: 999px;
  background:
    linear-gradient(135deg, rgba(9,27,18,.40), rgba(60,179,113,.12)),
    rgba(255,255,255,.08);
  box-shadow: 0 14px 34px rgba(0,0,0,.16), inset 0 1px 0 rgba(255,255,255,.10);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
}

.asset-frame__fallback-icon {
  position: absolute;
  right: 22px;
  top: 22px;
  z-index: 2;
  width: 62px;
  height: 62px;
  display: grid;
  place-items: center;
  border-radius: 22px;
  color: #f8fff9;
  border: 1px solid rgba(143,224,180,.32);
  background:
    radial-gradient(circle at 30% 18%, rgba(255,255,255,.38), transparent 34%),
    radial-gradient(circle at 74% 76%, rgba(242,192,120,.20), transparent 40%),
    linear-gradient(135deg, rgba(60,179,113,.36), rgba(60,179,113,.16));
  box-shadow: 0 20px 52px rgba(60,179,113,.28), 0 0 34px rgba(60,179,113,.16), inset 0 1px 0 rgba(255,255,255,.20);
}

.asset-frame__fallback-icon svg {
  width: 28px;
  height: 28px;
  fill: none;
  stroke: currentColor;
  stroke-width: 1.75;
  stroke-linecap: round;
  stroke-linejoin: round;
}

.asset-frame__fallback-kicker {
  width: fit-content;
  padding: 6px 10px;
  border: 1px solid rgba(143,224,180,.22);
  border-radius: 999px;
  color: #e9fff1;
  background: rgba(60,179,113,.16);
  font-size: .68rem !important;
  letter-spacing: .14em !important;
}

.asset-frame__fallback-scene {
  position: absolute;
  inset: 0;
  overflow: hidden;
  background:
    radial-gradient(circle at 76% 20%, rgba(242,192,120,.34), transparent 24%),
    radial-gradient(circle at 26% 14%, rgba(143,224,180,.24), transparent 28%),
    radial-gradient(circle at 14% 78%, rgba(60,179,113,.30), transparent 36%),
    linear-gradient(160deg, rgba(26,82,53,.82), rgba(12,39,27,.92));
}

.asset-frame__fallback-scene::before {
  content: '';
  position: absolute;
  inset: 0;
  opacity: .14;
  background-image:
    radial-gradient(circle at 12% 18%, rgba(255,255,255,.38) 0 1px, transparent 1px 5px),
    radial-gradient(circle at 78% 42%, rgba(255,255,255,.28) 0 1px, transparent 1px 6px);
  background-size: 7px 7px, 11px 11px;
  mix-blend-mode: screen;
}

.asset-frame__fallback-scene::after {
  content: '';
  position: absolute;
  inset: 0;
  opacity: .34;
  background:
    linear-gradient(115deg, transparent 0 18%, rgba(255,255,255,.08) 18.4% 18.8%, transparent 19% 100%),
    repeating-linear-gradient(135deg, rgba(255,255,255,.045) 0 1px, transparent 1px 18px);
  mask-image: radial-gradient(circle at 50% 50%, #000, transparent 76%);
}

.asset-frame__sun {
  position: absolute;
  right: 16%;
  top: 18%;
  width: clamp(74px, 12vw, 140px);
  aspect-ratio: 1;
  border-radius: 999px;
  background: radial-gradient(circle, rgba(255,236,185,.92), rgba(242,192,120,.46) 44%, transparent 68%);
  filter: blur(.4px);
  opacity: .72;
}

.asset-frame__hill {
  position: absolute;
  left: -12%;
  right: -12%;
  bottom: -18%;
  height: 52%;
  border-radius: 52% 52% 0 0;
  background: linear-gradient(180deg, rgba(60,179,113,.38), rgba(11,31,21,.86));
  filter: blur(.2px);
}

.asset-frame__hill--back {
  bottom: -8%;
  height: 48%;
  opacity: .56;
  transform: translateX(18%);
}

.asset-frame__hill--front {
  height: 42%;
  background: linear-gradient(180deg, rgba(55,151,96,.70), rgba(10,30,20,.94));
}

.asset-frame__tent {
  position: absolute;
  left: 14%;
  bottom: 25%;
  width: clamp(86px, 17vw, 160px);
  height: clamp(58px, 10vw, 104px);
  border-radius: 10px 10px 4px 4px;
  background:
    linear-gradient(116deg, transparent 0 49%, rgba(255,255,255,.16) 50% 52%, transparent 53% 100%),
    linear-gradient(135deg, rgba(242,192,120,.62), rgba(60,179,113,.58));
  clip-path: polygon(50% 0, 100% 100%, 0 100%);
  box-shadow: 0 18px 46px rgba(0,0,0,.22);
}

.asset-frame__tent::before,
.asset-frame__tent::after {
  content: '';
  position: absolute;
  pointer-events: none;
}

.asset-frame--fallback.photo-frame {
  min-height: 240px;
  border-color: rgba(143,224,180,.38);
  box-shadow: 0 30px 88px rgba(17,40,28,.22), 0 0 44px rgba(60,179,113,.16);
}

.asset-frame--fallback-camper .asset-frame__fallback-scene {
  background:
    radial-gradient(circle at 78% 20%, rgba(242,192,120,.34), transparent 26%),
    radial-gradient(circle at 18% 76%, rgba(60,179,113,.34), transparent 38%),
    linear-gradient(145deg, #4f7b5e, #1b422d 58%, #102117);
}

.asset-frame--fallback-camper .asset-frame__tent {
  left: 13%;
  bottom: 24%;
  width: clamp(130px, 20vw, 210px);
  height: clamp(58px, 8vw, 86px);
  clip-path: none;
  border-radius: 18px 24px 12px 12px;
  background:
    radial-gradient(circle at 22% 102%, rgba(8, 26, 17, .92) 0 9px, transparent 10px),
    radial-gradient(circle at 76% 102%, rgba(8, 26, 17, .92) 0 9px, transparent 10px),
    linear-gradient(135deg, rgba(242,192,120,.62), rgba(143,224,180,.58));
}

.asset-frame--fallback-bungalow .asset-frame__fallback-scene {
  background:
    radial-gradient(circle at 24% 18%, rgba(242,192,120,.30), transparent 30%),
    radial-gradient(circle at 82% 76%, rgba(143,224,180,.26), transparent 36%),
    linear-gradient(145deg, #55705b, #22452f 58%, #102117);
}

.asset-frame--fallback-bungalow .asset-frame__tent {
  left: 16%;
  bottom: 23%;
  width: clamp(118px, 18vw, 194px);
  height: clamp(82px, 12vw, 126px);
  clip-path: polygon(50% 0, 100% 42%, 100% 100%, 0 100%, 0 42%);
  border-radius: 12px;
  background:
    linear-gradient(90deg, transparent 46%, rgba(255,255,255,.16) 47% 49%, transparent 50%),
    linear-gradient(135deg, rgba(242,192,120,.56), rgba(60,179,113,.50));
}

.asset-frame--fallback-tram .asset-frame__fallback-scene {
  background:
    radial-gradient(circle at 80% 18%, rgba(242,192,120,.28), transparent 30%),
    linear-gradient(135deg, rgba(60,179,113,.32), transparent 38%),
    repeating-linear-gradient(135deg, rgba(255,255,255,.055) 0 2px, transparent 2px 22px),
    linear-gradient(145deg, #496f63, #1c4234 58%, #102117);
}

.asset-frame--fallback-tram .asset-frame__tent {
  left: 13%;
  bottom: 26%;
  width: clamp(128px, 20vw, 210px);
  height: clamp(58px, 8vw, 84px);
  clip-path: none;
  border-radius: 22px 22px 12px 12px;
  background:
    radial-gradient(circle at 26% 108%, rgba(8, 26, 17, .88) 0 8px, transparent 9px),
    radial-gradient(circle at 74% 108%, rgba(8, 26, 17, .88) 0 8px, transparent 9px),
    linear-gradient(180deg, rgba(255,255,255,.18), transparent 48%),
    linear-gradient(135deg, rgba(143,224,180,.72), rgba(60,179,113,.42));
}

.asset-frame--fallback-attractions .asset-frame__fallback-scene {
  background:
    radial-gradient(circle at 72% 18%, rgba(242,192,120,.38), transparent 26%),
    radial-gradient(circle at 20% 80%, rgba(60,179,113,.30), transparent 38%),
    linear-gradient(145deg, #5d7560, #203f2d 58%, #102117);
}

.asset-frame--fallback-attractions .asset-frame__tent {
  left: 15%;
  bottom: 22%;
  width: clamp(104px, 16vw, 174px);
  height: clamp(96px, 14vw, 148px);
  clip-path: polygon(50% 0, 92% 30%, 92% 100%, 8% 100%, 8% 30%);
  border-radius: 10px;
  background:
    repeating-linear-gradient(90deg, rgba(255,255,255,.16) 0 8px, transparent 8px 22px),
    linear-gradient(135deg, rgba(242,192,120,.56), rgba(60,179,113,.46));
}

.asset-frame--fallback-electricity .asset-frame__fallback-scene,
.asset-frame--fallback-sanitary .asset-frame__fallback-scene {
  background:
    radial-gradient(circle at 18% 18%, rgba(143,224,180,.32), transparent 30%),
    radial-gradient(circle at 82% 78%, rgba(242,192,120,.22), transparent 34%),
    linear-gradient(145deg, #486f66, #183f31 58%, #102117);
}

.asset-frame--fallback-electricity .asset-frame__tent,
.asset-frame--fallback-sanitary .asset-frame__tent {
  left: 16%;
  bottom: 25%;
  width: clamp(82px, 13vw, 132px);
  height: clamp(82px, 13vw, 132px);
  clip-path: none;
  border-radius: 30px;
  background:
    radial-gradient(circle at 28% 18%, rgba(255,255,255,.26), transparent 32%),
    linear-gradient(135deg, rgba(143,224,180,.64), rgba(60,179,113,.42));
}

.asset-frame--fallback-electricity .asset-frame__tent {
  rotate: -8deg;
}

.asset-frame--fallback .asset-frame__fallback-scene {
  transition: transform .8s cubic-bezier(.2,.8,.2,1), filter .8s ease;
}

.asset-frame--fallback:hover .asset-frame__fallback-scene {
  transform: scale(1.035);
  filter: saturate(1.06);
}

@media (max-width: 680px) {
  .asset-frame.photo-frame {
    border-radius: 22px;
  }

  .asset-frame figcaption,
  .asset-frame__fallback-content {
    left: 18px;
    bottom: 18px;
  }

  .asset-frame figcaption {
    right: 18px;
  }

  .asset-frame__fallback-content {
    max-width: calc(100% - 104px);
  }
}
</style>
