---
const items = [
  ['Blisko centrum Krakowa', 'Zielona baza pobytowa bez konieczności nocowania w ścisłym centrum.'],
  ['Tramwaj do Starego Miasta', 'Wygodny dojazd komunikacją miejską na zwiedzanie i wieczorne spacery.'],
  ['Kampery, namioty i przyczepy', 'Praktyczna infrastruktura dla klasycznego europejskiego campingu.'],
  ['Komfortowe domki', 'Wygodna opcja dla par, rodzin i grup planujących pobyt w Krakowie.'],
  ['Spokojna przestrzeń', 'Więcej zieleni, oddechu i rytmu odpoczynku po intensywnym dniu.'],
  ['Baza do Małopolski', 'Dobry punkt startowy na Wieliczkę, Oświęcim, Kazimierz i okolice.'],
];
---

<section class="site-section why reveal-section" id="dlaczego">
  <div class="container">
    <span class="section-kicker">Dlaczego Clepardia</span>
    <h2 class="section-title">Camping w Krakowie, który łączy miasto, zieleń i swobodę podróży.</h2>
    <div class="why__grid">
      {items.map(([title, copy], index) => (
        <article class="premium-card why__card">
          <div class="why__number">{String(index + 1).padStart(2, '0')}</div>
          <h3>{title}</h3>
          <p>{copy}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
.why { background: linear-gradient(180deg, #fbfbf7, #f0f6ef); }
.why__grid { margin-top: 42px; display: grid; grid-template-columns: 1fr; gap: 16px; }
.why__card { padding: 28px; }
.why__number { color: #3CB371; font-weight: 900; letter-spacing: .12em; margin-bottom: 34px; }
.why__card h3 { font-size: 1.25rem; font-weight: 900; margin-bottom: 12px; }
.why__card p { color: #5c685f; line-height: 1.7; }
@media (min-width: 760px) { .why__grid { grid-template-columns: repeat(2, 1fr); } }
@media (min-width: 1120px) { .why__grid { grid-template-columns: repeat(3, 1fr); } }
</style>
