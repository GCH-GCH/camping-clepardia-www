---
import ImageFrame from '@/components/ImageFrame.astro';
import Icon from '@/components/ui/Icon.astro';
import { getCoreUi, tourBookingHref } from '@/i18n/coreUi';
import { siteAssets } from '@/data/assets';
import { resolveContentLanguage } from '@/i18n/config';
import { getLocalizedPath, getPathContext, getPlannerLocalizedPath } from '@/utils/localizedLinks';

interface Props {
  languageCode?: string;
}

type Copy = {
  kicker: string;
  title: string;
  lead: string;
  featuredLabel: string;
  durationLabel: string;
  transportLabel: string;
  powered: string;
  cardsAria: string;
  benefitsTitle: string;
  tours: Array<{
    key: keyof typeof siteAssets.attractions;
    title: string;
    eyebrow: string;
    duration: string;
    transport: string;
    description: string;
    alt: string;
    icon: string;
    featured?: boolean;
  }>;
  benefits: Array<{
    title: string;
    text: string;
    icon: string;
  }>;
};

