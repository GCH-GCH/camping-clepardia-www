const { languageCode } = Astro.props as Props;
const lang = resolveContentLanguage(languageCode);
const copy = copyByLanguage[lang] ?? copyByLanguage.en;
const pathContext = getPathContext(Astro.url.pathname);
const explicitLanguage = pathContext.explicitLanguage ?? (languageCode && languageCode !== 'pl' ? languageCode : undefined);
const contactHref = getLocalizedPath(explicitLanguage, 'kontakt');
const qrCells = Array.from({ length: 25 }, (_, index) => index);
const featuredTour = copy.tours.find((tour) => tour.featured) ?? copy.tours[0];
const secondaryTours = copy.tours.filter((tour) => tour !== featuredTour);
---

<section class="site-section tours-section reveal-section" id="wycieczki" aria-labelledby="tours-title">
  <div class="tours-section__glow tours-section__glow--green" aria-hidden="true"></div>
  <div class="tours-section__glow tours-section__glow--gold" aria-hidden="true"></div>

  <div class="container tours-section__container">
    <div class="tours-section__intro">
      <span class="section-kicker">{copy.kicker}</span>
      <h2 class="section-title" id="tours-title">{copy.title}</h2>
      <p class="section-copy">{copy.lead}</p>
    </div>

    <div class="tours-section__layout">
      <article class="tours-section__featured premium-card reveal-section" style="--reveal-delay: 80ms">
        <div class="tours-section__featured-media">
          <ImageFrame
            src={siteAssets.attractions[featuredTour.key]}
            alt={featuredTour.alt}
            label={featuredTour.title}
            className="tours-section__media tours-section__media--featured"
          />
          <span class="tours-section__floating-badge">
            <Icon name={featuredTour.icon} size={16} />
            {copy.featuredLabel}
          </span>
        </div>
        <div class="tours-section__featured-content">
          <span class="tours-section__eyebrow">{featuredTour.eyebrow}</span>
          <h3>{featuredTour.title}</h3>
          <p>{featuredTour.description}</p>
          <dl class="tours-section__meta">
            <div>
              <dt>{copy.durationLabel}</dt>
              <dd><Icon name="clock" size={16} /> {featuredTour.duration}</dd>
            </div>
            <div>
              <dt>{copy.transportLabel}</dt>
              <dd><Icon name="route" size={16} /> {featuredTour.transport}</dd>
            </div>
          </dl>
        </div>
      </article>

      <aside class="tours-section__qr premium-card reveal-section" style="--reveal-delay: 160ms" aria-labelledby="tours-qr-title">
        <span class="tours-section__powered">{copy.powered}</span>
        <div class="tours-section__qr-code" role="img" aria-label={copy.qrPlaceholder}>
          {qrCells.map((cell) => (
            <span class:list={[
              'tours-section__qr-cell',
              cell % 4 === 0 && 'is-strong',
              cell === 6 && 'is-empty',
              cell === 18 && 'is-empty',
            ]}></span>
          ))}
          <strong>QR</strong>
        </div>
        <h3 id="tours-qr-title">{copy.qrTitle}</h3>
        <p>{copy.qrCopy}</p>
        <a class="btn btn-secondary tours-section__qr-cta" href={contactHref}>
          <Icon name="contact" size={18} />
          {copy.qrCta}
        </a>
      </aside>

      <div class="tours-section__cards" aria-label={copy.cardsAria}>
        {secondaryTours.map((tour, index) => (
          <article class="tours-section__card premium-card reveal-section" style={`--reveal-delay: ${220 + index * 70}ms`}>
            <ImageFrame
              src={siteAssets.attractions[tour.key]}
              alt={tour.alt}
              label={tour.title}
              className={`tours-section__media tours-section__media--${index + 1}`}
            />
            <div class="tours-section__card-content">
              <span class="tours-section__card-icon" aria-hidden="true">
                <Icon name={tour.icon} size={20} />
              </span>
              <div>
                <span class="tours-section__eyebrow">{tour.eyebrow}</span>
                <h3>{tour.title}</h3>
                <p>{tour.description}</p>
              </div>
              <div class="tours-section__chips" aria-label={`${copy.durationLabel}: ${tour.duration}. ${copy.transportLabel}: ${tour.transport}.`}>
                <span><Icon name="clock" size={14} /> {tour.duration}</span>
                <span><Icon name="route" size={14} /> {tour.transport}</span>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>

    <div class="tours-section__benefits" aria-label={copy.benefitsTitle}>
      <div class="tours-section__benefit-heading">
        <span class="section-kicker">Travel support</span>
        <h3>{copy.benefitsTitle}</h3>
      </div>
      {copy.benefits.map((benefit, index) => (
        <article class="tours-section__benefit reveal-section" style={`--reveal-delay: ${index * 90}ms`}>
          <span class="tours-section__benefit-icon" aria-hidden="true">
            <Icon name={benefit.icon} size={22} />
          </span>
          <div>
            <h4>{benefit.title}</h4>
            <p>{benefit.text}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
.tours-section {
  position: relative;
  isolation: isolate;
  overflow: hidden;
  background:
    radial-gradient(circle at 12% 18%, rgba(60,179,113,.18), transparent 30%),
    radial-gradient(circle at 86% 12%, rgba(242,192,120,.16), transparent 30%),
    linear-gradient(180deg, rgba(245,248,241,.58), rgba(255,255,255,.18));
}

html[data-theme="dark"] .tours-section {
  background:
    radial-gradient(circle at 12% 18%, rgba(60,179,113,.16), transparent 30%),
    radial-gradient(circle at 86% 12%, rgba(242,192,120,.12), transparent 31%),
    linear-gradient(180deg, rgba(16,33,23,.94), rgba(9,26,19,.78));
}

.tours-section__glow {
  position: absolute;
  z-index: -1;
  pointer-events: none;
  border-radius: 999px;
  filter: blur(42px);
  opacity: .72;
}

.tours-section__glow--green {
  left: -10%;
  top: 18%;
  width: min(38vw, 520px);
  aspect-ratio: 1;
  background: rgba(60,179,113,.20);
}

.tours-section__glow--gold {
  right: -8%;
  bottom: 12%;
  width: min(34vw, 460px);
  aspect-ratio: 1;
  background: rgba(242,192,120,.15);
}

.tours-section__container {
  position: relative;
  display: grid;
  gap: clamp(28px, 5vw, 58px);
}

.tours-section__intro {
  max-width: 860px;
}

.tours-section__layout {
  display: grid;
  grid-template-columns: minmax(0, 1.08fr) minmax(320px, .92fr);
  grid-template-areas:
    "featured qr"
    "cards cards";
  gap: clamp(18px, 3vw, 28px);
  align-items: stretch;
}

.tours-section__featured,
.tours-section__qr,
.tours-section__card,
.tours-section__benefit {
  border-color: rgba(143,224,180,.28);
  background:
    linear-gradient(145deg, rgba(255,255,255,.78), rgba(255,255,255,.54)),
    radial-gradient(circle at 18% 0%, rgba(60,179,113,.12), transparent 36%);
  box-shadow: 0 28px 90px rgba(18,42,29,.12), inset 0 1px 0 rgba(255,255,255,.60);
}

html[data-theme="dark"] .tours-section__featured,
html[data-theme="dark"] .tours-section__qr,
html[data-theme="dark"] .tours-section__card,
html[data-theme="dark"] .tours-section__benefit {
  background:
    linear-gradient(145deg, rgba(255,255,255,.075), rgba(255,255,255,.045)),
    radial-gradient(circle at 18% 0%, rgba(60,179,113,.18), transparent 38%);
  box-shadow: 0 28px 92px rgba(0,0,0,.28), inset 0 1px 0 rgba(255,255,255,.10);
}

.tours-section__featured {
  grid-area: featured;
  display: grid;
  grid-template-columns: minmax(0, 1.1fr) minmax(260px, .9fr);
  gap: clamp(18px, 3vw, 30px);
  padding: clamp(16px, 2.4vw, 24px);
  overflow: hidden;
}

.tours-section__featured-media {
  position: relative;
  min-width: 0;
}

:global(.tours-section__media.photo-frame) {
  width: 100%;
  height: 100%;
  min-height: 250px;
}

:global(.tours-section__media--featured.photo-frame) {
  min-height: clamp(320px, 32vw, 440px);
}

.tours-section__floating-badge {
  position: absolute;
  left: 18px;
  top: 18px;
  z-index: 3;
  display: inline-flex;
  align-items: center;
  gap: 8px;
  max-width: calc(100% - 36px);
  padding: 9px 13px;
  border: 1px solid rgba(242,192,120,.42);
  border-radius: 999px;
  color: #fffdf4;
  background:
