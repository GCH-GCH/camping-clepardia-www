  kicker: string;
  title: string;
  lead: string;
  featuredLabel: string;
  durationLabel: string;
  transportLabel: string;
  qrTitle: string;
  qrCopy: string;
  qrCta: string;
  qrPlaceholder: string;
  powered: string;
  cardsAria: string;
  benefitsTitle: string;
  tours: Array<{
    key: keyof typeof siteAssets.attractions;
    title: string;
    eyebrow: string;
    duration: string;
    transport: string;
    description: string;
    alt: string;
    icon: string;
    featured?: boolean;
  }>;
  benefits: Array<{
    title: string;
    text: string;
    icon: string;
  }>;
};

