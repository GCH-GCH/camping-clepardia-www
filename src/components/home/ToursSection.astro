const { languageCode } = Astro.props as Props;
const pathContext = getPathContext(Astro.url.pathname);
const activeLanguage = languageCode ?? pathContext.languageCode;
const lang = activeLanguage;
const copy = copyByLanguage[lang] ?? copyByLanguage.en;
const contactUrl = getLocalizedPath(pathContext.explicitLanguage, 'kontakt');
const plannerUrl = getPlannerLocalizedPath(pathContext.explicitLanguage);
const neutralBookingText = {
