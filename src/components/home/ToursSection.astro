const { languageCode } = Astro.props as Props;
const pathContext = getPathContext(Astro.url.pathname);
const activeLanguage = languageCode ?? pathContext.languageCode;
const lang = resolveContentLanguage(activeLanguage);
const copy = copyByLanguage[lang] ?? copyByLanguage.en;
const contactUrl = getLocalizedPath(pathContext.explicitLanguage, 'kontakt');
const plannerUrl = getPlannerLocalizedPath(pathContext.explicitLanguage);
const neutralBookingText = {
  pl: {
    reserveTitle: 'Zapytaj o wycieczki i transfery',
    reserveDescription: 'W recepcji możesz zapytać o dostępne wycieczki i praktyczne opcje dojazdu do popularnych miejsc.',
    sellingText: 'Wieliczka, Auschwitz-Birkenau, Zakopane, Ojców i rodzinne atrakcje możesz połączyć z pobytem bez zewnętrznego brandowania.',
    reserve: 'Zapytaj recepcję',
    planner: 'Otwórz planer',
    cards: 'Dodaj do planera',
    chips: ['Praktyczne wskazówki', 'Plan dnia', 'Transport', 'Spokojny powrót'],
  },
  en: {
    reserveTitle: 'Ask about trips and transfers',
    reserveDescription: 'Reception can help with practical information about available trips and transport to popular destinations.',
    sellingText: 'Combine Wieliczka, Auschwitz-Birkenau, Zakopane, Ojców and family attractions with your stay without external partner branding.',
    reserve: 'Ask reception',
    planner: 'Open planner',
    cards: 'Add to planner',
    chips: ['Practical guidance', 'Day plan', 'Transport', 'Calm return'],
  },
  de: {
    reserveTitle: 'Ausflüge und Transfers anfragen',
    reserveDescription: 'Die Rezeption hilft mit praktischen Informationen zu Ausflügen und Transportmöglichkeiten.',
    sellingText: 'Wieliczka, Auschwitz-Birkenau, Zakopane, Ojców und Familienziele lassen sich ohne externes Partner-Branding planen.',
    reserve: 'Rezeption fragen',
    planner: 'Planer öffnen',
    cards: 'Zum Planer',
    chips: ['Praktische Hinweise', 'Tagesplan', 'Transport', 'Ruhige Rückkehr'],
  },
  it: {
    reserveTitle: 'Chiedi informazioni su tour e transfer',
    reserveDescription: 'La reception può aiutare con informazioni pratiche su escursioni e trasporti.',
    sellingText: 'Combina Wieliczka, Auschwitz-Birkenau, Zakopane, Ojców e mete per famiglie senza marchi di partner esterni.',
    reserve: 'Chiedi alla reception',
    planner: 'Apri planner',
    cards: 'Aggiungi al planner',
    chips: ['Consigli pratici', 'Piano del giorno', 'Trasporto', 'Ritorno tranquillo'],
  },
};
const bookingText = neutralBookingText[lang] ?? neutralBookingText.en;
const tourUi = getCoreUi(activeLanguage).tour;
const bookingChips = bookingText.chips;
const featuredTour = copy.tours.find((tour) => tour.featured) ?? copy.tours[0];
const secondaryTours = copy.tours.filter((tour) => tour !== featuredTour);
const featuredRouteUrl = 'https://www.google.com/maps/search/?api=1&query=Auschwitz-Birkenau+Memorial';
---

<section class="site-section tours-section reveal-section" id="wycieczki" aria-labelledby="tours-title">
  <div class="tours-section__glow tours-section__glow--green" aria-hidden="true"></div>
  <div class="tours-section__glow tours-section__glow--gold" aria-hidden="true"></div>

  <div class="container tours-section__container">
    <div class="tours-section__intro">
      <span class="section-kicker">{copy.kicker}</span>
      <h2 class="section-title" id="tours-title">{copy.title}</h2>
      <p class="section-copy">{copy.lead}</p>
    </div>

    <div class="tours-section__layout">
      <article class="tours-section__featured premium-card reveal-section" style="--reveal-delay: 80ms">
        <div class="tours-section__featured-media">
          <ImageFrame
            src={siteAssets.attractions[featuredTour.key]}
            alt={featuredTour.alt}
            label={featuredTour.title}
            className="tours-section__media tours-section__media--featured"
          />
          <span class="tours-section__floating-badge">
            <Icon name={featuredTour.icon} size={16} />
            {copy.featuredLabel}
          </span>
        </div>
        <div class="tours-section__featured-content">
          <span class="tours-section__eyebrow">{featuredTour.eyebrow}</span>
          <h3>{featuredTour.title}</h3>
          <p>{featuredTour.description}</p>
          <dl class="tours-section__meta">
            <div>
              <dt>{copy.durationLabel}</dt>
              <dd><Icon name="clock" size={16} /> {featuredTour.duration}</dd>
            </div>
            <div>
              <dt>{copy.transportLabel}</dt>
              <dd><Icon name="route" size={16} /> {featuredTour.transport}</dd>
            </div>
          </dl>
          <div class="tours-section__featured-actions">
            <a class="btn btn-primary tours-section__book-link tours-section__book-link--featured" href={tourBookingHref} target="_blank" rel="noopener noreferrer">
              <Icon name="CalendarCheck" size={18} />
              {tourUi[1]}
              <Icon name="ArrowUpRight" size={16} />
            </a>
            <a class="tours-section__planner-cta" href={plannerUrl}>
              <Icon name="Map" size={17} />
              {bookingText.cards}
            </a>
            <a class="tours-section__planner-cta" href={featuredRouteUrl} target="_blank" rel="noopener noreferrer">
              <Icon name="MapPin" size={17} />
              {copy.transportLabel}
            </a>
            <button class="tours-section__planner-cta" type="button" data-tour-campy={featuredTour.title}>
              <Icon name="BotMessageSquare" size={17} />
              CAMPY
            </button>
          </div>
        </div>
      </article>

      <aside class="tours-section__booking premium-card reveal-section" style="--reveal-delay: 160ms" aria-labelledby="tours-booking-title">
        <ImageFrame
          src={siteAssets.attractions.tours}
          alt={bookingText.reserveTitle}
          label={copy.powered}
          className="tours-section__booking-media"
        />
        <span class="tours-section__powered">{copy.powered}</span>
        <div class="tours-section__booking-icon" aria-hidden="true">
          <Icon name="TicketCheck" size={34} />
        </div>
        <h3 id="tours-booking-title">{bookingText.reserveTitle}</h3>
        <p>{bookingText.reserveDescription}</p>
        <p class="tours-section__booking-selling">{bookingText.sellingText}</p>
        <div class="tours-section__booking-chips" aria-label={bookingText.reserveTitle}>
          {bookingChips.map((chip) => (
            <span><Icon name="check" size={14} /> {chip}</span>
          ))}
        </div>
        <div class="tours-section__booking-actions">
        <a class="btn btn-primary tours-section__booking-cta" href={tourBookingHref} target="_blank" rel="noopener noreferrer">
          <Icon name="MessageCircle" size={18} />
          {tourUi[0]}
          <Icon name="ArrowUpRight" size={16} />
        </a>
        <a class="tours-section__planner-cta" href={plannerUrl}>
          <Icon name="Map" size={17} />
          {bookingText.planner}
        </a>
        <button class="tours-section__planner-cta" type="button" data-tour-campy={bookingText.reserveTitle}>
          <Icon name="BotMessageSquare" size={17} />
          CAMPY
        </button>
        </div>
      </aside>

      <div class="tours-section__cards" aria-label={copy.cardsAria}>
        {secondaryTours.map((tour, index) => (
          <article class="tours-section__card premium-card reveal-section" style={`--reveal-delay: ${220 + index * 70}ms`}>
            <ImageFrame
              src={siteAssets.attractions[tour.key]}
              alt={tour.alt}
              label={tour.title}
              className={`tours-section__media tours-section__media--${index + 1}`}
            />
            <div class="tours-section__card-content">
              <span class="tours-section__card-icon" aria-hidden="true">
                <Icon name={tour.icon} size={20} />
              </span>
              <div>
                <span class="tours-section__eyebrow">{tour.eyebrow}</span>
                <h3>{tour.title}</h3>
                <p>{tour.description}</p>
              </div>
              <div class="tours-section__chips" aria-label={`${copy.durationLabel}: ${tour.duration}. ${copy.transportLabel}: ${tour.transport}.`}>
                <span><Icon name="clock" size={14} /> {tour.duration}</span>
                <span><Icon name="route" size={14} /> {tour.transport}</span>
              </div>
              <a class="tours-section__card-cta" href={plannerUrl}>
                {bookingText.cards}
                <Icon name="ArrowUpRight" size={14} />
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>

    <div class="tours-section__benefits" aria-label={copy.benefitsTitle}>
      <div class="tours-section__benefit-heading">
        <span class="section-kicker">Travel support</span>
        <h3>{copy.benefitsTitle}</h3>
      </div>
      {copy.benefits.map((benefit, index) => (
        <article class="tours-section__benefit reveal-section" style={`--reveal-delay: ${index * 90}ms`}>
          <span class="tours-section__benefit-icon" aria-hidden="true">
            <Icon name={benefit.icon} size={22} />
          </span>
          <div>
            <h4>{benefit.title}</h4>
            <p>{benefit.text}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('[data-tour-campy]').forEach((button) => {
    if (!(button instanceof HTMLButtonElement)) return;
    button.addEventListener('click', () => {
      window.dispatchEvent(new CustomEvent('campy:prompt', {
        detail: { prompt: `Opowiedz mi o: ${button.dataset.tourCampy ?? ''}` },
      }));
    });
  });
</script>

<style>
.tours-section {
  position: relative;
  isolation: isolate;
  overflow: hidden;
