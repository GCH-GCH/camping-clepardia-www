---
import { getTranslations } from '@/i18n/config';
import { getPathContext } from '@/utils/localizedLinks';
import Icon from '@/components/ui/Icon.astro';

interface Props {
  languageCode?: string;
}

const { languageCode } = Astro.props as Props;
const pathContext = getPathContext(Astro.url.pathname);
const t = getTranslations(languageCode ?? pathContext.languageCode);
const stats = t.home.stats;
const icons = ['map', 'tram', 'camping', 'leaf'] as const;
---

<section class="home-stats reveal-section" aria-label="Camping Clepardia">
  <div class="container">
    <div class="home-stats__panel">
      {stats.map((item, index) => (
        <article class="home-stats__item reveal-section" style={`--reveal-delay: ${index * 70}ms`}>
          <span class="home-stats__icon" aria-hidden="true">
            <Icon name={icons[index] ?? 'check'} size={24} strokeWidth={1.8} />
          </span>
          <small>{item.value}</small>
          <h2>{item.label}</h2>
          <p>{item.copy}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
.home-stats {
  position: relative;
  z-index: 5;
  margin-top: clamp(-78px, -6vw, -48px);
  padding: 0 0 clamp(62px, 8vw, 110px);
}

.home-stats__panel {
  display: grid;
  grid-template-columns: 1fr;
  gap: 12px;
  overflow: hidden;
  border: 1px solid rgba(255,255,255,.16);
  border-radius: 34px;
  padding: 12px;
  background:
    linear-gradient(135deg, rgba(9,27,18,.82), rgba(18,48,31,.66)),
    radial-gradient(circle at 88% 10%, rgba(242,192,120,.18), transparent 32%),
    radial-gradient(circle at 10% 92%, rgba(60,179,113,.14), transparent 30%);
  box-shadow:
    0 34px 100px rgba(0,0,0,.26),
    0 0 54px rgba(60,179,113,.12),
    inset 0 1px 0 rgba(255,255,255,.14);
  backdrop-filter: blur(24px) saturate(150%);
  -webkit-backdrop-filter: blur(24px) saturate(150%);
}

.home-stats__item {
  position: relative;
  min-height: 178px;
  display: grid;
  align-content: end;
  gap: 10px;
  padding: clamp(22px, 3vw, 34px);
  border: 1px solid rgba(255,255,255,.105);
  border-radius: 26px;
  background:
    linear-gradient(180deg, rgba(255,255,255,.12), rgba(255,255,255,.045)),
    radial-gradient(circle at 18% 14%, rgba(143,224,180,.18), transparent 32%);
  box-shadow: inset 0 1px 0 rgba(255,255,255,.10);
  overflow: hidden;
}

.home-stats__item::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(circle at 22% 18%, rgba(143,224,180,.16), transparent 36%),
    linear-gradient(180deg, rgba(255,255,255,.07), transparent);
  opacity: 0;
  transition: opacity .32s cubic-bezier(.22, 1, .36, 1);
}

.home-stats__item:hover::before {
  opacity: 1;
}

.home-stats__item small,
.home-stats__item h2,
.home-stats__item p,
.home-stats__icon {
  position: relative;
  z-index: 1;
}

.home-stats__icon {
  width: 48px;
  height: 48px;
  display: grid;
  place-items: center;
  margin-bottom: 8px;
  border-radius: 999px;
  color: #8fe0b4;
  border: 1px solid rgba(143,224,180,.22);
  background: rgba(143,224,180,.10);
  box-shadow: 0 12px 30px rgba(60,179,113,.14);
}

.home-stats__item small {
  color: #8fe0b4;
  font-size: .74rem;
  font-weight: 950;
  letter-spacing: .16em;
  text-transform: uppercase;
}

.home-stats__item h2 {
  max-width: 270px;
  color: #fff;
  font-size: clamp(1.18rem, 2vw, 1.52rem);
  line-height: 1.08;
  font-weight: 950;
  letter-spacing: 0;
}

.home-stats__item p {
  max-width: 310px;
  color: rgba(255,255,255,.70);
  font-size: .95rem;
  line-height: 1.6;
}

@media (min-width: 680px) {
  .home-stats__panel {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (min-width: 1080px) {
  .home-stats__panel {
    grid-template-columns: repeat(4, 1fr);
  }
}

@media (max-width: 560px) {
  .home-stats {
    margin-top: -38px;
    padding-bottom: 54px;
  }

  .home-stats__panel {
    border-radius: 26px;
    padding: 10px;
  }

  .home-stats__item {
    min-height: 154px;
    border-radius: 22px;
  }
}
</style>
