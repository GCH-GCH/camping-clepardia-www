---
const stats = [
  {
    label: 'Kraków blisko centrum',
    value: 'Miasto',
    copy: 'Zielona baza bez wjazdu autem w ścisłe centrum.',
  },
  {
    label: 'Tramwaj w pobliżu',
    value: 'Dojazd',
    copy: 'Wygodny start do Starego Miasta i Kazimierza.',
  },
  {
    label: 'Camping + domki',
    value: 'Pobyt',
    copy: 'Miejsca dla kamperów, namiotów, przyczep i gości domków.',
  },
  {
    label: 'Baza do zwiedzania Małopolski',
    value: 'Region',
    copy: 'Wieliczka, Ojców i rodzinne atrakcje w zasięgu wycieczki.',
  },
];
---

<section class="home-stats reveal-section" aria-label="Najważniejsze atuty Camping Clepardia">
  <div class="container">
    <div class="home-stats__panel">
      {stats.map((item, index) => (
        <article class="home-stats__item reveal-section" style={`--reveal-delay: ${index * 70}ms`}>
          <span>{item.value}</span>
          <h2>{item.label}</h2>
          <p>{item.copy}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
.home-stats {
  position: relative;
  z-index: 5;
  margin-top: clamp(-66px, -5vw, -42px);
  padding: 0 0 clamp(54px, 8vw, 96px);
}

.home-stats__panel {
  display: grid;
  grid-template-columns: 1fr;
  gap: 1px;
  overflow: hidden;
  border: 1px solid rgba(255,255,255,.18);
  border-radius: 30px;
  background:
    linear-gradient(135deg, rgba(9,27,18,.90), rgba(15,44,28,.78)),
    radial-gradient(circle at 90% 12%, rgba(239,174,99,.16), transparent 32%);
  box-shadow:
    0 30px 92px rgba(0,0,0,.26),
    0 0 46px rgba(60,179,113,.12),
    inset 0 1px 0 rgba(255,255,255,.12);
  backdrop-filter: blur(22px) saturate(145%);
  -webkit-backdrop-filter: blur(22px) saturate(145%);
}

.home-stats__item {
  position: relative;
  min-height: 156px;
  display: grid;
  align-content: center;
  gap: 10px;
  padding: clamp(22px, 3vw, 34px);
  background: rgba(255,255,255,.055);
}

.home-stats__item::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(circle at 22% 18%, rgba(143,224,180,.16), transparent 36%),
    linear-gradient(180deg, rgba(255,255,255,.07), transparent);
  opacity: 0;
  transition: opacity .32s cubic-bezier(.22, 1, .36, 1);
}

.home-stats__item:hover::before {
  opacity: 1;
}

.home-stats__item span,
.home-stats__item h2,
.home-stats__item p {
  position: relative;
  z-index: 1;
}

.home-stats__item span {
  color: #8fe0b4;
  font-size: .74rem;
  font-weight: 950;
  letter-spacing: .16em;
  text-transform: uppercase;
}

.home-stats__item h2 {
  max-width: 270px;
  color: #fff;
  font-size: clamp(1.18rem, 2vw, 1.52rem);
  line-height: 1.08;
  font-weight: 950;
  letter-spacing: 0;
}

.home-stats__item p {
  max-width: 310px;
  color: rgba(255,255,255,.70);
  font-size: .95rem;
  line-height: 1.6;
}

@media (min-width: 680px) {
  .home-stats__panel {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (min-width: 1080px) {
  .home-stats__panel {
    grid-template-columns: repeat(4, 1fr);
  }
}

@media (max-width: 560px) {
  .home-stats {
    margin-top: -34px;
    padding-bottom: 54px;
  }

  .home-stats__panel {
    border-radius: 24px;
  }

  .home-stats__item {
    min-height: 138px;
  }
}
</style>
