---
import { resolveContentLanguage } from '@/i18n/config';
import { getPathContext } from '@/utils/localizedLinks';
import Icon from '@/components/ui/Icon.astro';

interface Props {
  languageCode?: string;
}

const { languageCode } = Astro.props as Props;
const pathContext = getPathContext(Astro.url.pathname);
const lang = resolveContentLanguage(languageCode ?? pathContext.languageCode);
const copy = {
  pl: [
    { value: '9 przystanków', label: 'Do centrum', icon: 'tram' },
    { value: 'Google Maps', label: 'Dojazd po zmianie 2022', icon: 'map' },
    { value: '22:00-07:00', label: 'Cisza nocna', icon: 'moon' },
    { value: '2/3/4-os.', label: 'Domki bez kategorii rodzinnej', icon: 'bungalow' },
  ],
  en: [
    { value: '9 stops', label: 'To the city centre', icon: 'tram' },
    { value: 'Google Maps', label: 'Access route changed in 2022', icon: 'map' },
    { value: '22:00-07:00', label: 'Quiet hours', icon: 'moon' },
    { value: '2/3/4-person', label: 'Bungalows only', icon: 'bungalow' },
  ],
  de: [
    { value: '9 Haltestellen', label: 'Ins Zentrum', icon: 'tram' },
    { value: 'Google Maps', label: 'Zufahrt seit 2022 geändert', icon: 'map' },
    { value: '22:00-07:00', label: 'Nachtruhe', icon: 'moon' },
    { value: '2/3/4 Pers.', label: 'Nur diese Bungalows', icon: 'bungalow' },
  ],
  it: [
    { value: '9 fermate', label: 'Verso il centro', icon: 'tram' },
    { value: 'Google Maps', label: 'Accesso cambiato nel 2022', icon: 'map' },
    { value: '22:00-07:00', label: 'Silenzio notturno', icon: 'moon' },
    { value: '2/3/4 pers.', label: 'Solo questi bungalow', icon: 'bungalow' },
  ],
}[lang];
---

<section class="home-stats reveal-section" id="after-hero" aria-label="Camping Clepardia quick facts">
  <div class="container">
    <div class="home-stats__panel">
      {copy.map((item, index) => (
        <article class="home-stats__item reveal-section" style={`--reveal-delay: ${index * 55}ms`}>
          <span class="home-stats__icon" aria-hidden="true">
            <Icon name={item.icon} size={19} strokeWidth={1.9} />
          </span>
          <div>
            <strong>{item.value}</strong>
            <span>{item.label}</span>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
.home-stats {
  position: relative;
  z-index: 4;
  margin-top: clamp(14px, 2vw, 24px);
  padding: 0 0 clamp(38px, 5vw, 64px);
  scroll-margin-top: 96px;
}

.home-stats__panel {
  display: grid;
  grid-template-columns: 1fr;
  gap: 10px;
  padding: 10px;
  border: 1px solid rgba(143,224,180,.18);
  border-radius: 999px;
  background:
    radial-gradient(circle at 12% 0%, rgba(60,179,113,.16), transparent 34%),
    linear-gradient(135deg, rgba(255,255,255,.10), rgba(255,255,255,.055));
  box-shadow: 0 20px 56px rgba(0,0,0,.12), inset 0 1px 0 rgba(255,255,255,.12);
  backdrop-filter: blur(22px) saturate(140%);
  -webkit-backdrop-filter: blur(22px) saturate(140%);
}

.home-stats__item {
  display: flex;
  min-width: 0;
  align-items: center;
  gap: 12px;
  padding: 12px 14px;
  border: 1px solid rgba(255,255,255,.10);
  border-radius: 999px;
  color: #f4fff8;
  background: rgba(255,255,255,.055);
  box-shadow: inset 0 1px 0 rgba(255,255,255,.08);
  transition: transform .25s ease, border-color .25s ease, background .25s ease;
}

.home-stats__item:hover {
  transform: translateY(-2px);
  border-color: rgba(143,224,180,.34);
  background: rgba(60,179,113,.10);
}

.home-stats__icon {
  display: grid;
  width: 36px;
  height: 36px;
  flex: 0 0 auto;
  place-items: center;
  border-radius: 999px;
  color: #f8fff9;
  background:
    radial-gradient(circle at 28% 18%, rgba(255,255,255,.28), transparent 34%),
    linear-gradient(135deg, rgba(60,179,113,.74), rgba(42,133,83,.52));
  box-shadow: 0 10px 24px rgba(60,179,113,.22);
}

.home-stats__item div {
  display: grid;
  min-width: 0;
  gap: 2px;
}

.home-stats__item strong {
  color: #fff;
  font-size: .94rem;
  line-height: 1.1;
}

.home-stats__item span {
  color: rgba(244,251,246,.68);
  font-size: .78rem;
  line-height: 1.25;
}

@media (min-width: 700px) {
  .home-stats__panel {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    border-radius: 34px;
  }
}

@media (min-width: 1120px) {
  .home-stats__panel {
    grid-template-columns: repeat(4, minmax(0, 1fr));
    border-radius: 999px;
  }
}

@media (max-width: 520px) {
  .home-stats {
    padding-bottom: 36px;
  }

  .home-stats__panel {
    border-radius: 26px;
  }

  .home-stats__item {
    border-radius: 22px;
  }
}
</style>
