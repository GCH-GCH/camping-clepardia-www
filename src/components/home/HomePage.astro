---
import Hero from '@/components/Hero.astro';
import HomeStorySection from '@/components/home/HomeStorySection.astro';
import WhyClepardia from '@/components/home/WhyClepardia.astro';
import CampingSection from '@/components/home/CampingSection.astro';
import BungalowsSection from '@/components/home/BungalowsSection.astro';
import PricingPreview from '@/components/PricingPreview.astro';
import TramCenterGuide from '@/components/TramCenterGuide.astro';
import HomeAttractionsTours from '@/components/home/HomeAttractionsTours.astro';
import TrustSection from '@/components/TrustSection.astro';
import QuickInquiryCTA from '@/components/home/QuickInquiryCTA.astro';
import HomeFinalCTA from '@/components/home/HomeFinalCTA.astro';
import ArrivalFlowSection from '@/components/home/ArrivalFlowSection.astro';
import SiteNoticesSection from '@/components/home/SiteNoticesSection.astro';

interface Props {
  languageCode?: string;
}

const { languageCode } = Astro.props as Props;
---

<Hero languageCode={languageCode} />
<SiteNoticesSection languageCode={languageCode} />
<HomeStorySection languageCode={languageCode} />
<WhyClepardia languageCode={languageCode} />
<CampingSection languageCode={languageCode} />
<BungalowsSection languageCode={languageCode} />
<PricingPreview languageCode={languageCode} />
<TramCenterGuide languageCode={languageCode} variant="home" />
<ArrivalFlowSection languageCode={languageCode} />
<HomeAttractionsTours languageCode={languageCode} />
<TrustSection languageCode={languageCode} />
<QuickInquiryCTA languageCode={languageCode} />
<HomeFinalCTA languageCode={languageCode} />
