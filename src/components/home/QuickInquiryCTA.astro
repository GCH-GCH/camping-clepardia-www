    kicker: 'Szybkie zapytanie',
    title: 'Zapytaj o dostępność pobytu',
    lead: 'Wybierz wariant pobytu, a pełny formularz otworzy się z przygotowanym kontekstem.',
    button: 'Przejdź do rezerwacji',
    cardCta: 'Zarezerwuj',
    choices: {
      camping: {
        title: 'Camping',
        text: 'Kamper, przyczepa, namiot, van lub auto z namiotem dachowym.',
        icon: 'camping',
      },
      bungalow: {
        title: 'Domki',
        text: 'Domki 2-, 3- i 4-osobowe.',
        icon: 'bungalow',
      },
      combined: {
        title: 'Razem',
        text: 'Domek oraz miejsce campingowe w jednym zapytaniu.',
        icon: 'UsersRound',
      },
    },
  },
  en: {
    kicker: 'Quick enquiry',
    title: 'Ask about stay availability',
    lead: 'Choose your stay type and the full form opens with prepared context.',
    button: 'Go to the form',
    cardCta: 'Open form',
    choices: {
      camping: {
        title: 'Camping',
        text: 'Motorhome, caravan, tent, van or car with rooftop tent.',
        icon: 'camping',
      },
      bungalow: {
        title: 'Bungalows',
        text: '2-, 3- and 4-person bungalows.',
        icon: 'bungalow',
      },
      combined: {
        title: 'Combined',
        text: 'A bungalow and a camping pitch in one enquiry.',
        icon: 'UsersRound',
      },
    },
  },
  de: {
    kicker: 'Schnelle Anfrage',
    title: 'Verfügbarkeit anfragen',
    lead: 'Wählen Sie die Aufenthaltsart, das vollständige Formular öffnet mit vorbereitetem Kontext.',
    button: 'Zum Formular',
    cardCta: 'Formular öffnen',
    choices: {
      camping: {
        title: 'Camping',
        text: 'Wohnmobil, Wohnwagen, Zelt, Van oder Auto mit Dachzelt.',
        icon: 'camping',
      },
      bungalow: {
        title: 'Bungalows',
        text: 'Bungalows für 2, 3 und 4 Personen.',
        icon: 'bungalow',
      },
      combined: {
        title: 'Kombiniert',
        text: 'Bungalow und Campingplatz in einer Anfrage.',
        icon: 'UsersRound',
      },
    },
  },
  it: {
    kicker: 'Richiesta rapida',
    title: 'Richiedi disponibilità',
    lead: 'Scegli il tipo di soggiorno: il modulo completo si apre con il contesto già pronto.',
    button: 'Vai al modulo',
    cardCta: 'Apri modulo',
    choices: {
      camping: {
        title: 'Camping',
        text: 'Camper, roulotte, tenda, van o auto con tenda da tetto.',
        icon: 'camping',
      },
      bungalow: {
        title: 'Bungalow',
        text: 'Bungalow da 2, 3 e 4 persone.',
        icon: 'bungalow',
      },
      combined: {
        title: 'Combinato',
        text: 'Bungalow e piazzola camping in un’unica richiesta.',
        icon: 'UsersRound',
      },
    },
  },
  fr: {
    kicker: 'Demande rapide',
    title: 'Demandez la disponibilité du séjour',
    lead: 'Choisissez le type de séjour : le formulaire complet s’ouvre avec le bon contexte.',
    button: 'Aller au formulaire',
    cardCta: 'Ouvrir le formulaire',
    choices: {
      camping: { title: 'Camping', text: 'Camping-car, caravane, tente, van ou voiture avec tente de toit.', icon: 'camping' },
      bungalow: { title: 'Bungalows', text: 'Bungalows pour 2, 3 et 4 personnes.', icon: 'bungalow' },
      combined: { title: 'Combiné', text: 'Bungalow et emplacement camping dans une seule demande.', icon: 'UsersRound' },
    },
  },
  es: {
    kicker: 'Consulta rápida',
    title: 'Pregunta por disponibilidad',
    lead: 'Elige el tipo de estancia y el formulario se abre con el contexto preparado.',
    button: 'Ir al formulario',
    cardCta: 'Abrir formulario',
    choices: {
      camping: { title: 'Camping', text: 'Autocaravana, caravana, tienda, van o coche con tienda de techo.', icon: 'camping' },
      bungalow: { title: 'Bungalows', text: 'Bungalows para 2, 3 y 4 personas.', icon: 'bungalow' },
      combined: { title: 'Combinado', text: 'Bungalow y parcela camping en una consulta.', icon: 'UsersRound' },
    },
  },
  nl: {
    kicker: 'Snelle aanvraag',
    title: 'Vraag naar beschikbaarheid',
    lead: 'Kies je verblijfstype en het volledige formulier opent met context.',
    button: 'Naar formulier',
    cardCta: 'Open formulier',
    choices: {
      camping: { title: 'Camping', text: 'Camper, caravan, tent, van of auto met daktent.', icon: 'camping' },
      bungalow: { title: 'Bungalows', text: 'Bungalows voor 2, 3 en 4 personen.', icon: 'bungalow' },
      combined: { title: 'Gecombineerd', text: 'Bungalow en campingplaats in één aanvraag.', icon: 'UsersRound' },
    },
  },
  cs: {
    kicker: 'Rychlý dotaz',
    title: 'Zeptejte se na dostupnost pobytu',
    lead: 'Vyberte typ pobytu a celý formulář se otevře s připraveným kontextem.',
    button: 'Přejít na formulář',
    cardCta: 'Otevřít formulář',
    choices: {
      camping: { title: 'Kemp', text: 'Obytný vůz, karavan, stan, dodávka nebo auto se střešním stanem.', icon: 'camping' },
      bungalow: { title: 'Bungalovy', text: 'Bungalovy pro 2, 3 a 4 osoby.', icon: 'bungalow' },
      combined: { title: 'Kombinace', text: 'Bungalov a campingové místo v jednom dotazu.', icon: 'UsersRound' },
    },
  },
  sk: {
    kicker: 'Rýchly dopyt',
    title: 'Opýtajte sa na dostupnosť pobytu',
    lead: 'Vyberte typ pobytu a celý formulár sa otvorí s pripraveným kontextom.',
    button: 'Prejsť na formulár',
    cardCta: 'Otvoriť formulár',
    choices: {
      camping: { title: 'Kemp', text: 'Obytné auto, karavan, stan, dodávka alebo auto so strešným stanom.', icon: 'camping' },
      bungalow: { title: 'Bungalovy', text: 'Bungalovy pre 2, 3 a 4 osoby.', icon: 'bungalow' },
      combined: { title: 'Kombinácia', text: 'Bungalov a campingové miesto v jednom dopyte.', icon: 'UsersRound' },
    },
  },
  sv: {
    kicker: 'Snabb förfrågan',
    title: 'Fråga om tillgänglighet',
    lead: 'Välj vistelsetyp så öppnas formuläret med rätt kontext.',
