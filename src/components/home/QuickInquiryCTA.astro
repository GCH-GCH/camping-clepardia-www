---
import { getBookingLocalizedPath, getPathContext } from '@/utils/localizedLinks';
import Icon from '@/components/ui/Icon.astro';

interface Props {
  languageCode?: string;
}

const { languageCode } = Astro.props as Props;
const pathContext = getPathContext(Astro.url.pathname);
const lang = languageCode ?? pathContext.languageCode;
const bookingLanguage = languageCode ?? pathContext.languageCode;
const bookingHref = getBookingLocalizedPath(bookingLanguage);

const copyByLanguage = {
