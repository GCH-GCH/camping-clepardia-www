---

<aside class="hero-experience-slider" data-hero-experience-slider aria-label={copy.aria}>
  <span class="hero-experience-slider__glow" aria-hidden="true"></span>
  <span class="hero-experience-slider__particle hero-experience-slider__particle--one" aria-hidden="true"></span>
  <span class="hero-experience-slider__particle hero-experience-slider__particle--two" aria-hidden="true"></span>
  <span class="hero-experience-slider__particle hero-experience-slider__particle--three" aria-hidden="true"></span>
  <div class="hero-experience-slider__top">
    <span data-hero-slide-index>01</span>
    <small>{copy.of} {String(copy.slides.length).padStart(2, '0')}</small>
  </div>
  <span class="hero-experience-slider__progress" aria-hidden="true">
    <i data-hero-slide-progress></i>
  </span>

  <div class="hero-experience-slider__slides">
    {copy.slides.map((slide, index) => (
      <article class:list={['hero-experience-slider__slide', index === 0 && 'is-active']} data-hero-slide>
        <span class="hero-experience-slider__icon" aria-hidden="true">
          <Icon name={slide.icon} size={30} strokeWidth={1.8} />
        </span>
        <p>{slide.kicker}</p>
        <h2>{slide.title}</h2>
        <small>{slide.detail}</small>
        {'href' in slide && slide.href && (
          <a class="hero-experience-slider__link" href={slide.href} target="_blank" rel="noopener noreferrer">
            {slide.cta}
          </a>
        )}
      </article>
    ))}
  </div>

  <div class="hero-experience-slider__controls">
    <button type="button" data-hero-slide-prev aria-label={copy.prev}>
      <Icon name="chevronLeft" size={19} strokeWidth={2.2} />
    </button>
    <div class="hero-experience-slider__dots" aria-hidden="true">
      {copy.slides.map((_, index) => <span class:list={[index === 0 && 'is-active']} data-hero-slide-dot></span>)}
    </div>
    <button type="button" data-hero-slide-next aria-label={copy.next}>
      <Icon name="chevronRight" size={19} strokeWidth={2.2} />
    </button>
  </div>
</aside>

<script>
  (() => {
    const sliders = document.querySelectorAll('[data-hero-experience-slider]');
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

    sliders.forEach((slider) => {
      if (!(slider instanceof HTMLElement)) return;

      const slides = Array.from(slider.querySelectorAll('[data-hero-slide]')).filter((slide): slide is HTMLElement => slide instanceof HTMLElement);
      const dots = Array.from(slider.querySelectorAll('[data-hero-slide-dot]')).filter((dot): dot is HTMLElement => dot instanceof HTMLElement);
      const indexLabel = slider.querySelector('[data-hero-slide-index]');
      const progress = slider.querySelector('[data-hero-slide-progress]');
      const prev = slider.querySelector('[data-hero-slide-prev]');
      const next = slider.querySelector('[data-hero-slide-next]');
      let active = 0;
      let timer: number | undefined;

      const setActive = (nextIndex: number) => {
        slides[active]?.classList.remove('is-active');
        dots[active]?.classList.remove('is-active');
        active = (nextIndex + slides.length) % slides.length;
        slides[active]?.classList.add('is-active');
        dots[active]?.classList.add('is-active');
        if (indexLabel) indexLabel.textContent = String(active + 1).padStart(2, '0');
        if (progress instanceof HTMLElement) {
          progress.style.animation = 'none';
          progress.offsetHeight;
          progress.style.animation = '';
        }
      };

      const stop = () => {
        if (timer) window.clearInterval(timer);
        timer = undefined;
      };

      const start = () => {
        if (reducedMotion.matches || slides.length < 2 || timer) return;
        timer = window.setInterval(() => setActive(active + 1), 3600);
      };

      prev?.addEventListener('click', () => {
        stop();
        setActive(active - 1);
        start();
      });

      next?.addEventListener('click', () => {
        stop();
        setActive(active + 1);
        start();
      });

      dots.forEach((dot, index) => {
        dot.addEventListener('click', () => {
          stop();
          setActive(index);
          start();
        });
      });

      slider.addEventListener('mouseenter', stop);
      slider.addEventListener('mouseleave', start);
      reducedMotion.addEventListener?.('change', () => {
        stop();
        start();
      });
      start();
    });
  })();
</script>

<style>
.hero-experience-slider {
  position: relative;
  width: min(100%, 430px);
  min-width: 0;
  justify-self: end;
  display: grid;
  gap: 18px;
  padding: clamp(22px, 2.6vw, 32px);
  border: 1px solid rgba(143,224,180,.28);
  border-radius: 36px;
  color: #fff;
  background:
    radial-gradient(circle at 18% 0%, rgba(60,179,113,.30), transparent 38%),
    radial-gradient(circle at 86% 12%, rgba(242,192,120,.24), transparent 40%),
    linear-gradient(145deg, rgba(255,255,255,.17), rgba(255,255,255,.065));
  box-shadow:
    0 36px 100px rgba(0,0,0,.30),
    0 0 66px rgba(60,179,113,.20),
    inset 0 1px 0 rgba(255,255,255,.18);
  backdrop-filter: blur(26px) saturate(158%);
  -webkit-backdrop-filter: blur(26px) saturate(158%);
  overflow: hidden;
  isolation: isolate;
  animation:
    heroExperienceReveal .9s cubic-bezier(.22, 1, .36, 1) .58s both,
    heroExperienceFloat 7.8s ease-in-out 1.2s infinite;
}

.hero-experience-slider::before {
  content: '';
  position: absolute;
  inset: 1px;
  z-index: -1;
  border-radius: 35px;
  background:
    linear-gradient(135deg, rgba(255,255,255,.16), transparent 38%),
    radial-gradient(circle at 74% 82%, rgba(60,179,113,.18), transparent 38%);
}

.hero-experience-slider::after {
  content: '';
  position: absolute;
  inset: -40% -30%;
  z-index: -1;
  background:
    conic-gradient(from 120deg at 50% 50%, transparent 0 18%, rgba(143,224,180,.16) 24%, transparent 34%, rgba(242,192,120,.12) 48%, transparent 62% 100%);
  filter: blur(18px);
  opacity: .46;
  animation: heroExperienceLight 11s linear infinite;
}

.hero-experience-slider__glow {
  position: absolute;
  right: -88px;
  top: -82px;
  width: 230px;
  aspect-ratio: 1;
  border-radius: 999px;
  background: radial-gradient(circle, rgba(242,192,120,.28), rgba(60,179,113,.14) 44%, transparent 72%);
  filter: blur(8px);
  pointer-events: none;
}

.hero-experience-slider__particle {
  position: absolute;
  z-index: 1;
  width: 7px;
  height: 7px;
  border-radius: 999px;
  background: rgba(143,224,180,.76);
  box-shadow: 0 0 20px rgba(143,224,180,.48);
  pointer-events: none;
  opacity: .58;
  animation: heroExperienceParticle 8s ease-in-out infinite;
}

.hero-experience-slider__particle--one {
  right: 22%;
  top: 18%;
}

.hero-experience-slider__particle--two {
  left: 18%;
  top: 54%;
  width: 5px;
  height: 5px;
  animation-delay: -2.4s;
}

.hero-experience-slider__particle--three {
  right: 13%;
  bottom: 24%;
  width: 4px;
  height: 4px;
  background: rgba(242,192,120,.72);
  box-shadow: 0 0 18px rgba(242,192,120,.44);
  animation-delay: -4.1s;
}

.hero-experience-slider__top {
  position: relative;
  z-index: 2;
  display: flex;
  justify-content: space-between;
  align-items: center;
  color: rgba(255,255,255,.78);
  font-size: .72rem;
  font-weight: 950;
  letter-spacing: .16em;
  text-transform: uppercase;
}

.hero-experience-slider__progress {
  position: relative;
  z-index: 2;
  width: 100%;
  height: 3px;
  overflow: hidden;
  border-radius: 999px;
  background: rgba(255,255,255,.12);
  box-shadow: inset 0 1px 0 rgba(255,255,255,.08);
}

.hero-experience-slider__progress i {
  display: block;
  width: 100%;
  height: 100%;
  border-radius: inherit;
  transform-origin: left center;
  background: linear-gradient(90deg, rgba(143,224,180,.86), #3CB371, rgba(242,192,120,.72));
  box-shadow: 0 0 20px rgba(60,179,113,.42);
  animation: heroSlideProgress 3.6s linear infinite;
}

.hero-experience-slider:hover .hero-experience-slider__progress i {
  animation-play-state: paused;
}

.hero-experience-slider__top span {
  color: #8fe0b4;
}

.hero-experience-slider__slides {
  position: relative;
  min-height: 300px;
}

.hero-experience-slider__slide {
  position: absolute;
  inset: 0;
  display: grid;
  align-content: center;
  gap: 14px;
  opacity: 0;
  transform: translateY(18px) scale(.985);
  filter: blur(6px);
  pointer-events: none;
  transition: opacity .54s cubic-bezier(.22, 1, .36, 1), transform .54s cubic-bezier(.22, 1, .36, 1), filter .54s ease;
}

.hero-experience-slider__slide.is-active {
  opacity: 1;
  transform: translateY(0) scale(1);
  filter: blur(0);
  pointer-events: auto;
}

.hero-experience-slider:hover {
  transform: translateY(-6px) scale(1.012);
  box-shadow:
    0 42px 118px rgba(0,0,0,.34),
    0 0 82px rgba(60,179,113,.24),
    inset 0 1px 0 rgba(255,255,255,.20);
}

.hero-experience-slider__icon {
  width: 72px;
  height: 72px;
  display: grid;
  place-items: center;
  border: 1px solid rgba(143,224,180,.32);
  border-radius: 26px;
  color: #fff;
  background:
    radial-gradient(circle at 32% 18%, rgba(255,255,255,.34), transparent 36%),
    linear-gradient(135deg, rgba(60,179,113,.56), rgba(60,179,113,.22));
  box-shadow: 0 24px 64px rgba(60,179,113,.28), inset 0 1px 0 rgba(255,255,255,.18);
}

.hero-experience-slider__slide p {
  margin: 0;
  color: #8fe0b4;
  font-size: .78rem;
  font-weight: 950;
  letter-spacing: .14em;
  text-transform: uppercase;
}

.hero-experience-slider__slide h2 {
  max-width: 360px;
  margin: 0;
  color: #fff;
  font-size: clamp(1.7rem, 3.1vw, 2.35rem);
  line-height: 1.02;
  font-weight: 950;
  text-shadow: 0 12px 34px rgba(0,0,0,.30);
}

.hero-experience-slider__slide small {
  max-width: 340px;
  color: rgba(255,255,255,.76);
  font-size: .98rem;
  line-height: 1.6;
}

.hero-experience-slider__link {
  width: fit-content;
  display: inline-flex;
