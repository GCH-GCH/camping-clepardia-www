---
import ImageFrame from '@/components/ImageFrame.astro';
import { siteAssets } from '@/data/assets';
import { getTranslations, resolveContentLanguage } from '@/i18n/config';
import { getLocalizedPath, getPathContext } from '@/utils/localizedLinks';

interface Props {
  languageCode?: string;
}

const { languageCode } = Astro.props as Props;
const pathContext = getPathContext(Astro.url.pathname);
const explicitLanguage = pathContext.explicitLanguage ?? (languageCode && languageCode !== 'pl' ? languageCode : undefined);
const contentLanguage = resolveContentLanguage(languageCode ?? pathContext.languageCode);
const t = getTranslations(languageCode ?? pathContext.languageCode);
const page = t.pages.camping;
const campingCards = page.highlights.map((item, index) => ({
  ...item,
  label: String(index + 1).padStart(2, '0'),
  delay: index * 80,
}));
const pricingHref = getLocalizedPath(explicitLanguage, 'cennik');
const contactHref = getLocalizedPath(explicitLanguage, 'kontakt');
const mediaLabels = {
  pl: {
    aria: 'Zdjęcia sekcji camping',
    mainAlt: 'Strefa dla kamperów i vanów Camping Clepardia',
    main: 'Kampery i vany',
    pitchesAlt: 'Miejsca campingowe Camping Clepardia',
    pitches: 'Miejsca campingowe',
    tentsAlt: 'Strefa namiotowa Camping Clepardia',
    tents: 'Namioty',
    electricityAlt: 'Przyłącza prądu na campingu',
    electricity: 'Prąd i zaplecze',
  },
  en: {
    aria: 'Camping section photos',
    mainAlt: 'Motorhome and van area at Camping Clepardia',
    main: 'Motorhomes and vans',
    pitchesAlt: 'Camping pitches at Camping Clepardia',
    pitches: 'Camping pitches',
    tentsAlt: 'Tent area at Camping Clepardia',
    tents: 'Tents',
    electricityAlt: 'Electric hook-ups at the campsite',
    electricity: 'Electricity and facilities',
  },
  de: {
    aria: 'Fotos der Campingsektion',
    mainAlt: 'Wohnmobil- und Vanbereich auf Camping Clepardia',
    main: 'Wohnmobile und Vans',
    pitchesAlt: 'Stellplätze auf Camping Clepardia',
    pitches: 'Stellplätze',
    tentsAlt: 'Zeltbereich auf Camping Clepardia',
    tents: 'Zelte',
    electricityAlt: 'Stromanschlüsse auf dem Campingplatz',
    electricity: 'Strom und Infrastruktur',
  },
  it: {
    aria: 'Foto della sezione camping',
    mainAlt: 'Area camper e van a Camping Clepardia',
    main: 'Camper e van',
    pitchesAlt: 'Piazzole a Camping Clepardia',
    pitches: 'Piazzole camping',
    tentsAlt: 'Area tende a Camping Clepardia',
    tents: 'Tende',
    electricityAlt: 'Allacci elettrici nel camping',
    electricity: 'Elettricità e servizi',
  },
}[contentLanguage];
---

<section class="site-section camping-section reveal-section" id="camping">
  <div class="container camping-section__grid">
    <div class="camping-section__content">
      <span class="section-kicker">{page.overline}</span>
      <h2 class="section-title">{page.title}</h2>
      <p class="section-copy">
        {page.lead}
      </p>

      <div class="camping-section__cards">
        {campingCards.map((card) => (
          <article class="premium-card reveal-section camping-section__card" style={`--reveal-delay: ${card.delay}ms`}>
            <span>{card.label}</span>
            <h3>{card.title}</h3>
            <p>{card.copy}</p>
          </article>
        ))}
      </div>

      <div class="camping-section__cta">
        <a class="btn btn-primary premium-button" href={pricingHref}>{t.cta.pricing}</a>
        <a class="btn btn-glass camping-section__button-secondary" href={contactHref}>{t.cta.availability}</a>
      </div>
    </div>

    <div class="camping-section__media" aria-label={mediaLabels.aria}>
      <ImageFrame
        src={siteAssets.camping.camperArea}
        alt={mediaLabels.mainAlt}
        label={mediaLabels.main}
        className="camping-section__main-photo"
      />
      <div class="camping-section__floating camping-section__floating--one">
        <ImageFrame src={siteAssets.camping.pitches} alt={mediaLabels.pitchesAlt} label={mediaLabels.pitches} />
      </div>
      <div class="camping-section__floating camping-section__floating--two">
        <ImageFrame src={siteAssets.camping.tents} alt={mediaLabels.tentsAlt} label={mediaLabels.tents} />
      </div>
      <div class="camping-section__floating camping-section__floating--three">
        <ImageFrame src={siteAssets.camping.electricity} alt={mediaLabels.electricityAlt} label={mediaLabels.electricity} />
      </div>
    </div>
  </div>
</section>

<style>
.camping-section {
  background:
    radial-gradient(circle at 10% 18%, rgba(60,179,113,.14), transparent 32%),
    linear-gradient(180deg, #f1f7f0 0%, #fbfbf7 100%);
}

.camping-section__grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: clamp(42px, 6vw, 78px);
  align-items: center;
}

.camping-section__content {
  min-width: 0;
}

.camping-section__cards {
  margin-top: clamp(30px, 4vw, 42px);
  display: grid;
  grid-template-columns: 1fr;
  gap: 14px;
}

:global(.camping-section__card) {
  padding: 22px;
  border-radius: 24px;
  border-color: rgba(60,179,113,.16);
  background:
    linear-gradient(145deg, rgba(255,255,255,.86), rgba(255,255,255,.64)),
    radial-gradient(circle at 92% 12%, rgba(60,179,113,.10), transparent 34%);
}

:global(.camping-section__card span) {
  display: inline-flex;
  margin-bottom: 18px;
  color: #2d9a60;
  font-size: .72rem;
  font-weight: 950;
  letter-spacing: .14em;
  text-transform: uppercase;
}

:global(.camping-section__card h3) {
  margin: 0 0 10px;
  color: #14261b;
  font-size: 1.08rem;
  line-height: 1.2;
  font-weight: 900;
}

:global(.camping-section__card p) {
  margin: 0;
  color: #56655c;
  line-height: 1.66;
}

.camping-section__cta {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  margin-top: 30px;
}

.camping-section__button-secondary {
  display: inline-flex;
  min-height: 50px;
  align-items: center;
  justify-content: center;
  padding: 14px 24px;
  border-radius: 999px;
  border: 1px solid rgba(32, 74, 50, .16);
  color: #173624;
  background: rgba(255,255,255,.74);
  box-shadow: 0 16px 42px rgba(17,40,28,.08);
  font-size: .86rem;
  font-weight: 900;
  letter-spacing: .06em;
  transition: transform .25s ease, box-shadow .25s ease, border-color .25s ease;
}

.camping-section__button-secondary:hover {
  color: #173624;
  transform: translateY(-2px);
  border-color: rgba(60,179,113,.30);
  box-shadow: 0 22px 58px rgba(17,40,28,.12);
}

.camping-section__media {
  position: relative;
  min-height: clamp(520px, 52vw, 680px);
  isolation: isolate;
}

.camping-section__media::before,
.camping-section__media::after {
  content: '';
  position: absolute;
  pointer-events: none;
  border-radius: 999px;
}

.camping-section__media::before {
  inset: 8% auto auto -7%;
  width: 46%;
  aspect-ratio: 1;
  background: radial-gradient(circle, rgba(60,179,113,.18), transparent 68%);
  filter: blur(8px);
  z-index: -1;
}

.camping-section__media::after {
  right: 4%;
  bottom: 4%;
  width: 38%;
  aspect-ratio: 1;
  border: 1px solid rgba(60,179,113,.16);
  background: radial-gradient(circle, rgba(242,192,120,.14), transparent 70%);
  z-index: -1;
}

:global(.camping-section__main-photo) {
  min-height: clamp(440px, 46vw, 610px);
  border-radius: 42px 26px 38px 28px;
  transform: rotate(-1.2deg);
}

.camping-section__floating {
  position: absolute;
  width: min(42%, 250px);
  filter: drop-shadow(0 22px 38px rgba(17,40,28,.18));
}

.camping-section__floating :global(.asset-frame) {
  min-height: 150px;
  border-radius: 22px;
}

.camping-section__floating--one {
  left: -18px;
  bottom: 64px;
  transform: rotate(2.2deg);
}

.camping-section__floating--two {
  right: -12px;
  top: 36px;
  transform: rotate(-2.8deg);
}

.camping-section__floating--three {
  right: 26px;
  bottom: 10px;
  width: min(38%, 224px);
  transform: rotate(1.6deg);
}

@media (min-width: 760px) {
  .camping-section__cards {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (min-width: 1080px) {
  .camping-section__grid {
    grid-template-columns: minmax(0, .92fr) minmax(460px, 1fr);
  }
}

@media (max-width: 760px) {
  .camping-section__cta {
    display: grid;
  }

  .camping-section__button-secondary,
  .camping-section__cta :global(.premium-button) {
    width: 100%;
  }

  .camping-section__media {
    min-height: auto;
    display: grid;
    gap: 14px;
  }

  .camping-section__floating {
    position: static;
    width: 100%;
    transform: none;
  }

  :global(.camping-section__main-photo),
  .camping-section__floating :global(.asset-frame) {
    min-height: 240px;
    transform: none;
    border-radius: 24px;
  }

  .camping-section__media::before,
  .camping-section__media::after {
    display: none;
  }
}
</style>
