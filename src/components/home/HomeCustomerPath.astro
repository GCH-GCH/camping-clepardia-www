const baseCopy = copyByLanguage.en;
const localCopy = copyByLanguage[language as keyof typeof copyByLanguage] ?? baseCopy;
const copy = { ...baseCopy, ...localCopy };

const stayPrice = (id: string) => {
  const item = pricingConfig.stayTypes.find((entry) => entry.id === id);
  return item && 'price' in item ? item.price : 0;
};
const bungalowPrice = (id: string) => {
  const item = pricingConfig.stayTypes.find((entry) => entry.id === id);
  return item && 'seasonalPrices' in item ? item.seasonalPrices.low : 0;
};
const addonPrice = (id: string) => pricingConfig.addons.find((entry) => entry.id === id)?.price ?? 0;
const adult = pricingConfig.people.adults.price;

const stayLabels = {
  pl: ['2 osoby + kamper + prąd', '2 osoby + van', '2 osoby + namiot 1–2 os.', '2 osoby + przyczepa + auto + prąd', 'Domek 2-os.', 'Domek 3-os.', 'Domek 4-os.'],
  en: ['2 people + motorhome + power', '2 people + van', '2 people + small tent', '2 people + caravan + car + power', '2-person bungalow', '3-person bungalow', '4-person bungalow'],
  de: ['2 Personen + Wohnmobil + Strom', '2 Personen + Van', '2 Personen + kleines Zelt', '2 Personen + Wohnwagen + Auto + Strom', 'Bungalow für 2', 'Bungalow für 3', 'Bungalow für 4'],
  it: ['2 persone + camper + corrente', '2 persone + van', '2 persone + tenda piccola', '2 persone + roulotte + auto + corrente', 'Bungalow per 2', 'Bungalow per 3', 'Bungalow per 4'],
  fr: ['2 personnes + camping-car + électricité', '2 personnes + van', '2 personnes + petite tente', '2 personnes + caravane + voiture + électricité', 'Bungalow 2 personnes', 'Bungalow 3 personnes', 'Bungalow 4 personnes'],
  es: ['2 personas + autocaravana + electricidad', '2 personas + furgoneta', '2 personas + tienda pequeña', '2 personas + caravana + coche + electricidad', 'Bungalow para 2', 'Bungalow para 3', 'Bungalow para 4'],
  nl: ['2 personen + camper + stroom', '2 personen + van', '2 personen + kleine tent', '2 personen + caravan + auto + stroom', 'Bungalow voor 2', 'Bungalow voor 3', 'Bungalow voor 4'],
  cs: ['2 osoby + obytný vůz + elektřina', '2 osoby + dodávka', '2 osoby + malý stan', '2 osoby + karavan + auto + elektřina', 'Bungalov pro 2', 'Bungalov pro 3', 'Bungalov pro 4'],
  sk: ['2 osoby + obytné auto + elektrina', '2 osoby + dodávka', '2 osoby + malý stan', '2 osoby + karavan + auto + elektrina', 'Bungalov pre 2', 'Bungalov pre 3', 'Bungalov pre 4'],
  sv: ['2 personer + husbil + el', '2 personer + van', '2 personer + litet tält', '2 personer + husvagn + bil + el', 'Bungalow för 2', 'Bungalow för 3', 'Bungalow för 4'],
} as const;
const localizedStayLabels = stayLabels[language as keyof typeof stayLabels] ?? stayLabels.en;
const stays = [
  { icon: 'Caravan', label: localizedStayLabels[0], price: adult * 2 + stayPrice('camper') + addonPrice('electricity'), estimates: true },
  { icon: 'BusFront', label: localizedStayLabels[1], price: adult * 2 + stayPrice('van'), estimates: true },
  { icon: 'Tent', label: localizedStayLabels[2], price: adult * 2 + stayPrice('tent-small'), estimates: true },
  { icon: 'CarFront', label: localizedStayLabels[3], price: adult * 2 + stayPrice('caravan') + addonPrice('parking') + addonPrice('electricity'), estimates: true },
  { icon: 'House', label: localizedStayLabels[4], price: bungalowPrice('bungalow-2') },
  { icon: 'House', label: localizedStayLabels[5], price: bungalowPrice('bungalow-3') },
  { icon: 'House', label: localizedStayLabels[6], price: bungalowPrice('bungalow-4') },
];

const attractions = [
  { title: language === 'pl' ? 'Stare Miasto' : 'Old Town', image: attractionImages.mainSquare },
  { title: 'Kazimierz', image: attractionImages.kazimierz },
  { title: 'Wawel', image: attractionImages.wawel },
  { title: 'Wieliczka', image: attractionImages.wieliczka },
  { title: 'Auschwitz-Birkenau', image: attractionImages.auschwitz },
  { title: language === 'pl' ? 'Ojców' : 'Ojców National Park', image: attractionImages.ojcow },
];

const choiceLinks = [
  booking('camping'),
  booking('bungalow'),
  route('cennik'),
  route('dojazd'),
  tourBookingHref,
];
const mapsHref = 'https://www.google.com/maps/search/?api=1&query=Camping+Clepardia+Henryka+Pacho%C5%84skiego+28A+Krak%C3%B3w';
---

<section class="home-path site-section" id="start-content" data-after-hero>
  <div class="container">
    <header class="home-path__header reveal-section">
      <span class="section-kicker">{copy.kicker}</span>
      <h2 class="section-title">{copy.chooseTitle}</h2>
      <p class="section-copy">{copy.chooseLead}</p>
    </header>

    <div class="home-path__choices">
      {copy.choices.map((choice, index) => (
        <a
          class="home-path__choice premium-card reveal-section"
          href={choiceLinks[index]}
          target={index === 4 ? '_blank' : undefined}
          rel={index === 4 ? 'noopener noreferrer' : undefined}
          style={`--reveal-delay:${index * 55}ms`}
        >
          <span><Icon name={choice[2]} size={24} strokeWidth={1.9} /></span>
          <strong>{choice[0]}</strong>
          <small>{choice[1]}</small>
          <Icon name="ArrowUpRight" size={18} strokeWidth={2} />
        </a>
      ))}
    </div>

    <div class="home-path__info reveal-section">
      <header>
        <span class="section-kicker">{copy.infoKicker}</span>
        <h2 class="section-title">{copy.infoTitle}</h2>
      </header>
      <div class="home-path__facts">
        {copy.facts.map((fact) => (
          <div><Icon name={fact[0]} size={21} strokeWidth={1.9} /><span>{fact[1]}</span></div>
        ))}
      </div>
      <article class="home-path__summer">
        <span><Icon name="Sun" size={26} strokeWidth={2} /></span>
        <div>
          <h3>{copy.summerTitle}</h3>
          <p>{copy.summerText}</p>
        </div>
      </article>
    </div>

    <div class="home-path__prices reveal-section">
      <header>
        <span class="section-kicker">{copy.pricesKicker}</span>
        <h2 class="section-title">{copy.pricesTitle}</h2>
        <p class="section-copy">{copy.pricesLead}</p>
      </header>
      <div class="home-path__price-grid">
        {stays.map((stay) => (
          <article class="home-path__price-card">
            <Icon name={stay.icon} size={22} strokeWidth={1.9} />
            <div>
              <h3>{stay.label}</h3>
              <strong>{stay.icon === 'House' ? `${copy.from} ` : ''}{stay.price} PLN <small>{copy.perNight}</small></strong>
              {stay.estimates && <span>{formatCurrencyEstimates(stay.price)}</span>}
            </div>
          </article>
        ))}
      </div>
      <div class="home-path__price-footer">
        <p>{copy.priceDisclaimer}</p>
        <a class="btn btn-primary premium-button" href={route('cennik')}>{copy.fullPricing}</a>
      </div>
    </div>

    <div class="home-path__split reveal-section">
      <article class="home-path__directions premium-card">
        <span class="section-kicker">{copy.directionsKicker}</span>
        <h2>{copy.directionsTitle}</h2>
        <p>{copy.directionsText}</p>
        <div>
          <a class="btn btn-primary premium-button" href={mapsHref} target="_blank" rel="noopener noreferrer">
            <Icon name="MapPin" size={18} /> {copy.maps}
          </a>
          <a class="btn btn-glass" href={route('dojazd')}>{copy.directions}</a>
        </div>
      </article>
      <article class="home-path__city premium-card">
        <span class="section-kicker">{copy.cityKicker}</span>
        <h2>{copy.cityTitle}</h2>
        <p>{copy.cityText}</p>
        <div>
          <a href={route('dojazd')}>{copy.directions}</a>
          <a href={route('atrakcje')}>{copy.allAttractions}</a>
          <button type="button" data-home-campy>{copy.askCampy}</button>
        </div>
      </article>
    </div>

    <div class="home-path__attractions reveal-section">
      <header>
        <span class="section-kicker">{copy.attractionsKicker}</span>
        <h2 class="section-title">{copy.attractionsTitle}</h2>
        <p class="section-copy">{copy.attractionsLead}</p>
      </header>
      <div class="home-path__attraction-grid">
        {attractions.map((item) => (
          <a href={route('atrakcje')} class="home-path__attraction">
            <ImageFrame
              src={item.image.src}
              alt={language === 'pl' ? item.image.altPl : item.title}
              label={item.title}
              width={item.image.width}
              height={item.image.height}
              sizes="(max-width: 620px) calc(100vw - 32px), (max-width: 980px) 50vw, 33vw"
            />
          </a>
        ))}
      </div>
      <div class="home-path__attraction-actions">
        <a class="btn btn-glass" href={route('atrakcje')}>{copy.allAttractions}</a>
        <a class="btn btn-primary premium-button" href={tourBookingHref} target="_blank" rel="noopener noreferrer">{copy.tours}</a>
      </div>
    </div>

    <div class="home-path__checklist reveal-section">
      <header>
        <span class="section-kicker">{copy.checklistKicker}</span>
        <h2 class="section-title">{copy.checklistTitle}</h2>
      </header>
      <div>
        {copy.checklist.map((item) => (
          <article><Icon name={item[0]} size={20} strokeWidth={1.9} /><span>{item[1]}</span></article>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('[data-home-campy]').forEach((button) => {
