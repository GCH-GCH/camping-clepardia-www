const pathContext = getPathContext(Astro.url.pathname);
const language = languageCode ?? pathContext.languageCode;
const explicitLanguage = pathContext.explicitLanguage ?? (language !== 'pl' ? language : undefined);
const route = (slug: string) => getLocalizedPath(explicitLanguage, slug);
const booking = (stay?: string) => getBookingLocalizedPath(language, stay);

