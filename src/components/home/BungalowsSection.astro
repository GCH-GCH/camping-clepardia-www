---
import ImageFrame from '@/components/ImageFrame.astro';
import { siteAssets } from '@/data/assets';
import { getTranslations, resolveContentLanguage } from '@/i18n/config';
import { getLocalizedPath, getPathContext } from '@/utils/localizedLinks';

interface Props {
  languageCode?: string;
}

const { languageCode } = Astro.props as Props;
const pathContext = getPathContext(Astro.url.pathname);
const explicitLanguage = pathContext.explicitLanguage ?? (languageCode && languageCode !== 'pl' ? languageCode : undefined);
const contentLanguage = resolveContentLanguage(languageCode ?? pathContext.languageCode);
const t = getTranslations(languageCode ?? pathContext.languageCode);
const page = t.pages.domki;
const bungalowCards = page.highlights.map((item, index) => ({
  ...item,
  label: String(index + 1).padStart(2, '0'),
  delay: index * 80,
}));
const pricingHref = getLocalizedPath(explicitLanguage, 'cennik');
const contactHref = getLocalizedPath(explicitLanguage, 'kontakt');
const mediaLabels = {
  pl: {
    aria: 'Zdjęcia sekcji domki',
    mainAlt: 'Domki Camping Clepardia w Krakowie',
    main: 'Domki Camping Clepardia',
    roomAlt: 'Wnętrze domku Camping Clepardia',
    room: 'Wnętrze domku',
    bungalow4Alt: 'Domek 4-osobowy Camping Clepardia',
    bungalow4: 'Domek 4-os.',
  },
  en: {
    aria: 'Bungalow section photos',
    mainAlt: 'Camping Clepardia bungalows in Krakow',
    main: 'Camping Clepardia bungalows',
    roomAlt: 'Camping Clepardia bungalow interior',
    room: 'Bungalow interior',
    bungalow4Alt: 'Camping Clepardia 4-person bungalow',
    bungalow4: '4-person bungalow',
  },
  de: {
    aria: 'Fotos der Bungalowsektion',
    mainAlt: 'Bungalows von Camping Clepardia in Krakau',
    main: 'Camping Clepardia Bungalows',
    roomAlt: 'Innenraum eines Camping Clepardia Bungalows',
    room: 'Bungalow innen',
    bungalow4Alt: '4-Personen-Bungalow von Camping Clepardia',
    bungalow4: '4-Personen-Bungalow',
  },
  it: {
    aria: 'Foto della sezione bungalow',
    mainAlt: 'Bungalow Camping Clepardia a Cracovia',
    main: 'Bungalow Camping Clepardia',
    roomAlt: 'Interno bungalow Camping Clepardia',
    room: 'Interno bungalow',
    bungalow4Alt: 'Bungalow 4 persone Camping Clepardia',
    bungalow4: 'Bungalow 4 persone',
  },
}[contentLanguage];
---

<section class="site-section bungalows-section reveal-section" id="domki">
  <div class="container bungalows-section__grid">
    <div class="bungalows-section__content">
      <span class="section-kicker">{page.overline}</span>
      <h2 class="section-title">{page.title}</h2>
      <p class="section-copy">
        {page.lead}
      </p>

      <div class="bungalows-section__cards">
        {bungalowCards.map((card) => (
          <article class="premium-card reveal-section bungalows-section__card" style={`--reveal-delay: ${card.delay}ms`}>
            <span>{card.label}</span>
            <h3>{card.title}</h3>
            <p>{card.copy}</p>
          </article>
        ))}
      </div>

      <div class="bungalows-section__cta">
        <a class="btn btn-primary premium-button" href={contactHref}>{page.cta.secondaryLabel}</a>
        <a class="btn btn-glass bungalows-section__button-secondary" href={pricingHref}>{t.cta.pricing}</a>
      </div>
    </div>

    <div class="bungalows-section__media" aria-label={mediaLabels.aria}>
      <ImageFrame
        src={siteAssets.bungalows.exterior}
        alt={mediaLabels.mainAlt}
        label={mediaLabels.main}
        className="bungalows-section__main-photo"
      />
      <div class="bungalows-section__floating bungalows-section__floating--one">
        <ImageFrame src={siteAssets.bungalows.room} alt={mediaLabels.roomAlt} label={mediaLabels.room} />
      </div>
      <div class="bungalows-section__floating bungalows-section__floating--two">
        <ImageFrame src={siteAssets.bungalows.bungalow4} alt={mediaLabels.bungalow4Alt} label={mediaLabels.bungalow4} />
      </div>
    </div>
  </div>
</section>

<style>
.bungalows-section {
  background:
    radial-gradient(circle at 86% 8%, rgba(239,174,99,.16), transparent 32%),
    radial-gradient(circle at 14% 68%, rgba(60,179,113,.11), transparent 30%),
    linear-gradient(180deg, #fbfbf7 0%, #fff8ed 100%);
}

.bungalows-section__grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: clamp(42px, 6vw, 78px);
  align-items: center;
}

.bungalows-section__content {
  min-width: 0;
}

.bungalows-section__cards {
  margin-top: clamp(30px, 4vw, 42px);
  display: grid;
  grid-template-columns: 1fr;
  gap: 14px;
}

:global(.bungalows-section__card) {
  padding: 22px;
  border-radius: 24px;
  border-color: rgba(60,179,113,.14);
  background:
    linear-gradient(145deg, rgba(255,255,255,.88), rgba(255,255,255,.66)),
    radial-gradient(circle at 92% 12%, rgba(239,174,99,.12), transparent 34%);
}

:global(.bungalows-section__card span) {
  display: inline-flex;
  margin-bottom: 18px;
  color: #2d9a60;
  font-size: .72rem;
  font-weight: 950;
  letter-spacing: .14em;
  text-transform: uppercase;
}

:global(.bungalows-section__card h3) {
  margin: 0 0 10px;
  color: #14261b;
  font-size: 1.08rem;
  line-height: 1.2;
  font-weight: 900;
}

:global(.bungalows-section__card p) {
  margin: 0;
  color: #56655c;
  line-height: 1.66;
}

.bungalows-section__cta {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  margin-top: 30px;
}

.bungalows-section__button-secondary {
  display: inline-flex;
  min-height: 50px;
  align-items: center;
  justify-content: center;
  padding: 14px 24px;
  border-radius: 999px;
  border: 1px solid rgba(32, 74, 50, .16);
  color: #173624;
  background: rgba(255,255,255,.74);
  box-shadow: 0 16px 42px rgba(17,40,28,.08);
  font-size: .86rem;
  font-weight: 900;
  letter-spacing: .06em;
  transition: transform .25s ease, box-shadow .25s ease, border-color .25s ease;
}

.bungalows-section__button-secondary:hover {
  color: #173624;
  transform: translateY(-2px);
  border-color: rgba(60,179,113,.30);
  box-shadow: 0 22px 58px rgba(17,40,28,.12);
}

.bungalows-section__media {
  position: relative;
  min-height: clamp(520px, 52vw, 680px);
  padding: 10px 12px;
  isolation: isolate;
}

.bungalows-section__media::before {
  content: '';
  position: absolute;
  inset: 12% -4% auto auto;
  z-index: -1;
  width: 58%;
  aspect-ratio: 1;
  border-radius: 44% 56% 48% 52%;
  background:
    radial-gradient(circle at 36% 28%, rgba(242,192,120,.22), transparent 34%),
    radial-gradient(circle at 68% 72%, rgba(60,179,113,.16), transparent 42%);
  filter: blur(4px);
}

:global(.bungalows-section__main-photo) {
  min-height: clamp(440px, 46vw, 610px);
  border-radius: 34px 54px 30px 44px;
  transform: rotate(.6deg);
}

.bungalows-section__floating {
  position: absolute;
  width: min(38%, 238px);
  filter: drop-shadow(0 22px 38px rgba(17,40,28,.18));
}

.bungalows-section__floating :global(.asset-frame) {
  min-height: 150px;
  border-radius: 22px;
}

.bungalows-section__floating--one {
  right: 26px;
  top: 166px;
  transform: rotate(1.4deg);
}

.bungalows-section__floating--two {
  left: 20px;
  bottom: 74px;
  transform: rotate(-1.2deg);
}

@media (min-width: 760px) {
  .bungalows-section__cards {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (min-width: 1080px) {
  .bungalows-section__grid {
    grid-template-columns: minmax(460px, 1fr) minmax(0, .92fr);
  }

  .bungalows-section__media {
    order: -1;
  }
}

@media (max-width: 760px) {
  .bungalows-section__cta {
    display: grid;
  }

  .bungalows-section__button-secondary,
  .bungalows-section__cta :global(.premium-button) {
    width: 100%;
  }

  .bungalows-section__media {
    min-height: auto;
    display: grid;
    gap: 14px;
  }

  .bungalows-section__floating {
    position: static;
    width: 100%;
    transform: none;
  }

  :global(.bungalows-section__main-photo),
  .bungalows-section__floating :global(.asset-frame) {
    min-height: 240px;
    transform: none;
    border-radius: 24px;
  }

  .bungalows-section__media::before {
    display: none;
  }
}
</style>
