---
import { getBookingLocalizedPath, getLocalizedPath, getPathContext } from '@/utils/localizedLinks';
import { resolveContentLanguage } from '@/i18n/config';
import Icon from '@/components/ui/Icon.astro';

interface Props { languageCode?: string }
const { languageCode } = Astro.props as Props;
const context = getPathContext(Astro.url.pathname);
const lang = resolveContentLanguage(languageCode ?? context.languageCode);
const bookingHref = getBookingLocalizedPath(context.languageCode);
const contactHref = getLocalizedPath(context.explicitLanguage, 'kontakt');
const mapsHref = 'https://www.google.com/maps/search/?api=1&query=Camping+Clepardia+Henryka+Pacho%C5%84skiego+28A+Krak%C3%B3w';
const copy = {
  pl: {
    kicker: 'Opinie i zaufanie',
    title: 'Goście dobrze nas wspominają',
    lead: 'Najbardziej cenimy prawdziwe opinie. Zobacz aktualne recenzje w Google albo po pobycie podziel się własnym doświadczeniem.',
    cards: [
      ['Aktualne opinie', 'Oceny i najnowsze komentarze sprawdzisz bezpośrednio w profilu Camping Clepardia w Google.'],
      ['Camping w Krakowie', 'Goście wybierają Clepardię jako zieloną bazę blisko tramwaju, sklepów i atrakcji miasta.'],
      ['Twoja opinia ma znaczenie', 'Po pobycie napisz, co było dla Ciebie najbardziej pomocne — dojazd, obsługa, camping czy domki.'],
    ],
    google: 'Zobacz opinie w Google', review: 'Zostaw opinię po pobycie', booking: 'Zarezerwuj pobyt',
  },
  en: {
    kicker: 'Reviews and trust', title: 'Guests remember their stay',
    lead: 'We value genuine reviews. See current Google feedback or share your own experience after your stay.',
    cards: [
      ['Current reviews', 'See ratings and the latest comments directly in the Camping Clepardia Google profile.'],
      ['A campsite in Krakow', 'Guests use Clepardia as a green base close to trams, shops and city attractions.'],
      ['Your feedback matters', 'After your stay, tell others what helped most: directions, reception, camping or bungalows.'],
    ],
    google: 'See Google reviews', review: 'Leave a review', booking: 'Book your stay',
  },
}[lang] ?? null;
---

{copy && (
  <section class="site-section guest-reviews reveal-section" id="after-hero">
    <div class="container">
      <header class="guest-reviews__head">
        <span class="section-kicker">{copy.kicker}</span>
        <h2>{copy.title}</h2>
        <p>{copy.lead}</p>
      </header>
      <div class="guest-reviews__grid">
        {copy.cards.map(([title, text], index) => (
          <article class="premium-card guest-reviews__card reveal-section" style={`--reveal-delay:${index * 70}ms`}>
            <div class="guest-reviews__stars" aria-label="Google reviews">GOOGLE · OPINIE</div>
            <h3>{title}</h3>
            <p>{text}</p>
          </article>
        ))}
      </div>
      <div class="guest-reviews__actions">
        <a class="btn btn-primary premium-button" href={mapsHref} target="_blank" rel="noopener noreferrer"><Icon name="map" size={18} /> {copy.google}</a>
        <a class="btn btn-glass" href={mapsHref} target="_blank" rel="noopener noreferrer"><Icon name="Star" size={18} /> {copy.review}</a>
        <a class="btn btn-glass" href={bookingHref}><Icon name="calendar" size={18} /> {copy.booking}</a>
        <a class="guest-reviews__contact" href={contactHref}>Camping w mieście — zapytaj recepcję o szczegóły</a>
      </div>
    </div>
  </section>
)}

<style>
.guest-reviews{position:relative;padding:clamp(44px,7vw,82px) 0;background:radial-gradient(circle at 12% 0%,rgba(60,179,113,.16),transparent 34%)}.guest-reviews__head{max-width:820px;margin-bottom:28px}.guest-reviews__head h2{margin:10px 0 14px;color:var(--theme-text-primary,#fff);font-size:clamp(2rem,5vw,4rem);line-height:1}.guest-reviews__head p{color:var(--theme-text-muted,rgba(255,255,255,.72));line-height:1.72}.guest-reviews__grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:16px}.guest-reviews__card{min-height:220px;padding:clamp(22px,3vw,30px);border-radius:26px}.guest-reviews__stars{color:#f2c078;letter-spacing:.14em;font-size:1.08rem}.guest-reviews__card h3{margin:18px 0 10px;color:var(--theme-text-primary,#fff);font-size:1.28rem}.guest-reviews__card p{margin:0;color:var(--theme-text-muted,rgba(255,255,255,.7));line-height:1.7}.guest-reviews__actions{display:flex;flex-wrap:wrap;gap:10px;align-items:center;margin-top:24px}.guest-reviews__actions a{gap:8px}.guest-reviews__contact{color:var(--theme-text-muted,rgba(255,255,255,.72));font-weight:800}@media(max-width:850px){.guest-reviews__grid{grid-template-columns:1fr}.guest-reviews__actions{display:grid}.guest-reviews__actions>a{width:100%;justify-content:center}}html[data-theme="light"] .guest-reviews__head h2,html[data-theme="light"] .guest-reviews__card h3{color:#102018}html[data-theme="light"] .guest-reviews__head p,html[data-theme="light"] .guest-reviews__card p,html[data-theme="light"] .guest-reviews__contact{color:#536359}
</style>
