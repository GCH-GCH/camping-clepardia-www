const text = textByLanguage[requestedLanguage as keyof typeof textByLanguage] ?? textByLanguage.en;
---

<section class="site-section home-story reveal-section">
  <div class="container home-story__grid">
    <div class="home-story__media">
      <ImageFrame
        src={siteAssets.camping.camperArea}
        alt={text.imageMain}
        label={text.imageMain}
        className="home-story__image-main"
      />
      <div class="home-story__floating-photo">
        <ImageFrame
          src={siteAssets.transport.tramToCenter}
          alt={text.imageSmall}
          label={text.imageSmall}
          className="home-story__image-small"
        />
      </div>
    </div>

    <div class="home-story__content">
      <span class="section-kicker">{text.overline}</span>
      <h2 class="section-title">{text.title}</h2>
      <p class="section-copy">{text.copy}</p>

      <div class="home-story__steps">
        {text.steps.map((item, index) => (
          <article class="premium-card home-story__step reveal-section" style={`--reveal-delay: ${index * 90}ms`}>
            <span aria-hidden="true"><Icon name={item.icon} size={22} strokeWidth={1.8} /></span>
            <div>
              <h3>{item.title}</h3>
              <p>{item.copy}</p>
            </div>
          </article>
        ))}
      </div>

      <div class="section-actions">
        <a class="btn btn-primary premium-button" href={directionsHref}>{text.primary}</a>
        <a class="btn btn-glass" href={bookingHref}>{text.secondary}</a>
      </div>
    </div>
  </div>
</section>

<style>
.home-story {
  background:
    radial-gradient(circle at 78% 12%, rgba(242,192,120,.16), transparent 32%),
    radial-gradient(circle at 12% 82%, rgba(60,179,113,.13), transparent 34%),
    linear-gradient(180deg, #f7fbf4, #eef6ef);
}

:global(html[data-theme="dark"]) .home-story {
  background:
    radial-gradient(circle at 78% 12%, rgba(242,192,120,.13), transparent 34%),
    radial-gradient(circle at 12% 82%, rgba(60,179,113,.14), transparent 36%),
    linear-gradient(180deg, #10261A, #142B1F);
}

.home-story__grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: clamp(34px, 6vw, 76px);
  align-items: center;
}

.home-story__media {
  position: relative;
  isolation: isolate;
}

:global(.home-story__image-main.asset-frame) {
  aspect-ratio: 5 / 4;
  border-radius: 34px;
  box-shadow: 0 34px 110px rgba(17,40,28,.22);
}

.home-story__floating-photo {
  width: min(58%, 360px);
  margin: -24% 0 0 auto;
  position: relative;
  z-index: 2;
}

:global(.home-story__image-small.asset-frame) {
  aspect-ratio: 4 / 3;
  border-radius: 28px;
  box-shadow: 0 26px 80px rgba(0,0,0,.24);
}

.home-story__content {
  position: relative;
  z-index: 2;
}

.home-story__steps {
  display: grid;
  gap: 12px;
  margin-top: clamp(26px, 4vw, 40px);
}

:global(.home-story__step) {
  display: grid;
  grid-template-columns: 48px 1fr;
  gap: 16px;
  align-items: center;
  padding: 18px;
  border-radius: 24px;
}

:global(.home-story__step > span) {
  width: 48px;
  height: 48px;
  display: grid;
  place-items: center;
  border-radius: 999px;
  color: #2f9d63;
  background: rgba(60,179,113,.12);
  border: 1px solid rgba(60,179,113,.18);
}

:global(.home-story__step h3) {
  margin: 0 0 6px;
  color: #102018;
  font-size: 1.05rem;
  font-weight: 950;
}

:global(html[data-theme="dark"] .home-story__step h3) {
  color: #F3F8F4;
}

:global(.home-story__step p) {
  margin: 0;
  color: #536359;
  line-height: 1.58;
}

:global(html[data-theme="dark"] .home-story__step p) {
  color: rgba(243,248,244,.74);
}

@media (min-width: 980px) {
  .home-story__grid {
    grid-template-columns: .95fr 1.05fr;
  }
}

@media (max-width: 640px) {
  .home-story__floating-photo {
    width: 100%;
    margin: 14px 0 0;
  }

  :global(.home-story__step) {
    grid-template-columns: 44px 1fr;
    padding: 16px;
  }
}
</style>
