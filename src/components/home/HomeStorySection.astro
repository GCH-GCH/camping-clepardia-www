      { icon: 'parking', title: 'Nechajte vozidlo', copy: 'Obytné auto, auto alebo karavan zostane v kempe.' },
      { icon: 'tram', title: 'Choďte električkou', copy: 'Do centra bez hľadania parkovania.' },
      { icon: 'leaf', title: 'Späť do zelene', copy: 'Večer oddychujete v pokojnejšej časti mesta.' },
    ],
  },
  sv: {
