---
import ImageFrame from '@/components/ImageFrame.astro';
import Icon from '@/components/ui/Icon.astro';
import { siteAssets } from '@/data/assets';
import { getBookingLocalizedPath, getLocalizedPath, getPathContext } from '@/utils/localizedLinks';

interface Props {
  languageCode?: string;
}

const { languageCode } = Astro.props as Props;
const pathContext = getPathContext(Astro.url.pathname);
const requestedLanguage = languageCode ?? pathContext.languageCode;
const linkLanguage = pathContext.explicitLanguage;
const directionsHref = getLocalizedPath(linkLanguage, 'dojazd');
const bookingHref = getBookingLocalizedPath(linkLanguage);

