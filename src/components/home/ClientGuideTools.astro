    checklistTitle: 'Przygotuj przed przyjazdem',
    checklistReady: 'Gotowe — jesteś przygotowany do przyjazdu 🌿',
    checklist: [
      'dokument tożsamości',
      'numer rejestracyjny pojazdu',
