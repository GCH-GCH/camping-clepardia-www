---
import ImageFrame from '@/components/ImageFrame.astro';
import Icon from '@/components/ui/Icon.astro';
import { siteAssets } from '@/data/assets';
import { getBookingLocalizedPath, getLocalizedPath, getPathContext } from '@/utils/localizedLinks';
import { resolveContentLanguage } from '@/i18n/config';

interface Props {
  languageCode?: string;
  variant?: 'home' | 'transport' | 'reservation';
}

const { languageCode, variant = 'home' } = Astro.props as Props;
const isTransportVariant = variant === 'transport';
const isReservationVariant = variant === 'reservation';
const pathContext = getPathContext(Astro.url.pathname);
const contentLanguage = resolveContentLanguage(languageCode ?? pathContext.languageCode);
const bookingHref = getBookingLocalizedPath(contentLanguage);
const campingBookingHref = getBookingLocalizedPath(contentLanguage, 'camping');
const plannerHref = getLocalizedPath(pathContext.explicitLanguage, 'planer-pobytu');
const pricingHref = getLocalizedPath(pathContext.explicitLanguage, 'cennik');
const directionsHref = getLocalizedPath(pathContext.explicitLanguage, 'dojazd');

const copyByLang = {
  pl: {
    kicker: isTransportVariant ? 'Przed przyjazdem' : isReservationVariant ? 'Szybka pomoc' : 'Pomoc dla gości',
    title: isTransportVariant ? 'Przygotuj przyjazd bez nerwów' : 'Pomóż mi wybrać pobyt',
    lead: 'Kilka szybkich odpowiedzi wystarczy, żeby podpowiedzieć najlepszy wariant i przypomnieć najważniejsze rzeczy przed przyjazdem.',
    quizTitle: 'Mini quiz pobytu',
    quizLead: 'Kliknij odpowiedzi i zobacz rekomendację.',
    resultEmpty: 'Wybierz opcje, a tutaj pojawi się podpowiedź.',
    resultCamping: 'Najlepiej zacząć od wariantu Camping. Formularz policzy kampera, vana, przyczepę albo namiot oraz osoby.',
    resultBungalow: 'Najbardziej pasują Domki. Wybierz domek 2-, 3- albo 4-osobowy i wyślij zapytanie do recepcji.',
    resultFamily: 'Dla rodziny dobry będzie domek albo kamper z prądem. Przy 3+ nocach warto dodać Wieliczkę albo Energylandię.',
    resultTransit: 'Jeśli chcesz zwiedzać centrum, zostaw pojazd na campingu i jedź tramwajem 18 do Starego Kleparza.',
    questions: [
      { id: 'vehicle', label: 'Czym przyjeżdżasz?', options: [['camper', 'Kamper'], ['van', 'Van'], ['caravan', 'Przyczepa'], ['tent', 'Namiot'], ['bungalow', 'Szukam domku']] },
      { id: 'people', label: 'Ile osób?', options: [['two', '1-2'], ['family', 'Rodzina'], ['group', 'Grupa']] },
      { id: 'goal', label: 'Co chcesz robić?', options: [['center', 'Zwiedzać centrum'], ['rest', 'Odpocząć'], ['region', 'Małopolska'], ['overnight', 'Nocleg po drodze']] },
      { id: 'nights', label: 'Ile nocy?', options: [['one', '1'], ['two', '2'], ['three', '3'], ['long', '4+']] },
    ],
    ctas: {
