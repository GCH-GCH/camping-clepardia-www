---
import ImageFrame from '@/components/ImageFrame.astro';
import Icon from '@/components/ui/Icon.astro';
import { getHomepageSiteNotices, getNoticeCopy, siteNoticeCategories } from '@/data/siteNotices';
import { getBookingLocalizedPath, getLocalizedPath, getPlannerLocalizedPath } from '@/utils/localizedLinks';

interface Props {
  languageCode?: string;
}

const { languageCode = 'pl' } = Astro.props as Props;
const notices = getHomepageSiteNotices().slice(0, 4);
const noticesCopyByLanguage = {
  pl: { kicker: 'Aktualności', heading: 'Aktualnie na campingu i w Krakowie', lead: 'Najważniejsze komunikaty, wydarzenia i podpowiedzi dla gości Camping Clepardia.', all: 'Zobacz wszystkie aktualności', details: 'Zobacz szczegóły' },
  en: { kicker: 'Updates', heading: 'Current updates in Krakow and at the campsite', lead: 'Important events, notices and seasonal tips for Camping Clepardia guests.', all: 'See all updates', details: 'See details' },
  de: { kicker: 'Neuigkeiten', heading: 'Aktuelles am Campingplatz und in Krakau', lead: 'Wichtige Hinweise, Ereignisse und saisonale Tipps für Gäste von Camping Clepardia.', all: 'Alle Neuigkeiten ansehen', details: 'Details ansehen' },
  it: { kicker: 'Novità', heading: 'Aggiornamenti dal camping e da Cracovia', lead: 'Avvisi importanti, eventi e consigli stagionali per gli ospiti di Camping Clepardia.', all: 'Vedi tutte le novità', details: 'Vedi dettagli' },
  fr: { kicker: 'Actualités', heading: 'Actualités du camping et de Cracovie', lead: 'Informations importantes, événements et conseils de saison pour les clients de Camping Clepardia.', all: 'Voir toutes les actualités', details: 'Voir les détails' },
  es: { kicker: 'Noticias', heading: 'Actualidad del camping y de Cracovia', lead: 'Avisos importantes, eventos y consejos de temporada para huéspedes de Camping Clepardia.', all: 'Ver todas las noticias', details: 'Ver detalles' },
  nl: { kicker: 'Updates', heading: 'Actueel op de camping en in Krakau', lead: 'Belangrijke meldingen, evenementen en seizoenstips voor gasten van Camping Clepardia.', all: 'Bekijk alle updates', details: 'Bekijk details' },
  cs: { kicker: 'Novinky', heading: 'Aktuálně v kempu a v Krakově', lead: 'Důležitá oznámení, akce a sezónní tipy pro hosty Camping Clepardia.', all: 'Zobrazit všechny novinky', details: 'Zobrazit detail' },
  sk: { kicker: 'Novinky', heading: 'Aktuálne v kempe a v Krakove', lead: 'Dôležité oznamy, akcie a sezónne tipy pre hostí Camping Clepardia.', all: 'Zobraziť všetky novinky', details: 'Zobraziť detail' },
  sv: { kicker: 'Nyheter', heading: 'Aktuellt på campingen och i Kraków', lead: 'Viktiga meddelanden, evenemang och säsongstips för gäster på Camping Clepardia.', all: 'Se alla nyheter', details: 'Se detaljer' },
};
const noticesCopy = noticesCopyByLanguage[languageCode as keyof typeof noticesCopyByLanguage] ?? noticesCopyByLanguage.en;
const categoryLabelsByLanguage = {
  pl: { sezon: 'Sezon', camping: 'Camping', domki: 'Domki', dojazd: 'Dojazd', atrakcje: 'Atrakcje', wydarzenia: 'Wydarzenia', koncerty: 'Koncerty', rodzina: 'Rodzina', alerty: 'Alerty', oferty: 'Oferty', pogoda: 'Pogoda', recepcja: 'Recepcja', info: 'Info' },
  en: { sezon: 'Season', camping: 'Camping', domki: 'Bungalows', dojazd: 'Directions', atrakcje: 'Attractions', wydarzenia: 'Events', koncerty: 'Concerts', rodzina: 'Family', alerty: 'Alerts', oferty: 'Offers', pogoda: 'Weather', recepcja: 'Reception', info: 'Info' },
  de: { sezon: 'Saison', camping: 'Camping', domki: 'Bungalows', dojazd: 'Anreise', atrakcje: 'Attraktionen', wydarzenia: 'Events', koncerty: 'Konzerte', rodzina: 'Familie', alerty: 'Hinweise', oferty: 'Angebote', pogoda: 'Wetter', recepcja: 'Rezeption', info: 'Info' },
  it: { sezon: 'Stagione', camping: 'Camping', domki: 'Bungalow', dojazd: 'Accesso', atrakcje: 'Attrazioni', wydarzenia: 'Eventi', koncerty: 'Concerti', rodzina: 'Famiglia', alerty: 'Avvisi', oferty: 'Offerte', pogoda: 'Meteo', recepcja: 'Reception', info: 'Info' },
  fr: { sezon: 'Saison', camping: 'Camping', domki: 'Bungalows', dojazd: 'Accès', atrakcje: 'Attractions', wydarzenia: 'Événements', koncerty: 'Concerts', rodzina: 'Famille', alerty: 'Alertes', oferty: 'Offres', pogoda: 'Météo', recepcja: 'Réception', info: 'Info' },
  es: { sezon: 'Temporada', camping: 'Camping', domki: 'Bungalows', dojazd: 'Acceso', atrakcje: 'Atracciones', wydarzenia: 'Eventos', koncerty: 'Conciertos', rodzina: 'Familia', alerty: 'Avisos', oferty: 'Ofertas', pogoda: 'Tiempo', recepcja: 'Recepción', info: 'Info' },
  nl: { sezon: 'Seizoen', camping: 'Camping', domki: 'Bungalows', dojazd: 'Route', atrakcje: 'Attracties', wydarzenia: 'Evenementen', koncerty: 'Concerten', rodzina: 'Gezin', alerty: 'Meldingen', oferty: 'Aanbiedingen', pogoda: 'Weer', recepcja: 'Receptie', info: 'Info' },
  cs: { sezon: 'Sezóna', camping: 'Camping', domki: 'Bungalovy', dojazd: 'Doprava', atrakcje: 'Atrakce', wydarzenia: 'Akce', koncerty: 'Koncerty', rodzina: 'Rodina', alerty: 'Upozornění', oferty: 'Nabídky', pogoda: 'Počasí', recepcja: 'Recepce', info: 'Info' },
  sk: { sezon: 'Sezóna', camping: 'Camping', domki: 'Bungalovy', dojazd: 'Doprava', atrakcje: 'Atrakcie', wydarzenia: 'Akcie', koncerty: 'Koncerty', rodzina: 'Rodina', alerty: 'Upozornenia', oferty: 'Ponuky', pogoda: 'Počasie', recepcja: 'Recepcia', info: 'Info' },
  sv: { sezon: 'Säsong', camping: 'Camping', domki: 'Bungalower', dojazd: 'Väg', atrakcje: 'Sevärdheter', wydarzenia: 'Evenemang', koncerty: 'Konserter', rodzina: 'Familj', alerty: 'Meddelanden', oferty: 'Erbjudanden', pogoda: 'Väder', recepcja: 'Reception', info: 'Info' },
};
const localizedLanguage = languageCode === 'pl' ? undefined : languageCode;
const localizedDirectionsHref = getLocalizedPath(localizedLanguage, 'dojazd');
const localizedBookingHref = getBookingLocalizedPath(languageCode);
const resolveHref = (href?: string) => {
  if (href === '/dojazd') return localizedDirectionsHref;
  if (href === '/rezerwacja') return localizedBookingHref;
  if (href === '/cennik') return getLocalizedPath(localizedLanguage, 'cennik');
  if (href === '/planer-pobytu') return getPlannerLocalizedPath(languageCode);
  return href ?? localizedDirectionsHref;
};
const categoryLabel = (category: string) =>
  categoryLabelsByLanguage[languageCode as keyof typeof categoryLabelsByLanguage]?.[
    category as keyof typeof categoryLabelsByLanguage.en
  ] ?? siteNoticeCategories.find((item) => item.id === category)?.label ?? category;
---

{notices.length > 0 && (
  <section class="site-section site-notices reveal-section" id="start-content" data-after-hero aria-labelledby="siteNoticesTitle">
    <div class="container site-notices__inner">
      <div class="site-notices__head">
        <span class="section-kicker">{noticesCopy.kicker}</span>
        <h2 class="section-title" id="siteNoticesTitle">{noticesCopy.heading}</h2>
        <p class="section-copy">{noticesCopy.lead}</p>
        <a class="site-notices__all" href="/aktualnosci">
          <span>{noticesCopy.all}</span>
          <Icon name="ArrowUpRight" size={17} strokeWidth={2.2} />
        </a>
      </div>

      <div class="site-notices__grid">
        {notices.map((notice, index) => {
          const copy = getNoticeCopy(notice, languageCode);
          return (
            <article class:list={['premium-card site-notices__card', `site-notices__card--${notice.category}`]} style={`--notice-delay: ${index * 90}ms`}>
              <div class="site-notices__media">
                <ImageFrame
                  src={notice.image ?? ''}
                  alt={copy.imageAlt ?? copy.title}
                  label={copy.badge ?? categoryLabel(notice.category)}
                  className="site-notices__image"
                />
                <span class="site-notices__icon" aria-hidden="true">
                  <Icon name={notice.icon ?? 'Info'} size={22} strokeWidth={2} />
                </span>
              </div>
              <div class="site-notices__content">
                <div class="site-notices__meta">
                  {copy.badge && <span>{copy.badge}</span>}
                  <small>{categoryLabel(notice.category)}</small>
                </div>
                <h3>{copy.title}</h3>
                <p>{copy.shortDescription ?? copy.description}</p>
                <a href={resolveHref(notice.ctaHref)}>
                  <span>{copy.ctaLabel ?? noticesCopy.details}</span>
                  <Icon name="ArrowUpRight" size={17} strokeWidth={2.2} />
                </a>
              </div>
            </article>
          );
        })}
      </div>
    </div>
  </section>
)}

<style>
.site-notices {
  position: relative;
  overflow: hidden;
  padding: clamp(46px, 7vw, 92px) 0;
  background:
    radial-gradient(circle at 12% 0%, rgba(60,179,113,.18), transparent 34%),
    radial-gradient(circle at 86% 20%, rgba(242,192,120,.16), transparent 30%),
    linear-gradient(180deg, #f7f8f3, #eef6ec);
}

.site-notices::before {
  content: '';
  position: absolute;
  inset: 0;
  pointer-events: none;
  opacity: .14;
  background:
    repeating-linear-gradient(135deg, rgba(16,32,24,.12) 0 1px, transparent 1px 28px),
    linear-gradient(90deg, transparent, rgba(60,179,113,.18), transparent);
  mask-image: radial-gradient(circle at 50% 20%, #000, transparent 72%);
}

.site-notices__inner {
  position: relative;
  z-index: 1;
  display: grid;
  gap: clamp(24px, 4vw, 38px);
}

.site-notices__head {
  max-width: 820px;
}

.site-notices__all {
  width: fit-content;
  min-height: 42px;
  display: inline-flex;
  align-items: center;
  gap: 9px;
  margin-top: 18px;
  padding: 0 15px;
  border: 1px solid rgba(60,179,113,.22);
  border-radius: 999px;
  color: #123422;
  background: rgba(255,255,255,.76);
  font-size: .86rem;
  font-weight: 950;
  text-decoration: none;
  box-shadow: 0 14px 34px rgba(17,40,28,.08);
}

.site-notices__grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 16px;
}

.site-notices__card {
  position: relative;
  display: grid;
  gap: 16px;
  min-height: 100%;
  padding: 14px;
  border-radius: 28px;
  background:
    radial-gradient(circle at 16% 0%, rgba(60,179,113,.16), transparent 34%),
    rgba(255,255,255,.78);
  animation: noticeCardIn .55s cubic-bezier(.22, 1, .36, 1) both;
  animation-delay: var(--notice-delay, 0ms);
  transition: transform .24s ease, border-color .24s ease, box-shadow .24s ease;
}

.site-notices__card:hover {
  transform: translateY(-4px);
  border-color: rgba(60,179,113,.36);
  box-shadow: 0 24px 64px rgba(17,40,28,.13), 0 0 30px rgba(60,179,113,.10);
}

.site-notices__media {
  position: relative;
  min-width: 0;
}

:global(.site-notices__image) {
  min-height: 176px;
  border-radius: 22px;
}

.site-notices__icon {
  position: absolute;
  right: 14px;
  top: 14px;
  z-index: 3;
  width: 48px;
  height: 48px;
  display: grid;
  place-items: center;
  border-radius: 18px;
  color: #f8fff9;
  background:
    radial-gradient(circle at 30% 18%, rgba(255,255,255,.36), transparent 34%),
    linear-gradient(135deg, rgba(60,179,113,.92), rgba(26,96,60,.74));
  border: 1px solid rgba(143,224,180,.32);
  box-shadow: 0 14px 32px rgba(60,179,113,.24);
}

.site-notices__content {
  min-width: 0;
  display: grid;
  gap: 10px;
  padding: 0 8px 8px;
}

.site-notices__meta {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  align-items: center;
}

.site-notices__meta span,
.site-notices__meta small {
  width: fit-content;
  padding: 7px 10px;
  border-radius: 999px;
  color: #0f6b3f;
  background: rgba(60,179,113,.13);
  font-size: .72rem;
  font-weight: 950;
  text-transform: uppercase;
  letter-spacing: .06em;
}

.site-notices__meta small {
  color: #6c4c18;
  background: rgba(242,192,120,.20);
}

.site-notices__card h3 {
  margin: 0;
  color: #102018;
  font-size: clamp(1.08rem, 1.7vw, 1.28rem);
  line-height: 1.18;
  font-weight: 950;
}

.site-notices__card p {
  margin: 0;
  color: #52645a;
  line-height: 1.58;
  font-weight: 760;
}

.site-notices__card a {
  width: fit-content;
  min-height: 40px;
  display: inline-flex;
  align-items: center;
  gap: 9px;
  margin-top: 4px;
  padding: 0 13px;
  border-radius: 999px;
  color: #082016;
  background: linear-gradient(135deg, #a8f0c7, #3CB371 62%, #2f9d63);
  font-size: .82rem;
  font-weight: 950;
  text-decoration: none;
  box-shadow: 0 16px 34px rgba(60,179,113,.20);
}

html[data-theme="dark"] .site-notices {
  background:
    radial-gradient(circle at 12% 0%, rgba(60,179,113,.22), transparent 34%),
    radial-gradient(circle at 86% 20%, rgba(242,192,120,.12), transparent 30%),
    linear-gradient(180deg, #0f1d14, #13261a);
}

html[data-theme="dark"] .site-notices .section-title {
  color: #fff;
}

html[data-theme="dark"] .site-notices .section-copy {
  color: rgba(255,255,255,.72);
}

html[data-theme="dark"] .site-notices__all,
html[data-theme="dark"] .site-notices__card {
  border-color: rgba(255,255,255,.13);
  background:
    radial-gradient(circle at 16% 0%, rgba(60,179,113,.18), transparent 34%),
    rgba(255,255,255,.08);
}

html[data-theme="dark"] .site-notices__all,
html[data-theme="dark"] .site-notices__card h3 {
  color: #fff;
}

html[data-theme="dark"] .site-notices__card p {
  color: rgba(255,255,255,.72);
}

@keyframes noticeCardIn {
  from { opacity: 0; transform: translateY(18px) scale(.98); }
  to { opacity: 1; transform: translateY(0) scale(1); }
}

@media (max-width: 1120px) {
  .site-notices__grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

@media (max-width: 680px) {
  .site-notices__grid {
    grid-template-columns: 1fr;
  }
}
</style>
