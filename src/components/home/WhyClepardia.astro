---
import { publicAssetExists } from '../../data/assets';

const iconFallbacks = {
  tram: ['track', 'dot', 'dot', 'line'],
  camper: ['body', 'wheel', 'wheel', 'line'],
  bungalow: ['roof', 'body', 'door'],
  leaf: ['leaf', 'stem'],
  shower: ['drop', 'line', 'dot'],
  map: ['pin', 'route'],
} as const;

const resolveIcon = (...paths: string[]) => paths.find((path) => publicAssetExists(path));

const benefits = [
  {
    title: 'Blisko centrum Krakowa',
    copy: 'Szybki dojazd tramwajem do Starego Miasta bez szukania parkingu w centrum.',
    icon: resolveIcon('/brand/icons/icon-tram.svg', '/brand/icons/icon-map.svg'),
    fallback: 'tram',
    delay: 0,
  },
  {
    title: 'Miejsca dla kamperów i przyczep',
    copy: 'Wygodna baza dla podróżujących kamperem, vanem, przyczepą lub autem z namiotem dachowym.',
    icon: resolveIcon('/brand/icons/icon-camper.svg'),
    fallback: 'camper',
    delay: 80,
  },
  {
    title: 'Domki dla gości',
    copy: 'Komfortowa opcja noclegu dla osób, które chcą zostać w Krakowie bez własnego sprzętu campingowego.',
    icon: resolveIcon('/brand/icons/icon-bungalow.svg'),
    fallback: 'bungalow',
    delay: 160,
  },
  {
    title: 'Zielona okolica',
    copy: 'Spokojniejsza przestrzeń do odpoczynku po całym dniu zwiedzania Krakowa i Małopolski.',
    fallback: 'leaf',
    delay: 240,
  },
  {
    title: 'Dobre zaplecze',
    copy: 'Sanitariaty, kuchnie turystyczne, prąd, pralnia i podstawowe udogodnienia potrzebne w podróży.',
    icon: resolveIcon('/brand/icons/icon-shower.svg'),
    fallback: 'shower',
    delay: 320,
  },
  {
    title: 'Dobra baza wypadowa',
    copy: 'Wygodny start do zwiedzania Krakowa, Wieliczki, Ojcowa, Energylandii i innych atrakcji regionu.',
    icon: resolveIcon('/brand/icons/icon-map.svg'),
    fallback: 'map',
    delay: 400,
  },
];
---

<section class="site-section why reveal-section" id="dlaczego">
  <div class="container">
    <div class="why__header">
      <span class="section-kicker">Zielona baza w Krakowie</span>
      <h2 class="section-title">Dlaczego Camping Clepardia?</h2>
      <p class="section-copy">
        Zielona przestrzeń w Krakowie, wygodna baza do zwiedzania i szybki dojazd do centrum bez stresu z parkowaniem.
      </p>
    </div>

    <div class="why__grid">
      {benefits.map((benefit) => (
        <article class="premium-card reveal-section why__card" style={`--reveal-delay: ${benefit.delay}ms`}>
          <div class="why__icon" aria-hidden="true">
            {benefit.icon ? (
              <img src={benefit.icon} alt="" width="34" height="34" loading="lazy" decoding="async" />
            ) : (
              <span class:list={['why__icon-fallback', `why__icon-fallback--${benefit.fallback}`]}>
                {iconFallbacks[benefit.fallback].map((part) => <i class={`why__icon-part why__icon-part--${part}`}></i>)}
              </span>
            )}
          </div>
          <h3>{benefit.title}</h3>
          <p>{benefit.copy}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
.why {
  background:
    radial-gradient(circle at 12% 4%, rgba(60,179,113,.16), transparent 34%),
    radial-gradient(circle at 86% 12%, rgba(238,174,99,.14), transparent 30%),
    linear-gradient(180deg, #fbfbf7 0%, #f1f7f0 100%);
}

.why__header {
  max-width: 850px;
}

.why__grid {
  margin-top: clamp(34px, 5vw, 56px);
  display: grid;
  grid-template-columns: 1fr;
  gap: 18px;
}

.why__card {
  position: relative;
  min-height: 286px;
  padding: clamp(24px, 3vw, 32px);
  border-radius: 24px;
  border-color: rgba(60,179,113,.16);
  background:
    linear-gradient(145deg, rgba(255,255,255,.86), rgba(255,255,255,.62)),
    radial-gradient(circle at 86% 12%, rgba(60,179,113,.12), transparent 34%);
  box-shadow: 0 24px 74px rgba(17, 40, 28, .09);
  overflow: hidden;
}

.why__card::before {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: inherit;
  pointer-events: none;
  background: linear-gradient(135deg, rgba(255,255,255,.58), transparent 42%);
  opacity: .82;
}

.why__card::after {
  content: '';
  position: absolute;
  right: -44px;
  bottom: -44px;
  width: 138px;
  height: 138px;
  border-radius: 999px;
  background: rgba(60,179,113,.10);
  filter: blur(4px);
  transition: transform .28s ease, opacity .28s ease;
}

.why__card:hover {
  transform: translateY(-6px);
  border-color: rgba(60,179,113,.32);
  box-shadow: 0 32px 94px rgba(17, 40, 28, .14);
}

.why__card:hover::after {
  transform: scale(1.08);
  opacity: .9;
}

.why__icon,
.why__card h3,
.why__card p {
  position: relative;
  z-index: 1;
}

.why__icon {
  width: 66px;
  height: 66px;
  display: grid;
  place-items: center;
  margin-bottom: 34px;
  border-radius: 22px;
  border: 1px solid rgba(60,179,113,.20);
  background:
    linear-gradient(145deg, rgba(255,255,255,.92), rgba(255,255,255,.58)),
    radial-gradient(circle at 70% 24%, rgba(60,179,113,.22), transparent 42%);
  box-shadow: 0 16px 38px rgba(17, 40, 28, .10);
}

.why__icon img {
  width: 34px;
  height: 34px;
  object-fit: contain;
}

.why__icon-fallback {
  position: relative;
  width: 34px;
  height: 34px;
  display: block;
  color: #2f9b62;
}

.why__icon-part {
  position: absolute;
  display: block;
  border-color: currentColor;
  background: currentColor;
}

.why__icon-part--track {
  left: 6px;
  top: 7px;
  width: 22px;
  height: 18px;
  border: 2px solid currentColor;
  border-radius: 7px 7px 5px 5px;
  background: transparent;
}

.why__icon-part--dot {
  bottom: 3px;
  width: 5px;
  height: 5px;
  border-radius: 999px;
}

.why__icon-part--dot:nth-child(2) { left: 9px; }
.why__icon-part--dot:nth-child(3) { right: 9px; }

.why__icon-part--line {
  left: 7px;
  right: 7px;
  bottom: 10px;
  height: 2px;
  border-radius: 999px;
}

.why__icon-part--body {
  left: 3px;
  top: 10px;
  width: 27px;
  height: 15px;
  border: 2px solid currentColor;
  border-radius: 5px 8px 4px 4px;
  background: transparent;
}

.why__icon-part--wheel {
  bottom: 4px;
  width: 7px;
  height: 7px;
  border: 2px solid currentColor;
  border-radius: 999px;
  background: rgba(255,255,255,.7);
}

.why__icon-part--wheel:nth-child(2) { left: 8px; }
.why__icon-part--wheel:nth-child(3) { right: 6px; }

.why__icon-part--roof {
  left: 4px;
  top: 7px;
  width: 24px;
  height: 24px;
  border-left: 2px solid currentColor;
  border-top: 2px solid currentColor;
  background: transparent;
  transform: rotate(45deg);
}

.why__icon-part--door {
  left: 14px;
  bottom: 4px;
  width: 7px;
  height: 12px;
  border: 2px solid currentColor;
  border-bottom: 0;
  border-radius: 4px 4px 0 0;
  background: transparent;
}

.why__icon-part--leaf {
  left: 8px;
  top: 4px;
  width: 20px;
  height: 24px;
  border-radius: 20px 2px 20px 2px;
  transform: rotate(18deg);
}

.why__icon-part--stem {
  left: 16px;
  bottom: 4px;
  width: 2px;
  height: 18px;
  border-radius: 999px;
  transform: rotate(32deg);
}

.why__icon-part--drop {
  left: 10px;
  top: 4px;
  width: 14px;
  height: 20px;
  border-radius: 14px 14px 14px 4px;
  transform: rotate(45deg);
}

.why__icon-part--pin {
  left: 10px;
  top: 3px;
  width: 14px;
  height: 20px;
  border: 2px solid currentColor;
  border-radius: 12px 12px 12px 2px;
  background: transparent;
  transform: rotate(-45deg);
}

.why__icon-part--route {
  left: 5px;
  right: 4px;
  bottom: 5px;
  height: 2px;
  border-radius: 999px;
  box-shadow: 10px -5px 0 currentColor, 20px 0 0 currentColor;
}

.why__card h3 {
  max-width: 360px;
  margin: 0 0 14px;
  color: #12271c;
  font-size: clamp(1.18rem, 1.8vw, 1.42rem);
  line-height: 1.16;
  font-weight: 900;
  letter-spacing: 0;
}

.why__card p {
  margin: 0;
  color: #536359;
  line-height: 1.72;
  font-size: 1rem;
}

@media (min-width: 760px) {
  .why__grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (min-width: 1120px) {
  .why__grid {
    grid-template-columns: repeat(3, 1fr);
  }
}

@media (max-width: 560px) {
  .why__card {
    min-height: auto;
  }

  .why__icon {
    margin-bottom: 28px;
  }
}
</style>
