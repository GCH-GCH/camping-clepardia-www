---
import { getTranslations } from '@/i18n/config';
import { getPathContext } from '@/utils/localizedLinks';
import Icon from '@/components/ui/Icon.astro';

interface Props {
  languageCode?: string;
}

const { languageCode } = Astro.props as Props;
const pathContext = getPathContext(Astro.url.pathname);
const t = getTranslations(languageCode ?? pathContext.languageCode);

const benefits = [
  {
    title: t.home.why.benefits[0].title,
    copy: t.home.why.benefits[0].copy,
    icon: 'tram',
    delay: 0,
  },
  {
    title: t.home.why.benefits[1].title,
    copy: t.home.why.benefits[1].copy,
    icon: 'camper',
    delay: 80,
  },
  {
    title: t.home.why.benefits[2].title,
    copy: t.home.why.benefits[2].copy,
    icon: 'bungalow',
    delay: 160,
  },
  {
    title: t.home.why.benefits[3].title,
    copy: t.home.why.benefits[3].copy,
    icon: 'leaf',
    delay: 240,
  },
  {
    title: t.home.why.benefits[4].title,
    copy: t.home.why.benefits[4].copy,
    icon: 'shower',
    delay: 320,
  },
  {
    title: t.home.why.benefits[5].title,
    copy: t.home.why.benefits[5].copy,
    icon: 'map',
    delay: 400,
  },
];
---

<section class="site-section why reveal-section" id="dlaczego">
  <div class="container">
    <div class="why__header">
      <span class="section-kicker">{t.home.why.overline}</span>
      <h2 class="section-title">{t.home.why.title}</h2>
      <p class="section-copy">
        {t.home.why.lead}
      </p>
    </div>

    <div class="why__grid">
      {benefits.map((benefit) => (
        <article class="premium-card reveal-section why__card" style={`--reveal-delay: ${benefit.delay}ms`}>
          <div class="why__icon" aria-hidden="true">
            <Icon name={benefit.icon} size={34} strokeWidth={1.8} />
          </div>
          <h3>{benefit.title}</h3>
          <p>{benefit.copy}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
.why {
  background:
    radial-gradient(circle at 12% 4%, rgba(60,179,113,.16), transparent 34%),
    radial-gradient(circle at 86% 12%, rgba(238,174,99,.14), transparent 30%),
    linear-gradient(180deg, #fbfbf7 0%, #f1f7f0 100%);
}

.why__header {
  max-width: 850px;
}

.why__grid {
  margin-top: clamp(34px, 5vw, 56px);
  display: grid;
  grid-template-columns: 1fr;
  gap: 18px;
}

.why__card {
  position: relative;
  min-height: 286px;
  padding: clamp(24px, 3vw, 32px);
  border-radius: 24px;
  border-color: rgba(60,179,113,.16);
  background:
    linear-gradient(145deg, rgba(255,255,255,.86), rgba(255,255,255,.62)),
    radial-gradient(circle at 86% 12%, rgba(60,179,113,.12), transparent 34%);
  box-shadow: 0 24px 74px rgba(17, 40, 28, .09);
  overflow: hidden;
}

.why__card::before {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: inherit;
  pointer-events: none;
  background: linear-gradient(135deg, rgba(255,255,255,.58), transparent 42%);
  opacity: .82;
}

.why__card::after {
  content: '';
  position: absolute;
  right: -44px;
  bottom: -44px;
  width: 138px;
  height: 138px;
  border-radius: 999px;
  background: rgba(60,179,113,.10);
  filter: blur(4px);
  transition: transform .28s ease, opacity .28s ease;
}

.why__card:hover {
  transform: translateY(-6px);
  border-color: rgba(60,179,113,.32);
  box-shadow: 0 32px 94px rgba(17, 40, 28, .14);
}

.why__card:hover::after {
  transform: scale(1.08);
  opacity: .9;
}

.why__icon,
.why__card h3,
.why__card p {
  position: relative;
  z-index: 1;
}

.why__icon {
  width: 66px;
  height: 66px;
  display: grid;
  place-items: center;
  margin-bottom: 34px;
  border-radius: 22px;
  border: 1px solid rgba(60,179,113,.20);
  background:
    linear-gradient(145deg, rgba(255,255,255,.92), rgba(255,255,255,.58)),
    radial-gradient(circle at 70% 24%, rgba(60,179,113,.22), transparent 42%);
  box-shadow: 0 16px 38px rgba(17, 40, 28, .10);
}

.why__icon :global(svg) {
  color: #2f9b62;
  filter: drop-shadow(0 8px 18px rgba(60,179,113,.16));
}

.why__card h3 {
  max-width: 360px;
  margin: 0 0 14px;
  color: #12271c;
  font-size: clamp(1.18rem, 1.8vw, 1.42rem);
  line-height: 1.16;
  font-weight: 900;
  letter-spacing: 0;
}

.why__card p {
  margin: 0;
  color: #536359;
  line-height: 1.72;
  font-size: 1rem;
}

@media (min-width: 760px) {
  .why__grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (min-width: 1120px) {
  .why__grid {
    grid-template-columns: repeat(3, 1fr);
  }
}

@media (max-width: 560px) {
  .why__card {
    min-height: auto;
  }

  .why__icon {
    margin-bottom: 28px;
  }
}
</style>
