---
import { Buffer } from 'node:buffer';
import { loaderLogo, loaderLogoFallback } from '@/data/assets';
import { getTranslations } from '@/i18n/config';
import { getPathContext } from '@/utils/localizedLinks';

const pathContext = getPathContext(Astro.url.pathname);
const t = getTranslations(pathContext.languageCode);
const loaderMessages = t.loader.messages;
const loaderMessagesEncoded = Buffer.from(JSON.stringify(loaderMessages), 'utf-8').toString('base64');
---

<script is:inline>
  (() => {
    const root = document.documentElement;
    let didFinish = false;

    const setLoaderProgress = (value) => {
      const loader = document.querySelector('.page-loader');
      if (!(loader instanceof HTMLElement)) return;
      const safeValue = Math.max(0, Math.min(100, Math.round(value)));
      loader.style.setProperty('--loader-progress', `${safeValue}%`);
      loader.dataset.loaderProgress = String(safeValue);
      const progressValue = loader.querySelector('.page-loader__progress-value');
      if (progressValue instanceof HTMLElement) {
        progressValue.textContent = `${safeValue}%`;
      }
    };

    const finishLoading = () => {
      if (didFinish) return;
      didFinish = true;
      setLoaderProgress(100);
      root.classList.add('motion-loaded');
      root.classList.remove('motion-loading');
      const loader = document.querySelector('.page-loader');
      if (loader instanceof HTMLElement) {
        loader.classList.add('is-hidden');
        loader.setAttribute('aria-hidden', 'true');
        loader.setAttribute('inert', '');
        loader.removeAttribute('role');
        loader.removeAttribute('aria-live');
        loader.querySelector('.page-loader__status')?.removeAttribute('aria-live');
        window.setTimeout(() => {
          loader.hidden = true;
        }, 620);
      }
    };

    root.classList.add('motion-ready', 'motion-loading');
    window.__ccMotionSetLoaderProgress = setLoaderProgress;
    window.__ccMotionFinishLoading = finishLoading;
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    window.setTimeout(finishLoading, reduceMotion ? 400 : 2200);
  })();
</script>

<div
  class="page-loader"
  hidden
  inert
  aria-hidden="true"
  data-loader-messages={loaderMessagesEncoded}
  data-loader-progress="0"
>
  <div class="page-loader__ambient" aria-hidden="true">
    <span class="page-loader__light page-loader__light--green"></span>
    <span class="page-loader__light page-loader__light--warm"></span>
    <span class="page-loader__horizon"></span>
  </div>
  <div class="page-loader__particles" aria-hidden="true">
    <span></span>
    <span></span>
    <span></span>
    <span></span>
    <span></span>
    <span></span>
    <span></span>
  </div>
  <div class="page-loader__stage">
    <span class="page-loader__orbit page-loader__orbit--outer" aria-hidden="true"></span>
    <span class="page-loader__orbit page-loader__orbit--inner" aria-hidden="true"></span>
    <span class="page-loader__radar" aria-hidden="true"></span>
    <span class="page-loader__sweep" aria-hidden="true"></span>
    <span class="page-loader__glow" aria-hidden="true"></span>
    <div class="page-loader__core">
      <span class="page-loader__logo-fallback" aria-hidden="true">CC</span>
      <img
        class="page-loader__logo"
        src={loaderLogo}
        alt=""
        width="260"
        height="260"
        decoding="async"
        onerror={`if (!this.dataset.fallbackApplied) { this.dataset.fallbackApplied = 'true'; this.src = '${loaderLogoFallback}'; } else { this.hidden = true; this.closest('.page-loader__core')?.classList.add('has-fallback'); }`}
      />
    </div>
  </div>
  <div class="page-loader__copy">
    <p class="page-loader__status" id="pageLoaderStatus"></p>
    <div class="page-loader__progress" aria-hidden="true">
      <span class="page-loader__progress-track">
        <span class="page-loader__progress-bar" id="pageLoaderProgressBar"></span>
      </span>
      <span class="page-loader__progress-value" id="pageLoaderProgressValue"></span>
    </div>
  </div>
</div>

<noscript><style>.page-loader{display:none!important}</style></noscript>

<script is:inline>
  (() => {
    const loader = document.querySelector('.page-loader');
    const root = document.documentElement;
    if (!(loader instanceof HTMLElement) || !root.classList.contains('motion-loading')) return;

    loader.hidden = false;
    loader.classList.remove('is-hidden');
    loader.removeAttribute('inert');
    loader.setAttribute('aria-hidden', 'false');
    loader.setAttribute('role', 'status');
    loader.setAttribute('aria-live', 'polite');
    const decodeMessages = () => {
      try {
        const encoded = loader.dataset.loaderMessages || '';
        const binary = window.atob(encoded);
        const bytes = Uint8Array.from(binary, (char) => char.charCodeAt(0));
        const parsed = JSON.parse(new TextDecoder().decode(bytes));
        return Array.isArray(parsed) ? parsed.filter(Boolean) : [];
      } catch {
        return [];
      }
    };
    const status = loader.querySelector('.page-loader__status');
    if (status instanceof HTMLElement) {
      status.textContent = decodeMessages()[0] || 'Loading Camping Clepardia';
      status.setAttribute('aria-live', 'polite');
    }
    const progressValue = loader.querySelector('.page-loader__progress-value');
    if (progressValue instanceof HTMLElement) {
      progressValue.textContent = '0%';
    }
  })();
</script>

<script>
  import Lenis from 'lenis';

  const root = document.documentElement;
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
  const loader = document.querySelector('.page-loader');
  const loaderStatus = document.getElementById('pageLoaderStatus');
  const loaderProgressValue = document.getElementById('pageLoaderProgressValue');
  const loaderMessages = (() => {
    if (!(loader instanceof HTMLElement)) return ['Loading Camping Clepardia'];

    try {
      const encoded = loader.dataset.loaderMessages || '';
      const binary = window.atob(encoded);
      const bytes = Uint8Array.from(binary, (char) => char.charCodeAt(0));
      const parsed = JSON.parse(new TextDecoder().decode(bytes));
      const messages = Array.isArray(parsed) ? parsed.filter(Boolean) : [];
      return messages.length ? messages : ['Loading Camping Clepardia'];
    } catch {
      return ['Loading Camping Clepardia'];
    }
  })();
  if (loaderStatus) {
    loaderStatus.textContent = loaderMessages[0] || '';
  }
  let lenis;
  let rafId = 0;
  let loaderMessageIndex = 0;
  let loaderProgress = 0;
  let loaderProgressTimer = 0;
  let loaderLoaded = false;
  const loaderStartedAt = performance.now();
  const motionWindow = window;

  const setLoaderProgress = (value) => {
    loaderProgress = Math.max(0, Math.min(100, value));
    const safeValue = Math.round(loaderProgress);
    const externalProgress = motionWindow.__ccMotionSetLoaderProgress;
    if (externalProgress) {
      externalProgress(safeValue);
      return;
    }
    if (loader instanceof HTMLElement) {
      loader.style.setProperty('--loader-progress', `${safeValue}%`);
      loader.dataset.loaderProgress = String(safeValue);
    }
    if (loaderProgressValue) {
      loaderProgressValue.textContent = `${safeValue}%`;
    }
  };

  const startLoaderProgress = () => {
    if (!loader || reduceMotion.matches) {
      setLoaderProgress(100);
      return;
    }

    setLoaderProgress(0);
    loaderProgressTimer = window.setInterval(() => {
      const target = loaderLoaded ? 100 : 92;
      const step = loaderProgress < 38 ? 9 : loaderProgress < 65 ? 5 : loaderProgress < 92 ? 1.8 : 0.9;
      setLoaderProgress(Math.min(target, loaderProgress + step));

      if (loaderLoaded && loaderProgress >= 100) {
        window.clearInterval(loaderProgressTimer);
      }
    }, 86);
  };

  const loaderMessageTimer = window.setInterval(() => {
    if (!loaderStatus || reduceMotion.matches) return;
    loaderMessageIndex = (loaderMessageIndex + 1) % loaderMessages.length;
    loaderStatus.classList.add('is-swapping');
    window.setTimeout(() => {
      loaderStatus.textContent = loaderMessages[loaderMessageIndex];
      loaderStatus.classList.remove('is-swapping');
    }, 130);
  }, 820);

  const finishLoading = () => {
    window.clearInterval(loaderMessageTimer);
    window.clearInterval(loaderProgressTimer);
    setLoaderProgress(100);
    const safetyFinish = motionWindow.__ccMotionFinishLoading;
    if (safetyFinish) {
      safetyFinish();
      return;
    }
    root.classList.add('motion-loaded');
    root.classList.remove('motion-loading');
    if (loader instanceof HTMLElement) {
      loader.classList.add('is-hidden');
      loader.setAttribute('aria-hidden', 'true');
      loader.setAttribute('inert', '');
      loader.removeAttribute('role');
      loader.removeAttribute('aria-live');
      loaderStatus?.removeAttribute('aria-live');
      window.setTimeout(() => {
        loader.hidden = true;
      }, 620);
    }
  };

  const completeLoader = () => {
    loaderLoaded = true;
    const minimumDuration = reduceMotion.matches ? 160 : 1320;
    const elapsed = performance.now() - loaderStartedAt;
    const wait = Math.max(reduceMotion.matches ? 0 : 240, minimumDuration - elapsed);
    window.setTimeout(finishLoading, wait);
  };

  const revealElements = () => {
    const nodes = Array.from(document.querySelectorAll('.reveal-section, .premium-card, .photo-frame, .section-title, .section-copy'));

    nodes.forEach((node, index) => {
      if (!(node instanceof HTMLElement)) return;
      node.classList.add('motion-reveal');
      node.style.setProperty('--reveal-delay', `${Math.min(index % 7, 6) * 55}ms`);
    });

    if (reduceMotion.matches || !('IntersectionObserver' in window)) {
      nodes.forEach((node) => node.classList.add('is-visible'));
      return;
    }

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        });
      },
      { rootMargin: '0px 0px -10% 0px', threshold: 0.12 },
    );

    nodes.forEach((node) => observer.observe(node));
  };

  const animate = (time) => {
    if (!lenis) return;
    lenis.raf(time);
    rafId = requestAnimationFrame(animate);
  };

  const startLenis = () => {
    if (lenis || reduceMotion.matches || window.innerWidth < 768) return;
    lenis = new Lenis({
      duration: 1.08,
      easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
      smoothWheel: true,
      wheelMultiplier: 0.85,
      touchMultiplier: 1,
      anchors: false,
    });
    rafId = requestAnimationFrame(animate);
  };

  const stopLenis = () => {
    if (!lenis) return;
    cancelAnimationFrame(rafId);
    lenis.destroy();
    lenis = undefined;
  };

  const syncLenis = () => {
    if (reduceMotion.matches || window.innerWidth < 768) {
      stopLenis();
      return;
    }
    startLenis();
  };

  motionWindow.__ccScrollToTop = () => {
    if (lenis) {
      lenis.scrollTo(0, { duration: reduceMotion.matches ? 0 : 0.9 });
      return;
    }

    window.scrollTo({ top: 0, behavior: reduceMotion.matches ? 'auto' : 'smooth' });
  };

  document.addEventListener('click', (event) => {
    if (event.defaultPrevented) return;
    const targetElement = event.target instanceof Element ? event.target : null;
    const anchor = targetElement?.closest?.('a[href^="#"]');
    if (!anchor) return;

    const href = anchor.getAttribute('href');
    if (!href || href === '#') return;

    const target = document.querySelector(href);
    if (!(target instanceof HTMLElement)) return;

    event.preventDefault();
    const offset = window.innerWidth >= 1080 ? -78 : -84;

    if (lenis) {
      lenis.scrollTo(target, { offset });
    } else {
      const top = target.getBoundingClientRect().top + window.scrollY + offset;
      window.scrollTo({ top, behavior: reduceMotion.matches ? 'auto' : 'smooth' });
    }

    history.pushState(null, '', href);
  });

  startLoaderProgress();
  revealElements();
  syncLenis();
  reduceMotion.addEventListener('change', syncLenis);
  window.addEventListener('resize', syncLenis, { passive: true });

  if (document.readyState === 'complete') {
    window.setTimeout(completeLoader, reduceMotion.matches ? 0 : 160);
  } else {
    window.addEventListener('load', () => window.setTimeout(completeLoader, reduceMotion.matches ? 0 : 160), { once: true });
  }
</script>

<style is:global>
.page-loader {
  --loader-progress: 0%;
  position: fixed;
  inset: 0;
  z-index: 9999;
  display: grid;
  grid-template-rows: 1fr auto auto 1fr;
  justify-items: center;
  align-items: center;
  min-height: 100dvh;
  padding: clamp(24px, 4vw, 48px);
  overflow: hidden;
  color: #F4FBF6;
  background:
    radial-gradient(circle at 50% 44%, rgba(60, 179, 113, .30), transparent 24%),
    radial-gradient(circle at 72% 28%, rgba(242, 192, 120, .20), transparent 34%),
    radial-gradient(circle at 18% 72%, rgba(60, 179, 113, .16), transparent 40%),
    linear-gradient(135deg, #0B1A14 0%, #102117 48%, #163222 100%);
  opacity: 0;
  visibility: hidden;
  pointer-events: none;
  transform: scale(1);
  filter: blur(0);
  transition:
    opacity .58s cubic-bezier(.22, 1, .36, 1),
    visibility .58s cubic-bezier(.22, 1, .36, 1),
    transform .58s cubic-bezier(.22, 1, .36, 1),
    filter .58s cubic-bezier(.22, 1, .36, 1);
}

.page-loader[hidden] {
  display: none !important;
}

.page-loader::before,
.page-loader::after {
  content: '';
  position: absolute;
  inset: 0;
  pointer-events: none;
}

.page-loader::before {
  opacity: .32;
  background:
    linear-gradient(115deg, transparent 0 18%, rgba(255,255,255,.035) 18.2% 18.7%, transparent 19% 100%),
    repeating-radial-gradient(circle at 50% 50%, rgba(255,255,255,.04) 0 1px, transparent 1px 6px);
  mix-blend-mode: screen;
}

.page-loader::after {
  background:
    radial-gradient(ellipse at center, transparent 0 46%, rgba(1, 8, 5, .18) 68%, rgba(1, 8, 5, .44) 100%),
    linear-gradient(180deg, rgba(7,20,15,.24), transparent 42%, rgba(7,20,15,.54));
}

.motion-ready.motion-loading body {
  overflow: hidden;
}

.motion-ready.motion-loading .page-loader {
  opacity: 1;
  visibility: visible;
  pointer-events: auto;
}

.motion-ready.motion-loaded .page-loader,
.page-loader.is-hidden {
  opacity: 0;
  visibility: hidden;
  pointer-events: none;
  transform: scale(1.035);
  filter: blur(10px);
}

.page-loader__ambient,
.page-loader__particles {
  position: absolute;
  inset: 0;
  overflow: hidden;
  pointer-events: none;
}

.page-loader__light {
  position: absolute;
  display: block;
  border-radius: 999px;
  filter: blur(20px);
  opacity: .82;
}

.page-loader__light--green {
  width: min(56vw, 640px);
  height: min(56vw, 640px);
  left: 50%;
  top: 48%;
  transform: translate(-50%, -50%);
  background: radial-gradient(circle, rgba(60,179,113,.30), rgba(60,179,113,.08) 42%, transparent 70%);
  animation: loaderAmbient 4.8s ease-in-out infinite;
}

.page-loader__light--warm {
  width: min(38vw, 460px);
  height: min(38vw, 460px);
  right: 8%;
  top: 18%;
  background: radial-gradient(circle, rgba(242,192,120,.22), rgba(242,192,120,.07) 48%, transparent 70%);
  animation: loaderAmbient 5.8s ease-in-out infinite reverse;
}

.page-loader__horizon {
  position: absolute;
  left: 50%;
  bottom: 16%;
  width: min(720px, 82vw);
  height: 120px;
  border-radius: 50%;
  transform: translateX(-50%);
  background: radial-gradient(ellipse at center, rgba(242,192,120,.12), rgba(60,179,113,.08) 42%, transparent 70%);
  filter: blur(18px);
  opacity: .78;
  animation: loaderHorizon 4.5s ease-in-out infinite;
}

.page-loader__stage {
  position: relative;
  z-index: 2;
  grid-row: 2;
  width: clamp(220px, 24vw, 300px);
  height: clamp(220px, 24vw, 300px);
  display: grid;
  place-items: center;
  animation: loaderStageIn .72s cubic-bezier(.22, 1, .36, 1) both;
}

.page-loader__orbit,
.page-loader__radar,
.page-loader__sweep,
.page-loader__glow {
  position: absolute;
  border-radius: 999px;
  pointer-events: none;
}

.page-loader__orbit--outer {
  inset: 0;
  border: 1px solid rgba(244,251,246,.14);
  background:
    conic-gradient(from 0deg, transparent 0 10%, rgba(60,179,113,.62) 18%, rgba(242,192,120,.52) 27%, transparent 38% 100%);
  box-shadow: 0 0 54px rgba(60,179,113,.20), inset 0 0 46px rgba(60,179,113,.10);
  -webkit-mask: radial-gradient(circle, transparent 61%, #000 62%);
  mask: radial-gradient(circle, transparent 61%, #000 62%);
  animation: loaderOrbit 6.2s linear infinite;
}

.page-loader__orbit--inner {
  inset: 24px;
  border: 1px solid rgba(143,224,180,.18);
  background:
    conic-gradient(from 180deg, transparent 0 48%, rgba(143,224,180,.54) 58%, rgba(242,192,120,.36) 66%, transparent 76% 100%);
  -webkit-mask: radial-gradient(circle, transparent 57%, #000 58%);
  mask: radial-gradient(circle, transparent 57%, #000 58%);
  animation: loaderInnerOrbit 8.8s linear infinite;
}

.page-loader__radar {
  inset: 34px;
  border: 1px solid rgba(143,224,180,.22);
  box-shadow: inset 0 0 0 1px rgba(242,192,120,.08), 0 0 38px rgba(60,179,113,.12);
}

.page-loader__radar::before,
.page-loader__radar::after {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: inherit;
  border: 1px solid rgba(143,224,180,.28);
  animation: loaderRadar 2.15s ease-out infinite;
}

.page-loader__radar::after {
  animation-delay: .7s;
}

.page-loader__sweep {
  inset: 16px;
  background: conic-gradient(from 0deg, rgba(60,179,113,.20), transparent 18%, transparent 100%);
  opacity: .72;
  -webkit-mask: radial-gradient(circle, transparent 0 36%, #000 37% 63%, transparent 64%);
  mask: radial-gradient(circle, transparent 0 36%, #000 37% 63%, transparent 64%);
  animation: loaderOrbit 3.8s linear infinite;
}

.page-loader__glow {
  inset: 46px;
  background:
    radial-gradient(circle, rgba(60,179,113,.34), rgba(242,192,120,.13) 48%, transparent 72%);
  filter: blur(30px);
  animation: loaderGlow 2.35s ease-in-out infinite;
}

.page-loader__core {
  position: relative;
  z-index: 2;
  width: clamp(136px, 13.6vw, 164px);
  height: clamp(136px, 13.6vw, 164px);
  display: grid;
  place-items: center;
  border-radius: 999px;
  background:
    radial-gradient(circle at 50% 34%, rgba(255,255,255,.12), transparent 40%),
    linear-gradient(145deg, rgba(255,255,255,.10), rgba(255,255,255,.045));
  border: 1px solid rgba(255,255,255,.16);
  box-shadow:
    0 28px 90px rgba(0,0,0,.30),
    0 0 68px rgba(60,179,113,.30),
    inset 0 1px 0 rgba(255,255,255,.16);
  animation: loaderBreath 2.25s ease-in-out infinite;
}

.page-loader__logo {
  position: relative;
  z-index: 2;
  display: block;
  max-width: 82%;
  width: auto;
  height: clamp(112px, 10.8vw, 136px);
  object-fit: contain;
  image-rendering: auto;
  filter: drop-shadow(0 24px 50px rgba(60,179,113,.40)) drop-shadow(0 6px 20px rgba(242,192,120,.20));
}

.page-loader__logo-fallback {
  position: absolute;
  z-index: 1;
  display: none;
  width: 82px;
  height: 82px;
  place-items: center;
  border-radius: 999px;
  color: #F4FBF6;
  font-size: 1.55rem;
  font-weight: 950;
  letter-spacing: .04em;
  background: linear-gradient(135deg, rgba(60,179,113,.95), rgba(47,157,99,.82));
  box-shadow: 0 0 36px rgba(60,179,113,.34);
}

.page-loader__core.has-fallback .page-loader__logo-fallback {
  display: grid;
}

.page-loader__copy {
  position: relative;
  z-index: 2;
  grid-row: 3;
  width: min(340px, calc(100vw - 48px));
  display: grid;
  gap: 16px;
  justify-items: center;
  margin-top: 8px;
}

.page-loader__status {
  min-height: 24px;
  max-width: min(420px, calc(100vw - 48px));
  margin: 0;
  color: rgba(244,251,246,.88);
  font-size: .76rem;
  font-weight: 900;
  letter-spacing: .15em;
  line-height: 1.45;
  text-align: center;
  text-transform: uppercase;
  text-wrap: balance;
  transition: opacity .16s ease, transform .16s ease;
}

.page-loader__status.is-swapping {
  opacity: 0;
  transform: translateY(5px);
}

.page-loader__progress {
  width: min(320px, calc(100vw - 72px));
  display: grid;
  grid-template-columns: 1fr auto;
  align-items: center;
  gap: 12px;
}

.page-loader__progress-track {
  position: relative;
  height: 5px;
  overflow: hidden;
  border-radius: 999px;
  border: 1px solid rgba(255,255,255,.10);
  background: rgba(255,255,255,.12);
  box-shadow: inset 0 1px 0 rgba(255,255,255,.10), 0 0 26px rgba(60,179,113,.10);
}

.page-loader__progress-track::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,.36), transparent);
  opacity: .42;
  transform: translateX(-100%);
  animation: loaderProgressSheen 1.3s ease-in-out infinite;
}

.page-loader__progress-bar {
  position: absolute;
  inset: 0 auto 0 0;
  width: var(--loader-progress);
  border-radius: inherit;
  background: linear-gradient(90deg, #3CB371, #8FE0B4 58%, #F2C078);
  box-shadow: 0 0 28px rgba(60,179,113,.48), 0 0 10px rgba(242,192,120,.20);
  transition: width .24s ease;
}

.page-loader__progress-value {
  min-width: 40px;
  color: rgba(244,251,246,.76);
  font-size: .72rem;
  font-weight: 900;
  letter-spacing: .10em;
  text-align: right;
}

.page-loader__particles span {
  position: absolute;
  width: 5px;
  height: 5px;
  border-radius: 999px;
  background: rgba(242,192,120,.72);
  box-shadow: 0 0 18px rgba(242,192,120,.42);
  opacity: .42;
  animation: loaderParticle 5.2s ease-in-out infinite;
}

.page-loader__particles span:nth-child(1) { left: 17%; top: 28%; }
.page-loader__particles span:nth-child(2) { right: 19%; top: 33%; animation-delay: -1.1s; background: rgba(143,224,180,.76); }
.page-loader__particles span:nth-child(3) { left: 29%; bottom: 23%; animation-delay: -2.2s; }
.page-loader__particles span:nth-child(4) { right: 31%; bottom: 21%; animation-delay: -3.1s; background: rgba(143,224,180,.76); }
.page-loader__particles span:nth-child(5) { left: 47%; top: 17%; width: 3px; height: 3px; animation-delay: -1.8s; }
.page-loader__particles span:nth-child(6) { right: 12%; bottom: 34%; width: 4px; height: 4px; animation-delay: -3.9s; background: rgba(143,224,180,.72); }
.page-loader__particles span:nth-child(7) { left: 12%; bottom: 40%; width: 4px; height: 4px; animation-delay: -4.5s; }

.motion-ready .motion-reveal {
  opacity: 0;
  transform: translateY(28px);
  transition:
    opacity .78s cubic-bezier(.22, 1, .36, 1) var(--reveal-delay, 0ms),
    transform .78s cubic-bezier(.22, 1, .36, 1) var(--reveal-delay, 0ms);
  will-change: opacity, transform;
}

.motion-ready .motion-reveal.is-visible {
  opacity: 1;
