}

@media (prefers-reduced-motion: reduce) {
  .page-loader {
    display: none;
  }

  .motion-ready .motion-reveal,
  .motion-ready .photo-frame.motion-reveal,
  .motion-ready .premium-card.motion-reveal {
    opacity: 1;
    transform: none;
    transition: none;
  }
}
</style>
