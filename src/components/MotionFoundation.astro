---
import { loaderLogo, logoMainPng } from '@/data/assets';
---

<script is:inline>
  (() => {
    const root = document.documentElement;
    const finishLoading = () => {
      root.classList.add('motion-loaded');
      root.classList.remove('motion-loading');
    };

    root.classList.add('motion-ready', 'motion-loading');
    window.__ccMotionFinishLoading = finishLoading;
    window.setTimeout(finishLoading, 1800);
  })();
</script>

<div class="page-loader" aria-hidden="true">
  <div class="page-loader__stage">
    <div class="page-loader__radar"></div>
    <div class="page-loader__glow"></div>
    <img class="page-loader__logo" src={loaderLogo} alt="" width="240" height="240" onerror={`this.onerror=null;this.src='${logoMainPng}'`} />
  </div>
  <p class="page-loader__status" id="pageLoaderStatus">Ładujemy Camping Clepardia</p>
  <div class="page-loader__line"></div>
</div>

<script>
  import Lenis from 'lenis';

  const root = document.documentElement;
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
  const loaderStatus = document.getElementById('pageLoaderStatus');
  const loaderMessages = ['Ładujemy Camping Clepardia', 'Przygotowujemy zieloną bazę', 'Otwieramy bramę campingu'];
  let lenis: Lenis | undefined;
  let rafId = 0;
  let loaderMessageIndex = 0;
  const motionWindow = window as Window & {
    __ccMotionFinishLoading?: () => void;
    __ccScrollToTop?: () => void;
  };

  const loaderMessageTimer = window.setInterval(() => {
    if (!loaderStatus || reduceMotion.matches) return;
    loaderMessageIndex = (loaderMessageIndex + 1) % loaderMessages.length;
    loaderStatus.textContent = loaderMessages[loaderMessageIndex];
  }, 520);

  const finishLoading = () => {
    window.clearInterval(loaderMessageTimer);
    const safetyFinish = motionWindow.__ccMotionFinishLoading;
    if (safetyFinish) {
      safetyFinish();
      return;
    }
    root.classList.add('motion-loaded');
    root.classList.remove('motion-loading');
  };

  const revealElements = () => {
    const nodes = Array.from(document.querySelectorAll('.reveal-section, .premium-card, .photo-frame, .section-title, .section-copy'));

    nodes.forEach((node, index) => {
      if (!(node instanceof HTMLElement)) return;
      node.classList.add('motion-reveal');
      node.style.setProperty('--reveal-delay', `${Math.min(index % 7, 6) * 55}ms`);
    });

    if (reduceMotion.matches || !('IntersectionObserver' in window)) {
      nodes.forEach((node) => node.classList.add('is-visible'));
      return;
    }

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        });
      },
      { rootMargin: '0px 0px -10% 0px', threshold: 0.12 },
    );

    nodes.forEach((node) => observer.observe(node));
  };

  const animate = (time: number) => {
    if (!lenis) return;
    lenis.raf(time);
    rafId = requestAnimationFrame(animate);
  };

  const startLenis = () => {
    if (lenis || reduceMotion.matches || window.innerWidth < 768) return;
    lenis = new Lenis({
      duration: 1.08,
      easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
      smoothWheel: true,
      wheelMultiplier: 0.85,
      touchMultiplier: 1,
      anchors: false,
    });
    rafId = requestAnimationFrame(animate);
  };

  const stopLenis = () => {
    if (!lenis) return;
    cancelAnimationFrame(rafId);
    lenis.destroy();
    lenis = undefined;
  };

  const syncLenis = () => {
    if (reduceMotion.matches || window.innerWidth < 768) {
      stopLenis();
      return;
    }
    startLenis();
  };

  motionWindow.__ccScrollToTop = () => {
    if (lenis) {
      lenis.scrollTo(0, { duration: reduceMotion.matches ? 0 : 0.9 });
      return;
    }

    window.scrollTo({ top: 0, behavior: reduceMotion.matches ? 'auto' : 'smooth' });
  };

  document.addEventListener('click', (event) => {
    const anchor = (event.target as Element | null)?.closest?.('a[href^="#"]') as HTMLAnchorElement | null;
    if (!anchor) return;

    const href = anchor.getAttribute('href');
    if (!href || href === '#') return;

    const target = document.querySelector(href);
    if (!(target instanceof HTMLElement)) return;

    event.preventDefault();
    const offset = window.innerWidth >= 1080 ? -78 : -84;

    if (lenis) {
      lenis.scrollTo(target, { offset });
    } else {
      const top = target.getBoundingClientRect().top + window.scrollY + offset;
      window.scrollTo({ top, behavior: reduceMotion.matches ? 'auto' : 'smooth' });
    }

    history.pushState(null, '', href);
  });

  revealElements();
  syncLenis();
  reduceMotion.addEventListener('change', syncLenis);
  window.addEventListener('resize', syncLenis, { passive: true });

  if (document.readyState === 'complete') {
    window.setTimeout(finishLoading, reduceMotion.matches ? 0 : 260);
  } else {
    window.addEventListener('load', () => window.setTimeout(finishLoading, reduceMotion.matches ? 0 : 260), { once: true });
  }
</script>

<style is:global>
.page-loader {
  position: fixed;
  inset: 0;
  z-index: 3000;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 24px;
  background:
    radial-gradient(circle at 50% 42%, rgba(60, 179, 113, .22), transparent 22%),
    radial-gradient(circle at 72% 30%, rgba(231, 157, 84, .18), transparent 34%),
    radial-gradient(circle at 22% 64%, rgba(60, 179, 113, .18), transparent 34%),
    linear-gradient(135deg, #030705 0%, #0b1711 46%, #050806 100%);
  opacity: 0;
  visibility: hidden;
  pointer-events: none;
  transition: opacity .62s ease, visibility .62s ease, transform .62s ease;
}

.motion-ready.motion-loading body {
  overflow: hidden;
}

.motion-ready.motion-loading .page-loader {
  opacity: 1;
  visibility: visible;
  pointer-events: auto;
}

.motion-ready.motion-loaded .page-loader {
  opacity: 0;
  visibility: hidden;
  transform: translateY(-14px) scale(1.015);
}

.page-loader__stage {
  position: relative;
  width: 220px;
  height: 220px;
  display: grid;
  place-items: center;
}

.page-loader__glow {
  position: absolute;
  inset: 35px;
  border-radius: 999px;
  background: rgba(60, 179, 113, .22);
  filter: blur(34px);
  animation: loaderGlow 1.8s ease-in-out infinite;
}

.page-loader__radar {
  position: absolute;
  inset: 12px;
  border-radius: 999px;
  border: 1px solid rgba(143, 224, 180, .24);
}

.page-loader__radar::before,
.page-loader__radar::after {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: inherit;
  border: 1px solid rgba(143, 224, 180, .28);
  animation: loaderRadar 1.9s ease-out infinite;
}

.page-loader__radar::after {
  animation-delay: .55s;
}

.page-loader__logo {
  position: relative;
  z-index: 2;
  display: block;
  width: auto;
  height: 120px;
  object-fit: contain;
  image-rendering: auto;
  filter: drop-shadow(0 26px 56px rgba(60,179,113,.30)) drop-shadow(0 4px 22px rgba(0,0,0,.34));
  animation: loaderBreath 2.2s ease-in-out infinite;
}

.page-loader__status {
  min-height: 22px;
  color: rgba(255,255,255,.78);
  font-size: .78rem;
  font-weight: 900;
  letter-spacing: .16em;
  text-transform: uppercase;
}

.page-loader__line {
  width: min(260px, calc(100vw - 84px));
  height: 2px;
  border-radius: 99px;
  overflow: hidden;
  background: rgba(255,255,255,.14);
}

.page-loader__line::after {
  content: '';
  display: block;
  width: 45%;
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(90deg, transparent, #8fe0b4, transparent);
  animation: loaderLine 1.15s ease-in-out infinite;
}

.motion-ready .motion-reveal {
  opacity: 0;
  transform: translateY(28px);
  transition:
    opacity .78s cubic-bezier(.22, 1, .36, 1) var(--reveal-delay, 0ms),
    transform .78s cubic-bezier(.22, 1, .36, 1) var(--reveal-delay, 0ms);
  will-change: opacity, transform;
}

.motion-ready .motion-reveal.is-visible {
  opacity: 1;
  transform: translateY(0);
}

.motion-ready .photo-frame.motion-reveal,
.motion-ready .premium-card.motion-reveal {
  transform: translateY(34px) scale(.985);
}

.motion-ready .photo-frame.motion-reveal.is-visible,
.motion-ready .premium-card.motion-reveal.is-visible {
  transform: translateY(0) scale(1);
}

.site-section::after {
  content: '';
  position: absolute;
  left: 50%;
  bottom: -1px;
  width: min(1180px, calc(100% - 40px));
  height: 1px;
  transform: translateX(-50%);
  background: linear-gradient(90deg, transparent, rgba(60,179,113,.18), transparent);
  pointer-events: none;
}

@keyframes loaderLine {
  0% { transform: translateX(-120%); }
  100% { transform: translateX(260%); }
}

@keyframes loaderRadar {
  0% { transform: scale(.62); opacity: .78; }
  100% { transform: scale(1.18); opacity: 0; }
}

@keyframes loaderGlow {
  0%, 100% { opacity: .62; transform: scale(.96); }
  50% { opacity: 1; transform: scale(1.06); }
}

@keyframes loaderBreath {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.035); }
}

@media (max-width: 720px) {
  .page-loader__stage {
    width: 176px;
    height: 176px;
  }

  .page-loader__logo {
    height: 88px;
  }

  .page-loader__status {
    max-width: 280px;
    text-align: center;
    line-height: 1.5;
  }
}

@media (prefers-reduced-motion: reduce) {
  .page-loader {
    display: none;
  }

  .motion-ready .motion-reveal,
  .motion-ready .photo-frame.motion-reveal,
  .motion-ready .premium-card.motion-reveal,
  .page-loader__logo,
  .page-loader__glow,
  .page-loader__radar::before,
  .page-loader__radar::after,
  .page-loader__line::after {
    opacity: 1;
    transform: none;
    animation: none;
    transition: none;
  }
}
</style>
