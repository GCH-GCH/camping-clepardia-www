---
import { loaderLogo, logoMainPng } from '@/data/assets';
import { getTranslations } from '@/i18n/config';
import { getPathContext } from '@/utils/localizedLinks';

const pathContext = getPathContext(Astro.url.pathname);
const t = getTranslations(pathContext.languageCode);
const loaderMessages = t.loader.messages;
---

<script is:inline>
  (() => {
    const root = document.documentElement;
    const finishLoading = () => {
      root.classList.add('motion-loaded');
      root.classList.remove('motion-loading');
    };

    root.classList.add('motion-ready', 'motion-loading');
    window.__ccMotionFinishLoading = finishLoading;
    window.setTimeout(finishLoading, 1800);
  })();
</script>

<div class="page-loader" aria-hidden="true" data-loader-messages={JSON.stringify(loaderMessages)}>
  <div class="page-loader__particles" aria-hidden="true">
    <span></span>
    <span></span>
    <span></span>
    <span></span>
  </div>
  <div class="page-loader__stage">
    <div class="page-loader__halo"></div>
    <div class="page-loader__radar"></div>
    <div class="page-loader__glow"></div>
    <img class="page-loader__logo" src={loaderLogo} alt="" width="240" height="240" onerror={`this.onerror=null;this.src='${logoMainPng}'`} />
  </div>
  <p class="page-loader__status" id="pageLoaderStatus">{loaderMessages[0]}</p>
  <div class="page-loader__line"></div>
</div>

<script>
  import Lenis from 'lenis';

  const root = document.documentElement;
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
  const loader = document.querySelector('.page-loader');
  const loaderStatus = document.getElementById('pageLoaderStatus');
  const loaderMessages = (() => {
    try {
      const parsed = JSON.parse(loader?.dataset.loaderMessages ?? '[]');
      return Array.isArray(parsed) && parsed.length ? parsed : ['Loading Camping Clepardia'];
    } catch {
      return ['Loading Camping Clepardia'];
    }
  })();
  let lenis;
  let rafId = 0;
  let loaderMessageIndex = 0;
  const motionWindow = window;

  const loaderMessageTimer = window.setInterval(() => {
    if (!loaderStatus || reduceMotion.matches) return;
    loaderMessageIndex = (loaderMessageIndex + 1) % loaderMessages.length;
    loaderStatus.textContent = loaderMessages[loaderMessageIndex];
  }, 520);

  const finishLoading = () => {
    window.clearInterval(loaderMessageTimer);
    const safetyFinish = motionWindow.__ccMotionFinishLoading;
    if (safetyFinish) {
      safetyFinish();
      return;
    }
    root.classList.add('motion-loaded');
    root.classList.remove('motion-loading');
  };

  const revealElements = () => {
    const nodes = Array.from(document.querySelectorAll('.reveal-section, .premium-card, .photo-frame, .section-title, .section-copy'));

    nodes.forEach((node, index) => {
      if (!(node instanceof HTMLElement)) return;
      node.classList.add('motion-reveal');
      node.style.setProperty('--reveal-delay', `${Math.min(index % 7, 6) * 55}ms`);
    });

    if (reduceMotion.matches || !('IntersectionObserver' in window)) {
      nodes.forEach((node) => node.classList.add('is-visible'));
      return;
    }

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        });
      },
      { rootMargin: '0px 0px -10% 0px', threshold: 0.12 },
    );

    nodes.forEach((node) => observer.observe(node));
  };

  const animate = (time) => {
    if (!lenis) return;
    lenis.raf(time);
    rafId = requestAnimationFrame(animate);
  };

  const startLenis = () => {
    if (lenis || reduceMotion.matches || window.innerWidth < 768) return;
    lenis = new Lenis({
      duration: 1.08,
      easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
      smoothWheel: true,
      wheelMultiplier: 0.85,
      touchMultiplier: 1,
      anchors: false,
    });
    rafId = requestAnimationFrame(animate);
  };

  const stopLenis = () => {
    if (!lenis) return;
    cancelAnimationFrame(rafId);
    lenis.destroy();
    lenis = undefined;
  };

  const syncLenis = () => {
    if (reduceMotion.matches || window.innerWidth < 768) {
      stopLenis();
      return;
    }
    startLenis();
  };

  motionWindow.__ccScrollToTop = () => {
    if (lenis) {
      lenis.scrollTo(0, { duration: reduceMotion.matches ? 0 : 0.9 });
      return;
    }

    window.scrollTo({ top: 0, behavior: reduceMotion.matches ? 'auto' : 'smooth' });
  };

  document.addEventListener('click', (event) => {
    const targetElement = event.target instanceof Element ? event.target : null;
    const anchor = targetElement?.closest?.('a[href^="#"]');
    if (!anchor) return;

    const href = anchor.getAttribute('href');
    if (!href || href === '#') return;

    const target = document.querySelector(href);
    if (!(target instanceof HTMLElement)) return;

    event.preventDefault();
    const offset = window.innerWidth >= 1080 ? -78 : -84;

    if (lenis) {
      lenis.scrollTo(target, { offset });
    } else {
      const top = target.getBoundingClientRect().top + window.scrollY + offset;
      window.scrollTo({ top, behavior: reduceMotion.matches ? 'auto' : 'smooth' });
    }

    history.pushState(null, '', href);
  });

  revealElements();
  syncLenis();
  reduceMotion.addEventListener('change', syncLenis);
  window.addEventListener('resize', syncLenis, { passive: true });

  if (document.readyState === 'complete') {
    window.setTimeout(finishLoading, reduceMotion.matches ? 0 : 260);
  } else {
    window.addEventListener('load', () => window.setTimeout(finishLoading, reduceMotion.matches ? 0 : 260), { once: true });
  }
</script>

<style is:global>
.page-loader {
  position: fixed;
  inset: 0;
  z-index: 9999;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 24px;
  background:
    radial-gradient(circle at 50% 42%, rgba(60, 179, 113, .20), transparent 24%),
    radial-gradient(circle at 72% 30%, rgba(242, 192, 120, .16), transparent 36%),
    radial-gradient(circle at 22% 64%, rgba(60, 179, 113, .12), transparent 36%),
    linear-gradient(135deg, #081510 0%, #0B1A14 48%, #102117 100%);
  opacity: 0;
  visibility: hidden;
  pointer-events: none;
  transition: opacity .62s ease, visibility .62s ease, transform .62s ease;
}

.motion-ready.motion-loading body {
  overflow: hidden;
}

.motion-ready.motion-loading .page-loader {
  opacity: 1;
  visibility: visible;
  pointer-events: auto;
  animation: loaderMaxLife 1.8s ease forwards;
}

.motion-ready.motion-loaded .page-loader {
  opacity: 0;
  visibility: hidden;
  transform: translateY(-14px) scale(1.015);
  animation: none;
}

.page-loader__stage {
  position: relative;
  width: 220px;
  height: 220px;
  display: grid;
  place-items: center;
}

.page-loader__halo {
  position: absolute;
  inset: 7px;
  border-radius: 999px;
  background:
    conic-gradient(from 0deg, transparent, rgba(60,179,113,.12), rgba(242,192,120,.44), rgba(60,179,113,.62), transparent 76%);
  filter: drop-shadow(0 0 24px rgba(60,179,113,.16));
  animation: loaderSpin 5.5s linear infinite;
  -webkit-mask: radial-gradient(circle, transparent 60%, #000 61%);
  mask: radial-gradient(circle, transparent 60%, #000 61%);
}

.page-loader__glow {
  position: absolute;
  inset: 30px;
  border-radius: 999px;
  background:
    radial-gradient(circle, rgba(60, 179, 113, .23), rgba(242,192,120,.10) 46%, transparent 70%);
  filter: blur(30px);
  animation: loaderGlow 1.8s ease-in-out infinite;
}

.page-loader__radar {
  position: absolute;
  inset: 12px;
  border-radius: 999px;
  border: 1px solid rgba(143, 224, 180, .26);
  box-shadow: inset 0 0 0 1px rgba(242,192,120,.08), 0 0 38px rgba(60,179,113,.10);
}

.page-loader__radar::before,
.page-loader__radar::after {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: inherit;
  border: 1px solid rgba(143, 224, 180, .28);
  animation: loaderRadar 1.9s ease-out infinite;
}

.page-loader__radar::after {
  animation-delay: .55s;
}

.page-loader__logo {
  position: relative;
  z-index: 2;
  display: block;
  width: auto;
  height: 120px;
  object-fit: contain;
  image-rendering: auto;
  filter: drop-shadow(0 24px 54px rgba(60,179,113,.30)) drop-shadow(0 6px 20px rgba(242,192,120,.16));
  animation: loaderBreath 2.2s ease-in-out infinite;
}

.page-loader__status {
  min-height: 22px;
  color: rgba(255,255,255,.78);
  font-size: .78rem;
  font-weight: 900;
  letter-spacing: .16em;
  text-transform: uppercase;
}

.page-loader__line {
  width: min(260px, calc(100vw - 84px));
  height: 2px;
  border-radius: 99px;
  overflow: hidden;
  border: 1px solid rgba(255,255,255,.08);
  background: rgba(255,255,255,.12);
  box-shadow: inset 0 1px 0 rgba(255,255,255,.08), 0 0 24px rgba(60,179,113,.08);
}

.page-loader__line::after {
  content: '';
  display: block;
  width: 45%;
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(90deg, transparent, #3CB371 30%, #f2c078 52%, #8fe0b4 72%, transparent);
  animation: loaderLine 1.15s ease-in-out infinite;
}

.page-loader__particles {
  position: absolute;
  inset: 0;
  overflow: hidden;
  pointer-events: none;
}

.page-loader__particles span {
  position: absolute;
  width: 5px;
  height: 5px;
  border-radius: 999px;
  background: rgba(242,192,120,.72);
  box-shadow: 0 0 18px rgba(242,192,120,.38);
  opacity: .48;
  animation: loaderParticle 4.6s ease-in-out infinite;
}

.page-loader__particles span:nth-child(1) { left: 20%; top: 30%; }
.page-loader__particles span:nth-child(2) { right: 23%; top: 36%; animation-delay: -1.1s; background: rgba(143,224,180,.72); }
.page-loader__particles span:nth-child(3) { left: 31%; bottom: 24%; animation-delay: -2.2s; }
.page-loader__particles span:nth-child(4) { right: 32%; bottom: 22%; animation-delay: -3.1s; background: rgba(143,224,180,.72); }

.motion-ready .motion-reveal {
  opacity: 0;
  transform: translateY(28px);
  transition:
    opacity .78s cubic-bezier(.22, 1, .36, 1) var(--reveal-delay, 0ms),
    transform .78s cubic-bezier(.22, 1, .36, 1) var(--reveal-delay, 0ms);
  will-change: opacity, transform;
}

.motion-ready .motion-reveal.is-visible {
  opacity: 1;
  transform: translateY(0);
}

.motion-ready .photo-frame.motion-reveal,
.motion-ready .premium-card.motion-reveal {
  transform: translateY(34px) scale(.985);
}

.motion-ready .photo-frame.motion-reveal.is-visible,
.motion-ready .premium-card.motion-reveal.is-visible {
  transform: translateY(0) scale(1);
}

.site-section::after {
  content: '';
  position: absolute;
  left: 50%;
  bottom: -1px;
  width: min(1180px, calc(100% - 40px));
  height: 1px;
  transform: translateX(-50%);
  background: linear-gradient(90deg, transparent, rgba(60,179,113,.18), transparent);
  pointer-events: none;
}

@keyframes loaderLine {
  0% { transform: translateX(-120%); }
  100% { transform: translateX(260%); }
}

@keyframes loaderMaxLife {
  0%, 72% {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: none;
  }
  100% {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transform: translateY(-14px) scale(1.015);
  }
}

@keyframes loaderRadar {
  0% { transform: scale(.62); opacity: .78; }
  100% { transform: scale(1.18); opacity: 0; }
}

@keyframes loaderGlow {
  0%, 100% { opacity: .62; transform: scale(.96); }
  50% { opacity: 1; transform: scale(1.06); }
}

@keyframes loaderSpin {
  to { transform: rotate(360deg); }
}

@keyframes loaderBreath {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.035); }
}

@keyframes loaderParticle {
  0%, 100% { transform: translate3d(0, 0, 0) scale(.86); opacity: .30; }
  45% { transform: translate3d(10px, -18px, 0) scale(1.18); opacity: .72; }
}

@media (max-width: 720px) {
  .page-loader__stage {
    width: 176px;
    height: 176px;
  }

  .page-loader__logo {
    height: 88px;
  }

  .page-loader__status {
    max-width: 280px;
    text-align: center;
    line-height: 1.5;
  }
}

@media (prefers-reduced-motion: reduce) {
  .page-loader {
    display: none;
  }

  .motion-ready .motion-reveal,
  .motion-ready .photo-frame.motion-reveal,
  .motion-ready .premium-card.motion-reveal,
  .page-loader__logo,
  .page-loader__glow,
  .page-loader__halo,
  .page-loader__particles span,
  .page-loader__radar::before,
  .page-loader__radar::after,
  .page-loader__line::after {
    opacity: 1;
    transform: none;
    animation: none;
    transition: none;
  }
}
</style>
