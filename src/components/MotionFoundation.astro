  background: linear-gradient(135deg, #69dca3, #3CB371 48%, #21784c);
  box-shadow: 0 24px 80px rgba(60, 179, 113, .32), inset 0 1px 0 rgba(255,255,255,.24);
  font-weight: 950;
  letter-spacing: .08em;
}

.page-loader__line {
  width: 138px;
