---
// Camping Clepardia navigation
---

<nav class="navbar" id="navbar">
  <div class="navbar__container">
    <a href="/" class="navbar__brand" aria-label="Camping Clepardia Kraków">
      <span class="brand__icon" aria-hidden="true">
        <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M16 3L5 11V28H27V11L16 3Z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/>
          <path d="M16 3V18" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
          <circle cx="16" cy="23" r="1.8" fill="currentColor"/>
        </svg>
      </span>
      <div class="brand__text">
        <span class="brand__name">Camping Clepardia</span>
        <span class="brand__location">Kraków</span>
      </div>
    </a>

    <div class="navbar__center">
      <ul class="navbar__links">
        <li><a href="#camping" class="navbar__link">Camping</a></li>
        <li><a href="#domki" class="navbar__link">Domki</a></li>
        <li><a href="#cennik" class="navbar__link">Cennik</a></li>
        <li><a href="#dojazd" class="navbar__link">Dojazd</a></li>
        <li><a href="#atrakcje" class="navbar__link">Atrakcje</a></li>
        <li><a href="#kontakt" class="navbar__link">Kontakt</a></li>
      </ul>
    </div>

    <div class="navbar__actions">
      <div class="navbar__language-switch" aria-label="Język">
        <button type="button" class="navbar__lang navbar__lang--active">PL</button>
        <button type="button" class="navbar__lang">EN</button>
        <button type="button" class="navbar__lang">DE</button>
        <button type="button" class="navbar__lang">IT</button>
      </div>
      <button type="button" class="navbar__cta" onclick="window.scrollBy({top: window.innerHeight * 0.75, behavior: 'smooth'})">
        Sprawdź dostępność
      </button>
    </div>

    <button class="navbar__toggle" id="navbarToggle" aria-label="Otwórz menu" type="button">
      <span class="toggle__bar"></span>
      <span class="toggle__bar"></span>
      <span class="toggle__bar"></span>
    </button>
  </div>

  <div class="navbar__mobile-panel" id="navbarMobilePanel" aria-hidden="true">
    <div class="mobile-panel__content">
      <button class="mobile-panel__close" id="navbarClose" aria-label="Zamknij menu" type="button">
        <span></span>
        <span></span>
      </button>
      <ul class="mobile-panel__list">
        <li><a href="#camping" class="mobile-panel__link">Camping</a></li>
        <li><a href="#domki" class="mobile-panel__link">Domki</a></li>
        <li><a href="#cennik" class="mobile-panel__link">Cennik</a></li>
        <li><a href="#dojazd" class="mobile-panel__link">Dojazd</a></li>
        <li><a href="#atrakcje" class="mobile-panel__link">Atrakcje</a></li>
        <li><a href="#kontakt" class="mobile-panel__link">Kontakt</a></li>
      </ul>
      <div class="mobile-panel__footer">
        <div class="mobile-panel__languages">
          <button type="button" class="navbar__lang navbar__lang--active">PL</button>
          <button type="button" class="navbar__lang">EN</button>
          <button type="button" class="navbar__lang">DE</button>
          <button type="button" class="navbar__lang">IT</button>
        </div>
        <button type="button" class="navbar__cta navbar__cta--mobile" onclick="window.scrollBy({top: window.innerHeight * 0.75, behavior: 'smooth'})">
          Sprawdź dostępność
        </button>
      </div>
    </div>
  </div>
</nav>

<script>
  const navbarToggle = document.getElementById('navbarToggle');
  const navbarClose = document.getElementById('navbarClose');
  const mobilePanel = document.getElementById('navbarMobilePanel');
  const mobileLinks = document.querySelectorAll('.mobile-panel__link');
  const body = document.body;
  const navbar = document.getElementById('navbar');

  const openMenu = () => {
    mobilePanel?.classList.add('is-open');
    body.style.overflow = 'hidden';
  };

  const closeMenu = () => {
    mobilePanel?.classList.remove('is-open');
    body.style.overflow = 'auto';
  };

  navbarToggle?.addEventListener('click', openMenu);
  navbarClose?.addEventListener('click', closeMenu);

  mobileLinks.forEach((link) => {
    link.addEventListener('click', closeMenu);
  });

  window.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') {
      closeMenu();
    }
  });

  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) {
      navbar?.classList.add('is-scrolled');
    } else {
      navbar?.classList.remove('is-scrolled');
    }
  });
</script>

<style is:global>
.navbar {
  position: fixed;
  inset: 0 auto auto 0;
  width: 100%;
  height: 84px;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: rgba(8, 10, 12, 0.22);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  transition: background-color 220ms ease, border-color 220ms ease, box-shadow 220ms ease;
}

.navbar.is-scrolled {
  background-color: rgba(7, 10, 14, 0.94);
  border-bottom-color: rgba(255, 255, 255, 0.12);
  box-shadow: 0 24px 58px rgba(0, 0, 0, 0.24);
}

.navbar__container {
  width: min(1140px, 100% - 32px);
  display: grid;
  grid-template-columns: auto 1fr auto;
  align-items: center;
  gap: 28px;
}

.navbar__brand {
  display: flex;
  align-items: center;
  gap: 14px;
  color: rgba(255, 255, 255, 0.96);
  text-decoration: none;
}

.brand__icon {
  display: grid;
  place-items: center;
  width: 42px;
  height: 42px;
  border-radius: 12px;
  background: rgba(255, 255, 255, 0.08);
  color: #ffffff;
}

.brand__icon svg {
  width: 20px;
  height: 20px;
}

.brand__text {
  display: flex;
  flex-direction: column;
  line-height: 1.1;
}

.brand__name {
  font-size: 0.95rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.16em;
}

.brand__location {
  font-size: 0.72rem;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.7);
  letter-spacing: 0.18em;
  text-transform: uppercase;
}

.navbar__center {
  display: none;
}

.navbar__links {
  display: flex;
  justify-content: center;
  gap: 28px;
  padding: 0;
  margin: 0;
  list-style: none;
}

.navbar__link {
  font-size: 0.85rem;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.88);
  text-decoration: none;
  text-transform: uppercase;
  letter-spacing: 0.18em;
  transition: color 180ms ease;
}

.navbar__link:hover,
.navbar__link:focus {
  color: #3cb371;
}

.navbar__actions {
  display: none;
  align-items: center;
  justify-content: flex-end;
  gap: 18px;
}

.navbar__language-switch {
  display: flex;
  gap: 10px;
}

.navbar__lang {
  background: transparent;
  border: 1px solid rgba(255, 255, 255, 0.18);
  color: rgba(255, 255, 255, 0.85);
  border-radius: 999px;
  padding: 10px 12px;
  font-size: 0.72rem;
  font-weight: 700;
  cursor: pointer;
  transition: background-color 180ms ease, border-color 180ms ease, color 180ms ease;
}

.navbar__lang--active {
  background-color: rgba(255, 255, 255, 0.12);
  border-color: rgba(60, 179, 113, 0.4);
  color: #ffffff;
}

.navbar__lang:hover,
.navbar__lang:focus {
  border-color: rgba(60, 179, 113, 0.55);
  color: #ffffff;
}

.navbar__cta {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 182px;
  padding: 14px 20px;
  border-radius: 999px;
  border: 1px solid transparent;
  background: linear-gradient(135deg, #3cb371 0%, #2a7d56 100%);
  color: #ffffff;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.16em;
  cursor: pointer;
  transition: transform 180ms ease, box-shadow 180ms ease;
}

.navbar__cta:hover,
.navbar__cta:focus {
  transform: translateY(-1px);
  box-shadow: 0 18px 40px rgba(60, 179, 113, 0.22);
}

.navbar__toggle {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 46px;
  height: 46px;
  border: 1px solid rgba(255, 255, 255, 0.18);
  border-radius: 14px;
  background: rgba(4, 6, 8, 0.58);
  cursor: pointer;
  transition: transform 180ms ease, background-color 180ms ease;
}

.navbar__toggle:hover,
.navbar__toggle:focus {
  transform: translateY(-1px);
}

.toggle__bar {
  display: block;
  width: 18px;
  height: 2px;
  background: #fff;
  border-radius: 999px;
  transition: background 180ms ease;
}

.navbar__toggle span + span {
  margin-top: 5px;
}

.navbar__mobile-panel {
  position: fixed;
  inset: 0;
  z-index: 999;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  background: rgba(6, 8, 10, 0.92);
  opacity: 0;
  visibility: hidden;
  transform: translateY(100%);
  transition: transform 260ms ease, opacity 260ms ease, visibility 260ms ease;
}

.navbar__mobile-panel.is-open {
  opacity: 1;
  visibility: visible;
  transform: translateY(0);
}

.mobile-panel__content {
  width: 100%;
  max-width: 540px;
  background: rgba(12, 14, 18, 0.96);
  border-top-left-radius: 28px;
  border-top-right-radius: 28px;
  padding: 28px 24px 32px;
  box-shadow: 0 -18px 80px rgba(0, 0, 0, 0.35);
}

.mobile-panel__close {
  position: absolute;
  top: 18px;
  right: 18px;
  width: 38px;
  height: 38px;
  border: none;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 50%;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
}

.mobile-panel__close span {
  position: absolute;
  width: 18px;
  height: 2px;
  background: #fff;
}

.mobile-panel__close span:first-child {
  transform: rotate(45deg);
}

.mobile-panel__close span:last-child {
  transform: rotate(-45deg);
}

.mobile-panel__list {
  display: grid;
  gap: 20px;
  margin: 0;
  padding: 80px 0 0;
  list-style: none;
}

.mobile-panel__link {
  display: block;
  font-size: 1.1rem;
  font-weight: 700;
  color: #ffffff;
  text-decoration: none;
  text-transform: uppercase;
  letter-spacing: 0.14em;
  padding: 12px 0;
}

.mobile-panel__link:hover,
.mobile-panel__link:focus {
  color: #3cb371;
}

.mobile-panel__footer {
  margin-top: 32px;
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.mobile-panel__languages {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 12px;
}

.navbar__cta--mobile {
  width: 100%;
  padding: 16px 0;
}

@media (min-width: 1024px) {
  .navbar__toggle,
  .navbar__mobile-panel {
    display: none;
  }

  .navbar__center,
  .navbar__actions {
    display: flex;
  }
}

@media (max-width: 1023px) {
  .navbar__center,
  .navbar__actions {
    display: none;
  }
}
