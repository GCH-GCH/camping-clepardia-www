---
import { logoMain, logoMainPng } from '../data/assets';

const links = [
  ['#camping', 'Camping'],
  ['#domki', 'Domki'],
  ['#cennik', 'Cennik'],
  ['#dojazd', 'Dojazd'],
  ['#atrakcje', 'Atrakcje'],
  ['#kontakt', 'Kontakt'],
];
---

<nav class="navbar" id="navbar">
  <div class="navbar__container">
    <a href="/" class="navbar__brand" aria-label="Camping Clepardia Kraków">
      <img class="navbar__logo navbar__logo--desktop" src={logoMain} alt="Camping Clepardia" width="180" height="48" onerror={`this.onerror=null;this.src='${logoMainPng}'`} />
      <img class="navbar__logo navbar__logo--mobile" src={logoMain} alt="Camping Clepardia" width="158" height="42" onerror={`this.onerror=null;this.src='${logoMainPng}'`} />
    </a>

    <ul class="navbar__menu">
      {links.map(([href, label]) => <li><a href={href} class="navbar__link">{label}</a></li>)}
    </ul>

    <div class="navbar__right">
      <div class="navbar__languages" aria-label="Wybór języka">
        {['PL', 'EN', 'DE', 'IT'].map((lang) => <button type="button" class:list={['navbar__lang', lang === 'PL' && 'navbar__lang--active']}>{lang}</button>)}
      </div>
      <a href="#rezerwacja" class="navbar__cta">Sprawdź dostępność</a>
    </div>

    <button class="navbar__toggle" id="navbarToggle" aria-label="Otwórz menu" type="button">
      <span></span><span></span><span></span>
    </button>
  </div>

  <div class="navbar__mobile-menu" id="navbarMobileMenu" aria-hidden="true">
    <div class="mobile-menu__content">
      <button class="mobile-menu__close" id="navbarClose" aria-label="Zamknij menu" type="button"><span></span><span></span></button>
      <div class="mobile-menu__brand">
        <img src={logoMain} alt="Camping Clepardia" width="178" height="42" onerror={`this.onerror=null;this.src='${logoMainPng}'`} />
      </div>
      <ul class="mobile-menu__list">
        {links.map(([href, label]) => <li><a href={href} class="mobile-menu__link">{label}</a></li>)}
      </ul>
      <div class="mobile-menu__footer">
        <div class="mobile-menu__languages">{['PL', 'EN', 'DE', 'IT'].map((lang) => <button type="button" class:list={['navbar__lang', lang === 'PL' && 'navbar__lang--active']}>{lang}</button>)}</div>
        <a href="#rezerwacja" class="navbar__cta navbar__cta--mobile">Sprawdź dostępność</a>
      </div>
    </div>
  </div>
</nav>

<script>
  const navbar = document.getElementById('navbar');
  const toggle = document.getElementById('navbarToggle');
  const close = document.getElementById('navbarClose');
  const menu = document.getElementById('navbarMobileMenu');
  const mobileLinks = document.querySelectorAll('.mobile-menu__link, .navbar__cta--mobile');
  const navLinks = document.querySelectorAll('.navbar__link');

  const openMenu = () => {
    menu?.classList.add('is-open');
    menu?.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  };
  const closeMenu = () => {
    menu?.classList.remove('is-open');
    menu?.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  };

  toggle?.addEventListener('click', openMenu);
  close?.addEventListener('click', closeMenu);
  mobileLinks.forEach((link) => link.addEventListener('click', closeMenu));
  window.addEventListener('keydown', (event) => { if (event.key === 'Escape') closeMenu(); });

  const updateNav = () => {
    navbar?.classList.toggle('is-scrolled', window.scrollY > 28);
    let activeId = '';
    document.querySelectorAll('section[id]').forEach((section) => {
      const rect = section.getBoundingClientRect();
      if (rect.top <= 130 && rect.bottom >= 130) activeId = `#${section.id}`;
    });
    navLinks.forEach((link) => link.classList.toggle('is-active', link.getAttribute('href') === activeId));
  };
  updateNav();
  window.addEventListener('scroll', updateNav, { passive: true });
</script>

<style is:global>
.navbar {
  position: fixed;
  inset: 0 0 auto;
  z-index: 1000;
  height: 82px;
  background: rgba(5, 15, 10, .32);
  border-bottom: 1px solid rgba(255,255,255,.07);
  backdrop-filter: blur(16px);
  transition: height .28s ease, background .28s ease, box-shadow .28s ease, border-color .28s ease;
}

.navbar.is-scrolled {
  height: 70px;
  background: rgba(5, 15, 10, .84);
  border-bottom-color: rgba(255,255,255,.12);
  box-shadow: 0 14px 42px rgba(0,0,0,.18);
}

.navbar__container {
  height: 100%;
  max-width: 1440px;
  margin: 0 auto;
  padding: 0 32px;
  display: grid;
  grid-template-columns: auto 1fr auto;
  align-items: center;
  gap: 30px;
}

.navbar__brand {
  display: flex;
  align-items: center;
  color: #fff;
}

.navbar__logo {
  display: block;
  width: auto;
  object-fit: contain;
  image-rendering: auto;
}

.navbar__logo--desktop {
  height: 48px;
}

.navbar__logo--mobile {
  display: none;
  height: 42px;
}

.navbar__menu {
  list-style: none;
  justify-self: center;
  display: none;
  align-items: center;
  gap: 12px;
  margin: 0;
  padding: 0;
}

.navbar__link {
  position: relative;
  display: inline-flex;
  padding: 10px 8px;
  color: rgba(255,255,255,.78);
  font-size: .88rem;
  font-weight: 800;
  letter-spacing: .06em;
}

.navbar__link::after {
  content: '';
  position: absolute;
  left: 8px;
  right: 8px;
  bottom: 4px;
  height: 2px;
  border-radius: 999px;
  background: linear-gradient(90deg, #3CB371, #9ee7bd);
  transform: scaleX(0);
  transform-origin: left;
  transition: transform .28s ease;
}

.navbar__link:hover,
.navbar__link.is-active {
  color: #fff;
}

.navbar__link:hover::after,
.navbar__link.is-active::after {
  transform: scaleX(1);
}

.navbar__right {
  display: none;
  align-items: center;
  gap: 18px;
}

.navbar__languages {
  display: flex;
  gap: 7px;
}

.navbar__lang {
  min-width: 38px;
  min-height: 34px;
  padding: 7px 10px;
  border: 1px solid rgba(255,255,255,.14);
  border-radius: 999px;
  background: rgba(255,255,255,.06);
  color: rgba(255,255,255,.7);
  font-size: .72rem;
  font-weight: 900;
}

.navbar__lang:hover,
.navbar__lang--active {
  border-color: rgba(60,179,113,.55);
  color: #fff;
  background: rgba(60,179,113,.22);
}

.navbar__cta {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 44px;
  padding: 12px 22px;
  border-radius: 999px;
  color: #fff;
  background: linear-gradient(135deg, #67dea2 0%, #3CB371 48%, #24794e 100%);
  box-shadow: 0 14px 34px rgba(60,179,113,.28), inset 0 1px 0 rgba(255,255,255,.22);
  font-size: .82rem;
  font-weight: 900;
  letter-spacing: .08em;
  text-transform: uppercase;
}

.navbar__cta:hover {
  color: #fff;
  transform: translateY(-2px);
  box-shadow: 0 18px 46px rgba(60,179,113,.42);
}

.navbar__toggle {
  justify-self: end;
  width: 46px;
  height: 46px;
  border-radius: 16px;
  border: 1px solid rgba(255,255,255,.12);
  background: rgba(255,255,255,.08);
  display: grid;
  place-content: center;
  gap: 5px;
}

.navbar__toggle span {
  display: block;
  width: 22px;
  height: 2px;
  border-radius: 99px;
  background: #fff;
}

.navbar__mobile-menu {
  position: fixed;
  inset: 0;
  z-index: 999;
  opacity: 0;
  visibility: hidden;
  background: rgba(4, 14, 10, .96);
  backdrop-filter: blur(26px);
  transition: opacity .28s ease, visibility .28s ease;
}

.navbar__mobile-menu.is-open {
  opacity: 1;
  visibility: visible;
}

.mobile-menu__content {
  min-height: 100svh;
  display: flex;
  flex-direction: column;
  padding: 96px 24px 28px;
}

.mobile-menu__brand {
  display: flex;
  justify-content: center;
  margin-bottom: 24px;
}

.mobile-menu__brand img {
  height: 42px;
  width: auto;
  object-fit: contain;
  image-rendering: auto;
  filter: drop-shadow(0 18px 38px rgba(60,179,113,.25));
}

.mobile-menu__close {
  position: absolute;
  top: 24px;
  right: 22px;
  width: 46px;
  height: 46px;
  border-radius: 16px;
  background: rgba(255,255,255,.08);
}

.mobile-menu__close span {
  position: absolute;
  left: 13px;
  top: 22px;
  width: 20px;
  height: 2px;
  background: #fff;
}
.mobile-menu__close span:first-child { transform: rotate(45deg); }
.mobile-menu__close span:last-child { transform: rotate(-45deg); }

.mobile-menu__list {
  display: grid;
  gap: 2px;
  list-style: none;
  margin: 0;
  padding: 0;
}

.mobile-menu__link {
  display: flex;
  padding: 18px 0;
  border-bottom: 1px solid rgba(255,255,255,.09);
  color: #fff;
  font-size: 1.15rem;
  font-weight: 850;
}

.mobile-menu__footer {
  margin-top: auto;
  display: grid;
  gap: 18px;
  padding-top: 28px;
}

.mobile-menu__languages {
  display: flex;
  justify-content: center;
  gap: 8px;
}

.navbar__cta--mobile { width: 100%; }

@media (min-width: 1080px) {
  .navbar__menu,
  .navbar__right { display: flex; }
  .navbar__toggle { display: none; }
}

@media (max-width: 720px) {
  .navbar,
  .navbar.is-scrolled { height: 74px; }
  .navbar__container { padding: 0 18px; }
  .navbar__logo--desktop { display: none; }
  .navbar__logo--mobile { display: block; }
}
</style>
