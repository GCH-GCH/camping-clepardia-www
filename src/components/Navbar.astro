---
// Camping Clepardia Navigation - Hard Reset
---

<nav class="navbar" id="navbar">
  <div class="navbar__container">
    {/* Left: Logo & Location */}
    <div class="navbar__left">
      <a href="/" class="navbar__brand" aria-label="Camping Clepardia Kraków">
        <div class="brand__text">
          <span class="brand__name">Camping Clepardia</span>
          <span class="brand__location">Kraków</span>
        </div>
      </a>
    </div>

    {/* Center: Menu */}
    <div class="navbar__center">
      <ul class="navbar__menu">
        <li><a href="#camping" class="navbar__link">Camping</a></li>
        <li><a href="#domki" class="navbar__link">Domki</a></li>
        <li><a href="#cennik" class="navbar__link">Cennik</a></li>
        <li><a href="#dojazd" class="navbar__link">Dojazd</a></li>
        <li><a href="#atrakcje" class="navbar__link">Atrakcje</a></li>
        <li><a href="#kontakt" class="navbar__link">Kontakt</a></li>
      </ul>
    </div>

    {/* Right: Languages & CTA */}
    <div class="navbar__right">
      <div class="navbar__languages">
        <button type="button" class="navbar__lang navbar__lang--active" data-lang="pl">PL</button>
        <button type="button" class="navbar__lang" data-lang="en">EN</button>
        <button type="button" class="navbar__lang" data-lang="de">DE</button>
        <button type="button" class="navbar__lang" data-lang="it">IT</button>
      </div>
      <button type="button" class="navbar__cta">Sprawdź dostępność</button>
    </div>

    {/* Mobile Toggle */}
    <button class="navbar__toggle" id="navbarToggle" aria-label="Otwórz menu" type="button">
      <span class="toggle__line"></span>
      <span class="toggle__line"></span>
      <span class="toggle__line"></span>
    </button>
  </div>

  {/* Mobile Menu */}
  <div class="navbar__mobile-menu" id="navbarMobileMenu" aria-hidden="true">
    <div class="mobile-menu__content">
      <button class="mobile-menu__close" id="navbarClose" aria-label="Zamknij menu" type="button">
        <span></span>
        <span></span>
      </button>

      <ul class="mobile-menu__list">
        <li><a href="#camping" class="mobile-menu__link">Camping</a></li>
        <li><a href="#domki" class="mobile-menu__link">Domki</a></li>
        <li><a href="#cennik" class="mobile-menu__link">Cennik</a></li>
        <li><a href="#dojazd" class="mobile-menu__link">Dojazd</a></li>
        <li><a href="#atrakcje" class="mobile-menu__link">Atrakcje</a></li>
        <li><a href="#kontakt" class="mobile-menu__link">Kontakt</a></li>
      </ul>

      <div class="mobile-menu__footer">
        <div class="mobile-menu__languages">
          <button type="button" class="navbar__lang navbar__lang--active" data-lang="pl">PL</button>
          <button type="button" class="navbar__lang" data-lang="en">EN</button>
          <button type="button" class="navbar__lang" data-lang="de">DE</button>
          <button type="button" class="navbar__lang" data-lang="it">IT</button>
        </div>
        <button type="button" class="navbar__cta navbar__cta--mobile">Sprawdź dostępność</button>
      </div>
    </div>
  </div>
</nav>

<script>
  const navbar = document.getElementById('navbar');
  const navbarToggle = document.getElementById('navbarToggle');
  const navbarClose = document.getElementById('navbarClose');
  const mobileMenu = document.getElementById('navbarMobileMenu');
  const mobileLinks = document.querySelectorAll('.mobile-menu__link');
  const body = document.body;

  // Mobile menu toggle
  const openMobileMenu = () => {
    mobileMenu?.classList.add('is-open');
    body.style.overflow = 'hidden';
  };

  const closeMobileMenu = () => {
    mobileMenu?.classList.remove('is-open');
    body.style.overflow = 'auto';
  };

  navbarToggle?.addEventListener('click', openMobileMenu);
  navbarClose?.addEventListener('click', closeMobileMenu);

  mobileLinks.forEach((link) => {
    link.addEventListener('click', closeMobileMenu);
  });

  // Close menu on Escape
  window.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeMobileMenu();
  });

  // Scroll effect
  window.addEventListener('scroll', () => {
    if (window.scrollY > 30) {
      navbar?.classList.add('is-scrolled');
    } else {
      navbar?.classList.remove('is-scrolled');
    }
  });

  // CTA button scroll
  document.querySelectorAll('.navbar__cta').forEach((btn) => {
    btn.addEventListener('click', () => {
      closeMobileMenu();
      const heroHeight = window.innerHeight;
      window.scrollBy({ top: heroHeight * 0.75, behavior: 'smooth' });
    });
  });
</script>

<style is:global>
.navbar {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 82px;
  z-index: 1000;
  background: rgba(5, 15, 10, 0.35);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  transition: background-color 300ms ease, backdrop-filter 300ms ease, border-color 300ms ease;
}

.navbar.is-scrolled {
  background: rgba(5, 15, 10, 0.82);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  border-bottom-color: rgba(255, 255, 255, 0.1);
  box-shadow: 0 4px 32px rgba(0, 0, 0, 0.16);
}

.navbar__container {
  display: grid;
  grid-template-columns: auto 1fr auto auto;
  align-items: center;
  gap: 32px;
  height: 100%;
  max-width: 1440px;
  margin: 0 auto;
  padding: 0 32px;
}

/* Left: Brand */
.navbar__left {
  display: flex;
  align-items: center;
}

.navbar__brand {
  display: flex;
  align-items: center;
  text-decoration: none;
  color: #ffffff;
  transition: opacity 200ms ease;
}

.navbar__brand:hover {
  opacity: 0.8;
}

.brand__text {
  display: flex;
  flex-direction: column;
  line-height: 1.1;
}

.brand__name {
  font-size: 0.95rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  color: #ffffff;
}

.brand__location {
  font-size: 0.7rem;
  font-weight: 500;
  letter-spacing: 0.12em;
  color: rgba(255, 255, 255, 0.7);
  text-transform: uppercase;
}

/* Center: Menu */
.navbar__center {
  display: none;
  justify-content: center;
}

.navbar__menu {
  display: flex;
  list-style: none;
  margin: 0;
  padding: 0;
  gap: 2px;
}

.navbar__link {
  display: inline-block;
  padding: 8px 14px;
  font-size: 0.9rem;
  font-weight: 500;
  letter-spacing: 0.05em;
  color: rgba(255, 255, 255, 0.8);
  text-decoration: none;
  border-radius: 6px;
  transition: all 200ms ease;
}

.navbar__link:hover {
  background: rgba(255, 255, 255, 0.1);
  color: #ffffff;
}

/* Right: Languages & CTA */
.navbar__right {
  display: flex;
  align-items: center;
  gap: 18px;
}

.navbar__languages {
  display: none;
  gap: 8px;
}

.navbar__lang {
  padding: 6px 10px;
  font-size: 0.75rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  background: transparent;
  border: 1px solid rgba(255, 255, 255, 0.2);
  color: rgba(255, 255, 255, 0.6);
  border-radius: 4px;
  cursor: pointer;
  transition: all 200ms ease;
}

.navbar__lang:hover {
  border-color: rgba(255, 255, 255, 0.4);
  color: rgba(255, 255, 255, 0.8);
}

.navbar__lang--active {
  background: rgba(255, 255, 255, 0.12);
  border-color: rgba(255, 255, 255, 0.3);
  color: #ffffff;
}

.navbar__cta {
  padding: 10px 20px;
  font-size: 0.85rem;
  font-weight: 700;
  letter-spacing: 0.06em;
  background: linear-gradient(135deg, rgba(60, 179, 113, 0.9) 0%, rgba(44, 123, 88, 0.9) 100%);
  border: none;
  color: #ffffff;
  border-radius: 999px;
  cursor: pointer;
  transition: all 200ms ease;
  white-space: nowrap;
}

.navbar__cta:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(60, 179, 113, 0.3);
}

/* Mobile Toggle */
.navbar__toggle {
  display: none;
  flex-direction: column;
  gap: 5px;
  background: none;
  border: none;
  cursor: pointer;
  padding: 6px;
}

.toggle__line {
  width: 24px;
  height: 2px;
  background: #ffffff;
  border-radius: 2px;
  transition: all 200ms ease;
}

.navbar__toggle.is-open .toggle__line:nth-child(1) {
  transform: rotate(45deg) translate(10px, 10px);
}

.navbar__toggle.is-open .toggle__line:nth-child(2) {
  opacity: 0;
}

.navbar__toggle.is-open .toggle__line:nth-child(3) {
  transform: rotate(-45deg) translate(7px, -7px);
}

/* Mobile Menu */
.navbar__mobile-menu {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(5, 15, 10, 0.95);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  z-index: 999;
  opacity: 0;
  visibility: hidden;
  transition: opacity 300ms ease, visibility 300ms ease;
}

.navbar__mobile-menu.is-open {
  opacity: 1;
  visibility: visible;
}

.mobile-menu__content {
  display: flex;
  flex-direction: column;
  height: 100%;
  padding-top: 82px;
  overflow-y: auto;
}

.mobile-menu__close {
  position: absolute;
  top: 24px;
  right: 20px;
  width: 32px;
  height: 32px;
  background: none;
  border: none;
  cursor: pointer;
  z-index: 1001;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 5px;
}

.mobile-menu__close span {
  width: 20px;
  height: 2px;
  background: #ffffff;
  border-radius: 2px;
  transition: all 200ms ease;
}

.mobile-menu__close span:nth-child(1) {
  transform: rotate(45deg) translate(6px, 6px);
}

.mobile-menu__close span:nth-child(2) {
  transform: rotate(-45deg) translate(6px, -6px);
}

.mobile-menu__list {
  list-style: none;
  margin: 0;
  padding: 24px;
  display: flex;
  flex-direction: column;
  gap: 0;
}

.mobile-menu__link {
  padding: 16px 0;
  font-size: 1.1rem;
  font-weight: 600;
  letter-spacing: 0.02em;
  color: #ffffff;
  text-decoration: none;
  border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  transition: color 200ms ease;
}

.mobile-menu__link:hover {
  color: rgba(60, 179, 113, 0.9);
}

.mobile-menu__footer {
  margin-top: auto;
  padding: 24px;
  display: flex;
  flex-direction: column;
  gap: 16px;
  border-top: 1px solid rgba(255, 255, 255, 0.08);
}

.mobile-menu__languages {
  display: flex;
  gap: 8px;
  justify-content: center;
}

.navbar__cta--mobile {
  width: 100%;
}

@media (min-width: 1024px) {
  .navbar__center {
    display: flex;
  }

  .navbar__right {
    gap: 24px;
  }

  .navbar__languages {
    display: flex;
  }

  .navbar__toggle {
    display: none;
  }

  .navbar__mobile-menu {
    display: none;
  }
}

@media (max-width: 1023px) {
  .navbar__container {
    grid-template-columns: 1fr auto;
    gap: 16px;
    padding: 0 20px;
  }

  .navbar__center {
    display: none;
  }

  .navbar__right {
    display: none;
  }

  .navbar__toggle {
    display: flex;
  }

  .navbar__cta {
    display: none;
  }
}

@media (max-width: 640px) {
  .navbar {
    height: 76px;
  }

  .navbar__container {
    padding: 0 16px;
  }

  .brand__name {
    font-size: 0.85rem;
  }

  .brand__location {
    font-size: 0.65rem;
  }

  .mobile-menu__content {
    padding-top: 76px;
  }

  .mobile-menu__link {
    font-size: 1rem;
    padding: 14px 0;
  }
}
