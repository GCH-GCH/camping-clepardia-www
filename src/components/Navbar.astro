---
// Camping Clepardia Navbar Component
// Professional camping website navigation with Kraków identity
---

<nav class="navbar" id="navbar">
  <div class="container navbar__container">
    <!-- Logo -->
    <div class="navbar__logo">
      <a href="/" class="logo" title="Camping Clepardia Kraków">
        <svg class="logo__icon" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M16 2L4 10V30H28V10L16 2Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
          <path d="M16 2V18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          <circle cx="16" cy="23" r="1.5" fill="currentColor"/>
        </svg>
        <div class="logo__text">
          <span class="logo__brand">Camping Clepardia</span>
          <span class="logo__location">Kraków</span>
        </div>
      </a>
    </div>

    <!-- Desktop Navigation -->
    <div class="navbar__menu navbar__menu--desktop" id="desktopMenu">
      <ul class="navbar__list">
        <li class="navbar__item">
          <a href="#camping" class="navbar__link">Camping</a>
        </li>
        <li class="navbar__item">
          <a href="#domki" class="navbar__link">Domki</a>
        </li>
        <li class="navbar__item">
          <a href="#cennik" class="navbar__link">Cennik</a>
        </li>
        <li class="navbar__item">
          <a href="#dojazd" class="navbar__link">Dojazd</a>
        </li>
        <li class="navbar__item">
          <a href="#atrakcje" class="navbar__link">Atrakcje</a>
        </li>
        <li class="navbar__item">
          <a href="#kontakt" class="navbar__link">Kontakt</a>
        </li>
      </ul>
    </div>

    <!-- Desktop CTA Button -->
    <div class="navbar__actions">
      <button class="navbar__cta" onclick="window.scrollBy({top: window.innerHeight * 0.7, behavior: 'smooth'})">
        <span class="navbar__cta-text">Sprawdź dostępność</span>
      </button>
    </div>

    <!-- Mobile Menu Toggle -->
    <button class="navbar__mobile-toggle" id="mobileMenuToggle" title="Toggle menu">
      <span class="hamburger">
        <span class="hamburger__line"></span>
        <span class="hamburger__line"></span>
        <span class="hamburger__line"></span>
      </span>
    </button>
  </div>

  <!-- Mobile Navigation Menu -->
  <div class="navbar__mobile-menu" id="mobileMenu">
    <ul class="navbar__mobile-list">
      <li class="navbar__mobile-item">
        <a href="#camping" class="navbar__mobile-link">Camping</a>
      </li>
      <li class="navbar__mobile-item">
        <a href="#domki" class="navbar__mobile-link">Domki</a>
      </li>
      <li class="navbar__mobile-item">
        <a href="#cennik" class="navbar__mobile-link">Cennik</a>
      </li>
      <li class="navbar__mobile-item">
        <a href="#dojazd" class="navbar__mobile-link">Dojazd</a>
      </li>
      <li class="navbar__mobile-item">
        <a href="#atrakcje" class="navbar__mobile-link">Atrakcje</a>
      </li>
      <li class="navbar__mobile-item">
        <a href="#kontakt" class="navbar__mobile-link">Kontakt</a>
      </li>
    </ul>
  </div>
</nav>

<script>
  const mobileMenuToggle = document.getElementById('mobileMenuToggle');
  const mobileMenu = document.getElementById('mobileMenu');
  const navbar = document.getElementById('navbar');
  
  if (mobileMenuToggle) {
    mobileMenuToggle.addEventListener('click', () => {
      mobileMenu?.classList.toggle('is-open');
      mobileMenuToggle.classList.toggle('is-open');
      document.body.style.overflow = mobileMenu?.classList.contains('is-open') ? 'hidden' : 'auto';
    });
  }
  
  // Close mobile menu when clicking on a link
  const mobileLinks = document.querySelectorAll('.navbar__mobile-link');
  mobileLinks.forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu?.classList.remove('is-open');
      mobileMenuToggle?.classList.remove('is-open');
      document.body.style.overflow = 'auto';
    });
  });
  
  // Add scroll shadow to navbar
  window.addEventListener('scroll', () => {
    if (window.scrollY > 0) {
      navbar?.classList.add('is-scrolled');
    } else {
      navbar?.classList.remove('is-scrolled');
    }
  });
</script>

<style is:global>
/* ==================== */
/* NAVBAR STYLES */
/* ==================== */
.navbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  width: 100%;
  background-color: rgba(10, 12, 15, 0.16);
  backdrop-filter: blur(6px);
  -webkit-backdrop-filter: blur(6px);
  z-index: 1000;
  transition: all var(--transition-base) var(--ease-smooth);
  border-bottom: 1px solid rgba(255, 255, 255, 0.08);
}

.navbar.is-scrolled {
  background-color: rgba(255, 255, 255, 0.92);
  backdrop-filter: blur(18px);
  -webkit-backdrop-filter: blur(18px);
  border-bottom-color: rgba(60, 179, 113, 0.12);
  box-shadow: 0 18px 45px rgba(0, 0, 0, 0.08);
}

.navbar__container {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 4.5rem;
  gap: var(--space-8);
}

/* Logo */
.navbar__logo {
  flex-shrink: 0;
}

.logo {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  color: rgba(255, 255, 255, 0.96);
  font-size: var(--font-size-body);
  font-weight: var(--font-weight-semibold);
  letter-spacing: var(--letter-spacing-normal);
  transition: color var(--transition-base) var(--ease-smooth),
              transform var(--transition-base) var(--ease-smooth);
}

.logo:hover {
  color: var(--color-primary-dark);
  transform: translateY(-1px);
}

.logo__icon {
  width: 28px;
  height: 28px;
  color: inherit;
  flex-shrink: 0;
}

.logo__text {
  display: flex;
  flex-direction: column;
  line-height: 1.2;
}

.logo__brand {
  font-size: var(--font-size-body);
  font-weight: var(--font-weight-bold);
  letter-spacing: var(--letter-spacing-tight);
  text-transform: uppercase;
}

.logo__location {
  font-size: var(--font-size-body-xs);
  font-weight: var(--font-weight-normal);
  color: var(--color-text-secondary);
  letter-spacing: var(--letter-spacing-wide);
  text-transform: uppercase;
}

@media (max-width: 640px) {
  .logo__text {
    display: none;
  }
}

/* Desktop Menu */
.navbar__menu--desktop {
  display: none;
  flex: 1;
  justify-content: center;
  margin: 0 var(--space-12);
}

@media (min-width: 1024px) {
  .navbar__menu--desktop {
    display: flex;
  }
}

.navbar__list {
  display: flex;
  align-items: center;
  gap: var(--space-12);
  list-style: none;
  margin: 0;
  padding: 0;
}

.navbar__item {
  margin: 0;
  padding: 0;
}

.navbar__link {
  position: relative;
  display: block;
  padding: var(--space-2) 0;
  font-size: var(--font-size-body-sm);
  font-weight: var(--font-weight-medium);
  color: rgba(255, 255, 255, 0.92);
  letter-spacing: var(--letter-spacing-wide);
  text-transform: uppercase;
  transition: color var(--transition-base) var(--ease-smooth);
}

.navbar__link::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  width: 0;
  height: 2px;
  background-color: var(--color-primary);
  transition: width var(--transition-base) var(--ease-smooth);
}

.navbar__link:hover,
.navbar__link:focus {
  color: var(--color-primary);
}

.navbar__link:hover::after,
.navbar__link:focus::after {
  width: 100%;
}

/* Desktop Actions */
.navbar__actions {
  display: none;
  flex-shrink: 0;
}

.navbar__cta {
  padding: var(--space-3) var(--space-6);
  font-size: var(--font-size-body-sm);
  font-weight: var(--font-weight-semibold);
  color: var(--color-white);
  background-color: var(--color-primary);
  border: none;
  border-radius: var(--radius-lg);
  letter-spacing: var(--letter-spacing-wide);
  text-transform: uppercase;
  cursor: pointer;
  transition: all var(--transition-base) var(--ease-smooth);
  box-shadow: var(--shadow-md);
}

.navbar__cta:hover {
  background-color: var(--color-primary-dark);
  transform: translateY(-2px);
  box-shadow: var(--shadow-lg);
}

.navbar__cta:active {
  transform: translateY(0);
}

@media (min-width: 1024px) {
  .navbar__actions {
    display: block;
  }
}

/* Mobile Menu Toggle */
.navbar__mobile-toggle {
  display: block;
  padding: var(--space-2);
  background: none;
  border: none;
  cursor: pointer;
  transition: transform var(--transition-base) var(--ease-smooth);
}

.navbar__mobile-toggle:active {
  transform: scale(0.95);
}

@media (min-width: 1024px) {
  .navbar__mobile-toggle {
    display: none;
  }
}

.hamburger {
  display: flex;
  flex-direction: column;
  gap: var(--space-1);
  width: 24px;
  height: 20px;
}

.hamburger__line {
  width: 100%;
  height: 2px;
  background-color: var(--color-text-primary);
  border-radius: var(--radius-full);
  transition: all var(--transition-base) var(--ease-smooth);
  transform-origin: center;
}

.navbar__mobile-toggle.is-open .hamburger__line:nth-child(1) {
  transform: rotate(45deg) translateY(8px);
}

.navbar__mobile-toggle.is-open .hamburger__line:nth-child(2) {
  opacity: 0;
}

.navbar__mobile-toggle.is-open .hamburger__line:nth-child(3) {
  transform: rotate(-45deg) translateY(-8px);
}

/* Mobile Menu */
.navbar__mobile-menu {
  position: fixed;
  top: 4.5rem;
  left: 0;
  right: 0;
  background-color: var(--color-bg-primary);
  max-height: calc(100vh - 4.5rem);
  overflow-y: auto;
  transform: translateY(-100%);
  transition: transform var(--transition-base) var(--ease-smooth);
  z-index: 999;
  border-bottom: 1px solid var(--color-gray-100);
}

.navbar__mobile-menu.is-open {
  transform: translateY(0);
  box-shadow: var(--shadow-md);
}

.navbar__mobile-list {
  display: flex;
  flex-direction: column;
  list-style: none;
  margin: 0;
  padding: var(--space-4);
  gap: 0;
}

.navbar__mobile-item {
  margin: 0;
  padding: 0;
  border-bottom: 1px solid var(--color-gray-100);
}

.navbar__mobile-item:last-child {
  border-bottom: none;
}

.navbar__mobile-link {
  display: block;
  padding: var(--space-4);
  font-size: var(--font-size-body);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-primary);
  letter-spacing: var(--letter-spacing-wide);
  text-transform: uppercase;
  transition: all var(--transition-base) var(--ease-smooth);
}

.navbar__mobile-link:hover,
.navbar__mobile-link:focus {
  color: var(--color-primary);
  background-color: var(--color-gray-50);
}

/* Body offset for navbar */
body {
  padding-top: 4.5rem;
}

@media (max-width: 1023px) {
  body {
    padding-top: 4.5rem;
  }
}

@media (min-width: 1024px) {
  body {
    padding-top: 4.5rem;
  }
}
</style>
