    campingPeople: 'Personen beim Camping',
    bungalowCount: 'Anzahl der Bungalows',
  },
  it: {
    title: 'Richiesta premium di soggiorno',
    lead: 'Inizia scegliendo Camping, Bungalow o Combinato. Il modulo mostra solo i campi necessari.',
    steps: ['Scegli tipo di soggiorno', 'Date e ospiti', 'Dettagli soggiorno', 'Dati di contatto', 'Consensi e invio'],
    camping: 'Camping',
    campingCopy: 'Camper, tenda, roulotte, van o auto con tenda da tetto.',
    bungalow: 'Bungalow',
    bungalowCopy: 'Bungalow da 2, 3 e 4 persone.',
    combined: 'Combinato',
    combinedCopy: 'Bungalow e piazzola camping in un’unica richiesta, per esempio famiglia in bungalow e camper accanto.',
    selected: 'Selezionato',
    changeChoice: 'Cambia scelta',
    choiceTitle: 'A quale soggiorno si riferisce la richiesta?',
    choiceLead: 'Scegli il tipo di soggiorno e il modulo adatterà i campi.',
    countrySearch: 'Scrivi un paese, es. de, ge, niem',
