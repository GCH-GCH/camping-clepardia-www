---
import { languages } from '@/data/languages';
import { countries } from '@/data/countries';
import { getTranslations, resolveContentLanguage } from '@/i18n/config';
import Icon from '@/components/ui/Icon.astro';

interface Props {
  languageCode?: string;
}

const { languageCode } = Astro.props as Props;
const lang = resolveContentLanguage(languageCode);
const t = getTranslations(lang);
const pricingText = t.pricing;
const apiEndpoint = '/api/reservation-inquiry';
const formText = t.form;
const stayOptions = [
  { id: 'camper', category: 'camping', label: pricingText.stayTypes.camper },
  { id: 'van', category: 'camping', label: pricingText.stayTypes.van },
  { id: 'caravan', category: 'camping', label: pricingText.stayTypes.caravan },
  { id: 'tent-small', category: 'camping', label: pricingText.stayTypes['tent-small'] },
  { id: 'tent-large', category: 'camping', label: pricingText.stayTypes['tent-large'] },
  { id: 'rooftop-tent', category: 'camping', label: pricingText.stayTypes['rooftop-tent'] },
  { id: 'bus', category: 'camping', label: pricingText.stayTypes.bus },
  { id: 'bungalow-2', category: 'bungalow', label: pricingText.stayTypes['bungalow-2'] },
  { id: 'bungalow-3', category: 'bungalow', label: pricingText.stayTypes['bungalow-3'] },
  { id: 'bungalow-4', category: 'bungalow', label: pricingText.stayTypes['bungalow-4'] },
] as const;

