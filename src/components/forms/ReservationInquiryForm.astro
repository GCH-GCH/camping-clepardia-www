const formConfig = {
  copy,
  countries,
  lang,
};
---

<section class="site-section reservation-inquiry reveal-section" data-reservation-inquiry>
  <div class="container">
    <div class="reservation-inquiry__head">
      <span class="section-kicker">{formText.kicker}</span>
      <h2 class="section-title">{copy.title}</h2>
      <p class="section-copy">{copy.lead}</p>
    </div>

    <div class="contact-choice-overlay" data-contact-choice-overlay role="dialog" aria-modal="true" aria-labelledby="contactChoiceTitle" aria-describedby="contactChoiceLead">
      <div class="contact-choice-overlay__ambient" aria-hidden="true"></div>
      <div class="contact-choice-overlay__panel">
        <img src="/brand/logo/clepardia-logo-white.svg" alt="Camping Clepardia" width="190" height="58" loading="eager" decoding="async" />
        <span class="section-kicker">{formText.kicker}</span>
        <h2 id="contactChoiceTitle">{copy.choiceTitle}</h2>
        <p id="contactChoiceLead">{copy.choiceLead}</p>
        <div class="contact-choice-overlay__grid">
          {[
            { value: 'camping', title: copy.camping, text: copy.campingCopy, icon: 'camping' },
            { value: 'bungalow', title: copy.bungalow, text: copy.bungalowCopy, icon: 'bungalow' },
            { value: 'combined', title: copy.combined, text: copy.combinedCopy, icon: 'UsersRound' },
          ].map((choice) => (
            <a href={`?stay=${choice.value}`} class="contact-choice-card" data-contact-choice={choice.value}>
              <span aria-hidden="true"><Icon name={choice.icon} size={26} /></span>
              <strong>{choice.title}</strong>
              <small>{choice.text}</small>
            </a>
          ))}
        </div>
      </div>
    </div>

    <div class="reservation-inquiry__layout">
      <form class="premium-card reservation-inquiry__form" data-reservation-form novalidate>
        <div class="reservation-inquiry__choice-bar">
          <span><strong>{copy.selected}:</strong> <b data-selected-choice>{copy.camping}</b></span>
          <button type="button" data-change-choice>{copy.changeChoice}</button>
        </div>

        <label class="reservation-inquiry__honeypot" aria-hidden="true" tabindex="-1">
          <span>{formText.honeypotLabel}</span>
          <input name="website" type="text" autocomplete="off" tabindex="-1" data-honeypot>
        </label>

        <div class="reservation-inquiry__errors" data-form-errors role="alert" hidden></div>

        <nav class="reservation-inquiry__steps" aria-label={formText.kicker}>
          {copy.steps.map((step, index) => (
            <span><strong>{String(index + 1).padStart(2, '0')}</strong>{step}</span>
          ))}
        </nav>

        <fieldset class="reservation-inquiry__group reservation-inquiry__group--choice reveal-section" data-booking-category-group>
          <legend>{copy.steps[0]}</legend>
          <div class="reservation-inquiry__category-options">
            <label class="reservation-inquiry__category-card">
              <input type="radio" name="bookingCategory" value="camping" checked data-booking-category>
              <span><Icon name="camping" size={24} /></span>
              <strong>{copy.camping}</strong>
              <small>{copy.campingCopy}</small>
            </label>
            <label class="reservation-inquiry__category-card">
              <input type="radio" name="bookingCategory" value="bungalow" data-booking-category>
              <span><Icon name="bungalow" size={24} /></span>
              <strong>{copy.bungalow}</strong>
              <small>{copy.bungalowCopy}</small>
            </label>
            <label class="reservation-inquiry__category-card">
              <input type="radio" name="bookingCategory" value="combined" data-booking-category>
              <span><Icon name="UsersRound" size={24} /></span>
              <strong>{copy.combined}</strong>
              <small>{copy.combinedCopy}</small>
            </label>
          </div>
        </fieldset>

        <fieldset class="reservation-inquiry__group reveal-section">
          <legend>{copy.steps[1]}</legend>
          <div class="reservation-inquiry__fields">
            <label class="reservation-inquiry__field" data-field="arrival">
              <span>{formText.arrival} *</span>
              <input id="arrival" name="arrival" type="date" required data-arrival data-required aria-describedby="arrivalError">
              <small id="arrivalError" data-field-error="arrival"></small>
            </label>

            <label class="reservation-inquiry__field" data-field="departure">
              <span>{formText.departure} *</span>
              <input id="departure" name="departure" type="date" required data-departure data-required aria-describedby="departureError">
              <small id="departureError" data-field-error="departure"></small>
            </label>
          </div>
          <p class="reservation-inquiry__nights">{formText.nights}: <strong data-nights-label>{formText.completeDates}</strong></p>

          <div class="reservation-inquiry__counters" data-common-counters>
            {[
              ['adults', formText.adults, '2'],
              ['children', formText.children, '0'],
              ['toddlers', formText.toddlers, '0'],
            ].map(([name, label, value]) => (
              <div class="reservation-counter">
                <label for={name}>{label}</label>
                <div>
                  <button type="button" data-counter={name} data-delta="-1" aria-label={`${pricingText.decrement} ${label}`}>-</button>
                  <input id={name} name={name} type="number" min="0" value={value} inputmode="numeric" data-counter-input={name}>
                  <button type="button" data-counter={name} data-delta="1" aria-label={`${pricingText.increment} ${label}`}>+</button>
                </div>
              </div>
            ))}
          </div>
        </fieldset>

        <fieldset class="reservation-inquiry__group reveal-section" data-stay-group>
          <legend>{copy.steps[2]}</legend>
          <div class="reservation-inquiry__options" data-standard-stay-options>
            {stayOptions.map((option, index) => (
              <label class="reservation-inquiry__option" data-stay-option-category={option.category}>
                <input type="radio" name="stayType" value={option.id} required checked={index === 0} data-category={option.category} data-label={option.label} aria-describedby="stayTypeError">
                <span>{option.label}</span>
              </label>
            ))}
          </div>
          <div class="reservation-inquiry__combined-fields" data-combined-fields hidden>
            <p>{copy.combinedInfo}</p>
            <div class="reservation-inquiry__combined-section">
              <h3>{copy.combinedBungalowSection}</h3>
              <div class="reservation-inquiry__options reservation-inquiry__options--compact">
                {stayOptions.filter((option) => option.category === 'bungalow').map((option, index) => (
                  <label class="reservation-inquiry__option">
                    <input type="radio" name="combinedBungalowType" value={option.id} checked={index === 0} data-combined-field-input data-label={option.label}>
                    <span>{option.label}</span>
                  </label>
                ))}
              </div>
              <div class="reservation-inquiry__fields">
                <label class="reservation-inquiry__field">
                  <span>{copy.bungalowPeople}</span>
                  <input type="number" name="combinedBungalowPeople" min="0" value="2" inputmode="numeric" data-combined-field-input>
                </label>
                <label class="reservation-inquiry__field">
                  <span>{copy.bungalowCount}</span>
                  <input type="number" name="combinedBungalowCount" min="1" value="1" inputmode="numeric" data-combined-field-input>
                </label>
              </div>
            </div>
            <div class="reservation-inquiry__combined-section">
              <h3>{copy.combinedCampingSection}</h3>
              <div class="reservation-inquiry__options reservation-inquiry__options--compact">
                {stayOptions.filter((option) => option.category === 'camping').map((option, index) => (
                  <label class="reservation-inquiry__option">
                    <input type="radio" name="combinedCampingType" value={option.id} checked={index === 0} data-combined-field-input data-label={option.label}>
                    <span>{option.label}</span>
                  </label>
                ))}
              </div>
              <label class="reservation-inquiry__field">
                <span>{copy.campingPeople}</span>
                <input type="number" name="combinedCampingPeople" min="0" value="2" inputmode="numeric" data-combined-field-input>
              </label>
            </div>
          </div>
          <small class="reservation-inquiry__field-error" id="stayTypeError" data-field-error="stayType"></small>

          <div class="reservation-inquiry__variant-info" data-variant-info="camping">{copy.campingInfo}</div>
          <div class="reservation-inquiry__variant-info" data-variant-info="bungalow" hidden>{copy.bungalowInfo}</div>
          <div class="reservation-inquiry__variant-info" data-variant-info="combined" hidden>{copy.combinedInfo}</div>

          <div class="reservation-inquiry__addons">
            <label class="reservation-inquiry__addon" data-addon-id="electricity">
              <input type="checkbox" name="addons" value="electricity" data-label={pricingText.addons.electricity}>
              <span><Icon name="electricity" size={17} />{pricingText.addons.electricity}</span>
            </label>
            <label class="reservation-inquiry__addon" data-addon-id="dog">
              <input type="checkbox" name="addons" value="dog" data-label={pricingText.addons.dog}>
              <span><Icon name="dog" size={17} />{pricingText.addons.dog}</span>
            </label>
          </div>

          <label class="reservation-inquiry__consent reservation-inquiry__consent--soft" data-field="specialNeeds">
            <input id="specialNeeds" name="specialNeeds" type="checkbox" data-special-needs>
            <span>{copy.specialNeeds}</span>
          </label>

          <label class="reservation-inquiry__field reservation-inquiry__field--textarea reservation-inquiry__special-details" data-special-needs-details hidden>
            <span>{copy.specialNeedsDetails}</span>
            <textarea id="specialNeedsDetails" name="specialNeedsDetails" rows="3" placeholder={copy.specialNeedsDetails}></textarea>
          </label>
        </fieldset>

        <fieldset class="reservation-inquiry__group reveal-section">
          <legend>{copy.steps[3]}</legend>
          <div class="reservation-inquiry__fields">
            <label class="reservation-inquiry__field" data-field="fullName">
              <span>{formText.fullName} *</span>
              <input id="fullName" name="fullName" type="text" autocomplete="name" required data-required aria-describedby="fullNameError">
              <small id="fullNameError" data-field-error="fullName"></small>
            </label>

            <label class="reservation-inquiry__field" data-field="email">
              <span>{formText.email} *</span>
              <input id="email" name="email" type="email" autocomplete="email" required data-required aria-describedby="emailError">
              <small id="emailError" data-field-error="email"></small>
            </label>

            <label class="reservation-inquiry__field" data-field="phone">
              <span>{formText.phone}</span>
              <input id="phone" name="phone" type="tel" autocomplete="tel">
            </label>

            <div class="reservation-inquiry__field reservation-country" data-field="country" data-country-combobox>
              <label for="countrySearch">{formText.country}</label>
              <div class="reservation-country__control">
                <Icon name="search" size={17} />
                <input id="countrySearch" name="countrySearch" type="text" autocomplete="off" role="combobox" aria-autocomplete="list" aria-expanded="false" aria-controls="countryOptions" placeholder={copy.countrySearch} data-country-search>
                <input id="country" name="country" type="hidden" data-country-code>
              </div>
              <div class="reservation-country__list" id="countryOptions" role="listbox" data-country-list hidden></div>
              <small>{copy.countryHelp}</small>
            </div>

            <label class="reservation-inquiry__field" data-field="contactLanguage">
              <span>{formText.contactLanguage}</span>
              <select id="contactLanguage" name="contactLanguage">
                {languages.map((language) => (
                  <option value={language.code} selected={language.code === lang}>{language.name}</option>
                ))}
              </select>
            </label>
          </div>
        </fieldset>

        <fieldset class="reservation-inquiry__group reveal-section">
          <legend>{copy.steps[4]}</legend>
          <label class="reservation-inquiry__field reservation-inquiry__field--textarea" data-field="message">
            <span>{formText.message}</span>
            <textarea id="message" name="message" rows="5" placeholder={formText.messagePlaceholder}></textarea>
          </label>

          <div class="reservation-inquiry__season-notice" data-season-banner hidden>{formText.summerNotice}</div>
          <div class="reservation-inquiry__rule-notice">{formText.quietRule}</div>

          <label class="reservation-inquiry__consent" data-field="quietConsent">
            <input id="quietConsent" name="quietConsent" type="checkbox" required data-required aria-describedby="quietConsentError">
            <span>{formText.quietConsent}</span>
          </label>
          <small class="reservation-inquiry__field-error" id="quietConsentError" data-field-error="quietConsent"></small>

          <label class="reservation-inquiry__consent" data-field="consent">
            <input id="consent" name="consent" type="checkbox" required data-required aria-describedby="consentError">
            <span>{formText.consent}</span>
          </label>
          <small class="reservation-inquiry__field-error" id="consentError" data-field-error="consent"></small>
        </fieldset>

        <button class="btn btn-primary reservation-inquiry__submit" type="submit" data-submit-button data-default-label={formText.submit} data-loading-label={formText.loading}>
          {formText.submit}
        </button>

        <div class="reservation-inquiry__success" data-success role="status" tabindex="-1" hidden>{formText.success}</div>
      </form>

      <aside class="premium-card reservation-inquiry__summary" aria-live="polite">
        <span class="section-kicker">{formText.summary}</span>
        <h3>{formText.summary}</h3>
        <p data-summary-empty>{formText.summaryEmpty}</p>

        <div class="reservation-inquiry__summary-details" data-summary-details hidden>
          <div><span>{copy.categorySummary}</span><strong data-summary-category>{copy.camping}</strong></div>
          <div><span>{formText.term}</span><strong data-summary-dates>{formText.toComplete}</strong></div>
          <div><span>{formText.nights}</span><strong data-summary-nights>{formText.toComplete}</strong></div>
          <div><span>{formText.stayType}</span><strong data-summary-stay>{formText.toComplete}</strong></div>
          <div><span>{formText.people}</span><strong data-summary-people>2 {formText.adults}</strong></div>
          <div><span>{formText.extras}</span><strong data-summary-addons>{formText.noAddons}</strong></div>
          <div><span>{copy.specialNeeds}</span><strong data-summary-special>{formText.noAddons}</strong></div>
          <div><span>{formText.countrySummary}</span><strong data-summary-country>{formText.toComplete}</strong></div>
          <div><span>{formText.language}</span><strong data-summary-language>{lang.toUpperCase()}</strong></div>
          <div><span>{formText.season}</span><strong data-summary-season>{formText.toComplete}</strong></div>
        </div>

        <p class="reservation-inquiry__summary-notice" data-summary-notice hidden>{formText.summerNotice}</p>

        <div class="reservation-inquiry__summary-info" aria-label={formText.summary}>
          {[
            { icon: 'map', text: copy.mapsInfo },
            { icon: 'check', text: copy.availabilityInfo },
            { icon: 'warning', text: copy.partyInfo },
            { icon: 'clock', text: copy.hoursInfo },
          ].map((note) => (
            <div>
              <span aria-hidden="true"><Icon name={note.icon} size={17} /></span>
              <p>{note.text}</p>
            </div>
          ))}
        </div>
      </aside>
    </div>
  </div>
</section>

<script define:vars={{ formText, pricingText, apiEndpoint, formConfig }}>
  (() => {
    const root = document.querySelector('[data-reservation-inquiry]');
    if (!root) return;

    const form = root.querySelector('[data-reservation-form]');
    const errorBox = root.querySelector('[data-form-errors]');
    const successBox = root.querySelector('[data-success]');
    const arrivalInput = root.querySelector('[data-arrival]');
    const departureInput = root.querySelector('[data-departure]');
    const nightsLabel = root.querySelector('[data-nights-label]');
    const seasonBanner = root.querySelector('[data-season-banner]');
    const submitButton = root.querySelector('[data-submit-button]');
    const summaryEmpty = root.querySelector('[data-summary-empty]');
    const summaryDetails = root.querySelector('[data-summary-details]');
    const summaryNotice = root.querySelector('[data-summary-notice]');
    const countrySearch = root.querySelector('[data-country-search]');
    const countryCode = root.querySelector('[data-country-code]');
    const countryList = root.querySelector('[data-country-list]');
    const specialNeeds = root.querySelector('[data-special-needs]');
    const specialDetails = root.querySelector('[data-special-needs-details]');
    const choiceOverlay = root.querySelector('[data-contact-choice-overlay]');
    const selectedChoice = root.querySelector('[data-selected-choice]');
    const changeChoiceButton = root.querySelector('[data-change-choice]');
    const standardStayOptions = root.querySelector('[data-standard-stay-options]');
    const commonCounters = root.querySelector('[data-common-counters]');
    const combinedFields = root.querySelector('[data-combined-fields]');
    const DAY = 24 * 60 * 60 * 1000;
    const summerNotice = formText.summerNotice;
    const countries = formConfig.countries || [];
    const lang = formConfig.lang || 'en';
    const copy = formConfig.copy || {};
    let isSubmitting = false;
    let lastSubmitAt = 0;
    let activeCountryIndex = -1;
    let countryMatches = [];
    let choiceMade = false;

    const summary = {
      category: root.querySelector('[data-summary-category]'),
      dates: root.querySelector('[data-summary-dates]'),
      nights: root.querySelector('[data-summary-nights]'),
      stay: root.querySelector('[data-summary-stay]'),
      people: root.querySelector('[data-summary-people]'),
      addons: root.querySelector('[data-summary-addons]'),
      special: root.querySelector('[data-summary-special]'),
      country: root.querySelector('[data-summary-country]'),
      language: root.querySelector('[data-summary-language]'),
      season: root.querySelector('[data-summary-season]'),
    };

    const normalize = (value = '') => value
      .toLowerCase()
      .normalize('NFD')
      .replace(/[\u0300-\u036f]/g, '')
      .replace(/ł/g, 'l')
      .trim();
    const setText = (element, value) => { if (element) element.textContent = value; };
    const getField = (name) => form?.elements.namedItem(name);
    const getInput = (name) => {
      const field = getField(name);
      return field instanceof HTMLInputElement || field instanceof HTMLTextAreaElement || field instanceof HTMLSelectElement ? field : null;
    };
    const getErrorElement = (name) => root.querySelector(`[data-field-error="${name}"]`);
    const setFieldError = (name, message = '') => {
      const field = getInput(name);
      const errorElement = getErrorElement(name);
      const wrapper = root.querySelector(`[data-field="${name}"]`);
      if (field) field.setAttribute('aria-invalid', message ? 'true' : 'false');
      if (wrapper) wrapper.classList.toggle('is-invalid', Boolean(message));
      setText(errorElement, message);
    };
    const setErrorBox = (errors) => {
      if (!errorBox) return;
      errorBox.replaceChildren();
      errorBox.hidden = errors.length === 0;
      if (!errors.length) return;
      const heading = document.createElement('strong');
      heading.textContent = formText.errorHeading;
      const list = document.createElement('ul');
      errors.forEach((error) => {
        const item = document.createElement('li');
        item.textContent = error;
        list.appendChild(item);
      });
      errorBox.append(heading, list);
    };
    const normalizeCategoryParam = (value) => {
      const normalizedValue = normalize(value || '');
      if (['bungalow', 'bungalows', 'domki', 'domek'].includes(normalizedValue)) return 'bungalow';
      if (['combined', 'razem', 'combo'].includes(normalizedValue)) return 'combined';
      return 'camping';
    };
    const setChoiceOverlay = (open) => {
      if (!(choiceOverlay instanceof HTMLElement)) return;
      choiceOverlay.hidden = !open;
      choiceOverlay.setAttribute('aria-hidden', open ? 'false' : 'true');
      document.body.classList.toggle('has-contact-choice-open', open);
    };
    const updateStayQuery = (category) => {
      const url = new URL(window.location.href);
      url.searchParams.set('stay', category);
      window.history.replaceState({}, '', url);
    };
    const chooseCategory = (category, options = {}) => {
      const normalizedCategory = normalizeCategoryParam(category);
      const categoryInput = root.querySelector(`input[name="bookingCategory"][value="${normalizedCategory}"]`);
      if (categoryInput instanceof HTMLInputElement) categoryInput.checked = true;
      choiceMade = true;
      syncStayCategory();
      updateSummary();
      if (options.updateUrl !== false) updateStayQuery(normalizedCategory);
      setChoiceOverlay(false);
      if (options.scroll !== false) {
        const firstField = root.querySelector('[data-field="arrival"] input');
        if (firstField instanceof HTMLElement) firstField.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }
    };
    const setSubmitting = (submitting) => {
      isSubmitting = submitting;
      if (submitButton instanceof HTMLButtonElement) {
        submitButton.disabled = submitting;
        submitButton.setAttribute('aria-busy', submitting ? 'true' : 'false');
        submitButton.textContent = submitting
          ? submitButton.dataset.loadingLabel || formText.loading
          : submitButton.dataset.defaultLabel || formText.submit;
      }
    };
    const parseDate = (value) => {
      if (!value) return null;
      const parts = value.split('-').map(Number);
      if (parts.length !== 3 || parts.some((part) => !Number.isFinite(part))) return null;
      const date = new Date(Date.UTC(parts[0], parts[1] - 1, parts[2]));
      return date.getUTCFullYear() === parts[0] && date.getUTCMonth() === parts[1] - 1 && date.getUTCDate() === parts[2] ? date : null;
    };
    const addDays = (date, days) => new Date(date.getTime() + days * DAY);
    const toDateValue = (date) => `${date.getUTCFullYear()}-${String(date.getUTCMonth() + 1).padStart(2, '0')}-${String(date.getUTCDate()).padStart(2, '0')}`;
    const formatDate = (date) => `${String(date.getUTCDate()).padStart(2, '0')}.${String(date.getUTCMonth() + 1).padStart(2, '0')}.${date.getUTCFullYear()}`;
    const normalizeCounterValue = (value) => {
      const numericValue = Number(value);
      return Number.isFinite(numericValue) ? Math.max(0, numericValue) : 0;
    };
    const formatNights = (nights) => nights === 1 ? pricingText.night.one : pricingText.night.other.replace('{count}', String(nights));
    const getNights = () => {
      const arrival = parseDate(arrivalInput?.value);
      const departure = parseDate(departureInput?.value);
      if (!arrival || !departure || departure <= arrival) return 0;
      return Math.max(1, Math.round((departure.getTime() - arrival.getTime()) / DAY));
    };
    const getRangeDates = (arrival, departure) => {
      if (!arrival || !departure || departure < arrival) return [];
      const dates = [];
      let cursor = arrival;
      while (cursor <= departure) {
        dates.push(cursor);
        cursor = addDays(cursor, 1);
      }
      return dates;
    };
    const isSummerDate = (date) => [6, 7, 8].includes(date.getUTCMonth() + 1);
    const getBookingCategory = () => {
      const selected = root.querySelector('input[name="bookingCategory"]:checked');
      return selected instanceof HTMLInputElement ? selected.value : 'camping';
    };
    const getCategoryLabel = () => ({
      camping: copy.camping,
      bungalow: copy.bungalow,
      combined: copy.combined,
    })[getBookingCategory()] || copy.camping;
    const getCheckedLabel = (name) => {
      const selected = root.querySelector(`input[name="${name}"]:checked`);
      return selected instanceof HTMLInputElement ? selected.dataset.label || selected.value : '';
    };
    const getCombinedDetails = () => ({
      bungalowType: getCheckedLabel('combinedBungalowType'),
      campingType: getCheckedLabel('combinedCampingType'),
      bungalowPeople: normalizeCounterValue(getInput('combinedBungalowPeople')?.value ?? 0),
      campingPeople: normalizeCounterValue(getInput('combinedCampingPeople')?.value ?? 0),
      bungalowCount: Math.max(1, normalizeCounterValue(getInput('combinedBungalowCount')?.value ?? 1)),
    });
    const getSelectedStay = () => {
      if (getBookingCategory() === 'combined') {
        const details = getCombinedDetails();
        return {
          id: 'combined',
          label: `${details.bungalowType || copy.bungalow} + ${details.campingType || copy.camping}`,
          category: 'combined',
          details,
        };
      }
      const selected = root.querySelector('input[name="stayType"]:checked');
      if (!(selected instanceof HTMLInputElement)) return null;
      return { id: selected.value, label: selected.dataset.label || selected.value, category: selected.dataset.category || 'camping' };
    };
    const getSelectedAddons = () =>
      Array.from(root.querySelectorAll('input[name="addons"]:checked')).map((input) => ({
        id: input.value,
        label: input.dataset.label || input.value,
      }));
    const getPeople = () => ({
      adults: normalizeCounterValue(getInput('adults')?.value ?? 0),
      children: normalizeCounterValue(getInput('children')?.value ?? 0),
      toddlers: normalizeCounterValue(getInput('toddlers')?.value ?? 0),
    });
    const getPeopleSummary = (people) => {
      if (getBookingCategory() === 'combined') {
        const details = getCombinedDetails();
        return `${copy.bungalow}: ${details.bungalowPeople}, ${copy.camping}: ${details.campingPeople}, ${copy.bungalowCount}: ${details.bungalowCount}`;
      }
      const parts = [];
      if (people.adults > 0) parts.push(`${people.adults} ${formText.adults}`);
      if (people.children > 0) parts.push(`${people.children} ${formText.children}`);
      if (people.toddlers > 0) parts.push(`${people.toddlers} ${formText.toddlers}`);
      return parts.length ? parts.join(', ') : formText.noPeople;
    };
    const getLanguageLabel = () => {
      const language = getInput('contactLanguage');
      if (!(language instanceof HTMLSelectElement)) return lang.toUpperCase();
      return language.selectedOptions[0]?.textContent?.trim() || language.value;
    };
    const hasSummerCampingNotice = () => {
      const stay = getSelectedStay();
      const arrival = parseDate(arrivalInput?.value);
      const departure = parseDate(departureInput?.value);
      if (!stay || !['camping', 'combined'].includes(stay.category)) return false;
      return getRangeDates(arrival, departure).some(isSummerDate);
    };
    const getCountryLabel = () => countrySearch instanceof HTMLInputElement ? countrySearch.value.trim() : '';
    const hasSpecialNeeds = () => specialNeeds instanceof HTMLInputElement && specialNeeds.checked;
    const hasAnySummaryData = () => {
      const fields = ['fullName', 'email', 'phone', 'arrival', 'departure', 'message'];
      return fields.some((name) => Boolean(getInput(name)?.value.trim())) || Boolean(getSelectedStay()) || getSelectedAddons().length > 0 || Boolean(getCountryLabel()) || hasSpecialNeeds();
    };
    const setStayError = (message = '') => {
      const stayGroup = root.querySelector('[data-stay-group]');
      root.querySelectorAll('input[name="stayType"]').forEach((input) => input.setAttribute('aria-invalid', message ? 'true' : 'false'));
      stayGroup?.classList.toggle('is-invalid', Boolean(message));
      setText(getErrorElement('stayType'), message);
    };
    const syncStayCategory = () => {
      const category = getBookingCategory();
      const isCombined = category === 'combined';
      root.dataset.bookingCategory = category;
      setText(selectedChoice, getCategoryLabel());
      if (standardStayOptions instanceof HTMLElement) standardStayOptions.hidden = isCombined;
      if (commonCounters instanceof HTMLElement) commonCounters.hidden = isCombined;
      if (combinedFields instanceof HTMLElement) combinedFields.hidden = !isCombined;
      root.querySelectorAll('[data-combined-field-input]').forEach((input) => {
        if (input instanceof HTMLInputElement || input instanceof HTMLSelectElement || input instanceof HTMLTextAreaElement) {
          input.disabled = !isCombined;
        }
      });
      root.querySelectorAll('[data-stay-option-category]').forEach((option) => {
        const visible = !isCombined && option.dataset.stayOptionCategory === category;
        option.hidden = !visible;
        const input = option.querySelector('input');
        if (input instanceof HTMLInputElement) {
          input.disabled = !visible;
          if (!visible) input.checked = false;
        }
      });
      const checked = root.querySelector('input[name="stayType"]:checked');
      if (!isCombined && !(checked instanceof HTMLInputElement)) {
        const first = root.querySelector(`input[name="stayType"][data-category="${category}"]`);
        if (first instanceof HTMLInputElement) first.checked = true;
      }
      const electricity = root.querySelector('[data-addon-id="electricity"]');
      if (electricity instanceof HTMLElement) {
        electricity.hidden = category === 'bungalow';
        const input = electricity.querySelector('input');
        if (input instanceof HTMLInputElement && category === 'bungalow') input.checked = false;
      }
      root.querySelectorAll('[data-variant-info]').forEach((item) => {
        if (item instanceof HTMLElement) item.hidden = item.dataset.variantInfo !== category;
      });
    };
    const renderCountries = (matches) => {
      if (!(countryList instanceof HTMLElement) || !(countrySearch instanceof HTMLInputElement)) return;
      countryList.replaceChildren();
      countrySearch.setAttribute('aria-expanded', matches.length ? 'true' : 'false');
      countryList.hidden = matches.length === 0;
      matches.forEach((country, index) => {
        const option = document.createElement('button');
        option.type = 'button';
        option.role = 'option';
        option.className = 'reservation-country__option';
        option.dataset.countryIndex = String(index);
        option.setAttribute('aria-selected', String(index === activeCountryIndex));
        const flag = document.createElement('span');
        flag.className = `reservation-country__flag ${country.flagClass}`;
        const label = document.createElement('strong');
        label.textContent = country.names[lang] || country.names.en;
        const code = document.createElement('small');
        code.textContent = country.code;
        option.append(flag, label, code);
        option.addEventListener('click', () => selectCountry(country));
        countryList.appendChild(option);
      });
    };
    const findCountries = (query) => {
      const normalized = normalize(query);
      if (!normalized) return countries.slice(0, 8);
      return countries
        .map((country) => {
          const values = [
            country.code,
            country.names.pl,
            country.names.en,
            country.names.de,
            country.names.it,
            ...(country.aliases || []),
          ].map(normalize);
          const exact = values.some((value) => value === normalized);
          const starts = values.some((value) => value.startsWith(normalized));
          const includes = values.some((value) => value.includes(normalized));
          return { country, score: exact ? 3 : starts ? 2 : includes ? 1 : 0 };
        })
        .filter((item) => item.score > 0)
        .sort((a, b) => b.score - a.score || a.country.names.en.localeCompare(b.country.names.en))
        .slice(0, 8)
        .map((item) => item.country);
    };
    const selectCountry = (country) => {
      if (countrySearch instanceof HTMLInputElement) {
        countrySearch.value = country.names[lang] || country.names.en;
        countrySearch.setAttribute('aria-expanded', 'false');
      }
      if (countryCode instanceof HTMLInputElement) countryCode.value = country.code;
      activeCountryIndex = -1;
      countryMatches = [];
      renderCountries([]);
      updateSummary();
    };
    const syncCountrySearch = () => {
      if (!(countrySearch instanceof HTMLInputElement)) return;
      const value = countrySearch.value.trim();
      if (countryCode instanceof HTMLInputElement) countryCode.value = '';
      countryMatches = findCountries(value);
      activeCountryIndex = countryMatches.length ? 0 : -1;
      renderCountries(countryMatches);
      updateSummary();
    };
    const updateSummary = () => {
      syncStayCategory();
      const arrival = parseDate(arrivalInput?.value);
      const departure = parseDate(departureInput?.value);
      const nights = getNights();
      const stay = getSelectedStay();
      const people = getPeople();
      const addons = getSelectedAddons();
      const hasNotice = hasSummerCampingNotice();

      if (arrivalInput instanceof HTMLInputElement) {
        const today = new Date();
        const todayUtc = new Date(Date.UTC(today.getFullYear(), today.getMonth(), today.getDate()));
        arrivalInput.min = toDateValue(todayUtc);
      }
      if (departureInput instanceof HTMLInputElement && arrival) departureInput.min = toDateValue(addDays(arrival, 1));
      if (specialDetails instanceof HTMLElement) specialDetails.hidden = !hasSpecialNeeds();

      setText(nightsLabel, nights > 0 ? formatNights(nights) : formText.completeDates);
      if (seasonBanner instanceof HTMLElement) seasonBanner.hidden = !hasNotice;
      if (summaryNotice instanceof HTMLElement) {
        summaryNotice.hidden = !hasNotice;
        if (!summaryNotice.hidden) setText(summaryNotice, summerNotice);
      }

      const hasData = hasAnySummaryData();
      if (summaryEmpty instanceof HTMLElement) summaryEmpty.hidden = hasData;
      if (summaryDetails instanceof HTMLElement) summaryDetails.hidden = !hasData;
      if (!hasData) return;

      setText(summary.category, getCategoryLabel());
      setText(summary.dates, arrival && departure && nights > 0 ? `${formatDate(arrival)} - ${formatDate(departure)}` : formText.toComplete);
      setText(summary.nights, nights > 0 ? formatNights(nights) : formText.toComplete);
      setText(summary.stay, stay?.label ?? formText.toComplete);
      setText(summary.people, getPeopleSummary(people));
      setText(summary.addons, addons.length ? addons.map((addon) => addon.label).join(', ') : formText.noAddons);
      setText(summary.special, hasSpecialNeeds() ? copy.specialNeedsSummary : formText.noAddons);
      setText(summary.country, getCountryLabel() || formText.toComplete);
      setText(summary.language, getLanguageLabel());
      setText(summary.season, hasNotice ? formText.summerSeason : arrival && departure ? formText.outsideSummer : formText.toComplete);
    };
    const validate = () => {
      const errors = [];
      const fullName = getInput('fullName')?.value.trim() ?? '';
      const email = getInput('email')?.value.trim() ?? '';
      const arrival = parseDate(arrivalInput?.value);
      const departure = parseDate(departureInput?.value);
      const stay = getSelectedStay();
      const consent = getInput('consent');
      const quietConsent = getInput('quietConsent');
      ['fullName', 'email', 'arrival', 'departure', 'quietConsent', 'consent'].forEach((name) => setFieldError(name));
      setStayError();
      if (!fullName) { errors.push(formText.validation.fullName); setFieldError('fullName', formText.validation.fullName); }
      if (!email) {
        errors.push(formText.validation.email);
        setFieldError('email', formText.validation.email);
      } else if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        errors.push(formText.validation.emailFormat);
        setFieldError('email', formText.validation.emailFormat);
      }
      if (!arrival) { errors.push(formText.validation.arrival); setFieldError('arrival', formText.validation.arrival); }
      if (!departure) {
        errors.push(formText.validation.departure);
        setFieldError('departure', formText.validation.departure);
      } else if (arrival && departure <= arrival) {
        errors.push(formText.validation.departureAfterArrival);
        setFieldError('departure', formText.validation.departureAfterArrival);
      }
      if (!stay) { errors.push(formText.validation.stayType); setStayError(formText.validation.stayType); }
      if (!(quietConsent instanceof HTMLInputElement) || !quietConsent.checked) {
        errors.push(formText.validation.quietConsent);
        setFieldError('quietConsent', formText.validation.quietConsent);
      }
      if (!(consent instanceof HTMLInputElement) || !consent.checked) {
        errors.push(formText.validation.consent);
        setFieldError('consent', formText.validation.consent);
      }
      setErrorBox(errors);
      return errors.length === 0;
    };
    const collectPayload = () => {
      const people = getPeople();
      const arrival = parseDate(arrivalInput?.value);
      const departure = parseDate(departureInput?.value);
      const stay = getSelectedStay();
      const addons = getSelectedAddons();
      return {
        fullName: getInput('fullName')?.value.trim() ?? '',
        email: getInput('email')?.value.trim() ?? '',
        phone: getInput('phone')?.value.trim() ?? '',
        country: getCountryLabel(),
        countryCode: countryCode instanceof HTMLInputElement ? countryCode.value : '',
        contactLanguage: getLanguageLabel(),
        bookingCategory: getBookingCategory(),
        arrivalIso: arrival ? toDateValue(arrival) : '',
        departureIso: departure ? toDateValue(departure) : '',
        arrival: arrival ? formatDate(arrival) : '',
        departure: departure ? formatDate(departure) : '',
        nights: getNights(),
        stayType: stay?.label ?? '',
        stayTypeId: stay?.id ?? '',
        stayCategory: stay?.category ?? '',
        combinedDetails: getBookingCategory() === 'combined' ? getCombinedDetails() : null,
        people,
        addons: addons.map((addon) => addon.label),
        specialNeeds: hasSpecialNeeds(),
        specialNeedsDetails: getInput('specialNeedsDetails')?.value.trim() ?? '',
        message: getInput('message')?.value.trim() ?? '',
        summerNotice: hasSummerCampingNotice(),
        quietConsent: Boolean(getInput('quietConsent')?.checked),
        consent: Boolean(getInput('consent')?.checked),
        website: getInput('website')?.value.trim() ?? '',
        source: 'website',
        locale: document.documentElement.lang || 'pl',
        submittedAtClient: new Date().toISOString(),
      };
    };
    const buildMailBody = (payload) => [
      formText.mailTitle,
      '',
      `${copy.categorySummary}: ${payload.bookingCategory}`,
      `${formText.mailLabels.fullName}: ${payload.fullName}`,
      `${formText.mailLabels.email}: ${payload.email}`,
      `${formText.mailLabels.phone}: ${payload.phone || formText.mailLabels.notProvided}`,
      `${formText.mailLabels.country}: ${payload.country || formText.mailLabels.notProvided} ${payload.countryCode ? `(${payload.countryCode})` : ''}`,
      `${formText.mailLabels.contactLanguage}: ${payload.contactLanguage}`,
      '',
      `${formText.mailLabels.term}: ${payload.arrival} - ${payload.departure}`,
      `${formText.mailLabels.nights}: ${payload.nights}`,
      `${formText.mailLabels.stayType}: ${payload.stayType}`,
      `${copy.combinedBungalowSection}: ${payload.combinedDetails ? `${payload.combinedDetails.bungalowType}, ${copy.bungalowPeople}: ${payload.combinedDetails.bungalowPeople}, ${copy.bungalowCount}: ${payload.combinedDetails.bungalowCount}` : formText.mailLabels.notApplicable}`,
      `${copy.combinedCampingSection}: ${payload.combinedDetails ? `${payload.combinedDetails.campingType}, ${copy.campingPeople}: ${payload.combinedDetails.campingPeople}` : formText.mailLabels.notApplicable}`,
      `${formText.mailLabels.adults}: ${payload.people.adults}`,
      `${formText.mailLabels.children}: ${payload.people.children}`,
      `${formText.mailLabels.toddlers}: ${payload.people.toddlers}`,
      `${formText.mailLabels.addons}: ${payload.addons.length ? payload.addons.join(', ') : formText.mailLabels.none}`,
      `${copy.specialNeeds}: ${payload.specialNeeds ? formText.mailLabels.accepted : formText.mailLabels.notApplicable}`,
      `${copy.specialNeedsDetails}: ${payload.specialNeedsDetails || formText.mailLabels.none}`,
      '',
      `${formText.mailLabels.summerNotice}: ${payload.summerNotice ? summerNotice : formText.mailLabels.notApplicable}`,
      `${formText.mailLabels.quietConsent}: ${payload.quietConsent ? formText.mailLabels.accepted : formText.mailLabels.notApplicable}`,
      '',
      `${formText.mailLabels.message}: ${payload.message || formText.mailLabels.none}`,
    ].join('\n');
    const submitToBackend = async (payload) => {
      const response = await fetch(apiEndpoint, {
        method: 'POST',
        headers: { 'content-type': 'application/json', accept: 'application/json' },
        body: JSON.stringify(payload),
      });
      const contentType = response.headers.get('content-type') || '';
      const data = contentType.includes('application/json') ? await response.json() : null;
      if (!response.ok || !data?.ok) {
        const backendErrors = data?.errors ? Object.values(data.errors) : [data?.message || formText.networkError];
        const error = new Error(backendErrors.join('\n'));
        error.backendResponse = Boolean(data);
        error.status = response.status;
        throw error;
      }
      return data;
    };
    const showSuccess = () => {
      if (successBox) {
        successBox.hidden = false;
        successBox.focus({ preventScroll: true });
        successBox.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }
    };
    const applyQueryParams = () => {
      const params = new URLSearchParams(window.location.search);
      const categoryParam = params.get('stay') || params.get('category');
      if (categoryParam) {
        chooseCategory(normalizeCategoryParam(categoryParam), { updateUrl: false, scroll: false });
      } else {
        setChoiceOverlay(true);
      }
      syncStayCategory();
      const type = params.get('type');
      if (type) {
        const typeInput = root.querySelector(`input[name="stayType"][value="${CSS.escape(type)}"]`);
        if (typeInput instanceof HTMLInputElement && !typeInput.disabled) typeInput.checked = true;
      }
      ['arrival', 'departure', 'adults', 'children', 'toddlers'].forEach((name) => {
        const value = params.get(name);
        const input = getInput(name);
        if (value && input instanceof HTMLInputElement) input.value = value;
      });
      ['electricity', 'dog'].forEach((id) => {
        const value = params.get(id);
        const input = root.querySelector(`input[name="addons"][value="${id}"]`);
        if (input instanceof HTMLInputElement) input.checked = value === '1' || value === 'true';
      });
      const countryParam = params.get('country');
      if (countryParam) {
        const country = findCountries(countryParam)[0];
        if (country) selectCountry(country);
      }
    };

    form?.addEventListener('submit', async (event) => {
      event.preventDefault();
      if (isSubmitting || Date.now() - lastSubmitAt < 1200) return;
      lastSubmitAt = Date.now();
      updateSummary();
      if (successBox) successBox.hidden = true;
      if (!validate()) {
        const firstInvalid = form.querySelector('[aria-invalid="true"]');
        if (firstInvalid instanceof HTMLElement) firstInvalid.focus({ preventScroll: true });
        errorBox?.scrollIntoView({ behavior: 'smooth', block: 'center' });
        return;
      }
      const payload = collectPayload();
      const mailBody = buildMailBody(payload);
      setSubmitting(true);
      setErrorBox([]);
      try {
        const result = await submitToBackend(payload);
        console.log('Zapytanie Camping Clepardia przyjete przez backend:', result);
        console.log('Gotowa tresc maila do recepcji Camping Clepardia:\n' + mailBody);
        showSuccess();
      } catch (error) {
        if (error?.backendResponse) {
          setErrorBox(String(error.message || formText.networkError).split('\n').filter(Boolean));
          errorBox?.scrollIntoView({ behavior: 'smooth', block: 'center' });
          return;
        }
        console.warn('Backend formularza niedostepny lub zwrocil blad. Uruchamiam lokalny fallback mock.', error);
        console.log('Gotowa tresc maila do recepcji Camping Clepardia:\n' + mailBody);
        console.log('Dane formularza zapytania Camping Clepardia:', payload);
        showSuccess();
      } finally {
        setSubmitting(false);
      }
    });

    form?.addEventListener('input', () => {
      root.querySelectorAll('[data-counter-input]').forEach((input) => {
        if (input instanceof HTMLInputElement) input.value = String(normalizeCounterValue(input.value || 0));
      });
      updateSummary();
      if (errorBox && !errorBox.hidden) validate();
    });
    form?.addEventListener('change', () => {
      updateSummary();
      if (errorBox && !errorBox.hidden) validate();
    });
    root.querySelectorAll('[data-counter]').forEach((button) => {
      button.addEventListener('click', () => {
        const name = button.dataset.counter;
        const delta = Number(button.dataset.delta ?? 0);
        const input = root.querySelector(`[data-counter-input="${name}"]`);
        if (input instanceof HTMLInputElement) input.value = String(Math.max(0, normalizeCounterValue(input.value || 0) + delta));
        updateSummary();
      });
    });
    root.querySelectorAll('[data-booking-category]').forEach((input) => {
      input.addEventListener('change', () => {
        chooseCategory(input.value, { scroll: false });
      });
    });
    root.querySelectorAll('[data-contact-choice]').forEach((choice) => {
      choice.addEventListener('click', (event) => {
        event.preventDefault();
        if (choice instanceof HTMLElement) chooseCategory(choice.dataset.contactChoice || 'camping');
      });
    });
    changeChoiceButton?.addEventListener('click', () => setChoiceOverlay(true));
    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && choiceMade && choiceOverlay instanceof HTMLElement && !choiceOverlay.hidden) {
        setChoiceOverlay(false);
      }
    });
    specialNeeds?.addEventListener('change', updateSummary);
    countrySearch?.addEventListener('input', syncCountrySearch);
    countrySearch?.addEventListener('focus', syncCountrySearch);
    countrySearch?.addEventListener('keydown', (event) => {
      if (!countryMatches.length) return;
      if (event.key === 'ArrowDown') {
        event.preventDefault();
        activeCountryIndex = Math.min(countryMatches.length - 1, activeCountryIndex + 1);
        renderCountries(countryMatches);
      } else if (event.key === 'ArrowUp') {
        event.preventDefault();
        activeCountryIndex = Math.max(0, activeCountryIndex - 1);
        renderCountries(countryMatches);
      } else if (event.key === 'Enter') {
        event.preventDefault();
        selectCountry(countryMatches[Math.max(0, activeCountryIndex)]);
      } else if (event.key === 'Escape') {
        renderCountries([]);
      }
    });
    document.addEventListener('click', (event) => {
      if (event.target instanceof Element && !event.target.closest('[data-country-combobox]')) renderCountries([]);
    });

    applyQueryParams();
    updateSummary();
  })();
</script>

