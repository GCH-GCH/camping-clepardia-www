---
import Icon from '@/components/ui/Icon.astro';
import { getWeatherCopy } from '@/i18n/weather';
import { getPlannerLocalizedPath } from '@/utils/localizedLinks';

interface Props { languageCode?: string; compact?: boolean; hero?: boolean; }
const { languageCode = 'pl', compact = false, hero = false } = Astro.props as Props;
const copy = getWeatherCopy(languageCode);
const plannerHref = getPlannerLocalizedPath(languageCode);
const dialogId = `weather-forecast-${languageCode}`;
const config = JSON.stringify({ copy,languageCode,plannerHref });
---

<section class:list={['weather-card',compact && 'weather-card--compact',hero && 'weather-card--hero']} data-weather-card data-weather-variant={hero ? 'hero' : 'card'} data-weather-config={config} aria-label={copy.title}>
  {hero ? (
    <>
      <button class="weather-card__trigger" type="button" data-weather-open aria-haspopup="dialog" aria-controls={dialogId} aria-expanded="false" aria-label={copy.drawerAria}>
        <span class="weather-card__panel">
          <span class="weather-card__main">
            <span class="weather-card__eyebrow"><i aria-hidden="true"></i>{copy.heroLocation}</span>
            <span class="weather-card__loading" data-weather-status>{copy.loading}</span>
            <span class="weather-card__facts" data-weather-facts hidden>
              <span data-weather-condition>—</span>
              <small class="weather-card__feels" data-weather-feels>—</small>
              <span class="weather-card__metrics">
                <small data-weather-rain>—</small>
                <small data-weather-wind>—</small>
              </span>
              <small class="weather-card__updated" data-weather-card-updated></small>
            </span>
          </span>
          <span class="weather-card__open-label">{copy.viewForecast}<Icon name="ArrowUpRight" size={16} strokeWidth={2} /></span>
        </span>
        <span class="weather-card__edge-summary" aria-hidden="true">
          <small>{copy.weatherLabel}</small>
          <span class="weather-card__edge-row">
            <span class="weather-card__icon" data-weather-icon><Icon name="CloudSun" size={30} strokeWidth={1.9} /></span>
            <strong data-weather-temperature>—</strong>
          </span>
          <span class="weather-card__edge-meta"><i data-weather-tab-rain>—</i><b>‹</b></span>
        </span>
      </button>

      <dialog class="weather-dialog" id={dialogId} data-weather-dialog role="dialog" aria-modal="true" aria-labelledby={`${dialogId}-title`}>
        <div class="weather-dialog__shell">
          <header class="weather-dialog__header">
            <div>
              <span>{copy.forecast}</span>
              <h2 id={`${dialogId}-title`}>{copy.title}</h2>
            </div>
            <button type="button" class="weather-dialog__close weather-dialog__close--icon" data-weather-close aria-label={copy.close}>×</button>
          </header>
          <div class="weather-dialog__scroll">
            <div class="weather-dialog__loading" data-weather-dialog-status role="status">{copy.loading}</div>
            <div class="weather-dialog__content" data-weather-dialog-content hidden>
              <section class="weather-dialog__current" aria-labelledby={`${dialogId}-current`}>
                <div class="weather-dialog__current-main">
                  <span class="weather-dialog__current-icon" data-weather-dialog-icon aria-hidden="true">☁️</span>
                  <div>
                    <span>{copy.currentWeather}</span>
                    <strong data-weather-dialog-temperature>—</strong>
                    <p data-weather-dialog-condition>—</p>
                  </div>
                </div>
                <div class="weather-dialog__current-facts">
                  <span><b>◉</b><small>{copy.feels}</small><strong data-weather-dialog-feels>—</strong></span>
                  <span><b>⌁</b><small>{copy.wind}</small><strong data-weather-dialog-wind>—</strong></span>
                  <span><b>⌄</b><small>{copy.rain}</small><strong data-weather-dialog-rain>—</strong></span>
                  <span><b>◌</b><small>{copy.humidity}</small><strong data-weather-dialog-humidity>—</strong></span>
                </div>
                <small class="weather-dialog__updated" data-weather-updated></small>
              </section>

              <section class="weather-dialog__section" aria-labelledby={`${dialogId}-hourly`}>
                <div class="weather-dialog__section-head"><span>◷</span><h3 id={`${dialogId}-hourly`}>{copy.hourlyForecast}</h3></div>
                <div class="weather-dialog__hourly" data-weather-hourly></div>
              </section>

              <section class="weather-dialog__section" aria-labelledby={`${dialogId}-daily`}>
                <div class="weather-dialog__section-head"><span>▦</span><h3 id={`${dialogId}-daily`}>{copy.weekForecast}</h3></div>
                <div class="weather-dialog__daily" data-weather-daily></div>
              </section>

              <aside class="weather-dialog__recommendation">
                <span aria-hidden="true">✦</span>
                <div><h3>{copy.recommendationTitle}</h3><p data-weather-recommendation>{copy.recommendations.neutral}</p></div>
              </aside>
            </div>
          </div>
          <footer class="weather-dialog__footer">
            <a href={plannerHref} data-analytics-cta><Icon name="CalendarDays" size={18} strokeWidth={2} />{copy.openPlanner}</a>
            <button type="button" data-weather-campy><Icon name="TentTree" size={18} strokeWidth={2} />{copy.askCampy}</button>
            <button type="button" data-weather-close>{copy.close}</button>
          </footer>
        </div>
      </dialog>
    </>
  ) : (
    <>
      <div class="weather-card__icon" data-weather-icon><Icon name="CloudSun" size={27} strokeWidth={1.9} /></div>
      <div class="weather-card__main">
        <span>{copy.live}</span>
        <h2>{copy.title}</h2>
        <p data-weather-status>{copy.loading}</p>
        <div class="weather-card__facts" data-weather-facts hidden>
          <strong data-weather-temperature>—</strong>
          <span data-weather-condition>—</span>
          <small data-weather-rain>—</small>
          <small data-weather-wind>—</small>
        </div>
      </div>
      <a href={plannerHref} class="weather-card__cta" data-weather-cta data-analytics-cta>
        <span>{copy.details}</span><Icon name="ArrowUpRight" size={17} strokeWidth={2} />
      </a>
    </>
  )}
</section>

<script>
  import { clearWeatherRequestCache,getPublicWeather,weatherCodeGroup,weatherEmoji } from '@/lib/weatherClient.js';

  const trackWeather = (eventType,metadata = {}) => window.dispatchEvent(new CustomEvent('cc:analytics',{ detail:{ eventType,metadata } }));
  const safeNumber = (value,fallback = 0) => Number.isFinite(Number(value)) ? Number(value) : fallback;
  const escapeHtml = (value) => String(value ?? '').replace(/[&<>"']/g,(character) => ({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' })[character]);

  document.querySelectorAll('[data-weather-card]').forEach((root) => {
    if (!(root instanceof HTMLElement) || root.dataset.weatherReady === 'true') return;
    root.dataset.weatherReady = 'true';
    let config;
    try { config = JSON.parse(root.dataset.weatherConfig || '{}'); } catch { return; }
    const copy = config.copy;
    const hero = root.dataset.weatherVariant === 'hero';
    const status = root.querySelector('[data-weather-status]');
    const facts = root.querySelector('[data-weather-facts]');
    const dialog = root.querySelector('[data-weather-dialog]');
    const dialogStatus = root.querySelector('[data-weather-dialog-status]');
    const dialogContent = root.querySelector('[data-weather-dialog-content]');
    let lastTrigger = null;
    let payload = null;

    const dateLocale = config.languageCode === 'en' ? 'en-GB' : config.languageCode || 'pl';
    const conditionFor = (code) => {
      const group = weatherCodeGroup(code);
      return { group,emoji:weatherEmoji(group),label:copy.conditions[group] || copy.conditions.cloudy };
    };
    const recommendationFor = (result) => {
      const current = result?.current || {};
      const rainy = safeNumber(current.precipitationMm) > 0 || (result?.daily || []).slice(0,2).some((day) => safeNumber(day.rainProbability) >= 55);
      if (rainy) return copy.recommendations.rain;
      if (safeNumber(current.temperatureC) >= 29) return copy.recommendations.heat;
      if (safeNumber(current.windKmh) >= 28) return copy.recommendations.wind;
      if (['clear','mostlyClear'].includes(conditionFor(current.weatherCode).group)) return copy.recommendations.clear;
      return copy.recommendations.neutral;
    };
    const renderDialog = (result) => {
      if (!(dialogContent instanceof HTMLElement)) return;
      const current = result.current;
      const condition = conditionFor(current.weatherCode);
      root.querySelector('[data-weather-dialog-icon]').textContent = condition.emoji;
      root.querySelector('[data-weather-dialog-temperature]').textContent = `${Math.round(safeNumber(current.temperatureC))}°C`;
      root.querySelector('[data-weather-dialog-condition]').textContent = condition.label;
      root.querySelector('[data-weather-dialog-feels]').textContent = `${Math.round(safeNumber(current.apparentTemperatureC,current.temperatureC))}°C`;
      root.querySelector('[data-weather-dialog-wind]').textContent = `${Math.round(safeNumber(current.windKmh))} km/h`;
      root.querySelector('[data-weather-dialog-rain]').textContent = `${safeNumber(current.precipitationMm).toFixed(1)} mm`;
      root.querySelector('[data-weather-dialog-humidity]').textContent = Number.isFinite(Number(current.humidityPercent)) ? `${Math.round(Number(current.humidityPercent))}%` : '—';
      const updated = root.querySelector('[data-weather-updated]');
      if (updated) {
        const date = result.updatedAt ? new Date(result.updatedAt) : null;
        updated.textContent = date && !Number.isNaN(date.getTime()) ? `${copy.updated}: ${new Intl.DateTimeFormat(dateLocale,{ hour:'2-digit',minute:'2-digit' }).format(date)}` : '';
      }

      const hourly = root.querySelector('[data-weather-hourly]');
      const hours = Array.isArray(result.hourly) ? result.hourly.slice(0,12) : [];
      if (hourly) hourly.innerHTML = hours.length ? hours.map((hour) => {
        const weather = conditionFor(hour.weatherCode);
        const date = new Date(hour.time);
        const time = Number.isNaN(date.getTime()) ? String(hour.time || '').slice(11,16) : new Intl.DateTimeFormat(dateLocale,{ hour:'2-digit',minute:'2-digit' }).format(date);
        return `<article class="weather-hour-card" data-weather-hour-card><time>${escapeHtml(time)}</time><span class="weather-hour-card__icon" aria-hidden="true">${weather.emoji}</span><strong>${Math.round(safeNumber(hour.temperatureC))}°</strong><small>⌄ ${Number.isFinite(Number(hour.rainProbability)) ? Math.round(Number(hour.rainProbability)) : 0}%</small><small>⌁ ${Math.round(safeNumber(hour.windKmh))} km/h</small></article>`;
      }).join('') : `<p class="weather-dialog__empty">${escapeHtml(copy.hourlyEmpty)}</p>`;

      const daily = root.querySelector('[data-weather-daily]');
      const days = Array.isArray(result.daily) ? result.daily.slice(0,7) : [];
      const today = new Date(); today.setHours(0,0,0,0);
      if (daily) daily.innerHTML = days.length ? days.map((day,index) => {
        const weather = conditionFor(day.weatherCode);
        const date = new Date(`${day.date}T12:00:00`);
        const dayLabel = index === 0 ? copy.today : index === 1 ? copy.tomorrow : new Intl.DateTimeFormat(dateLocale,{ weekday:'short',day:'2-digit',month:'2-digit' }).format(date);
        const windKmh = safeNumber(day.windKmh,day.windMaxKmh);
        const key = safeNumber(day.rainProbability) >= 55 || ['rain','drizzle','storm'].includes(weather.group)
          ? 'rain'
          : safeNumber(day.temperatureMaxC) >= 29
            ? 'heat'
            : windKmh >= 28
              ? 'wind'
              : ['clear','mostlyClear'].includes(weather.group) ? 'clear' : 'neutral';
        return `<article class="weather-day-card" data-weather-day-card><header><span class="weather-day-card__icon" aria-hidden="true">${weather.emoji}</span><div><strong>${escapeHtml(dayLabel)}</strong><small>${escapeHtml(weather.label)}</small></div></header><div class="weather-day-card__temperature"><b>${Math.round(safeNumber(day.temperatureMaxC))}°</b><span>${Math.round(safeNumber(day.temperatureMinC))}°</span></div><div class="weather-day-card__facts"><span>⌄ ${Math.round(safeNumber(day.rainProbability))}%</span><span>⌁ ${Math.round(windKmh)} km/h</span></div><p>${escapeHtml(copy.dayStatuses[key])}</p></article>`;
      }).join('') : `<p class="weather-dialog__empty">${escapeHtml(copy.dailyEmpty)}</p>`;
      const recommendation = root.querySelector('[data-weather-recommendation]');
      if (recommendation) recommendation.textContent = recommendationFor(result);
      if (dialogStatus instanceof HTMLElement) dialogStatus.hidden = true;
      dialogContent.hidden = false;
    };

    const renderCard = (result) => {
      const current = result.current;
      const condition = conditionFor(current.weatherCode);
      const icon = root.querySelector('[data-weather-icon]');
      const temperature = root.querySelector('[data-weather-temperature]');
      const conditionNode = root.querySelector('[data-weather-condition]');
      const feels = root.querySelector('[data-weather-feels]');
      const rain = root.querySelector('[data-weather-rain]');
      const wind = root.querySelector('[data-weather-wind]');
      const tabRain = root.querySelector('[data-weather-tab-rain]');
      const cardUpdated = root.querySelector('[data-weather-card-updated]');
      if (icon) icon.textContent = condition.emoji;
      if (temperature) temperature.textContent = `${Math.round(safeNumber(current.temperatureC))}°C`;
      if (conditionNode) conditionNode.textContent = hero ? condition.label : `${condition.label} · ${copy.feels} ${Math.round(safeNumber(current.apparentTemperatureC,current.temperatureC))}°C`;
      if (feels) feels.textContent = `${copy.feels}: ${Math.round(safeNumber(current.apparentTemperatureC,current.temperatureC))}°C`;
      if (rain) {
        const probability = result.daily?.[0]?.rainProbability;
        rain.textContent = Number.isFinite(Number(probability)) ? `${copy.rain}: ${Math.round(Number(probability))}%` : `${copy.rain}: ${safeNumber(current.precipitationMm).toFixed(1)} mm`;
        if (tabRain) tabRain.textContent = Number.isFinite(Number(probability)) ? `⌄ ${Math.round(Number(probability))}%` : `⌄ ${safeNumber(current.precipitationMm).toFixed(1)} mm`;
      }
      if (wind) wind.textContent = `${copy.wind}: ${Math.round(safeNumber(current.windKmh))} km/h`;
      if (cardUpdated) {
        const date = result.updatedAt ? new Date(result.updatedAt) : null;
        cardUpdated.textContent = date && !Number.isNaN(date.getTime())
          ? `${copy.updated}: ${new Intl.DateTimeFormat(dateLocale,{ hour:'2-digit',minute:'2-digit' }).format(date)}`
          : copy.live;
      }
      if (status instanceof HTMLElement) status.hidden = true;
      if (facts instanceof HTMLElement) facts.hidden = false;
      root.classList.remove('is-fallback');
      renderDialog(result);
    };

    const renderFallback = () => {
      root.classList.add('is-fallback');
      if (status instanceof HTMLElement) {
        status.hidden = false;
        status.textContent = hero ? copy.heroUnavailable : copy.unavailable;
      }
      if (facts instanceof HTMLElement) facts.hidden = true;
      if (dialogStatus instanceof HTMLElement) {
        dialogStatus.hidden = false;
        dialogStatus.innerHTML = `<span>☁️</span><strong>${escapeHtml(copy.unavailable)}</strong><button type="button" data-weather-retry>${escapeHtml(copy.retry)}</button>`;
      }
      if (dialogContent instanceof HTMLElement) dialogContent.hidden = true;
    };

    const load = async (force = false) => {
      if (force) clearWeatherRequestCache();
      if (dialogStatus instanceof HTMLElement) { dialogStatus.hidden = false; dialogStatus.textContent = copy.loading; }
      try {
        const result = await getPublicWeather({ locale:config.languageCode || 'pl' });
        if (!result.current) throw new Error('WEATHER_CURRENT_MISSING');
        payload = result;
        renderCard(result);
      } catch {
        payload = null;
        renderFallback();
      }
    };

    const closeDialog = () => {
      if (!(dialog instanceof HTMLDialogElement) || !dialog.open) return;
      dialog.classList.remove('is-visible');
      dialog.classList.add('is-closing');
      root.querySelector('[data-weather-open]')?.setAttribute('aria-expanded','false');
      window.setTimeout(() => {
        dialog.close();
        dialog.classList.remove('is-closing');
        document.body.classList.remove('weather-modal-open');
        if (lastTrigger instanceof HTMLElement) lastTrigger.focus();
      },window.matchMedia('(prefers-reduced-motion: reduce)').matches ? 0 : 180);
    };
    const openDialog = (trigger) => {
      if (!(dialog instanceof HTMLDialogElement)) return;
      lastTrigger = trigger instanceof HTMLElement ? trigger : root.querySelector('[data-weather-open]');
      if (!dialog.open) dialog.showModal();
      root.querySelector('[data-weather-open]')?.setAttribute('aria-expanded','true');
      document.body.classList.add('weather-modal-open');
      requestAnimationFrame(() => {
        dialog.classList.add('is-visible');
        dialog.querySelector('[data-weather-close]')?.focus();
      });
      if (payload) renderDialog(payload);
      trackWeather('open_weather',{ source:'hero_weather_drawer' });
    };

    root.addEventListener('click',(event) => {
      const element = event.target instanceof Element ? event.target : null;
      if (!element) return;
      if (element.closest('[data-weather-open]')) { openDialog(element.closest('[data-weather-open]')); return; }
      if (element.closest('[data-weather-close]')) { closeDialog(); return; }
      if (element.closest('[data-weather-retry]')) { load(true); return; }
      if (element.closest('[data-weather-campy]')) {
        window.dispatchEvent(new CustomEvent('campy:prompt',{ detail:{ prompt:copy.campyPrompt,actionKey:'weatherPlanner' } }));
        closeDialog();
      }
    });
    if (dialog instanceof HTMLDialogElement) {
      dialog.addEventListener('cancel',(event) => { event.preventDefault(); closeDialog(); });
      dialog.addEventListener('click',(event) => { if (event.target === dialog) closeDialog(); });
      dialog.addEventListener('keydown',(event) => {
        if (event.key === 'Escape') { event.preventDefault(); closeDialog(); return; }
        if (event.key !== 'Tab') return;
        const focusable = [...dialog.querySelectorAll('a[href],button:not([disabled]),[tabindex]:not([tabindex="-1"])')].filter((node) => node instanceof HTMLElement && !node.hidden);
        if (!focusable.length) return;
        const first = focusable[0];
        const last = focusable[focusable.length - 1];
        if (event.shiftKey && document.activeElement === first) { event.preventDefault(); last.focus(); }
        else if (!event.shiftKey && document.activeElement === last) { event.preventDefault(); first.focus(); }
      });
      dialog.addEventListener('close',() => document.body.classList.remove('weather-modal-open'));
    }
    if (hero) window.addEventListener('weather:open',(event) => openDialog(event.detail?.trigger));
    root.querySelector('[data-weather-cta]')?.addEventListener('click',() => trackWeather('weather_cta_click',{ source:'public_weather_card' }));
    load();
  });
</script>

<style>
.weather-card{width:min(1180px,calc(100% - 32px));margin:clamp(20px,4vw,42px) auto;display:grid;grid-template-columns:auto minmax(0,1fr) auto;align-items:center;gap:18px;padding:18px 20px;border:1px solid color-mix(in srgb,var(--color-primary,#3cb371) 26%,transparent);border-radius:24px;background:linear-gradient(135deg,color-mix(in srgb,var(--color-primary,#3cb371) 13%,var(--color-bg-secondary,#10251a)),color-mix(in srgb,var(--color-bg-secondary,#10251a) 94%,transparent));box-shadow:0 20px 55px rgba(4,23,14,.14);color:var(--color-text-primary,#effbf3)}
.weather-card__icon{width:58px;height:58px;display:grid;place-items:center;border-radius:18px;background:rgba(87,220,147,.14);font-size:1.75rem;color:#8fe0b4}.weather-card__main{min-width:0}.weather-card__main>span:first-child{display:block;color:#69d99b;font-size:.7rem;font-weight:900;letter-spacing:.11em;text-transform:uppercase}.weather-card h2{margin:3px 0 2px;font-size:1.2rem}.weather-card p{margin:0;color:var(--color-text-muted,rgba(239,251,243,.65));font-size:.9rem}.weather-card__facts{display:flex;flex-wrap:wrap;align-items:baseline;gap:7px 13px}.weather-card__facts strong{font-size:1.7rem}.weather-card__facts span{font-weight:800}.weather-card__facts small{color:var(--color-text-muted,rgba(239,251,243,.65));font-weight:700}.weather-card__cta{min-height:44px;display:inline-flex;align-items:center;gap:8px;padding:0 14px;border:1px solid rgba(114,235,166,.25);border-radius:14px;color:inherit;text-decoration:none;font-weight:850;background:rgba(255,255,255,.055)}.weather-card__cta:hover{border-color:#72eba6;transform:translateY(-1px)}.weather-card--compact{margin-top:18px;margin-bottom:18px}.weather-card.is-fallback .weather-card__icon{filter:saturate(.5)}
.weather-card--hero{position:absolute;z-index:7;top:47%;right:min(0px,calc((1440px - 100vw)/2));bottom:auto;width:292px;max-width:none;margin:0;padding:0;display:block;border:0;background:transparent;box-shadow:none;color:#fff;transform:translateY(-50%)}
.weather-card__trigger{position:relative;width:292px;min-height:132px;display:grid;grid-template-columns:82px minmax(0,1fr);grid-template-rows:1fr auto;align-items:center;gap:5px 13px;padding:13px 14px 13px 11px;overflow:hidden;border:1px solid rgba(147,239,188,.46);border-right:0;border-radius:20px 0 0 20px;color:inherit;background:radial-gradient(circle at 12% 0,rgba(107,238,164,.24),transparent 42%),linear-gradient(135deg,rgba(5,32,23,.94),rgba(8,70,44,.91));box-shadow:0 22px 55px rgba(0,0,0,.36),inset 0 1px rgba(255,255,255,.15),0 0 30px rgba(57,211,123,.12);backdrop-filter:blur(18px);-webkit-backdrop-filter:blur(18px);font:inherit;text-align:left;cursor:pointer;transform:translateX(176px);transition:transform .44s cubic-bezier(.22,1,.36,1),border-color .25s ease,box-shadow .25s ease,background .25s ease}
.weather-card__trigger::before{content:"";position:absolute;inset:0;pointer-events:none;background:linear-gradient(115deg,rgba(255,255,255,.11),transparent 28% 72%,rgba(120,243,174,.08));opacity:.8}
.weather-card--hero:hover .weather-card__trigger,.weather-card__trigger:focus-visible{transform:translateX(0);border-color:rgba(145,250,191,.78);background:radial-gradient(circle at 12% 0,rgba(107,238,164,.3),transparent 43%),linear-gradient(135deg,rgba(5,36,25,.97),rgba(9,79,49,.95));box-shadow:0 25px 62px rgba(0,0,0,.42),inset 0 1px rgba(255,255,255,.18),0 0 34px rgba(62,222,131,.2);outline:none}
.weather-card__edge-summary{position:relative;z-index:1;grid-row:1/3;display:grid;justify-items:center;align-content:center;gap:7px;min-width:0}.weather-card__edge-summary strong{color:#fff;font-size:2rem;line-height:1;letter-spacing:-.055em;text-shadow:0 4px 15px rgba(0,0,0,.34)}
.weather-card--hero .weather-card__icon{width:52px;height:52px;border:1px solid rgba(145,246,188,.16);border-radius:16px;background:rgba(79,218,139,.13);font-size:1.65rem;filter:drop-shadow(0 7px 15px rgba(49,209,118,.18))}
.weather-card--hero .weather-card__main{position:relative;z-index:1;align-self:end}.weather-card--hero .weather-card__eyebrow{display:flex!important;align-items:center;gap:6px;color:#9df2bf!important;font-size:.61rem!important;letter-spacing:.1em!important}.weather-card__eyebrow i{width:6px;height:6px;flex:0 0 auto;border-radius:50%;background:#64ec9d;box-shadow:0 0 0 4px rgba(100,236,157,.12),0 0 12px rgba(100,236,157,.55)}
