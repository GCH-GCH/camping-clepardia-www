---
import { logoMain, logoMainPng } from '@/data/assets';
import { getLanguageSwitchLinks, getLocalizedPath, getPathContext } from '@/utils/localizedLinks';

const footerNavItems = [
  { slug: '', label: 'Start' },
  { slug: 'camping', label: 'Camping' },
  { slug: 'domki', label: 'Domki' },
  { slug: 'cennik', label: 'Cennik' },
  { slug: 'dojazd', label: 'Dojazd' },
  { slug: 'atrakcje', label: 'Atrakcje' },
  { slug: 'kontakt', label: 'Kontakt' },
];

const pathContext = getPathContext(Astro.url.pathname);
const footerNavLinks = footerNavItems.map((item) => ({
  ...item,
  href: getLocalizedPath(pathContext.explicitLanguage, item.slug),
}));
const footerLanguageLinks = getLanguageSwitchLinks(Astro.url.pathname);
const footerSocialLinks = [
  { label: 'Facebook', href: 'https://www.facebook.com/CampingClepardia' },
  {
    label: 'Google Maps',
    href: 'https://www.google.com/maps/search/?api=1&query=Camping+Clepardia+Henryka+Pacho%C5%84skiego+28A+Krak%C3%B3w',
  },
];
---

<footer class="footer" id="kontakt">
  <div class="container footer__grid">
    <div class="footer__brand">
      <img class="footer__logo" src={logoMain} alt="Camping Clepardia" width="196" height="52" onerror={`this.onerror=null;this.src='${logoMainPng}'`} />
      <h2>Camping Clepardia</h2>
      <p>Camping w Krakowie blisko centrum miasta. Strona przygotowana pod przyszłe rezerwacje online i integrację z CC SYSTEM.</p>
      <div class="footer__langs" aria-label="Wersje językowe">
        {footerLanguageLinks.map((language) => (
          <a
            href={language.href}
            class:list={[language.active && 'is-active']}
            aria-label={`${language.name} ${language.code.toUpperCase()}`}
            aria-current={language.active ? 'page' : undefined}
          >
            {language.code.toUpperCase()}
          </a>
        ))}
      </div>
    </div>
    <div>
      <h3>Szybkie linki</h3>
      {footerNavLinks.map((link) => (
        <a href={link.href}>{link.label}</a>
      ))}
    </div>
    <div>
      <h3>Kontakt</h3>
      <p>Camping Clepardia<br />Kraków, Polska</p>
      <p>Recepcja i zapytania rezerwacyjne</p>
    </div>
    <div>
      <h3>Social media</h3>
      {footerSocialLinks.map((link) => (
        <a href={link.href} target="_blank" rel="noopener noreferrer">{link.label}</a>
      ))}
    </div>
  </div>
  <div class="container footer__bottom">
    <p>© <span id="year"></span> Camping Clepardia. Wszystkie prawa zastrzeżone.</p>
    <p>Online booking foundation ready.</p>
  </div>
</footer>

<script>
  const year = document.getElementById('year');
  if (year) year.textContent = String(new Date().getFullYear());
</script>

<style>
.footer { background: #0d1812; color: #fff; padding: 72px 0 28px; overflow: hidden; }
.footer__grid { display: grid; gap: 34px; grid-template-columns: 1fr; }
.footer__grid > *, .footer__brand { min-width: 0; }
.footer__logo { display: block; height: 52px; width: auto; object-fit: contain; image-rendering: auto; margin-bottom: 22px; filter: drop-shadow(0 16px 34px rgba(60,179,113,.20)); }
.footer h2 { color: #fff; font-size: clamp(2rem, 4vw, 3rem); font-weight: 900; margin-bottom: 18px; }
.footer h3 { color: #8fe0b4; font-size: .86rem; text-transform: uppercase; letter-spacing: .14em; margin-bottom: 18px; }
.footer p, .footer a { color: rgba(255,255,255,.72); line-height: 1.75; }
.footer a { display: block; margin: 8px 0; overflow-wrap: anywhere; }
.footer a:hover { color: #8fe0b4; }
.footer__brand p { max-width: 520px; }
.footer__langs { display: flex; flex-wrap: wrap; gap: 8px; max-width: 100%; margin-top: 24px; }
.footer__langs a { padding: 8px 12px; border-radius: 999px; border: 1px solid rgba(255,255,255,.14); color: #fff; font-weight: 900; }
.footer__langs a:hover, .footer__langs a.is-active { border-color: rgba(143,224,180,.48); color: #8fe0b4; }
.footer__bottom { margin-top: 46px; padding-top: 24px; border-top: 1px solid rgba(255,255,255,.10); display: flex; flex-direction: column; gap: 8px; justify-content: space-between; }
@media (min-width: 800px) { .footer__grid { grid-template-columns: 1.6fr .8fr .8fr .6fr; } .footer__bottom { flex-direction: row; } }
@media (max-width: 640px) { .footer h2 { font-size: clamp(1.85rem, 9vw, 2.55rem); } .footer__langs a { margin: 0; } }
</style>
