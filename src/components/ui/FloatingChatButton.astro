  background:
    linear-gradient(180deg, rgba(255,255,255,.07), rgba(255,255,255,0)),
    radial-gradient(circle at 20% 0%, rgba(60,179,113,.12), transparent 42%);
}

.floating-chat__avatar {
  border-radius: 24px;
  background:
    radial-gradient(circle at 30% 14%, rgba(255,255,255,.86), transparent 30%),
    linear-gradient(145deg, #f2c078, #9be7bb 48%, #3CB371);
