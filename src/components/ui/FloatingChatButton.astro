---
import { getTranslations } from '@/i18n/config';
import { getPathContext } from '@/utils/localizedLinks';
import Icon from '@/components/ui/Icon.astro';
import { campyIcon, publicAssetExists } from '@/data/assets';

const pathContext = getPathContext(Astro.url.pathname);
const t = getTranslations(pathContext.languageCode);
const chatTexts = t.chat;
const hasCampyIcon = publicAssetExists(campyIcon);
const campyUxCopy = {
  pl: {
    actions: {
      todayAttractions: 'Atrakcje na dziś',
      tramRoute: 'Trasa tramwajem',
