      wieliczka: 'Wieliczka to klasyczna wycieczka z Krakowa: podziemne trasy i historia kopalni soli. Warto sprawdzić aktualne godziny i dostępność przed wyjazdem.',
      auschwitz: 'Auschwitz-Birkenau to poważna, całodniowa wycieczka. Najlepiej wcześniej sprawdzić bilety, zasady zwiedzania i transport.',
      weather: 'Nie mam jeszcze podpiętej pogody live. Najpewniej sprawdź aktualną prognozę w aplikacji pogodowej, a ja podpowiem plan: centrum tramwajem przy dobrej pogodzie, muzea i Fabryka Schindlera przy deszczu.',
      rain: 'Na deszczowy dzień wybierz Fabrykę Schindlera, muzea, kawiarnie na Starym Mieście albo Wieliczkę. Tramwaj pozwala zostawić auto na campingu.',
    },
  },
  en: {
    actions: {
      todayAttractions: 'Today’s attractions',
      tramRoute: 'Tram route',
      etoll: 'e-TOLL',
      energylandia: 'Energylandia',
      wieliczka: 'Wieliczka',
      auschwitz: 'Auschwitz',
      weather: 'Weather',
      rain: 'Rainy day ideas',
    },
    answers: {
      todayAttractions: 'Start light: tram to the centre, Old Town, coffee or lunch, then return to the calm green base at Clepardia. For a bigger trip, check Wieliczka, Schindler’s Factory or SeeKrakow.',
      tramRoute: 'The tram stop is about 40 m from the gate. It is about 9 stops and around 14 minutes to Stary Kleparz / the city centre. Use Jakdojade and Google Maps for routes and tickets.',
      etoll: 'If you travel with a larger vehicle or combination, check e-TOLL rules before the route. CAMPY does not quote limits without a source.',
      energylandia: 'Energylandia is a full-day trip outside Krakow. Treat it as a separate day and return to rest at the campsite.',
      wieliczka: 'Wieliczka is a classic Krakow-area tour with underground routes and salt mine history. Check current hours and availability before leaving.',
      auschwitz: 'Auschwitz-Birkenau is a serious full-day visit. Check tickets, visitor rules and transport in advance.',
      weather: 'I do not have live weather connected yet. Check your weather app; I can suggest Old Town on sunny days and museums or Schindler’s Factory when it rains.',
      rain: 'For rain, choose Schindler’s Factory, museums, Old Town cafés or Wieliczka. The tram lets you leave the car at the campsite.',
    },
  },
  de: {
    actions: {
      todayAttractions: 'Attraktionen heute',
      tramRoute: 'Straßenbahnroute',
      etoll: 'e-TOLL',
      energylandia: 'Energylandia',
      wieliczka: 'Wieliczka',
      auschwitz: 'Auschwitz',
      weather: 'Wetter',
      rain: 'Ideen bei Regen',
    },
    answers: {
      todayAttractions: 'Starten Sie entspannt: Straßenbahn ins Zentrum, Altstadt, Kaffee oder Mittagessen und danach zurück zur grünen Basis Clepardia. Für größere Ausflüge: Wieliczka, Schindler-Fabrik oder SeeKrakow.',
      tramRoute: 'Die Haltestelle ist ca. 40 m vom Tor entfernt. Zum Stary Kleparz / Zentrum sind es ca. 9 Haltestellen und etwa 14 Minuten. Nutzen Sie Jakdojade und Google Maps.',
      etoll: 'Wenn Sie mit größerem Fahrzeug oder Gespann reisen, prüfen Sie vor der Route e-TOLL. CAMPY nennt keine Grenzen ohne Quelle.',
      energylandia: 'Energylandia ist ein Tagesausflug außerhalb von Krakau. Planen Sie ihn als eigenen Tag und erholen Sie sich danach auf dem Campingplatz.',
      wieliczka: 'Wieliczka ist ein klassischer Ausflug mit unterirdischen Routen und Salzbergwerk-Geschichte. Prüfen Sie Zeiten und Verfügbarkeit.',
      auschwitz: 'Auschwitz-Birkenau ist ein ernster Tagesausflug. Tickets, Regeln und Transport bitte vorab prüfen.',
      weather: 'Live-Wetter ist noch nicht angebunden. Prüfen Sie die Wetter-App; bei Regen empfehle ich Museen oder die Schindler-Fabrik.',
      rain: 'Bei Regen: Schindler-Fabrik, Museen, Cafés in der Altstadt oder Wieliczka. Mit der Straßenbahn bleibt das Auto auf dem Campingplatz.',
    },
  },
  it: {
    actions: {
      todayAttractions: 'Attrazioni oggi',
      tramRoute: 'Percorso tram',
      etoll: 'e-TOLL',
      energylandia: 'Energylandia',
      wieliczka: 'Wieliczka',
      auschwitz: 'Auschwitz',
      weather: 'Meteo',
      rain: 'Idee con pioggia',
    },
    answers: {
      todayAttractions: 'Inizia leggero: tram per il centro, Città Vecchia, caffè o pranzo, poi ritorno alla base verde Clepardia. Per una gita più grande: Wieliczka, Fabbrica di Schindler o SeeKrakow.',
      tramRoute: 'La fermata è a circa 40 m dal cancello. Sono circa 9 fermate e 14 minuti fino a Stary Kleparz / centro. Usa Jakdojade e Google Maps.',
      etoll: 'Se viaggi con un veicolo grande o un insieme, controlla le regole e-TOLL prima del percorso. CAMPY non indica limiti senza fonte.',
      energylandia: 'Energylandia è una gita di un’intera giornata fuori Cracovia. Pianificala come giorno separato e poi rilassati al camping.',
      wieliczka: 'Wieliczka è una gita classica con percorsi sotterranei e storia della miniera di sale. Controlla orari e disponibilità.',
      auschwitz: 'Auschwitz-Birkenau è una visita seria di un’intera giornata. Controlla biglietti, regole e trasporto in anticipo.',
      weather: 'Non ho ancora il meteo live collegato. Controlla l’app meteo; con pioggia consiglio musei o Fabbrica di Schindler.',
      rain: 'Con pioggia scegli Fabbrica di Schindler, musei, caffè nel centro storico o Wieliczka. Il tram permette di lasciare l’auto al camping.',
    },
  },
};
const campyEnhancement = campyUxCopy[pathContext.languageCode as keyof typeof campyUxCopy] ?? campyUxCopy.en;
const enhancedChatTexts = {
  ...chatTexts,
  actions: {
    ...chatTexts.actions,
    ...campyEnhancement.actions,
  },
  answers: {
    ...chatTexts.answers,
    ...campyEnhancement.answers,
  },
};
const chatConfigEncoded = Buffer.from(JSON.stringify(enhancedChatTexts), 'utf8').toString('base64');
const quickActions = [
  { key: 'dayPlan', icon: 'map', label: enhancedChatTexts.actions.dayPlan ?? enhancedChatTexts.actions.attractions },
  { key: 'todayAttractions', icon: 'Sparkles', label: enhancedChatTexts.actions.todayAttractions },
  { key: 'tramRoute', icon: 'tram', label: enhancedChatTexts.actions.tramRoute },
  { key: 'maps', icon: 'map', label: enhancedChatTexts.actions.maps },
  { key: 'sctEtoll', icon: 'route', label: enhancedChatTexts.actions.sctEtoll ?? 'SCT / e-TOLL' },
  { key: 'etoll', icon: 'Truck', label: enhancedChatTexts.actions.etoll },
  { key: 'energylandia', icon: 'FerrisWheel', label: enhancedChatTexts.actions.energylandia },
  { key: 'wieliczka', icon: 'Mountain', label: enhancedChatTexts.actions.wieliczka },
  { key: 'auschwitz', icon: 'landmark', label: enhancedChatTexts.actions.auschwitz },
  { key: 'weather', icon: 'CloudSun', label: enhancedChatTexts.actions.weather },
  { key: 'rain', icon: 'CloudRain', label: enhancedChatTexts.actions.rain },
  { key: 'reception', icon: 'message', label: enhancedChatTexts.actions.reception },
];
---

<div class="floating-chat" data-floating-chat>
  <button
    class="floating-chat__button"
    type="button"
    data-chat-toggle
    aria-label={chatTexts.open}
    aria-expanded="false"
    aria-controls="floatingChatPanel"
  >
    {hasCampyIcon ? (
      <img class="floating-chat__button-image" src={campyIcon} alt="" width="62" height="62" loading="eager" decoding="async" />
    ) : (
      <span class="floating-chat__button-fallback" aria-hidden="true">CAMPY</span>
    )}
  </button>

  <div class="floating-chat__scrim" data-chat-close aria-hidden="true"></div>

  <section
    class="floating-chat__panel"
    id="floatingChatPanel"
    data-chat-panel
    role="dialog"
    aria-modal="true"
    aria-label={chatTexts.title}
    aria-hidden="true"
    hidden
    inert
  >
    <header class="floating-chat__header">
      <span class="floating-chat__avatar" aria-hidden="true">
        {hasCampyIcon ? (
          <img class="floating-chat__avatar-image" src={campyIcon} alt="" width="62" height="62" loading="lazy" decoding="async" />
        ) : (
          <>
            <Icon name="sparkle" size={21} strokeWidth={1.9} />
            <strong>CAMPY</strong>
          </>
        )}
      </span>
      <div class="floating-chat__identity">
        <span data-chat-title-node></span>
        <strong><i aria-hidden="true"></i><span data-chat-status-node></span></strong>
      </div>
      <button type="button" data-chat-close aria-label={chatTexts.close}>
        <Icon name="close" size={20} strokeWidth={2} />
      </button>
    </header>

    <div class="floating-chat__messages" data-chat-messages aria-live="polite"></div>

    <div class="floating-chat__quick" data-chat-quick-rail tabindex="0" role="list" aria-label={chatTexts.quickLabel}>
      {quickActions.map((action) => (
        <button type="button" data-chat-prompt={action.label} aria-label={action.label} role="listitem">
          <Icon name={action.icon} size={16} strokeWidth={1.9} />
          <span data-chat-quick-label></span>
        </button>
      ))}
    </div>

    <form class="floating-chat__form" data-chat-form>
      <label class="sr-only" for="floatingChatInput" data-chat-input-label></label>
      <input id="floatingChatInput" data-chat-input type="text" autocomplete="off" placeholder="" />
      <button type="submit" data-chat-send aria-label="">
        <Icon name="send" size={20} strokeWidth={2} />
      </button>
    </form>
  </section>
</div>

<script define:vars={{ chatConfigEncoded }}>
  (() => {
    const root = document.querySelector('[data-floating-chat]');
    if (!(root instanceof HTMLElement)) return;

    const decodeChatTexts = () => {
      try {
        const binary = window.atob(chatConfigEncoded);
        const bytes = Uint8Array.from(binary, (character) => character.charCodeAt(0));
        return JSON.parse(new TextDecoder().decode(bytes));
      } catch {
        return null;
      }
    };

    const chatTexts = decodeChatTexts();
    if (!chatTexts) return;

    const toggle = root.querySelector('[data-chat-toggle]');
    const panel = root.querySelector('[data-chat-panel]');
    const closeButtons = root.querySelectorAll('[data-chat-close]');
    const form = root.querySelector('[data-chat-form]');
    const input = root.querySelector('[data-chat-input]');
    const messages = root.querySelector('[data-chat-messages]');
    const quickActionButtons = root.querySelectorAll('[data-chat-prompt]');
    const titleNode = root.querySelector('[data-chat-title-node]');
    const statusNode = root.querySelector('[data-chat-status-node]');
    const inputLabel = root.querySelector('[data-chat-input-label]');
    const sendButton = root.querySelector('[data-chat-send]');
    const quickRail = root.querySelector('.floating-chat__quick');

    if (!(toggle instanceof HTMLButtonElement) || !(panel instanceof HTMLElement) || !(messages instanceof HTMLElement)) return;

    let open = false;
    let hideTimer = 0;
    let panelHydrated = false;

    const hydratePanelCopy = () => {
      if (panelHydrated) return;
      if (titleNode instanceof HTMLElement) titleNode.textContent = chatTexts.title;
      if (statusNode instanceof HTMLElement) statusNode.textContent = chatTexts.status;
      if (inputLabel instanceof HTMLElement) inputLabel.textContent = chatTexts.inputLabel;
      if (input instanceof HTMLInputElement) input.placeholder = chatTexts.inputPlaceholder;
      if (sendButton instanceof HTMLButtonElement) sendButton.setAttribute('aria-label', chatTexts.send);
      quickActionButtons.forEach((button) => {
        if (!(button instanceof HTMLElement)) return;
        const label = button.dataset.chatPrompt ?? '';
        const labelNode = button.querySelector('[data-chat-quick-label]');
        if (labelNode instanceof HTMLElement) labelNode.textContent = label;
      });
      panelHydrated = true;
    };

    const updateMobileAvailability = () => {
      const available = window.innerWidth > 640 || window.scrollY > 320 || open;
      root.classList.toggle('is-available', available);
    };

    const updateStickyOffset = () => {
      const mobileSummary = document.querySelector('[data-mobile-summary]');
      const hasMobileSummary = mobileSummary instanceof HTMLElement
        && window.innerWidth <= 1079
        && window.getComputedStyle(mobileSummary).display !== 'none';

      root.classList.toggle('is-raised', hasMobileSummary);
      updateMobileAvailability();
    };

    const setOpen = (nextOpen) => {
      open = nextOpen;
      window.clearTimeout(hideTimer);
      toggle.setAttribute('aria-expanded', String(open));
      toggle.setAttribute('aria-label', open ? chatTexts.close : chatTexts.open);
      panel.setAttribute('aria-hidden', String(!open));
      document.body.classList.toggle('has-floating-chat-open', open);
      updateMobileAvailability();

      if (open) {
        panel.hidden = false;
        panel.removeAttribute('inert');
        hydratePanelCopy();
        initializeMessages();
        root.classList.add('is-open');
        window.setTimeout(() => {
          if (input instanceof HTMLInputElement) input.focus({ preventScroll: true });
        }, 140);
        return;
      }

      root.classList.remove('is-open');
      panel.setAttribute('inert', '');
      hideTimer = window.setTimeout(() => {
        panel.hidden = true;
      }, 260);
      toggle.focus({ preventScroll: true });
    };

    const appendMessage = (text, type) => {
      const bubble = document.createElement('div');
      bubble.className = `floating-chat__message floating-chat__message--${type}`;
      bubble.textContent = text;
      messages.appendChild(bubble);
      messages.scrollTop = messages.scrollHeight;
      return bubble;
    };

    const initializeMessages = () => {
      if (messages.dataset.initialized === 'true') return;
      appendMessage(chatTexts.intro, 'bot');
      const notice = document.createElement('div');
      notice.className = 'floating-chat__notice';
      notice.textContent = chatTexts.notice;
      messages.appendChild(notice);
      messages.dataset.initialized = 'true';
    };

    const appendTyping = () => {
      const bubble = document.createElement('div');
      bubble.className = 'floating-chat__message floating-chat__message--bot floating-chat__message--typing';
      bubble.innerHTML = '<span></span><span></span><span></span>';
      messages.appendChild(bubble);
      messages.scrollTop = messages.scrollHeight;
      return bubble;
    };

    const resolveAnswer = (rawPrompt) => {
      const prompt = rawPrompt.toLowerCase();

      if (rawPrompt === chatTexts.actions.pricing || rawPrompt === chatTexts.actions.camperPrice) return chatTexts.answers.camperPrice ?? chatTexts.answers.pricing;
      if (rawPrompt === chatTexts.actions.directions || rawPrompt === chatTexts.actions.transit || rawPrompt === chatTexts.actions.centerTransit) return chatTexts.answers.centerTransit ?? chatTexts.answers.transit ?? chatTexts.answers.directions;
      if (rawPrompt === chatTexts.actions.dog) return chatTexts.answers.dog ?? chatTexts.answers.camping;
      if (rawPrompt === chatTexts.actions.campingBooking) return chatTexts.answers.campingBooking ?? chatTexts.answers.camping;
      if (rawPrompt === chatTexts.actions.bungalow) return chatTexts.answers.bungalows;
      if (rawPrompt === chatTexts.actions.arrival) return chatTexts.answers.arrival ?? chatTexts.answers.maps;
      if (rawPrompt === chatTexts.actions.reception) return chatTexts.answers.reception;
      if (rawPrompt === chatTexts.actions.quiet) return chatTexts.answers.quiet;
      if (rawPrompt === chatTexts.actions.maps) return chatTexts.answers.maps;
      if (rawPrompt === chatTexts.actions.sctEtoll) return chatTexts.answers.sctEtoll ?? chatTexts.answers.maps;
      if (rawPrompt === chatTexts.actions.attractions) return chatTexts.answers.attractions ?? chatTexts.answers.fallback;
      if (rawPrompt === chatTexts.actions.dayPlan) return chatTexts.answers.dayPlan ?? chatTexts.answers.attractions ?? chatTexts.answers.fallback;
      if (rawPrompt === chatTexts.actions.familyAttractions) return chatTexts.answers.familyAttractions ?? chatTexts.answers.attractions ?? chatTexts.answers.fallback;
      if (rawPrompt === chatTexts.actions.todayAttractions) return chatTexts.answers.todayAttractions ?? chatTexts.answers.attractions ?? chatTexts.answers.fallback;
      if (rawPrompt === chatTexts.actions.tramRoute) return chatTexts.answers.tramRoute ?? chatTexts.answers.centerTransit ?? chatTexts.answers.transit ?? chatTexts.answers.fallback;
      if (rawPrompt === chatTexts.actions.etoll) return chatTexts.answers.etoll ?? chatTexts.answers.sctEtoll ?? chatTexts.answers.fallback;
      if (rawPrompt === chatTexts.actions.energylandia) return chatTexts.answers.energylandia ?? chatTexts.answers.attractions ?? chatTexts.answers.fallback;
      if (rawPrompt === chatTexts.actions.wieliczka) return chatTexts.answers.wieliczka ?? chatTexts.answers.attractions ?? chatTexts.answers.fallback;
      if (rawPrompt === chatTexts.actions.auschwitz) return chatTexts.answers.auschwitz ?? chatTexts.answers.attractions ?? chatTexts.answers.fallback;
      if (rawPrompt === chatTexts.actions.weather) return chatTexts.answers.weather ?? chatTexts.answers.fallback;
      if (rawPrompt === chatTexts.actions.rain) return chatTexts.answers.rain ?? chatTexts.answers.attractions ?? chatTexts.answers.fallback;

      if (prompt.includes('kamper') || prompt.includes('camper') || prompt.includes('motorhome') || prompt.includes('cennik') || prompt.includes('cena') || prompt.includes('koszt')) {
        return chatTexts.answers.camperPrice ?? chatTexts.answers.pricing;
      }

      if (prompt.includes('tram') || prompt.includes('centrum') || prompt.includes('transport')) {
        return chatTexts.answers.tramRoute ?? chatTexts.answers.centerTransit ?? chatTexts.answers.transit ?? chatTexts.answers.directions;
      }

      if (prompt.includes('dojaz') || prompt.includes('jak dojecha') || prompt.includes('maps') || prompt.includes('map') || prompt.includes('nawig')) {
        return chatTexts.answers.maps ?? chatTexts.answers.directions;
      }

      if (prompt.includes('planuj') || prompt.includes('plan') || prompt.includes('dzień') || prompt.includes('day')) {
        return chatTexts.answers.dayPlan ?? chatTexts.answers.attractions ?? chatTexts.answers.fallback;
      }

      if (prompt.includes('dzieck') || prompt.includes('children') || prompt.includes('kids') || prompt.includes('kind')) {
        return chatTexts.answers.familyAttractions ?? chatTexts.answers.attractions ?? chatTexts.answers.fallback;
      }

      if (prompt.includes('pogod') || prompt.includes('weather')) return chatTexts.answers.weather ?? chatTexts.answers.fallback;
      if (prompt.includes('deszcz') || prompt.includes('rain')) return chatTexts.answers.rain ?? chatTexts.answers.attractions ?? chatTexts.answers.fallback;
      if (prompt.includes('energy')) return chatTexts.answers.energylandia ?? chatTexts.answers.attractions ?? chatTexts.answers.fallback;
      if (prompt.includes('wielicz')) return chatTexts.answers.wieliczka ?? chatTexts.answers.attractions ?? chatTexts.answers.fallback;
      if (prompt.includes('auschwitz') || prompt.includes('birkenau')) return chatTexts.answers.auschwitz ?? chatTexts.answers.attractions ?? chatTexts.answers.fallback;

      if (prompt.includes('atrakc') || prompt.includes('krak') || prompt.includes('zwiedz')) {
        return chatTexts.answers.todayAttractions ?? chatTexts.answers.attractions ?? chatTexts.answers.fallback;
      }

      if (prompt.includes('pies') || prompt.includes('psa') || prompt.includes('dog') || prompt.includes('hund') || prompt.includes('cane')) {
        return chatTexts.answers.dog ?? chatTexts.answers.camping;
      }

      if (prompt.includes('przyjazd') || prompt.includes('arrival') || prompt.includes('ankunft') || prompt.includes('arrivo')) {
        return chatTexts.answers.arrival ?? chatTexts.answers.maps;
      }

      if (prompt.includes('rezerw') || prompt.includes('booking') || prompt.includes('reserve') || prompt.includes('reserv')) {
        return chatTexts.answers.campingBooking ?? chatTexts.answers.reception;
      }

      if (prompt.includes('sct') || prompt.includes('e-toll') || prompt.includes('etoll')) {
        return chatTexts.answers.sctEtoll ?? chatTexts.answers.maps;
      }

      if (prompt.includes('cisza') || prompt.includes('imprez') || prompt.includes('quiet') || prompt.includes('party') || prompt.includes('ruhe')) {
        return chatTexts.answers.quiet;
      }

      if (prompt.includes('domek') || prompt.includes('domki')) {
        return chatTexts.answers.bungalows;
      }

      if (prompt.includes('kontakt') || prompt.includes('recepc')) {
        return chatTexts.answers.reception;
      }

      if (prompt.includes('camping') || prompt.includes('kamper') || prompt.includes('namiot') || prompt.includes('przyczepa')) {
        return chatTexts.answers.camping;
      }

      return chatTexts.answers.fallback;
    };

    const submitPrompt = (prompt) => {
      const cleanPrompt = prompt.trim();
      if (!cleanPrompt) return;

      appendMessage(cleanPrompt, 'user');
      const typing = appendTyping();
      window.setTimeout(() => {
        typing.remove();
        appendMessage(resolveAnswer(cleanPrompt), 'bot');
      }, 420);

      if (input instanceof HTMLInputElement) {
        input.value = '';
        input.focus({ preventScroll: true });
      }
    };

    toggle.addEventListener('click', () => setOpen(!open));

    closeButtons.forEach((button) => {
      button.addEventListener('click', () => setOpen(false));
    });

    quickActionButtons.forEach((button) => {
      button.addEventListener('click', () => {
        if (!(button instanceof HTMLButtonElement)) return;
        submitPrompt(button.dataset.chatPrompt ?? button.textContent ?? '');
      });
    });

    if (quickRail instanceof HTMLElement) {
      let dragging = false;
      let dragged = false;
      let startX = 0;
      let startScroll = 0;
      const maxScroll = () => Math.max(0, quickRail.scrollWidth - quickRail.clientWidth);

      quickRail.addEventListener('wheel', (event) => {
        const max = maxScroll();
        if (max <= 0) return;
        const delta = Math.abs(event.deltaX) > Math.abs(event.deltaY) ? event.deltaX : event.deltaY;
        const next = Math.max(0, Math.min(max, quickRail.scrollLeft + delta));
        if (next === quickRail.scrollLeft) return;
        event.preventDefault();
        quickRail.scrollLeft = next;
      }, { passive: false });

      quickRail.addEventListener('pointerdown', (event) => {
        if (event.button !== 0) return;
        dragging = true;
        dragged = false;
        startX = event.clientX;
        startScroll = quickRail.scrollLeft;
        quickRail.classList.add('is-dragging');
        quickRail.setPointerCapture?.(event.pointerId);
      });

      quickRail.addEventListener('pointermove', (event) => {
        if (!dragging) return;
        const delta = event.clientX - startX;
        if (Math.abs(delta) > 4) dragged = true;
        event.preventDefault();
        quickRail.scrollLeft = startScroll - delta;
      });

      const stopDrag = (event) => {
        dragging = false;
        quickRail.classList.remove('is-dragging');
        if ('pointerId' in event) quickRail.releasePointerCapture?.(event.pointerId);
        window.setTimeout(() => { dragged = false; }, 0);
      };

      quickRail.addEventListener('pointerup', stopDrag);
      quickRail.addEventListener('pointercancel', stopDrag);
      quickRail.addEventListener('mouseleave', () => {
        dragging = false;
        quickRail.classList.remove('is-dragging');
      });
      quickRail.addEventListener('click', (event) => {
        if (!dragged) return;
        event.preventDefault();
        event.stopPropagation();
      }, true);
      quickRail.addEventListener('keydown', (event) => {
        const step = event.shiftKey ? 240 : 120;
        if (event.key === 'ArrowRight') {
          event.preventDefault();
          quickRail.scrollBy({ left: step, behavior: 'smooth' });
        }
        if (event.key === 'ArrowLeft') {
          event.preventDefault();
          quickRail.scrollBy({ left: -step, behavior: 'smooth' });
        }
        if (event.key === 'Home') {
          event.preventDefault();
          quickRail.scrollTo({ left: 0, behavior: 'smooth' });
        }
        if (event.key === 'End') {
          event.preventDefault();
          quickRail.scrollTo({ left: maxScroll(), behavior: 'smooth' });
        }
      });
    }

    form?.addEventListener('submit', (event) => {
      event.preventDefault();
      submitPrompt(input instanceof HTMLInputElement ? input.value : '');
    });

    window.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && open) setOpen(false);
    });

    window.addEventListener('scroll', updateMobileAvailability, { passive: true });
    window.addEventListener('resize', updateStickyOffset, { passive: true });
    document.addEventListener('click', (event) => {
      const target = event.target;
      if (target instanceof Element && target.closest('[data-mobile-toggle]')) {
        window.setTimeout(updateStickyOffset, 40);
      }
    });

    updateStickyOffset();
  })();
</script>

