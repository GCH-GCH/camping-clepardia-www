    radial-gradient(circle at 18% 0%, rgba(60,179,113,.30), transparent 38%),
    radial-gradient(circle at 88% 100%, rgba(242,192,120,.18), transparent 42%),
    linear-gradient(145deg, rgba(13,32,24,.98), rgba(29,63,45,.94));
  box-shadow:
    0 30px 92px rgba(0,0,0,.28),
    0 0 34px rgba(60,179,113,.14),
    inset 0 1px 0 rgba(255,255,255,.12);
  backdrop-filter: blur(24px) saturate(145%);
  -webkit-backdrop-filter: blur(24px) saturate(145%);
  opacity: 0;
  transform: translateY(18px) scale(.97);
  transform-origin: bottom right;
  pointer-events: auto;
  transition:
    opacity .28s cubic-bezier(.22, 1, .36, 1),
    transform .28s cubic-bezier(.22, 1, .36, 1);
}

.floating-chat.has-quick-panel-open .floating-chat__panel {
  grid-template-rows: auto minmax(74px, .34fr) minmax(0, 1fr) auto;
}

.floating-chat__panel[hidden] {
  display: none !important;
}

.floating-chat.is-open .floating-chat__panel {
  opacity: 1;
  transform: translateY(0) scale(1);
}

.floating-chat__header {
  display: grid;
  grid-template-columns: 62px 1fr 40px;
  align-items: center;
  gap: 12px;
  padding: 18px 18px 15px;
  border-bottom: 1px solid rgba(255,255,255,.10);
}

.floating-chat__avatar {
  position: relative;
  width: 62px;
  height: 62px;
  display: grid;
  place-items: center;
  border-radius: 20px;
  color: #092016;
  background:
    radial-gradient(circle at 28% 20%, rgba(255,255,255,.82), transparent 30%),
    linear-gradient(135deg, #f2c078, #8fe0b4 48%, #3CB371);
  box-shadow: 0 16px 36px rgba(60,179,113,.28), 0 0 22px rgba(242,192,120,.14), inset 0 1px 0 rgba(255,255,255,.38);
}

.floating-chat__avatar-image {
  position: relative;
  z-index: 1;
  width: 100%;
  height: 100%;
  display: block;
  object-fit: cover;
  border-radius: inherit;
  filter: drop-shadow(0 8px 18px rgba(0,0,0,.16));
}

.floating-chat__avatar svg {
  position: absolute;
  right: 7px;
  top: 7px;
  width: 22px;
  height: 22px;
  opacity: .72;
}

.floating-chat__avatar strong {
  position: relative;
  z-index: 1;
  color: #092016;
  font-size: .62rem;
  font-weight: 1000;
  letter-spacing: .08em;
  text-shadow: 0 1px 0 rgba(255,255,255,.36);
}

.floating-chat__identity {
  min-width: 0;
}

.floating-chat__identity > span {
  display: block;
  color: #fff;
  font-size: 1rem;
  font-weight: 950;
  letter-spacing: -.01em;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.floating-chat__identity strong {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  margin-top: 3px;
  color: #8fe0b4;
  font-size: .72rem;
  font-weight: 900;
  letter-spacing: .12em;
  text-transform: uppercase;
}

.floating-chat__header i {
  width: 8px;
  height: 8px;
  border-radius: 999px;
  background: #8fe0b4;
  box-shadow: 0 0 16px rgba(143,224,180,.72);
}

.floating-chat__header button {
  width: 40px;
  height: 40px;
  display: grid;
  place-items: center;
  border: 1px solid rgba(255,255,255,.12);
  border-radius: 14px;
  color: #fff;
  background: rgba(255,255,255,.08);
  transition: transform .2s ease, border-color .2s ease, background .2s ease;
}

.floating-chat__header button:hover {
  transform: translateY(-1px);
  border-color: rgba(143,224,180,.34);
  background: rgba(255,255,255,.12);
}

.floating-chat__header svg,
.floating-chat__form svg {
  width: 20px;
  height: 20px;
  fill: none;
  stroke: currentColor;
  stroke-width: 2;
  stroke-linecap: round;
  stroke-linejoin: round;
}

.floating-chat__messages {
  display: grid;
  align-content: start;
  gap: 10px;
  min-height: 0;
  padding: 16px;
  overflow-y: auto;
}

.floating-chat.has-quick-panel-open .floating-chat__messages {
  max-height: min(210px, 26svh);
}

.floating-chat__message {
  max-width: 88%;
  padding: 12px 14px;
  border-radius: 20px;
  font-size: .92rem;
  line-height: 1.55;
  box-shadow: 0 12px 28px rgba(0,0,0,.08);
}

.floating-chat__message--bot {
  justify-self: start;
  color: rgba(255,255,255,.86);
  background:
    linear-gradient(145deg, rgba(255,255,255,.145), rgba(255,255,255,.082)),
    radial-gradient(circle at 12% 0%, rgba(60,179,113,.22), transparent 38%);
  border: 1px solid rgba(143,224,180,.16);
}

.floating-chat__message--user {
  justify-self: end;
  color: #07120d;
  background: #8fe0b4;
  box-shadow: 0 14px 34px rgba(60,179,113,.24);
}

.floating-chat__message-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-top: 10px;
}

.floating-chat__message-actions a {
  display: inline-flex;
  align-items: center;
  min-height: 34px;
  padding: 0 11px;
  border-radius: 999px;
  color: #082016;
  background: linear-gradient(135deg, #a8f0c4, #3CB371);
  font-size: .78rem;
  font-weight: 900;
  text-decoration: none;
  box-shadow: 0 10px 24px rgba(60,179,113,.20);
  transition: transform .18s ease, box-shadow .18s ease;
}

.floating-chat__message-actions a:hover {
  transform: translateY(-1px);
  box-shadow: 0 14px 30px rgba(60,179,113,.28);
}

.floating-chat__notice {
  padding: 11px 13px;
  border-radius: 16px;
  color: rgba(255,255,255,.82);
  background: linear-gradient(135deg, rgba(242,192,120,.12), rgba(60,179,113,.08));
  border: 1px solid rgba(242,192,120,.20);
  font-size: .78rem;
  line-height: 1.5;
}

.floating-chat__message--typing {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  width: fit-content;
  min-width: 62px;
}

.floating-chat__message--typing span {
  width: 6px;
  height: 6px;
  border-radius: 999px;
  background: #8fe0b4;
  opacity: .42;
  animation: chatTyping 1s ease-in-out infinite;
}

.floating-chat__message--typing span:nth-child(2) { animation-delay: .14s; }
.floating-chat__message--typing span:nth-child(3) { animation-delay: .28s; }

.floating-chat__quick-hub {
  position: relative;
  z-index: 1;
  width: 100%;
  max-width: 100%;
  min-width: 0;
  min-height: 0;
  display: flex;
  flex-direction: column;
  padding: 0 16px 10px;
  overflow: hidden;
}

.floating-chat__quick-toggle {
  width: 100%;
  min-height: 46px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
  padding: 0 14px;
  border: 1px solid rgba(143,224,180,.24);
  border-radius: 18px;
  color: #e7fff0;
  background:
    radial-gradient(circle at 16% 0%, rgba(143,224,180,.18), transparent 42%),
    linear-gradient(145deg, rgba(255,255,255,.12), rgba(255,255,255,.055));
  font-size: .84rem;
  font-weight: 950;
  box-shadow: 0 12px 28px rgba(0,0,0,.10), inset 0 1px 0 rgba(255,255,255,.12);
  transition: transform .2s ease, border-color .2s ease, box-shadow .2s ease, background .2s ease;
}

.floating-chat__quick-toggle:hover,
.floating-chat__quick-toggle[aria-expanded="true"] {
  transform: translateY(-1px);
  border-color: rgba(143,224,180,.48);
  background:
    radial-gradient(circle at 16% 0%, rgba(143,224,180,.24), transparent 44%),
    linear-gradient(145deg, rgba(255,255,255,.15), rgba(255,255,255,.07));
  box-shadow: 0 16px 34px rgba(60,179,113,.14), inset 0 1px 0 rgba(255,255,255,.14);
}

.floating-chat__quick-toggle span {
  flex: 1;
  text-align: left;
}

.floating-chat__quick-chevron {
  transition: transform .22s cubic-bezier(.22, 1, .36, 1);
}

.floating-chat__quick-toggle[aria-expanded="true"] .floating-chat__quick-chevron {
  transform: rotate(180deg);
}

.floating-chat__quick-panel {
  flex: 1 1 auto;
  min-height: 0;
  margin-top: 10px;
  max-height: none;
  padding: 12px 12px 82px;
  border: 1px solid rgba(143,224,180,.18);
  border-radius: 22px;
  background:
    radial-gradient(circle at 12% 0%, rgba(60,179,113,.16), transparent 36%),
    rgba(8,24,17,.76);
  box-shadow: inset 0 1px 0 rgba(255,255,255,.10), 0 18px 46px rgba(0,0,0,.16);
  overflow-y: auto;
  scroll-padding-bottom: 82px;
  overscroll-behavior: contain;
  scrollbar-width: thin;
  scrollbar-color: rgba(143,224,180,.72) rgba(255,255,255,.08);
  animation: campyQuickPanel .24s cubic-bezier(.22, 1, .36, 1) both;
}

.floating-chat__quick-panel::-webkit-scrollbar {
  width: 8px;
}

.floating-chat__quick-panel::-webkit-scrollbar-track {
  border-radius: 999px;
  background: rgba(255,255,255,.07);
}

.floating-chat__quick-panel::-webkit-scrollbar-thumb {
  border: 2px solid rgba(8,24,17,.76);
  border-radius: 999px;
  background: linear-gradient(180deg, #8fe0b4, #3CB371);
  box-shadow: 0 0 12px rgba(60,179,113,.22);
}

.floating-chat__quick-panel:focus-visible {
  outline: 0;
  box-shadow: inset 0 0 0 2px rgba(143,224,180,.38), 0 18px 46px rgba(0,0,0,.16);
}

.floating-chat__quick-panel[hidden] {
  display: none !important;
}

.floating-chat__quick-section + .floating-chat__quick-section {
  margin-top: 13px;
}

.floating-chat__quick-section h3 {
  display: flex;
  align-items: center;
  gap: 7px;
  margin: 0 0 8px;
  color: #a7f2c7;
  font-size: .72rem;
  font-weight: 950;
  letter-spacing: .08em;
  text-transform: uppercase;
}

.floating-chat__quick-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 7px;
}

.floating-chat__quick-grid button {
  width: 100%;
  min-height: 40px;
  display: flex;
  align-items: center;
  gap: 9px;
  padding: 9px 10px;
  border: 1px solid rgba(143,224,180,.18);
  border-radius: 15px;
  color: #e9fff2;
  background:
    linear-gradient(145deg, rgba(255,255,255,.10), rgba(255,255,255,.045)),
    rgba(60,179,113,.08);
  font-size: .82rem;
  font-weight: 850;
  text-align: left;
  transition: transform .18s ease, border-color .18s ease, background .18s ease, box-shadow .18s ease;
}

.floating-chat__quick-grid button:hover {
  transform: translateY(-1px);
  border-color: rgba(143,224,180,.42);
  background: rgba(60,179,113,.16);
  box-shadow: 0 12px 28px rgba(60,179,113,.12);
}

.floating-chat__quick {
  display: flex;
  width: 100%;
  max-width: 100%;
  min-width: 0;
  gap: 8px;
  padding: 0 16px 10px;
  overflow-x: auto;
  cursor: grab;
  scroll-snap-type: x mandatory;
  overscroll-behavior-inline: contain;
  scrollbar-width: none;
  touch-action: pan-x pan-y;
  -webkit-overflow-scrolling: touch;
  user-select: none;
  mask-image: linear-gradient(90deg, transparent 0, #000 20px, #000 calc(100% - 20px), transparent 100%);
}

.floating-chat__quick::-webkit-scrollbar {
  display: none;
}

.floating-chat__quick.is-dragging {
  cursor: grabbing;
  scroll-snap-type: none;
}

.floating-chat__quick:focus-visible {
  outline: 2px solid #8fe0b4;
  outline-offset: 3px;
}

.floating-chat__quick button {
  flex: 0 0 auto;
  min-width: 128px;
  min-height: 38px;
  display: inline-flex;
  align-items: center;
  gap: 7px;
  padding: 0 13px;
  border: 1px solid rgba(143,224,180,.28);
  border-radius: 999px;
  color: #d9ffe9;
  background:
    radial-gradient(circle at 20% 0%, rgba(255,255,255,.12), transparent 38%),
    rgba(60,179,113,.14);
  font-size: .78rem;
  font-weight: 850;
  white-space: nowrap;
  scroll-snap-align: start;
  transition: transform .2s ease, background .2s ease, border-color .2s ease, color .2s ease;
}

.floating-chat__quick svg {
  width: 16px;
  height: 16px;
  fill: none;
  stroke: currentColor;
  stroke-width: 1.9;
  stroke-linecap: round;
  stroke-linejoin: round;
}

.floating-chat__quick button:hover {
  border-color: rgba(143,224,180,.56);
  background: rgba(60,179,113,.24);
  box-shadow: 0 12px 28px rgba(60,179,113,.18);
  transform: translateY(-1px);
}

.floating-chat__quick-scrollbar {
  position: relative;
  height: 12px;
  margin: 0 18px 10px;
  border-radius: 999px;
  background:
    linear-gradient(90deg, rgba(255,255,255,.10), rgba(255,255,255,.045)),
    rgba(7,20,15,.34);
  box-shadow: inset 0 1px 0 rgba(255,255,255,.08);
  cursor: grab;
  pointer-events: auto;
  transition: opacity .2s ease, background .2s ease;
  overflow: hidden;
}

.floating-chat__quick-scrollbar::before,
.floating-chat__quick-scrollbar::after {
  content: '';
  position: absolute;
  inset-block: 0;
  width: 32px;
  z-index: 1;
  pointer-events: none;
  transition: opacity .18s ease;
}

.floating-chat__quick-scrollbar::before {
  left: 0;
  background: linear-gradient(90deg, rgba(7,20,15,.72), transparent);
}

.floating-chat__quick-scrollbar::after {
  right: 0;
  background: linear-gradient(270deg, rgba(7,20,15,.72), transparent);
}

.floating-chat__quick-scrollbar.is-at-start::before,
.floating-chat__quick-scrollbar.is-at-end::after {
  opacity: .18;
}

.floating-chat__quick-scrollbar.is-hidden {
  opacity: 0;
  pointer-events: none;
}

.floating-chat__quick-scrollbar.is-dragging {
  cursor: grabbing;
}

.floating-chat__quick-scrollbar:hover,
.floating-chat__quick-scrollbar.is-dragging {
  background:
    linear-gradient(90deg, rgba(143,224,180,.16), rgba(255,255,255,.06)),
    rgba(7,20,15,.42);
}

.floating-chat__quick-scrollbar span {
  position: absolute;
  inset-block: 2px;
  left: 2px;
  z-index: 2;
  width: 42px;
  border-radius: 999px;
  background:
    linear-gradient(90deg, rgba(255,255,255,.42), transparent 30%),
    linear-gradient(90deg, #8fe0b4, #3CB371);
  box-shadow: 0 0 16px rgba(60,179,113,.34), inset 0 1px 0 rgba(255,255,255,.34);
  transform: translateX(0);
  transition: width .18s cubic-bezier(.22, 1, .36, 1), box-shadow .18s ease;
  will-change: transform, width;
}

.floating-chat__quick-scrollbar.is-dragging span {
  transition: width .16s ease, box-shadow .16s ease;
}

.floating-chat__form {
  display: grid;
  grid-template-columns: 1fr 46px;
  gap: 10px;
  padding: 14px 16px 16px;
  border-top: 1px solid rgba(255,255,255,.10);
}

.floating-chat__form input {
  min-width: 0;
  height: 46px;
  padding: 0 14px;
  border: 1px solid rgba(255,255,255,.12);
  border-radius: 16px;
  color: #fff;
  background: rgba(255,255,255,.075);
  outline: none;
}

.floating-chat__form input::placeholder {
  color: rgba(255,255,255,.54);
}

.floating-chat__form input:focus {
  border-color: rgba(143,224,180,.54);
  box-shadow: 0 0 0 4px rgba(60,179,113,.16);
}

.floating-chat__form button {
  width: 46px;
  height: 46px;
  display: grid;
  place-items: center;
  border-radius: 16px;
  color: #fff;
  background: linear-gradient(135deg, #63d99c, #3CB371 50%, #24794e);
  box-shadow: 0 16px 38px rgba(60,179,113,.30);
}

.floating-chat button:focus-visible,
.floating-chat input:focus-visible {
  outline: 2px solid #8fe0b4;
  outline-offset: 3px;
}

html[data-theme="light"] .floating-chat__panel {
  color: #102018;
  border-color: rgba(25,54,38,.12);
  background:
    radial-gradient(circle at 18% 0%, rgba(60,179,113,.16), transparent 34%),
    radial-gradient(circle at 88% 100%, rgba(242,192,120,.14), transparent 38%),
    linear-gradient(145deg, rgba(247,248,241,.98), rgba(236,244,233,.95));
  box-shadow: 0 34px 90px rgba(42,62,45,.22), 0 0 34px rgba(60,179,113,.12), inset 0 1px 0 rgba(255,255,255,.78);
}

html[data-theme="light"] .floating-chat__header,
html[data-theme="light"] .floating-chat__form {
  border-color: rgba(25,54,38,.10);
}

html[data-theme="light"] .floating-chat__identity > span,
html[data-theme="light"] .floating-chat__header button {
  color: #102018;
}

html[data-theme="light"] .floating-chat__header button,
html[data-theme="light"] .floating-chat__message--bot,
html[data-theme="light"] .floating-chat__form input {
  color: #173624;
  border-color: rgba(25,54,38,.11);
  background: rgba(255,255,255,.62);
}

html[data-theme="light"] .floating-chat__notice {
  color: rgba(23,54,36,.72);
  border-color: rgba(166,115,47,.18);
  background: rgba(242,192,120,.16);
}

html[data-theme="light"] .floating-chat__form input::placeholder {
  color: rgba(23,54,36,.54);
}

html[data-theme="light"] .floating-chat__quick button {
  color: #1f744b;
  background: rgba(60,179,113,.12);
}

html[data-theme="light"] .floating-chat__quick-toggle,
html[data-theme="light"] .floating-chat__quick-panel,
html[data-theme="light"] .floating-chat__quick-grid button {
  color: #173624;
  border-color: rgba(25,54,38,.12);
  background:
    radial-gradient(circle at 12% 0%, rgba(60,179,113,.12), transparent 36%),
    rgba(255,255,255,.62);
}

html[data-theme="light"] .floating-chat__quick-section h3 {
  color: #1f744b;
}

html[data-theme="light"] .floating-chat__quick-scrollbar {
  background: rgba(35,73,48,.10);
  box-shadow: inset 0 1px 0 rgba(255,255,255,.80);
}

