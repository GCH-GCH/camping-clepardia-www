  },
  en: {
    actions: {
      bookStay: 'Book your stay',
      camperPrice: 'Camper price',
      centerTransit: 'How to reach centre?',
      dayPlan: 'Plan a Krakow day',
      familyAttractions: 'Kids attractions',
      dog: 'Can I bring a dog?',
      bungalowOptions: '2/3/4-person bungalows',
      combinedStay: 'Camping + bungalow',
      quiet: 'Quiet hours',
      sctEtoll: 'SCT / e-TOLL',
      maps: 'Google Maps',
      reception: 'Contact reception',
    },
    answers: {
      bookStay: 'Sure. Open the booking flow and choose Camping, Bungalows or Combined. It is an enquiry; reception confirms availability and final conditions.',
      camperPrice: 'Camper: 80 PLN / night. Adults: 35 PLN, children 4-14: 20 PLN, electricity: 25 PLN, dog: 0 PLN. The full calculator is on the price page.',
      centerTransit: 'The tram stop is about 40 m from the gate. It is about 9 stops and around 14 minutes to Stary Kleparz / the centre. Use Google Maps and Jakdojade.',
      dayPlan: 'Let us plan it. Tell me how much time you have, whether you travel with children, calm or intensive pace, and tram or car.',
      familyAttractions: 'With children, Old Town and Wawel, Wieliczka, Ojców or Energylandia usually work well depending on time and weather.',
      dog: 'Yes, dogs are welcome. Dog fee is 0 PLN. Please keep your dog under care and clean up after it.',
      bungalowOptions: 'Bungalows are only 2-, 3- and 4-person units. Availability is separate, and a deposit may be required after confirmation.',
      combinedStay: 'Choose Combined if part of the group stays in a bungalow and part arrives with a camper, caravan or tent.',
      quiet: 'Camping Clepardia is a calm campsite, not a party place. Quiet hours are 22:00-07:00.',
      sctEtoll: 'Before arrival, check current Krakow SCT and e-TOLL rules, especially for larger vehicles or combinations. Use official sources because rules can change.',
      maps: 'We recommend Google Maps because access to the campsite changed in 2022 and older navigation can be wrong.',
      reception: 'Reception: +48 795 294 486, email: clepardia@gmail.com. You can also open contact or booking.',
    },
  },
};
const finalCampy = finalCampyCopy[pathContext.languageCode as keyof typeof finalCampyCopy] ?? finalCampyCopy.en;
const enhancedChatTexts = {
  ...chatTexts,
  actions: {
    ...chatTexts.actions,
    ...campyEnhancement.actions,
    ...finalCampy.actions,
  },
  answers: {
    ...chatTexts.answers,
    ...campyEnhancement.answers,
    ...finalCampy.answers,
  },
  links: {
    booking: bookingHref,
    bookingCamping: bookingCampingHref,
    bookingBungalow: bookingBungalowHref,
    bookingCombined: bookingCombinedHref,
    prices: pricesHref,
    contact: contactHref,
    maps: mapsHref,
    jakdojade: jakdojadeHref,
    sct: sctHref,
    etoll: etollHref,
  },
};
const chatConfigEncoded = Buffer.from(JSON.stringify(enhancedChatTexts), 'utf8').toString('base64');
const quickActions = [
  { key: 'bookStay', icon: 'CalendarCheck', label: enhancedChatTexts.actions.bookStay },
  { key: 'camperPrice', icon: 'ReceiptText', label: enhancedChatTexts.actions.camperPrice },
  { key: 'centerTransit', icon: 'TramFront', label: enhancedChatTexts.actions.centerTransit },
  { key: 'dayPlan', icon: 'Map', label: enhancedChatTexts.actions.dayPlan },
  { key: 'familyAttractions', icon: 'UsersRound', label: enhancedChatTexts.actions.familyAttractions },
  { key: 'dog', icon: 'PawPrint', label: enhancedChatTexts.actions.dog },
  { key: 'bungalowOptions', icon: 'House', label: enhancedChatTexts.actions.bungalowOptions },
  { key: 'combinedStay', icon: 'Combine', label: enhancedChatTexts.actions.combinedStay },
  { key: 'quiet', icon: 'Moon', label: enhancedChatTexts.actions.quiet },
  { key: 'sctEtoll', icon: 'Route', label: enhancedChatTexts.actions.sctEtoll },
  { key: 'maps', icon: 'MapPin', label: enhancedChatTexts.actions.maps },
  { key: 'reception', icon: 'Mail', label: enhancedChatTexts.actions.reception },
];
---

<div class="floating-chat" data-floating-chat>
  <button
    class="floating-chat__button"
    type="button"
    data-chat-toggle
    aria-label={chatTexts.open}
    aria-expanded="false"
    aria-controls="floatingChatPanel"
  >
    {hasCampyIcon ? (
      <img class="floating-chat__button-image" src={campyIcon} alt="" width="62" height="62" loading="eager" decoding="async" />
    ) : (
      <span class="floating-chat__button-fallback" aria-hidden="true">CAMPY</span>
    )}
  </button>

  <div class="floating-chat__scrim" data-chat-close aria-hidden="true"></div>

  <section
    class="floating-chat__panel"
    id="floatingChatPanel"
    data-chat-panel
    role="dialog"
    aria-modal="true"
    aria-label={chatTexts.title}
    aria-hidden="true"
    hidden
    inert
  >
    <header class="floating-chat__header">
      <span class="floating-chat__avatar" aria-hidden="true">
        {hasCampyIcon ? (
          <img class="floating-chat__avatar-image" src={campyIcon} alt="" width="62" height="62" loading="lazy" decoding="async" />
        ) : (
          <>
            <Icon name="sparkle" size={21} strokeWidth={1.9} />
            <strong>CAMPY</strong>
          </>
        )}
      </span>
      <div class="floating-chat__identity">
        <span data-chat-title-node></span>
        <strong><i aria-hidden="true"></i><span data-chat-status-node></span></strong>
      </div>
      <button type="button" data-chat-close aria-label={chatTexts.close}>
        <Icon name="close" size={20} strokeWidth={2} />
      </button>
    </header>

    <div class="floating-chat__messages" data-chat-messages aria-live="polite"></div>

    <div class="floating-chat__quick" data-chat-quick-rail tabindex="0" role="list" aria-label={chatTexts.quickLabel}>
      {quickActions.map((action) => (
        <button type="button" data-chat-action={action.key} data-chat-prompt={action.label} aria-label={action.label} role="listitem">
          <Icon name={action.icon} size={16} strokeWidth={1.9} />
          <span data-chat-quick-label></span>
        </button>
      ))}
    </div>
    <div class="floating-chat__quick-scrollbar" data-chat-quick-scrollbar aria-hidden="true">
      <span data-chat-quick-scroll-thumb></span>
    </div>

    <form class="floating-chat__form" data-chat-form>
      <label class="sr-only" for="floatingChatInput" data-chat-input-label></label>
      <input id="floatingChatInput" data-chat-input type="text" autocomplete="off" placeholder="" />
      <button type="submit" data-chat-send aria-label="">
        <Icon name="send" size={20} strokeWidth={2} />
      </button>
    </form>
  </section>
</div>

<script define:vars={{ chatConfigEncoded }}>
  (() => {
    const root = document.querySelector('[data-floating-chat]');
    if (!(root instanceof HTMLElement)) return;

    const decodeChatTexts = () => {
      try {
        const binary = window.atob(chatConfigEncoded);
        const bytes = Uint8Array.from(binary, (character) => character.charCodeAt(0));
        return JSON.parse(new TextDecoder().decode(bytes));
      } catch {
        return null;
      }
    };

    const chatTexts = decodeChatTexts();
    if (!chatTexts) return;

    const toggle = root.querySelector('[data-chat-toggle]');
    const panel = root.querySelector('[data-chat-panel]');
    const closeButtons = root.querySelectorAll('[data-chat-close]');
    const form = root.querySelector('[data-chat-form]');
    const input = root.querySelector('[data-chat-input]');
    const messages = root.querySelector('[data-chat-messages]');
    const quickActionButtons = root.querySelectorAll('[data-chat-prompt]');
    const titleNode = root.querySelector('[data-chat-title-node]');
    const statusNode = root.querySelector('[data-chat-status-node]');
    const inputLabel = root.querySelector('[data-chat-input-label]');
    const sendButton = root.querySelector('[data-chat-send]');
    const quickRail = root.querySelector('.floating-chat__quick');
    const quickScrollbar = root.querySelector('[data-chat-quick-scrollbar]');
    const quickThumb = root.querySelector('[data-chat-quick-scroll-thumb]');

    if (!(toggle instanceof HTMLButtonElement) || !(panel instanceof HTMLElement) || !(messages instanceof HTMLElement)) return;

    let open = false;
    let hideTimer = 0;
    let panelHydrated = false;
    let quickThumbDragging = false;
    let quickThumbStartX = 0;
    let quickThumbStartScroll = 0;
    let quickScrollTarget = 0;
    let quickScrollRaf = 0;

    const quickMaxScroll = () => quickRail instanceof HTMLElement
      ? Math.max(0, quickRail.scrollWidth - quickRail.clientWidth)
      : 0;

    const updateQuickScrollbar = () => {
      if (!(quickRail instanceof HTMLElement) || !(quickScrollbar instanceof HTMLElement) || !(quickThumb instanceof HTMLElement)) return;
      const max = quickMaxScroll();
      quickScrollbar.classList.toggle('is-hidden', max <= 4);
      quickScrollbar.classList.toggle('is-at-start', quickRail.scrollLeft <= 2);
      quickScrollbar.classList.toggle('is-at-end', max > 4 && quickRail.scrollLeft >= max - 2);
      if (max <= 4) {
        quickThumb.style.width = '100%';
        quickThumb.style.transform = 'translateX(0)';
        return;
      }
      const trackWidth = quickScrollbar.clientWidth;
      const thumbWidth = Math.max(42, trackWidth * (quickRail.clientWidth / quickRail.scrollWidth));
      const travel = Math.max(1, trackWidth - thumbWidth);
      const left = (quickRail.scrollLeft / max) * travel;
      quickThumb.style.width = `${thumbWidth}px`;
      quickThumb.style.transform = `translate3d(${left}px,0,0)`;
    };

    const animateQuickScrollTo = (target) => {
      if (!(quickRail instanceof HTMLElement)) return;
      const max = quickMaxScroll();
      quickScrollTarget = Math.max(0, Math.min(max, target));
      if (quickScrollRaf) return;
      const tick = () => {
        if (!(quickRail instanceof HTMLElement)) {
          quickScrollRaf = 0;
          return;
        }
        const delta = quickScrollTarget - quickRail.scrollLeft;
        if (Math.abs(delta) < 0.5) {
          quickRail.scrollLeft = quickScrollTarget;
          quickScrollRaf = 0;
          updateQuickScrollbar();
          return;
        }
        quickRail.scrollLeft += delta * 0.22;
        updateQuickScrollbar();
        quickScrollRaf = window.requestAnimationFrame(tick);
      };
      quickScrollRaf = window.requestAnimationFrame(tick);
    };

    const hydratePanelCopy = () => {
      if (panelHydrated) return;
      if (titleNode instanceof HTMLElement) titleNode.textContent = chatTexts.title;
      if (statusNode instanceof HTMLElement) statusNode.textContent = chatTexts.status;
      if (inputLabel instanceof HTMLElement) inputLabel.textContent = chatTexts.inputLabel;
      if (input instanceof HTMLInputElement) input.placeholder = chatTexts.inputPlaceholder;
      if (sendButton instanceof HTMLButtonElement) sendButton.setAttribute('aria-label', chatTexts.send);
      quickActionButtons.forEach((button) => {
        if (!(button instanceof HTMLElement)) return;
        const label = button.dataset.chatPrompt ?? '';
        const labelNode = button.querySelector('[data-chat-quick-label]');
        if (labelNode instanceof HTMLElement) labelNode.textContent = label;
      });
      panelHydrated = true;
    };

    const updateMobileAvailability = () => {
      const available = window.innerWidth > 640 || window.scrollY > 320 || open;
      root.classList.toggle('is-available', available);
    };

    const updateStickyOffset = () => {
      const mobileSummary = document.querySelector('[data-mobile-summary]');
      const hasMobileSummary = mobileSummary instanceof HTMLElement
        && window.innerWidth <= 1079
        && window.getComputedStyle(mobileSummary).display !== 'none';

      root.classList.toggle('is-raised', hasMobileSummary);
      updateMobileAvailability();
    };

    const setOpen = (nextOpen) => {
      open = nextOpen;
      window.clearTimeout(hideTimer);
      toggle.setAttribute('aria-expanded', String(open));
      toggle.setAttribute('aria-label', open ? chatTexts.close : chatTexts.open);
      panel.setAttribute('aria-hidden', String(!open));
      document.body.classList.toggle('has-floating-chat-open', open);
      updateMobileAvailability();

      if (open) {
        panel.hidden = false;
        panel.removeAttribute('inert');
        hydratePanelCopy();
        initializeMessages();
        root.classList.add('is-open');
        window.setTimeout(updateQuickScrollbar, 80);
        window.setTimeout(() => {
          if (input instanceof HTMLInputElement) input.focus({ preventScroll: true });
        }, 140);
        return;
      }

      root.classList.remove('is-open');
      panel.setAttribute('inert', '');
      hideTimer = window.setTimeout(() => {
        panel.hidden = true;
      }, 260);
      toggle.focus({ preventScroll: true });
    };

    const appendMessage = (content, type) => {
      const text = typeof content === 'string' ? content : (content?.text || '');
      const actions = Array.isArray(content?.actions) ? content.actions : [];
      const bubble = document.createElement('div');
      bubble.className = `floating-chat__message floating-chat__message--${type}`;
      const textNode = document.createElement('span');
      textNode.textContent = text;
      bubble.appendChild(textNode);
      if (actions.length) {
        const actionWrap = document.createElement('div');
        actionWrap.className = 'floating-chat__message-actions';
        actions.forEach((action) => {
          if (!action?.href || !action?.label) return;
          const link = document.createElement('a');
          link.href = action.href;
          link.textContent = action.label;
          if (/^https?:\/\//.test(action.href)) {
            link.target = '_blank';
            link.rel = 'noopener noreferrer';
          }
          actionWrap.appendChild(link);
        });
        bubble.appendChild(actionWrap);
      }
      messages.appendChild(bubble);
      messages.scrollTop = messages.scrollHeight;
      return bubble;
    };

    const initializeMessages = () => {
      if (messages.dataset.initialized === 'true') return;
      appendMessage(chatTexts.intro, 'bot');
      const notice = document.createElement('div');
      notice.className = 'floating-chat__notice';
      notice.textContent = chatTexts.notice;
      messages.appendChild(notice);
      messages.dataset.initialized = 'true';
    };

    const appendTyping = () => {
      const bubble = document.createElement('div');
      bubble.className = 'floating-chat__message floating-chat__message--bot floating-chat__message--typing';
      bubble.innerHTML = '<span></span><span></span><span></span>';
      messages.appendChild(bubble);
      messages.scrollTop = messages.scrollHeight;
      return bubble;
    };

    const actionResponse = (key) => {
      const answers = chatTexts.answers || {};
      const links = chatTexts.links || {};
      const actionLabels = {
        booking: 'Przejdź do rezerwacji',
        prices: 'Zobacz cennik',
        maps: 'Otwórz Google Maps',
        jakdojade: 'Otwórz Jakdojade',
        contact: 'Kontakt',
        camping: 'Camping',
        bungalow: 'Domki',
        combined: 'Razem',
        sct: 'SCT Kraków',
        etoll: 'e-TOLL',
      };

      if (key === 'bookStay') return { text: answers.bookStay, actions: [{ label: actionLabels.booking, href: links.booking }] };
      if (key === 'camperPrice') return { text: answers.camperPrice, actions: [{ label: actionLabels.prices, href: links.prices }] };
      if (key === 'centerTransit') return { text: answers.centerTransit, actions: [{ label: actionLabels.maps, href: links.maps }, { label: actionLabels.jakdojade, href: links.jakdojade }] };
      if (key === 'dayPlan') return { text: answers.dayPlan };
      if (key === 'familyAttractions') return { text: answers.familyAttractions };
      if (key === 'dog') return { text: answers.dog };
      if (key === 'bungalowOptions') return { text: answers.bungalowOptions, actions: [{ label: actionLabels.bungalow, href: links.bookingBungalow }] };
      if (key === 'combinedStay') return { text: answers.combinedStay, actions: [{ label: actionLabels.camping, href: links.bookingCamping }, { label: actionLabels.bungalow, href: links.bookingBungalow }, { label: actionLabels.combined, href: links.bookingCombined }] };
      if (key === 'quiet') return { text: answers.quiet };
      if (key === 'sctEtoll') return { text: answers.sctEtoll, actions: [{ label: actionLabels.sct, href: links.sct }, { label: actionLabels.etoll, href: links.etoll }] };
      if (key === 'maps') return { text: answers.maps, actions: [{ label: actionLabels.maps, href: links.maps }] };
      if (key === 'reception') return { text: answers.reception, actions: [{ label: actionLabels.contact, href: links.contact }, { label: actionLabels.booking, href: links.booking }] };
      return null;
    };

    const resolveAnswer = (rawPrompt, actionKey = '') => {
      const keyed = actionResponse(actionKey);
      if (keyed) return keyed;
      const prompt = rawPrompt.toLowerCase();

      if (rawPrompt === chatTexts.actions.bookStay) return actionResponse('bookStay');
      if (rawPrompt === chatTexts.actions.pricing || rawPrompt === chatTexts.actions.camperPrice) return actionResponse('camperPrice') ?? chatTexts.answers.camperPrice ?? chatTexts.answers.pricing;
      if (rawPrompt === chatTexts.actions.directions || rawPrompt === chatTexts.actions.transit || rawPrompt === chatTexts.actions.centerTransit) return actionResponse('centerTransit') ?? chatTexts.answers.centerTransit ?? chatTexts.answers.transit ?? chatTexts.answers.directions;
      if (rawPrompt === chatTexts.actions.dog) return actionResponse('dog') ?? chatTexts.answers.dog ?? chatTexts.answers.camping;
      if (rawPrompt === chatTexts.actions.campingBooking) return chatTexts.answers.campingBooking ?? chatTexts.answers.camping;
      if (rawPrompt === chatTexts.actions.bungalow || rawPrompt === chatTexts.actions.bungalowOptions) return actionResponse('bungalowOptions') ?? chatTexts.answers.bungalows;
      if (rawPrompt === chatTexts.actions.arrival) return chatTexts.answers.arrival ?? chatTexts.answers.maps;
      if (rawPrompt === chatTexts.actions.reception) return actionResponse('reception') ?? chatTexts.answers.reception;
      if (rawPrompt === chatTexts.actions.quiet) return actionResponse('quiet') ?? chatTexts.answers.quiet;
      if (rawPrompt === chatTexts.actions.maps) return actionResponse('maps') ?? chatTexts.answers.maps;
      if (rawPrompt === chatTexts.actions.sctEtoll) return actionResponse('sctEtoll') ?? chatTexts.answers.sctEtoll ?? chatTexts.answers.maps;
      if (rawPrompt === chatTexts.actions.attractions) return chatTexts.answers.attractions ?? chatTexts.answers.fallback;
      if (rawPrompt === chatTexts.actions.dayPlan) return chatTexts.answers.dayPlan ?? chatTexts.answers.attractions ?? chatTexts.answers.fallback;
      if (rawPrompt === chatTexts.actions.familyAttractions) return chatTexts.answers.familyAttractions ?? chatTexts.answers.attractions ?? chatTexts.answers.fallback;
      if (rawPrompt === chatTexts.actions.todayAttractions) return chatTexts.answers.todayAttractions ?? chatTexts.answers.attractions ?? chatTexts.answers.fallback;
      if (rawPrompt === chatTexts.actions.tramRoute) return chatTexts.answers.tramRoute ?? chatTexts.answers.centerTransit ?? chatTexts.answers.transit ?? chatTexts.answers.fallback;
      if (rawPrompt === chatTexts.actions.etoll) return chatTexts.answers.etoll ?? chatTexts.answers.sctEtoll ?? chatTexts.answers.fallback;
      if (rawPrompt === chatTexts.actions.energylandia) return chatTexts.answers.energylandia ?? chatTexts.answers.attractions ?? chatTexts.answers.fallback;
      if (rawPrompt === chatTexts.actions.wieliczka) return chatTexts.answers.wieliczka ?? chatTexts.answers.attractions ?? chatTexts.answers.fallback;
      if (rawPrompt === chatTexts.actions.auschwitz) return chatTexts.answers.auschwitz ?? chatTexts.answers.attractions ?? chatTexts.answers.fallback;
      if (rawPrompt === chatTexts.actions.weather) return chatTexts.answers.weather ?? chatTexts.answers.fallback;
      if (rawPrompt === chatTexts.actions.rain) return chatTexts.answers.rain ?? chatTexts.answers.attractions ?? chatTexts.answers.fallback;

      if (prompt.includes('kamper') || prompt.includes('camper') || prompt.includes('motorhome') || prompt.includes('cennik') || prompt.includes('cena') || prompt.includes('koszt')) {
        return actionResponse('camperPrice') ?? chatTexts.answers.camperPrice ?? chatTexts.answers.pricing;
      }

      if (prompt.includes('tram') || prompt.includes('centrum') || prompt.includes('transport')) {
        return actionResponse('centerTransit') ?? chatTexts.answers.tramRoute ?? chatTexts.answers.centerTransit ?? chatTexts.answers.transit ?? chatTexts.answers.directions;
      }

      if (prompt.includes('dojaz') || prompt.includes('jak dojecha') || prompt.includes('maps') || prompt.includes('map') || prompt.includes('nawig')) {
        return actionResponse('maps') ?? chatTexts.answers.maps ?? chatTexts.answers.directions;
      }

      if (prompt.includes('planuj') || prompt.includes('plan') || prompt.includes('dzień') || prompt.includes('day')) {
        return chatTexts.answers.dayPlan ?? chatTexts.answers.attractions ?? chatTexts.answers.fallback;
      }

      if (prompt.includes('dzieck') || prompt.includes('children') || prompt.includes('kids') || prompt.includes('kind')) {
        return chatTexts.answers.familyAttractions ?? chatTexts.answers.attractions ?? chatTexts.answers.fallback;
      }

      if (prompt.includes('pogod') || prompt.includes('weather')) return chatTexts.answers.weather ?? chatTexts.answers.fallback;
      if (prompt.includes('deszcz') || prompt.includes('rain')) return chatTexts.answers.rain ?? chatTexts.answers.attractions ?? chatTexts.answers.fallback;
      if (prompt.includes('energy')) return chatTexts.answers.energylandia ?? chatTexts.answers.attractions ?? chatTexts.answers.fallback;
      if (prompt.includes('wielicz')) return chatTexts.answers.wieliczka ?? chatTexts.answers.attractions ?? chatTexts.answers.fallback;
      if (prompt.includes('auschwitz') || prompt.includes('birkenau')) return chatTexts.answers.auschwitz ?? chatTexts.answers.attractions ?? chatTexts.answers.fallback;

      if (prompt.includes('atrakc') || prompt.includes('krak') || prompt.includes('zwiedz')) {
        return chatTexts.answers.todayAttractions ?? chatTexts.answers.attractions ?? chatTexts.answers.fallback;
      }

      if (prompt.includes('pies') || prompt.includes('psa') || prompt.includes('dog') || prompt.includes('hund') || prompt.includes('cane')) {
        return actionResponse('dog') ?? chatTexts.answers.dog ?? chatTexts.answers.camping;
      }

      if (prompt.includes('przyjazd') || prompt.includes('arrival') || prompt.includes('ankunft') || prompt.includes('arrivo')) {
        return chatTexts.answers.arrival ?? chatTexts.answers.maps;
      }

      if (prompt.includes('rezerw') || prompt.includes('booking') || prompt.includes('reserve') || prompt.includes('reserv')) {
        return actionResponse('bookStay') ?? chatTexts.answers.campingBooking ?? chatTexts.answers.reception;
      }

      if (prompt.includes('sct') || prompt.includes('e-toll') || prompt.includes('etoll')) {
        return actionResponse('sctEtoll') ?? chatTexts.answers.sctEtoll ?? chatTexts.answers.maps;
      }

      if (prompt.includes('cisza') || prompt.includes('imprez') || prompt.includes('quiet') || prompt.includes('party') || prompt.includes('ruhe')) {
        return actionResponse('quiet') ?? chatTexts.answers.quiet;
      }

      if (prompt.includes('domek') || prompt.includes('domki')) {
        return actionResponse('bungalowOptions') ?? chatTexts.answers.bungalows;
      }

      if (prompt.includes('kontakt') || prompt.includes('recepc')) {
        return actionResponse('reception') ?? chatTexts.answers.reception;
      }

      if (prompt.includes('camping') || prompt.includes('kamper') || prompt.includes('namiot') || prompt.includes('przyczepa')) {
        return chatTexts.answers.camping;
      }

      return chatTexts.answers.fallback;
    };

    const submitPrompt = (prompt, actionKey = '') => {
      const cleanPrompt = prompt.trim();
      if (!cleanPrompt) return;

      appendMessage(cleanPrompt, 'user');
      const typing = appendTyping();
      window.setTimeout(() => {
        typing.remove();
        appendMessage(resolveAnswer(cleanPrompt, actionKey), 'bot');
      }, 420);

      if (input instanceof HTMLInputElement) {
        input.value = '';
        input.focus({ preventScroll: true });
      }
    };

    toggle.addEventListener('click', () => setOpen(!open));

    closeButtons.forEach((button) => {
      button.addEventListener('click', () => setOpen(false));
    });

    quickActionButtons.forEach((button) => {
      button.addEventListener('click', (event) => {
        event.preventDefault();
        if (!(button instanceof HTMLButtonElement)) return;
        submitPrompt(button.dataset.chatPrompt ?? button.textContent ?? '', button.dataset.chatAction ?? '');
      });
    });

    if (quickRail instanceof HTMLElement) {
      let dragging = false;
      let dragged = false;
      let startX = 0;
      let startScroll = 0;
      const maxScroll = () => Math.max(0, quickRail.scrollWidth - quickRail.clientWidth);

      quickRail.addEventListener('wheel', (event) => {
        const max = maxScroll();
        if (max <= 0) return;
        const delta = (Math.abs(event.deltaX) > Math.abs(event.deltaY) ? event.deltaX : event.deltaY) * 1.08;
        const next = Math.max(0, Math.min(max, (quickScrollRaf ? quickScrollTarget : quickRail.scrollLeft) + delta));
        if (next === quickRail.scrollLeft) return;
        event.preventDefault();
        animateQuickScrollTo(next);
      }, { passive: false });

      quickRail.addEventListener('pointerdown', (event) => {
        if (event.button !== 0) return;
        dragging = true;
        dragged = false;
        startX = event.clientX;
        startScroll = quickRail.scrollLeft;
        quickScrollTarget = quickRail.scrollLeft;
        if (quickScrollRaf) {
          window.cancelAnimationFrame(quickScrollRaf);
          quickScrollRaf = 0;
        }
        quickRail.classList.add('is-dragging');
        quickRail.setPointerCapture?.(event.pointerId);
      });

      quickRail.addEventListener('pointermove', (event) => {
        if (!dragging) return;
        const delta = event.clientX - startX;
        if (Math.abs(delta) > 4) dragged = true;
        event.preventDefault();
        quickRail.scrollLeft = startScroll - delta;
        updateQuickScrollbar();
      });

      const stopDrag = (event) => {
        dragging = false;
        quickRail.classList.remove('is-dragging');
        if ('pointerId' in event) quickRail.releasePointerCapture?.(event.pointerId);
        window.setTimeout(() => { dragged = false; }, 0);
      };

      quickRail.addEventListener('pointerup', stopDrag);
      quickRail.addEventListener('pointercancel', stopDrag);
      quickRail.addEventListener('mouseleave', () => {
        dragging = false;
        quickRail.classList.remove('is-dragging');
      });
      quickRail.addEventListener('click', (event) => {
        if (!dragged) return;
        event.preventDefault();
        event.stopPropagation();
      }, true);
      quickRail.addEventListener('keydown', (event) => {
        const step = event.shiftKey ? 240 : 120;
        if (event.key === 'ArrowRight') {
          event.preventDefault();
          quickRail.scrollBy({ left: step, behavior: 'smooth' });
          window.setTimeout(updateQuickScrollbar, 180);
        }
        if (event.key === 'ArrowLeft') {
          event.preventDefault();
          quickRail.scrollBy({ left: -step, behavior: 'smooth' });
          window.setTimeout(updateQuickScrollbar, 180);
        }
        if (event.key === 'Home') {
          event.preventDefault();
          quickRail.scrollTo({ left: 0, behavior: 'smooth' });
          window.setTimeout(updateQuickScrollbar, 180);
        }
        if (event.key === 'End') {
          event.preventDefault();
          quickRail.scrollTo({ left: maxScroll(), behavior: 'smooth' });
          window.setTimeout(updateQuickScrollbar, 180);
        }
      });
      quickRail.addEventListener('scroll', updateQuickScrollbar, { passive: true });
    }

    if (quickScrollbar instanceof HTMLElement && quickRail instanceof HTMLElement) {
      const scrollFromTrack = (event) => {
        const max = quickMaxScroll();
        if (max <= 0) return;
        const rect = quickScrollbar.getBoundingClientRect();
        const thumbWidth = quickThumb instanceof HTMLElement ? quickThumb.getBoundingClientRect().width : 42;
        const travel = Math.max(1, rect.width - thumbWidth);
        const x = Math.max(0, Math.min(travel, event.clientX - rect.left - thumbWidth / 2));
        quickRail.scrollLeft = (x / travel) * max;
        quickScrollTarget = quickRail.scrollLeft;
        updateQuickScrollbar();
      };

      quickScrollbar.addEventListener('pointerdown', (event) => {
        if (event.button !== 0) return;
        quickThumbDragging = true;
        quickScrollbar.classList.add('is-dragging');
        quickScrollbar.setPointerCapture?.(event.pointerId);
        if (quickScrollRaf) {
          window.cancelAnimationFrame(quickScrollRaf);
          quickScrollRaf = 0;
        }
        scrollFromTrack(event);
        quickThumbStartX = event.clientX;
        quickThumbStartScroll = quickRail.scrollLeft;
        event.preventDefault();
      });

      quickScrollbar.addEventListener('pointermove', (event) => {
        if (!quickThumbDragging) return;
        const max = quickMaxScroll();
        const rect = quickScrollbar.getBoundingClientRect();
        const thumbWidth = quickThumb instanceof HTMLElement ? quickThumb.getBoundingClientRect().width : 42;
        const travel = Math.max(1, rect.width - thumbWidth);
        const delta = event.clientX - quickThumbStartX;
        quickRail.scrollLeft = quickThumbStartScroll + (delta / travel) * max;
        quickScrollTarget = quickRail.scrollLeft;
        updateQuickScrollbar();
        event.preventDefault();
      });

      const stopThumbDrag = (event) => {
        quickThumbDragging = false;
        quickScrollbar.classList.remove('is-dragging');
        if ('pointerId' in event) quickScrollbar.releasePointerCapture?.(event.pointerId);
      };

      quickScrollbar.addEventListener('pointerup', stopThumbDrag);
      quickScrollbar.addEventListener('pointercancel', stopThumbDrag);
    }

    form?.addEventListener('submit', (event) => {
      event.preventDefault();
      submitPrompt(input instanceof HTMLInputElement ? input.value : '');
    });

    window.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && open) setOpen(false);
    });

    window.addEventListener('scroll', updateMobileAvailability, { passive: true });
    window.addEventListener('resize', () => {
      updateStickyOffset();
      updateQuickScrollbar();
    }, { passive: true });
    document.addEventListener('click', (event) => {
      const target = event.target;
      if (target instanceof Element && target.closest('[data-mobile-toggle]')) {
        window.setTimeout(updateStickyOffset, 40);
      }
    });

    updateStickyOffset();
  })();
</script>

