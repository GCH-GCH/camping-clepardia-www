---
import { getTranslations } from '@/i18n/config';
import { getPathContext } from '@/utils/localizedLinks';
import Icon from '@/components/ui/Icon.astro';
import { campyIcon, publicAssetExists } from '@/data/assets';

const pathContext = getPathContext(Astro.url.pathname);
const t = getTranslations(pathContext.languageCode);
const chatTexts = t.chat;
const hasCampyIcon = publicAssetExists(campyIcon);
const quickActions = [
  { key: 'pricing', icon: 'pricing', label: chatTexts.actions.pricing },
  { key: 'transit', icon: 'tram', label: chatTexts.actions.transit ?? chatTexts.actions.directions },
  { key: 'bungalow', icon: 'bungalow', label: chatTexts.actions.bungalow },
  { key: 'maps', icon: 'map', label: chatTexts.actions.maps },
  { key: 'reception', icon: 'phone', label: chatTexts.actions.reception },
  { key: 'quiet', icon: 'moon', label: chatTexts.actions.quiet },
  { key: 'attractions', icon: 'attractions', label: chatTexts.actions.attractions ?? 'Atrakcje' },
];
---

<div class="floating-chat" data-floating-chat>
  <button
    class="floating-chat__button"
    type="button"
    data-chat-toggle
    aria-label={chatTexts.open}
    aria-expanded="false"
    aria-controls="floatingChatPanel"
  >
    {hasCampyIcon ? (
      <img class="floating-chat__button-image" src={campyIcon} alt="" width="62" height="62" loading="eager" decoding="async" />
    ) : (
      <span class="floating-chat__button-fallback" aria-hidden="true">CAMPY</span>
    )}
  </button>

  <div class="floating-chat__scrim" data-chat-close aria-hidden="true"></div>

  <section
    class="floating-chat__panel"
    id="floatingChatPanel"
    data-chat-panel
    role="dialog"
    aria-modal="true"
    aria-label={chatTexts.title}
    aria-hidden="true"
    hidden
    inert
  >
    <header class="floating-chat__header">
      <span class="floating-chat__avatar" aria-hidden="true">
        {hasCampyIcon ? (
          <img class="floating-chat__avatar-image" src={campyIcon} alt="" width="62" height="62" loading="lazy" decoding="async" />
        ) : (
          <>
            <Icon name="sparkle" size={21} strokeWidth={1.9} />
            <strong>CAMPY</strong>
          </>
        )}
      </span>
      <div class="floating-chat__identity">
        <span data-chat-title-node></span>
        <strong><i aria-hidden="true"></i><span data-chat-status-node></span></strong>
      </div>
      <button type="button" data-chat-close aria-label={chatTexts.close}>
        <Icon name="close" size={20} strokeWidth={2} />
      </button>
    </header>

    <div class="floating-chat__messages" data-chat-messages aria-live="polite"></div>

    <div class="floating-chat__quick" aria-label={chatTexts.quickLabel}>
      {quickActions.map((action) => (
        <button type="button" data-chat-prompt={action.label} aria-label={action.label}>
          <Icon name={action.icon} size={16} strokeWidth={1.9} />
          <span data-chat-quick-label></span>
        </button>
      ))}
    </div>

    <form class="floating-chat__form" data-chat-form>
      <label class="sr-only" for="floatingChatInput">{chatTexts.inputLabel}</label>
      <input id="floatingChatInput" data-chat-input type="text" autocomplete="off" placeholder={chatTexts.inputPlaceholder} />
      <button type="submit" aria-label={chatTexts.send}>
        <Icon name="send" size={20} strokeWidth={2} />
      </button>
    </form>
  </section>
</div>

<script define:vars={{ chatTexts }}>
  (() => {
    const root = document.querySelector('[data-floating-chat]');
    if (!(root instanceof HTMLElement)) return;

    const toggle = root.querySelector('[data-chat-toggle]');
    const panel = root.querySelector('[data-chat-panel]');
    const closeButtons = root.querySelectorAll('[data-chat-close]');
    const form = root.querySelector('[data-chat-form]');
    const input = root.querySelector('[data-chat-input]');
    const messages = root.querySelector('[data-chat-messages]');
    const quickActionButtons = root.querySelectorAll('[data-chat-prompt]');
    const titleNode = root.querySelector('[data-chat-title-node]');
    const statusNode = root.querySelector('[data-chat-status-node]');

    if (!(toggle instanceof HTMLButtonElement) || !(panel instanceof HTMLElement) || !(messages instanceof HTMLElement)) return;

    let open = false;
    let hideTimer = 0;
    let panelHydrated = false;

    const hydratePanelCopy = () => {
      if (panelHydrated) return;
      if (titleNode instanceof HTMLElement) titleNode.textContent = chatTexts.title;
      if (statusNode instanceof HTMLElement) statusNode.textContent = chatTexts.status;
      quickActionButtons.forEach((button) => {
        if (!(button instanceof HTMLElement)) return;
        const label = button.dataset.chatPrompt ?? '';
        const labelNode = button.querySelector('[data-chat-quick-label]');
        if (labelNode instanceof HTMLElement) labelNode.textContent = label;
      });
      panelHydrated = true;
    };

    const updateMobileAvailability = () => {
      const available = window.innerWidth > 640 || window.scrollY > 320 || open;
      root.classList.toggle('is-available', available);
    };

    const updateStickyOffset = () => {
      const mobileSummary = document.querySelector('[data-mobile-summary]');
      const hasMobileSummary = mobileSummary instanceof HTMLElement
        && window.innerWidth <= 1079
        && window.getComputedStyle(mobileSummary).display !== 'none';

      root.classList.toggle('is-raised', hasMobileSummary);
      updateMobileAvailability();
    };

    const setOpen = (nextOpen) => {
      open = nextOpen;
      window.clearTimeout(hideTimer);
      toggle.setAttribute('aria-expanded', String(open));
      toggle.setAttribute('aria-label', open ? chatTexts.close : chatTexts.open);
      panel.setAttribute('aria-hidden', String(!open));
      document.body.classList.toggle('has-floating-chat-open', open);
      updateMobileAvailability();

      if (open) {
        panel.hidden = false;
        panel.removeAttribute('inert');
        hydratePanelCopy();
        initializeMessages();
        root.classList.add('is-open');
        window.setTimeout(() => {
          if (input instanceof HTMLInputElement) input.focus({ preventScroll: true });
        }, 140);
        return;
      }

      root.classList.remove('is-open');
      panel.setAttribute('inert', '');
      hideTimer = window.setTimeout(() => {
        panel.hidden = true;
      }, 260);
      toggle.focus({ preventScroll: true });
    };

    const appendMessage = (text, type) => {
      const bubble = document.createElement('div');
      bubble.className = `floating-chat__message floating-chat__message--${type}`;
      bubble.textContent = text;
      messages.appendChild(bubble);
      messages.scrollTop = messages.scrollHeight;
      return bubble;
    };

    const initializeMessages = () => {
      if (messages.dataset.initialized === 'true') return;
      appendMessage(chatTexts.intro, 'bot');
      const notice = document.createElement('div');
      notice.className = 'floating-chat__notice';
      notice.textContent = chatTexts.notice;
      messages.appendChild(notice);
      messages.dataset.initialized = 'true';
    };

    const appendTyping = () => {
      const bubble = document.createElement('div');
      bubble.className = 'floating-chat__message floating-chat__message--bot floating-chat__message--typing';
      bubble.innerHTML = '<span></span><span></span><span></span>';
      messages.appendChild(bubble);
      messages.scrollTop = messages.scrollHeight;
      return bubble;
    };

    const resolveAnswer = (rawPrompt) => {
      const prompt = rawPrompt.toLowerCase();

      if (rawPrompt === chatTexts.actions.pricing) return chatTexts.answers.pricing;
      if (rawPrompt === chatTexts.actions.directions || rawPrompt === chatTexts.actions.transit) return chatTexts.answers.transit ?? chatTexts.answers.directions;
      if (rawPrompt === chatTexts.actions.bungalow) return chatTexts.answers.bungalows;
      if (rawPrompt === chatTexts.actions.reception) return chatTexts.answers.reception;
      if (rawPrompt === chatTexts.actions.quiet) return chatTexts.answers.quiet;
      if (rawPrompt === chatTexts.actions.maps) return chatTexts.answers.maps;
      if (rawPrompt === chatTexts.actions.attractions) return chatTexts.answers.attractions ?? chatTexts.answers.fallback;

      if (prompt.includes('cennik') || prompt.includes('cena') || prompt.includes('koszt')) {
        return chatTexts.answers.pricing;
      }

      if (prompt.includes('tram') || prompt.includes('centrum') || prompt.includes('transport')) {
        return chatTexts.answers.transit ?? chatTexts.answers.directions;
      }

      if (prompt.includes('dojaz') || prompt.includes('jak dojecha') || prompt.includes('maps') || prompt.includes('map') || prompt.includes('nawig')) {
        return chatTexts.answers.maps ?? chatTexts.answers.directions;
      }

      if (prompt.includes('atrakc') || prompt.includes('krak') || prompt.includes('wielicz') || prompt.includes('energy') || prompt.includes('zwiedz')) {
        return chatTexts.answers.attractions ?? chatTexts.answers.fallback;
      }

      if (prompt.includes('cisza') || prompt.includes('imprez') || prompt.includes('quiet') || prompt.includes('party') || prompt.includes('ruhe')) {
        return chatTexts.answers.quiet;
      }

      if (prompt.includes('domek') || prompt.includes('domki')) {
        return chatTexts.answers.bungalows;
      }

      if (prompt.includes('kontakt') || prompt.includes('recepc')) {
        return chatTexts.answers.reception;
      }

      if (prompt.includes('camping') || prompt.includes('kamper') || prompt.includes('namiot') || prompt.includes('przyczepa')) {
        return chatTexts.answers.camping;
      }

      return chatTexts.answers.fallback;
    };

    const submitPrompt = (prompt) => {
      const cleanPrompt = prompt.trim();
      if (!cleanPrompt) return;

      appendMessage(cleanPrompt, 'user');
      const typing = appendTyping();
      window.setTimeout(() => {
        typing.remove();
        appendMessage(resolveAnswer(cleanPrompt), 'bot');
      }, 420);

      if (input instanceof HTMLInputElement) {
        input.value = '';
        input.focus({ preventScroll: true });
      }
    };

    toggle.addEventListener('click', () => setOpen(!open));

    closeButtons.forEach((button) => {
      button.addEventListener('click', () => setOpen(false));
    });

    quickActionButtons.forEach((button) => {
      button.addEventListener('click', () => {
        if (!(button instanceof HTMLButtonElement)) return;
        submitPrompt(button.dataset.chatPrompt ?? button.textContent ?? '');
      });
    });

    form?.addEventListener('submit', (event) => {
      event.preventDefault();
      submitPrompt(input instanceof HTMLInputElement ? input.value : '');
    });

    window.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && open) setOpen(false);
    });

    window.addEventListener('scroll', updateMobileAvailability, { passive: true });
    window.addEventListener('resize', updateStickyOffset, { passive: true });
    document.addEventListener('click', (event) => {
      const target = event.target;
      if (target instanceof Element && target.closest('[data-mobile-toggle]')) {
        window.setTimeout(updateStickyOffset, 40);
      }
    });

    updateStickyOffset();
  })();
</script>

<style is:global>
body.has-floating-chat-open {
  overflow: hidden;
}

.sr-only {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0, 0, 0, 0);
  white-space: nowrap;
  border: 0;
}

.floating-chat {
  position: fixed;
  inset: auto max(24px, env(safe-area-inset-right)) max(96px, calc(96px + env(safe-area-inset-bottom))) auto;
  z-index: 1250;
  pointer-events: none;
  max-width: calc(100vw - 24px);
  contain: layout style paint;
}

.floating-chat.is-open {
  z-index: 1300;
}

.floating-chat__button {
  position: relative;
  z-index: 1;
  width: 78px;
  height: 78px;
  display: grid;
  place-items: center;
  border-radius: 999px;
  border: 1px solid rgba(255,255,255,.22);
  color: #fff;
  background:
    radial-gradient(circle at 36% 24%, rgba(255,255,255,.34), transparent 30%),
    linear-gradient(135deg, #69dea3 0%, #3CB371 44%, #247a4f 100%);
  box-shadow:
    0 24px 70px rgba(60,179,113,.42),
    0 0 0 8px rgba(60,179,113,.08),
    inset 0 1px 0 rgba(255,255,255,.30);
  pointer-events: auto;
  overflow: hidden;
  transition:
    opacity .26s cubic-bezier(.22, 1, .36, 1),
    transform .26s cubic-bezier(.22, 1, .36, 1),
    box-shadow .26s cubic-bezier(.22, 1, .36, 1),
    border-color .26s cubic-bezier(.22, 1, .36, 1);
  animation: chatPulse 2.8s ease-in-out infinite;
}

.floating-chat__button:hover {
  transform: translateY(-4px) scale(1.04);
  border-color: rgba(255,255,255,.38);
  box-shadow:
    0 30px 86px rgba(60,179,113,.52),
    0 0 44px rgba(60,179,113,.32),
    inset 0 1px 0 rgba(255,255,255,.34);
}

.floating-chat__button:active {
  transform: translateY(0) scale(.96);
}

.floating-chat__icon {
  width: 28px;
  height: 28px;
  fill: none;
  stroke: currentColor;
  stroke-width: 1.9;
  stroke-linecap: round;
  stroke-linejoin: round;
  filter: drop-shadow(0 8px 18px rgba(0,0,0,.20));
}

.floating-chat__button-image {
  position: relative;
  z-index: 1;
  width: 62px;
  height: 62px;
  display: block;
  object-fit: contain;
  border-radius: 999px;
  filter:
    drop-shadow(0 10px 22px rgba(0,0,0,.22))
    drop-shadow(0 0 16px rgba(255,255,255,.18));
}

.floating-chat__button-fallback {
  position: relative;
  z-index: 1;
  color: #082017;
  font-size: .68rem;
  font-weight: 1000;
  letter-spacing: .06em;
  text-shadow: 0 1px 0 rgba(255,255,255,.34);
}

.floating-chat.is-open .floating-chat__button {
  opacity: 0;
  pointer-events: none;
  transform: translateY(10px) scale(.9);
}

.floating-chat.is-raised {
  inset-block-end: max(166px, calc(166px + env(safe-area-inset-bottom)));
}

.floating-chat__scrim {
  position: fixed;
  inset: 0;
  z-index: 0;
  background: rgba(7, 20, 15, .34);
  opacity: 0;
  visibility: hidden;
  transition: opacity .26s ease, visibility .26s ease;
  pointer-events: none;
}

.floating-chat.is-open .floating-chat__scrim {
  opacity: 1;
  visibility: visible;
  pointer-events: auto;
}

.floating-chat__panel {
  position: fixed;
  right: max(24px, env(safe-area-inset-right));
  bottom: max(104px, calc(104px + env(safe-area-inset-bottom)));
  z-index: 2;
  width: min(392px, calc(100vw - 32px));
  max-height: min(680px, calc(100svh - 132px));
  display: grid;
  grid-template-rows: auto minmax(180px, 1fr) auto auto;
  overflow: hidden;
  border: 1px solid rgba(255,255,255,.16);
  border-radius: 28px;
  color: #fff;
  background:
    radial-gradient(circle at 18% 0%, rgba(60,179,113,.30), transparent 38%),
    radial-gradient(circle at 88% 100%, rgba(242,192,120,.18), transparent 42%),
    linear-gradient(145deg, rgba(13,32,24,.98), rgba(29,63,45,.94));
  box-shadow:
    0 30px 92px rgba(0,0,0,.28),
    0 0 34px rgba(60,179,113,.14),
    inset 0 1px 0 rgba(255,255,255,.12);
  backdrop-filter: blur(24px) saturate(145%);
  -webkit-backdrop-filter: blur(24px) saturate(145%);
  opacity: 0;
  transform: translateY(18px) scale(.97);
  transform-origin: bottom right;
  pointer-events: auto;
  transition:
    opacity .28s cubic-bezier(.22, 1, .36, 1),
    transform .28s cubic-bezier(.22, 1, .36, 1);
}

.floating-chat__panel[hidden] {
  display: none !important;
}

.floating-chat.is-open .floating-chat__panel {
  opacity: 1;
  transform: translateY(0) scale(1);
}

.floating-chat__header {
  display: grid;
  grid-template-columns: 62px 1fr 40px;
  align-items: center;
  gap: 12px;
  padding: 18px 18px 15px;
  border-bottom: 1px solid rgba(255,255,255,.10);
}

.floating-chat__avatar {
  position: relative;
  width: 62px;
  height: 62px;
  display: grid;
  place-items: center;
  border-radius: 20px;
  color: #092016;
  background:
    radial-gradient(circle at 28% 20%, rgba(255,255,255,.82), transparent 30%),
    linear-gradient(135deg, #f2c078, #8fe0b4 48%, #3CB371);
  box-shadow: 0 16px 36px rgba(60,179,113,.28), 0 0 22px rgba(242,192,120,.14), inset 0 1px 0 rgba(255,255,255,.38);
}

.floating-chat__avatar-image {
  position: relative;
  z-index: 1;
  width: 100%;
  height: 100%;
  display: block;
  object-fit: cover;
  border-radius: inherit;
  filter: drop-shadow(0 8px 18px rgba(0,0,0,.16));
}

.floating-chat__avatar svg {
  position: absolute;
  right: 7px;
  top: 7px;
  width: 22px;
  height: 22px;
  opacity: .72;
}

.floating-chat__avatar strong {
  position: relative;
  z-index: 1;
  color: #092016;
  font-size: .62rem;
  font-weight: 1000;
  letter-spacing: .08em;
  text-shadow: 0 1px 0 rgba(255,255,255,.36);
}

.floating-chat__identity {
  min-width: 0;
}

.floating-chat__identity > span {
  display: block;
  color: #fff;
  font-size: 1rem;
  font-weight: 950;
  letter-spacing: -.01em;
}

.floating-chat__identity strong {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  margin-top: 3px;
  color: #8fe0b4;
  font-size: .72rem;
  font-weight: 900;
  letter-spacing: .12em;
  text-transform: uppercase;
}

.floating-chat__header i {
  width: 8px;
  height: 8px;
  border-radius: 999px;
  background: #8fe0b4;
  box-shadow: 0 0 16px rgba(143,224,180,.72);
}

.floating-chat__header button {
  width: 40px;
  height: 40px;
  display: grid;
  place-items: center;
  border: 1px solid rgba(255,255,255,.12);
  border-radius: 14px;
  color: #fff;
  background: rgba(255,255,255,.08);
  transition: transform .2s ease, border-color .2s ease, background .2s ease;
}

.floating-chat__header button:hover {
  transform: translateY(-1px);
  border-color: rgba(143,224,180,.34);
  background: rgba(255,255,255,.12);
}

.floating-chat__header svg,
.floating-chat__form svg {
  width: 20px;
  height: 20px;
  fill: none;
  stroke: currentColor;
  stroke-width: 2;
  stroke-linecap: round;
  stroke-linejoin: round;
}

.floating-chat__messages {
  display: grid;
  align-content: start;
  gap: 10px;
  min-height: 0;
  padding: 16px;
  overflow-y: auto;
}

.floating-chat__message {
  max-width: 88%;
  padding: 12px 14px;
  border-radius: 20px;
  font-size: .92rem;
  line-height: 1.55;
  box-shadow: 0 12px 28px rgba(0,0,0,.08);
}

.floating-chat__message--bot {
  justify-self: start;
  color: rgba(255,255,255,.86);
  background:
    linear-gradient(145deg, rgba(255,255,255,.145), rgba(255,255,255,.082)),
    radial-gradient(circle at 12% 0%, rgba(60,179,113,.22), transparent 38%);
  border: 1px solid rgba(143,224,180,.16);
}

.floating-chat__message--user {
  justify-self: end;
  color: #07120d;
  background: #8fe0b4;
  box-shadow: 0 14px 34px rgba(60,179,113,.24);
}

.floating-chat__notice {
  padding: 11px 13px;
  border-radius: 16px;
  color: rgba(255,255,255,.82);
  background: linear-gradient(135deg, rgba(242,192,120,.12), rgba(60,179,113,.08));
  border: 1px solid rgba(242,192,120,.20);
  font-size: .78rem;
  line-height: 1.5;
}

.floating-chat__message--typing {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  width: fit-content;
  min-width: 62px;
}

.floating-chat__message--typing span {
  width: 6px;
  height: 6px;
  border-radius: 999px;
  background: #8fe0b4;
  opacity: .42;
  animation: chatTyping 1s ease-in-out infinite;
}

.floating-chat__message--typing span:nth-child(2) { animation-delay: .14s; }
.floating-chat__message--typing span:nth-child(3) { animation-delay: .28s; }

.floating-chat__quick {
  display: flex;
  gap: 8px;
  padding: 0 16px 14px;
  overflow-x: auto;
}

.floating-chat__quick button {
  flex: 0 0 auto;
  min-height: 38px;
  display: inline-flex;
  align-items: center;
  gap: 7px;
  padding: 0 13px;
  border: 1px solid rgba(143,224,180,.28);
  border-radius: 999px;
  color: #d9ffe9;
  background:
    radial-gradient(circle at 20% 0%, rgba(255,255,255,.12), transparent 38%),
    rgba(60,179,113,.14);
  font-size: .78rem;
  font-weight: 850;
  white-space: nowrap;
  transition: transform .2s ease, background .2s ease, border-color .2s ease, color .2s ease;
}

.floating-chat__quick svg {
  width: 16px;
  height: 16px;
  fill: none;
  stroke: currentColor;
  stroke-width: 1.9;
  stroke-linecap: round;
  stroke-linejoin: round;
}

.floating-chat__quick button:hover {
  border-color: rgba(143,224,180,.56);
  background: rgba(60,179,113,.24);
  box-shadow: 0 12px 28px rgba(60,179,113,.18);
  transform: translateY(-1px);
}

.floating-chat__form {
  display: grid;
  grid-template-columns: 1fr 46px;
  gap: 10px;
  padding: 14px 16px 16px;
  border-top: 1px solid rgba(255,255,255,.10);
}

.floating-chat__form input {
  min-width: 0;
  height: 46px;
  padding: 0 14px;
  border: 1px solid rgba(255,255,255,.12);
  border-radius: 16px;
  color: #fff;
  background: rgba(255,255,255,.075);
  outline: none;
}

.floating-chat__form input::placeholder {
  color: rgba(255,255,255,.54);
}

.floating-chat__form input:focus {
  border-color: rgba(143,224,180,.54);
  box-shadow: 0 0 0 4px rgba(60,179,113,.16);
}

.floating-chat__form button {
  width: 46px;
  height: 46px;
  display: grid;
  place-items: center;
  border-radius: 16px;
  color: #fff;
  background: linear-gradient(135deg, #63d99c, #3CB371 50%, #24794e);
  box-shadow: 0 16px 38px rgba(60,179,113,.30);
}

.floating-chat button:focus-visible,
.floating-chat input:focus-visible {
  outline: 2px solid #8fe0b4;
  outline-offset: 3px;
}

html[data-theme="light"] .floating-chat__panel {
  color: #102018;
  border-color: rgba(25,54,38,.12);
  background:
    radial-gradient(circle at 18% 0%, rgba(60,179,113,.16), transparent 34%),
