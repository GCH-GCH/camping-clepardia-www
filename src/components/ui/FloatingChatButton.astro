const campyEnhancement = campyUxCopy[pathContext.languageCode as keyof typeof campyUxCopy] ?? campyUxCopy.en;
const bookingHref = getBookingLocalizedPath(pathContext.languageCode);
const bookingCampingHref = getBookingLocalizedPath(pathContext.languageCode, 'camping');
const bookingBungalowHref = getBookingLocalizedPath(pathContext.languageCode, 'bungalow');
const bookingCombinedHref = getBookingLocalizedPath(pathContext.languageCode, 'combined');
const pricesHref = getLocalizedPath(pathContext.explicitLanguage, 'cennik');
const contactHref = getLocalizedPath(pathContext.explicitLanguage, 'kontakt');
const mapsHref = 'https://www.google.com/maps/search/?api=1&query=Camping+Clepardia+Henryka+Pacho%C5%84skiego+28A+Krak%C3%B3w';
const jakdojadeHref = 'https://jakdojade.pl/krakow';
const sctHref = 'https://www.sct.ztp.krakow.pl/';
const etollHref = 'https://etoll.gov.pl/';
const finalCampyCopy = {
  pl: {
    actions: {
      bookStay: 'Zarezerwuj pobyt',
      camperPrice: 'Ile kosztuje kamper?',
      centerTransit: 'Jak dojadę do centrum?',
      dayPlan: 'Zaplanuj dzień w Krakowie',
      familyAttractions: 'Co zwiedzić z dziećmi?',
      dog: 'Czy można z psem?',
      bungalowOptions: 'Domki 2/3/4-os.',
      combinedStay: 'Camping + domki razem',
      quiet: 'Cisza nocna',
      sctEtoll: 'SCT / e-TOLL',
      maps: 'Google Maps',
      reception: 'Kontakt z recepcją',
    },
    answers: {
      bookStay: 'Jasne. Najwygodniej przejść do rezerwacji i wybrać Camping, Domki albo Razem. To zapytanie do recepcji, a dostępność i warunki potwierdza obiekt.',
