  >
    {hasCampyIcon ? (
      <img class="floating-chat__button-image" src={campyIconSrc} alt="" width="62" height="62" loading="eager" decoding="async" draggable="false" />
    ) : (
      <span class="floating-chat__button-fallback" aria-hidden="true">CAMPY</span>
    )}
  </button>
  <aside class="floating-chat__welcome" data-chat-welcome hidden>
    <button type="button" data-chat-welcome-close aria-label="Zamknij">×</button>
    <p>{pageWelcome}</p>
  </aside>

  <div class="floating-chat__scrim" data-chat-close aria-hidden="true"></div>

  <section
    class="floating-chat__panel"
    id="floatingChatPanel"
    data-chat-panel
    role="dialog"
    aria-modal="true"
    aria-label={enhancedChatTexts.title}
    aria-hidden="true"
    hidden
    inert
  >
    <header class="floating-chat__header">
      <span class="floating-chat__avatar" aria-hidden="true">
        {hasCampyIcon ? (
          <img class="floating-chat__avatar-image" src={campyIconSrc} alt="" width="62" height="62" loading="lazy" decoding="async" draggable="false" />
        ) : (
          <>
            <Icon name="sparkle" size={21} strokeWidth={1.9} />
            <strong>CAMPY</strong>
          </>
        )}
      </span>
      <div class="floating-chat__identity">
        <span data-chat-title-node></span>
        <strong><i aria-hidden="true"></i><span data-chat-status-node></span></strong>
      </div>
      <button type="button" data-chat-close aria-label={enhancedChatTexts.close}>
        <Icon name="close" size={20} strokeWidth={2} />
      </button>
    </header>

    <div class="floating-chat__messages" data-chat-messages aria-live="polite"></div>

    <div class="floating-chat__quick-hub" data-chat-quick-hub>
      <button
        class="floating-chat__quick-toggle"
        type="button"
        data-chat-quick-toggle
        aria-expanded="false"
        aria-controls="floatingChatQuickPanel"
      >
        <Icon name="MessagesSquare" size={17} strokeWidth={2} />
        <span>{campyQuick.toggle}</span>
        <Icon name="ChevronDown" size={17} strokeWidth={2} class="floating-chat__quick-chevron" />
      </button>
      <div
        class="floating-chat__quick-panel"
        id="floatingChatQuickPanel"
        data-chat-quick-panel
        aria-label={campyQuick.aria}
        tabindex="0"
        hidden
      ></div>
      <template data-chat-quick-template>
        {quickActionGroups.map((group) => (
          <section class="floating-chat__quick-section" aria-labelledby={`campyQuick-${group.key}`}>
            <h3 id={`campyQuick-${group.key}`}>
              <Icon name={group.icon} size={16} strokeWidth={2} />
              <span>{group.title}</span>
            </h3>
            <div class="floating-chat__quick-grid" role="list">
              {group.actions.map((action) => (
                <button type="button" data-chat-action={action.key} data-chat-prompt={action.label} aria-label={action.label} role="listitem">
                  <Icon name={action.icon} size={16} strokeWidth={1.9} />
                  <span>{action.label}</span>
                </button>
              ))}
            </div>
          </section>
        ))}
      </template>
    </div>

    <form class="floating-chat__form" data-chat-form>
      <label class="sr-only" for="floatingChatInput" data-chat-input-label></label>
      <input id="floatingChatInput" data-chat-input type="text" autocomplete="off" placeholder="" />
      <button type="submit" data-chat-send aria-label="">
        <Icon name="send" size={20} strokeWidth={2} />
      </button>
    </form>
  </section>
</div>

<script define:vars={{ chatConfigEncoded }}>
  (() => {
    const root = document.querySelector('[data-floating-chat]');
    if (!(root instanceof HTMLElement)) return;

    const decodeChatTexts = () => {
      try {
        const binary = window.atob(chatConfigEncoded);
        const bytes = Uint8Array.from(binary, (character) => character.charCodeAt(0));
        return JSON.parse(new TextDecoder().decode(bytes));
      } catch {
        return null;
      }
    };

    let chatTexts = null;
    const getChatTexts = () => {
      if (chatTexts) return chatTexts;
      chatTexts = decodeChatTexts();
      return chatTexts;
    };

    const toggle = root.querySelector('[data-chat-toggle]');
    const panel = root.querySelector('[data-chat-panel]');
    const closeButtons = root.querySelectorAll('[data-chat-close]');
    const form = root.querySelector('[data-chat-form]');
    const input = root.querySelector('[data-chat-input]');
    const messages = root.querySelector('[data-chat-messages]');
    const quickActionButtons = root.querySelectorAll('[data-chat-prompt]');
    const titleNode = root.querySelector('[data-chat-title-node]');
    const statusNode = root.querySelector('[data-chat-status-node]');
    const inputLabel = root.querySelector('[data-chat-input-label]');
    const sendButton = root.querySelector('[data-chat-send]');
    const quickToggleButton = root.querySelector('[data-chat-quick-toggle]');
    const quickPanel = root.querySelector('[data-chat-quick-panel]');
    const quickTemplate = root.querySelector('[data-chat-quick-template]');
    const welcome = root.querySelector('[data-chat-welcome]');
    const welcomeClose = root.querySelector('[data-chat-welcome-close]');

    if (!(toggle instanceof HTMLButtonElement) || !(panel instanceof HTMLElement) || !(messages instanceof HTMLElement)) return;

    let open = false;
    let hideTimer = 0;
    let welcomeTimer = 0;
    let panelHydrated = false;
    let quickPanelHydrated = false;
    let quickPanelOpen = false;

    const hydratePanelCopy = () => {
      if (panelHydrated) return;
      if (titleNode instanceof HTMLElement) titleNode.textContent = chatTexts.title;
      if (statusNode instanceof HTMLElement) statusNode.textContent = chatTexts.status;
      if (inputLabel instanceof HTMLElement) inputLabel.textContent = chatTexts.inputLabel;
      if (input instanceof HTMLInputElement) input.placeholder = chatTexts.inputPlaceholder;
      if (sendButton instanceof HTMLButtonElement) sendButton.setAttribute('aria-label', chatTexts.send);
      quickActionButtons.forEach((button) => {
        if (!(button instanceof HTMLElement)) return;
        const label = button.dataset.chatPrompt ?? '';
        const labelNode = button.querySelector('[data-chat-quick-label]');
        if (labelNode instanceof HTMLElement) labelNode.textContent = label;
      });
      panelHydrated = true;
    };

    const hydrateQuickPanel = () => {
      if (quickPanelHydrated || !(quickPanel instanceof HTMLElement) || !(quickTemplate instanceof HTMLTemplateElement)) return;
      quickPanel.appendChild(quickTemplate.content.cloneNode(true));
      quickPanelHydrated = true;
    };

    const syncPanelTitle = () => {
      if (!(titleNode instanceof HTMLElement)) return;
      titleNode.textContent = window.innerWidth <= 480
        ? (chatTexts.mobileTitle || chatTexts.title)
        : chatTexts.title;
    };

    const setQuickPanelOpen = (nextOpen) => {
      if (!(quickToggleButton instanceof HTMLButtonElement) || !(quickPanel instanceof HTMLElement)) return;
      if (nextOpen) hydrateQuickPanel();
      quickPanelOpen = nextOpen;
      quickToggleButton.setAttribute('aria-expanded', String(quickPanelOpen));
      quickPanel.hidden = !quickPanelOpen;
      root.classList.toggle('has-quick-panel-open', quickPanelOpen);
    };

    const updateMobileAvailability = () => {
      const available = window.innerWidth > 640 || window.scrollY > 320 || open || root.classList.contains('has-welcome');
      root.classList.toggle('is-available', available);
    };

    const updateStickyOffset = () => {
      const mobileSummary = document.querySelector('[data-mobile-summary]');
      const hasMobileSummary = mobileSummary instanceof HTMLElement
        && window.innerWidth <= 1079
        && window.getComputedStyle(mobileSummary).display !== 'none';

      root.classList.toggle('is-raised', hasMobileSummary);
      updateMobileAvailability();
    };

    const setOpen = (nextOpen) => {
      if (!getChatTexts()) return;
      open = nextOpen;
      if (welcome instanceof HTMLElement) {
        welcome.hidden = true;
        root.classList.remove('has-welcome');
        window.clearTimeout(welcomeTimer);
      }
      window.clearTimeout(hideTimer);
      toggle.setAttribute('aria-expanded', String(open));
      toggle.setAttribute('aria-label', open ? chatTexts.close : chatTexts.open);
      panel.setAttribute('aria-hidden', String(!open));
      document.body.classList.toggle('has-floating-chat-open', open);
      updateMobileAvailability();

      if (open) {
        panel.hidden = false;
        panel.removeAttribute('inert');
        hydratePanelCopy();
        syncPanelTitle();
        initializeMessages();
        root.classList.add('is-open');
        if (window.innerWidth > 640) {
          window.setTimeout(() => {
            if (input instanceof HTMLInputElement) input.focus({ preventScroll: true });
          }, 140);
        }
        return;
      }

      setQuickPanelOpen(false);
      root.classList.remove('is-open');
      panel.setAttribute('inert', '');
      hideTimer = window.setTimeout(() => {
        panel.hidden = true;
      }, 260);
      toggle.focus({ preventScroll: true });
    };

    const appendMessage = (content, type) => {
      const text = typeof content === 'string' ? content : (content?.text || '');
      const actions = Array.isArray(content?.actions) ? content.actions : [];
      const bubble = document.createElement('div');
      bubble.className = `floating-chat__message floating-chat__message--${type}`;
      const textNode = document.createElement('span');
      textNode.textContent = text;
      bubble.appendChild(textNode);
      if (actions.length) {
        const actionWrap = document.createElement('div');
        actionWrap.className = 'floating-chat__message-actions';
        actions.forEach((action) => {
          if (!action?.href || !action?.label) return;
          const link = document.createElement('a');
          link.href = action.href;
          link.textContent = action.label;
          if (/^https?:\/\//.test(action.href)) {
            link.target = '_blank';
            link.rel = 'noopener noreferrer';
          }
          actionWrap.appendChild(link);
        });
        bubble.appendChild(actionWrap);
      }
      messages.appendChild(bubble);
      messages.scrollTop = messages.scrollHeight;
      return bubble;
    };

    const initializeMessages = () => {
      if (messages.dataset.initialized === 'true') return;
      appendMessage(chatTexts.intro, 'bot');
      const notice = document.createElement('div');
      notice.className = 'floating-chat__notice';
      notice.textContent = chatTexts.notice;
      messages.appendChild(notice);
      messages.dataset.initialized = 'true';
    };

    const appendTyping = () => {
      const bubble = document.createElement('div');
      bubble.className = 'floating-chat__message floating-chat__message--bot floating-chat__message--typing';
      bubble.innerHTML = '<span></span><span></span><span></span>';
      messages.appendChild(bubble);
      messages.scrollTop = messages.scrollHeight;
      return bubble;
    };

    const actionResponse = (key) => {
      const answers = chatTexts.answers || {};
      const links = chatTexts.links || {};
      const actionLabels = {
        booking: chatTexts.actions?.bookStay || 'Rezerwacja',
        prices: chatTexts.actions?.campingPricing || chatTexts.actions?.pricing || 'Cennik',
        attractions: chatTexts.actions?.attractions || 'Atrakcje',
        maps: chatTexts.actions?.maps || 'Google Maps',
        jakdojade: 'Jakdojade',
        directions: chatTexts.actions?.directions || chatTexts.actions?.centerTransit || 'Dojazd',
        contact: chatTexts.actions?.reception || 'Kontakt',
        camping: 'Camping',
        bungalow: chatTexts.actions?.bungalowOptions || 'Domki',
        combined: chatTexts.actions?.combinedStay || 'Razem',
        sct: 'SCT Kraków',
        etoll: 'e-TOLL',
        tours: chatTexts.tourLabels?.[0] || 'Sprawdź wycieczki',
      };

      if (key === 'bookStay') return { text: answers.bookStay, actions: [{ label: actionLabels.booking, href: links.booking }] };
      if (key === 'siteSearch') return { text: answers.siteSearch };
      if (key === 'registration') return { text: answers.registration, actions: [{ label: actionLabels.booking, href: links.booking }, { label: actionLabels.contact, href: links.contact }] };
      if (key === 'camperPrice') return { text: answers.camperPrice, actions: [{ label: actionLabels.prices, href: links.prices }] };
      if (key === 'currency') return { text: answers.currency, actions: [{ label: actionLabels.prices, href: links.prices }] };
      if (key === 'stayCompare') return { text: answers.stayCompare, actions: [{ label: actionLabels.camping, href: links.bookingCamping }, { label: actionLabels.bungalow, href: links.bookingBungalow }, { label: actionLabels.combined, href: links.bookingCombined }] };
      if (key === 'campingPricing') return { text: answers.campingPricing, actions: [{ label: actionLabels.prices, href: links.prices }] };
      if (key === 'powerDog') return { text: answers.powerDog, actions: [{ label: actionLabels.prices, href: links.prices }] };
      if (key === 'evCharging') return { text: answers.evCharging ?? answers.powerDog, actions: [{ label: actionLabels.directions, href: links.directions }, { label: actionLabels.contact, href: links.contact }] };
      if (key === 'summerCamping') return { text: answers.summerCamping, actions: [{ label: actionLabels.bungalow, href: links.bookingBungalow }, { label: actionLabels.contact, href: links.contact }] };
      if (key === 'lateArrival') return { text: answers.lateArrival ?? answers.receptionHours, actions: [{ label: actionLabels.contact, href: links.contact }, { label: actionLabels.booking, href: links.booking }] };
      if (key === 'lateCheckout') return { text: answers.lateCheckout, actions: [{ label: actionLabels.booking, href: links.booking }] };
      if (key === 'cityCamping') return { text: answers.cityCamping, actions: [{ label: actionLabels.camping, href: links.bookingCamping }, { label: actionLabels.directions, href: links.directions }] };
      if (key === 'centerTransit') return { text: answers.centerTransit, actions: [{ label: actionLabels.maps, href: links.maps }, { label: actionLabels.jakdojade, href: links.jakdojade }, { label: actionLabels.directions, href: links.directions }] };
      if (key === 'tramTickets') return { text: answers.tramTickets, actions: [{ label: actionLabels.jakdojade, href: links.jakdojade }] };
      if (key === 'dayPlan') return { text: answers.dayPlan };
      if (key === 'oneNightPlan') return { text: answers.oneNightPlan, actions: [{ label: actionLabels.attractions, href: links.attractions }] };
      if (key === 'twoNightPlan') return { text: answers.twoNightPlan, actions: [{ label: actionLabels.attractions, href: links.attractions }] };
      if (key === 'threeNightPlan') return { text: answers.threeNightPlan, actions: [{ label: actionLabels.attractions, href: links.attractions }] };
      if (key === 'stayLength') return { text: answers.stayLength, actions: [{ label: actionLabels.attractions, href: links.attractions }] };
      if (key === 'currentNotices') return { text: answers.currentNotices, actions: [{ label: actionLabels.directions, href: links.directions }, { label: actionLabels.booking, href: links.booking }] };
      if (key === 'familyAttractions') return { text: answers.familyAttractions };
      if (key === 'wawel') return { text: answers.wawel, actions: [{ label: actionLabels.attractions, href: links.attractions }] };
      if (key === 'wieliczka') return { text: answers.wieliczka, actions: [{ label: actionLabels.attractions, href: links.attractions }, { label: actionLabels.tours, href: links.tours, external: true }] };
      if (key === 'auschwitz') return { text: answers.auschwitz, actions: [{ label: actionLabels.attractions, href: links.attractions }, { label: actionLabels.tours, href: links.tours, external: true }] };
      if (key === 'schindler') return { text: answers.schindler, actions: [{ label: actionLabels.attractions, href: links.attractions }] };
      if (key === 'waterRelax') return { text: answers.waterRelax, actions: [{ label: actionLabels.attractions, href: links.attractions }] };
      if (key === 'dog') return { text: answers.dog };
      if (key === 'bungalowOptions') return { text: answers.bungalowOptions, actions: [{ label: actionLabels.bungalow, href: links.bookingBungalow }] };
      if (key === 'combinedStay') return { text: answers.combinedStay, actions: [{ label: actionLabels.camping, href: links.bookingCamping }, { label: actionLabels.bungalow, href: links.bookingBungalow }, { label: actionLabels.combined, href: links.bookingCombined }] };
      if (key === 'toursFromKrakow') return { text: answers.toursFromKrakow, actions: [{ label: actionLabels.tours, href: links.tours, external: true }, { label: actionLabels.attractions, href: links.attractions }] };
      if (key === 'quiet') return { text: answers.quiet };
      if (key === 'sctEtoll') return { text: answers.sctEtoll, actions: [{ label: actionLabels.sct, href: links.sct }, { label: actionLabels.etoll, href: links.etoll }] };
      if (key === 'maps') return { text: answers.maps, actions: [{ label: actionLabels.maps, href: links.maps }] };
      if (key === 'reception') return { text: answers.reception, actions: [{ label: actionLabels.contact, href: links.contact }, { label: actionLabels.booking, href: links.booking }] };
      if (key === 'receptionHours') return { text: answers.receptionHours, actions: [{ label: actionLabels.contact, href: links.contact }] };
      return null;
    };

    const searchCampyIndex = (rawPrompt) => {
      const entries = Array.isArray(chatTexts.searchIndex) ? chatTexts.searchIndex : [];
      const normalize = (value) => String(value || '').toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '');
      const query = normalize(rawPrompt).replace(/\b(szukaj|znajdz|znajdź|search|find|pokaż|pokaz)\b/g, '').trim();
      if (query.length < 3 || entries.length === 0) return null;
      const parts = query.split(/\s+/).filter((part) => part.length > 2);
      const matches = entries
        .map((entry) => {
          const haystack = normalize([entry.title, entry.description, entry.category, entry.badge, ...(entry.keywords || [])].filter(Boolean).join(' '));
          const matchingParts = parts.filter((part) => haystack.includes(part)).length;
          const score = haystack.includes(query) ? 8 : matchingParts >= Math.max(1, Math.ceil(parts.length * .6)) ? matchingParts : 0;
          return { entry, score };
        })
        .filter((item) => item.score > 0)
        .sort((a, b) => b.score - a.score)
        .slice(0, 3)
        .map((item) => item.entry);
      if (!matches.length) return null;
      return {
        text: `${chatTexts.searchResultPrefix || 'I found similar topics:'} ${matches.map((entry) => entry.title).join(', ')}.`,
        actions: matches.map((entry) => ({ label: entry.title, href: entry.href })),
      };
    };

    const resolveAnswer = (rawPrompt, actionKey = '') => {
      const keyed = actionResponse(actionKey);
      if (keyed) return keyed;
      const prompt = rawPrompt.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '');
      const hasAny = (...parts) => parts.some((part) => prompt.includes(part));

      if (hasAny('godziny recepcji', 'otwarta recepcja', 'czynna recepcja', 'reception hours', 'offnungszeiten rezeption', 'offnungszeiten', 'oeffnungszeiten rezeption', 'rezeption oeffnungszeiten', 'rezeption offnungszeiten', 'orari reception', 'horaires reception', 'horario recepcion', 'openingstijden receptie', 'oteviraci doba recepce', 'hodiny recepce', 'otvaracie hodiny recepcie', 'hodiny recepcie', 'recepcia hodiny', 'receptionens oppettider', 'reception oppettider', 'oppettider')) {
        return {
          text: chatTexts.answers.receptionHours,
          actions: [{ label: chatTexts.actions?.reception || 'Kontakt', href: chatTexts.links?.contact }],
        };
      }

      if (hasAny('do ktorej brama', 'do ktorej jest brama', 'godziny bramy', 'brama otwarta', 'gate hours', 'gate open', 'tor offen', 'cancello', 'portail', 'puerta', 'poort', 'brana', 'porten')) {
        return {
          text: chatTexts.answers.gateHours || chatTexts.answers.receptionHours,
          actions: [{ label: chatTexts.actions?.reception || 'Kontakt', href: chatTexts.links?.contact }],
        };
      }

      if (hasAny('wycieczk', 'tour', 'excursion', 'ausflug', 'gita', 'visita', 'excursion', 'vylet', 'vilet', 'tur') && hasAny('wielicz', 'auschwitz', 'zakop', 'ojcow', 'ojców', 'energy', 'wawel', 'bagry', 'kryspin', 'zarezerw', 'sprawdz', 'check', 'book', 'reserv', 'prenot', 'buchen')) {
        return {
          text: chatTexts.answers.toursFromKrakow ?? chatTexts.answers.wieliczka ?? chatTexts.answers.attractions,
          actions: [{ label: chatTexts.tourLabels?.[0] || 'Sprawdź wycieczki', href: chatTexts.links?.tours, external: true }, { label: chatTexts.tourLabels?.[2] || 'Zapytaj recepcję', href: chatTexts.links?.contact }],
        };
      }

      if (hasAny('najlepiej przyjechac', 'o ktorej przyjechac', 'pora przyjazdu', 'best arrival', 'wann anreisen', 'quando arrivare', 'quand arriver', 'cuando llegar', 'wanneer aankomen', 'kdy prijet', 'kedy prist', 'nar anlanda') && hasAny('sezon', 'lipiec', 'sierpien', 'kamper', 'camping', 'july', 'august', 'juli', 'agosto', 'juillet', 'julio', 'srpen', 'jul', 'augusti')) {
        return {
          text: chatTexts.answers.arrivalTiming ?? chatTexts.answers.summerCamping,
          actions: [{ label: chatTexts.actions?.reception || 'Kontakt', href: chatTexts.links?.contact }, { label: chatTexts.actions?.centerTransit || 'Dojazd', href: chatTexts.links?.directions }],
        };
      }

      if (hasAny('2 dni', 'dwa dni', '2 noce', 'dwie noce', 'two days', 'two nights')) {
        return actionResponse('twoNightPlan') ?? chatTexts.answers.twoNightPlan;
      }

      if (hasAny('auto elektryczne', 'samochod elektryczny', 'ladowac auto', 'ladowanie auta', 'charge an electric', 'electric vehicle', 'ev charging', 'elektroauto', 'e auto', 'auto elettrica', 'voiture electrique', 'coche electrico', 'elektrische auto', 'elektromobil', 'elbil', 'plug in', 'hybrid', 'charger', 'recharger', 'caricare', 'cargar', 'nabij', 'ladda', 'electri')) {
        return {
          text: chatTexts.answers.evCharging ?? chatTexts.answers.powerDog,
          actions: [{ label: chatTexts.actions?.centerTransit || 'Dojazd', href: chatTexts.links?.directions }, { label: chatTexts.actions?.reception || 'Kontakt', href: chatTexts.links?.contact }],
        };
      }

      if (hasAny('ciezki pojazd', 'ciezkim pojazdem', 'ciezarow', 'autobus', 'heavy vehicle', 'heavy motorhome', 'na trawie', 'on grass', 'schweres fahrzeug', 'lkw', 'poids lourd', 'vehiculo pesado', 'veicolo pesante', 'zwaar voertuig', 'tezke vozidlo', 'tazke vozidlo', 'tungt fordon', 'grass', 'erba', 'herbe', 'cesped', 'gras', 'trava')) {
        return {
          text: chatTexts.answers.heavyVehicle,
          actions: [{ label: chatTexts.actions?.reception || 'Kontakt', href: chatTexts.links?.contact }, { label: chatTexts.actions?.centerTransit || 'Dojazd', href: chatTexts.links?.directions }],
        };
      }

      if (hasAny('lipiec', 'lipcu', 'sierpien', 'sierpniu', 'july', 'august', 'juli', 'luglio', 'agosto', 'juillet', 'julio', 'srpen', 'cerven', 'cervenci', 'jul', 'augusti')
        && hasAny('kamper', 'camper', 'motorhome', 'wohnmobil', 'camping car', 'camping-car', 'obytne auto', 'obytny vuz', 'obytny voz', 'obytny automobil', 'obytny', 'husbil', 'van', 'namiot', 'tent', 'przyczep', 'caravan', 'camping')) {
        return {
          text: chatTexts.answers.summerCamping,
          actions: [{ label: chatTexts.actions?.bungalowOptions || 'Domki', href: chatTexts.links?.bookingBungalow }, { label: chatTexts.actions?.reception || 'Kontakt', href: chatTexts.links?.contact }],
        };
      }

      if (hasAny('recznik', 'reczniki', 'towel', 'towels', 'kosmetyk', 'handtuch', 'asciugaman', 'serviette', 'toalla', 'handdoek', 'rucnik', 'uterak', 'handduk') && hasAny('domk', 'bungalow', 'cabin', 'chatk', 'stug')) {
        return {
          text: chatTexts.answers.bungalowTowels ?? chatTexts.answers.bungalowOptions,
          actions: [{ label: chatTexts.actions?.bungalowOptions || 'Domki', href: chatTexts.links?.bookingBungalow }, { label: chatTexts.actions?.bookStay || 'Rezerwacja', href: chatTexts.links?.booking }],
        };
      }

      if (hasAny('po 21', 'po21', '21:00', '21.00', 'pozny przyjazd', 'pozno przyjech', 'late arrival', 'after 21', 'nach 21', 'dopo le 21', 'apres 21', 'despues de las 21', 'na 21', 'po 21:00', 'efter 21')) {
        return {
