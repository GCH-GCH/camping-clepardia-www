<div class="ambient-background" aria-hidden="true">
  <span class="ambient-background__glow ambient-background__glow--green"></span>
  <span class="ambient-background__glow ambient-background__glow--warm"></span>
  <span class="ambient-background__glow ambient-background__glow--deep"></span>
  <span class="ambient-background__glow ambient-background__glow--soft"></span>
  <span class="ambient-background__particles ambient-background__particles--near"></span>
  <span class="ambient-background__particles ambient-background__particles--far"></span>
  <span class="ambient-background__orb ambient-background__orb--1"></span>
  <span class="ambient-background__orb ambient-background__orb--2"></span>
  <span class="ambient-background__orb ambient-background__orb--3"></span>
  <span class="ambient-background__orb ambient-background__orb--4"></span>
  <span class="ambient-background__orb ambient-background__orb--5"></span>
  <span class="ambient-background__orb ambient-background__orb--6"></span>
  <span class="ambient-background__grain"></span>
</div>

<script>
  (() => {
    const root = document.querySelector('.ambient-background');
    if (!(root instanceof HTMLElement) || matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    let queued = false;
    const update = () => {
      queued = false;
      root.style.setProperty('--ambient-scroll', `${Math.min(80, scrollY * .025)}px`);
    };
    addEventListener('scroll', () => {
      if (queued) return;
      queued = true;
      requestAnimationFrame(update);
    }, { passive: true });
    update();
  })();
</script>

