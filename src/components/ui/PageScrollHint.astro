---
import { getPathContext } from '@/utils/localizedLinks';
import { resolveContentLanguage } from '@/i18n/config';

const pathContext = getPathContext(Astro.url.pathname);
const lang = resolveContentLanguage(pathContext.languageCode);
const isHome = !pathContext.slug;
const copy = {
  pl: { home: 'Przewiń', page: 'Przewiń' },
  en: { home: 'Scroll', page: 'Scroll' },
  de: { home: 'Scrollen', page: 'Scrollen' },
  it: { home: 'Scorri', page: 'Scorri' },
}[lang] ?? { home: 'Scroll', page: 'Scroll' };

const label = isHome ? copy.home : copy.page;
---

<button class="page-scroll-hint" type="button" data-page-scroll-hint aria-label={label}>
  <span class="page-scroll-hint__mouse" aria-hidden="true">
    <span class="page-scroll-hint__wheel"></span>
  </span>
  <span class="page-scroll-hint__label">{label}</span>
</button>

<script>
  (() => {
    const hint = document.querySelector('[data-page-scroll-hint]');
    if (!(hint instanceof HTMLButtonElement)) return;

    const getTarget = () => {
      const preferred = document.querySelector('#after-hero, [data-after-hero]');
      if (preferred instanceof HTMLElement && preferred.getBoundingClientRect().top > 96) return preferred;

      const main = document.querySelector('main');
      const sections = Array.from((main ?? document).querySelectorAll('section'))
        .filter((section) => section instanceof HTMLElement)
        .filter((section) => !section.contains(hint))
        .filter((section) => {
          const rect = section.getBoundingClientRect();
          return rect.height > 32 && rect.bottom > 0;
        });

      const belowHero = sections.find((section, index) => {
        if (!(section instanceof HTMLElement)) return false;
        const rect = section.getBoundingClientRect();
        return index > 0 && rect.top > 80;
      });

      const secondSection = sections[1];
      const firstUsefulSection = sections.find((section) => section instanceof HTMLElement && section.getBoundingClientRect().top > window.innerHeight * 0.35);
      return (belowHero ?? secondSection ?? firstUsefulSection ?? null) instanceof HTMLElement
        ? (belowHero ?? secondSection ?? firstUsefulSection)
        : null;
    };

    const scrollToTarget = () => {
      const motionWindow = window;
      const scrollTo = (top) => {
        if (typeof motionWindow.__ccScrollTo === 'function') {
          motionWindow.__ccScrollTo(top, { duration: 0.9 });
          return;
        }
        window.scrollTo({ top, behavior: 'smooth' });
      };
      const target = getTarget();
      if (!target) {
        scrollTo(Math.max(window.innerHeight * 0.82, 320));
        return;
      }
      const navbar = document.querySelector('[data-main-navbar], #mainNavbarShell, #mainNavbar');
      const offset = navbar instanceof HTMLElement ? navbar.getBoundingClientRect().height + 16 : 92;
      const targetTop = Math.max(0, window.scrollY + target.getBoundingClientRect().top - offset);
      const fallbackTop = Math.min(
        document.documentElement.scrollHeight - window.innerHeight,
        window.scrollY + Math.max(window.innerHeight * 0.72, 320),
      );
      const top = targetTop > window.scrollY + 8 ? targetTop : fallbackTop;
      scrollTo(top);
    };

    const updateVisibility = () => {
      hint.classList.toggle('is-hidden', window.scrollY > 260);
    };

    hint.addEventListener('click', (event) => {
      event.preventDefault();
      event.stopPropagation();
      window.requestAnimationFrame(scrollToTarget);
    });
    window.addEventListener('scroll', updateVisibility, { passive: true });
    updateVisibility();
  })();
</script>

<style is:global>
.page-scroll-hint {
  position: fixed;
  left: 50%;
  bottom: max(24px, calc(24px + env(safe-area-inset-bottom)));
  z-index: 920;
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 7px;
  width: max-content;
  min-width: 92px;
  min-height: 78px;
  padding: 0;
  border: 0;
  color: rgba(247,255,249,.86);
  background: transparent;
  box-shadow: none;
  transform: translateX(-50%);
  cursor: pointer;
  touch-action: manipulation;
  pointer-events: auto;
  transition: opacity .22s ease, transform .22s ease, visibility .22s ease;
}

.page-scroll-hint__mouse {
  position: relative;
  display: block;
  width: 25px;
  height: 41px;
  border: 2px solid rgba(143,224,180,.82);
  border-radius: 999px;
  background:
    linear-gradient(180deg, rgba(255,255,255,.08), rgba(255,255,255,.02)),
    rgba(8,25,16,.30);
  box-shadow:
    0 0 0 1px rgba(255,255,255,.06),
    0 10px 28px rgba(0,0,0,.18),
    0 0 22px rgba(60,179,113,.20);
  animation: page-scroll-float 2.7s ease-in-out infinite;
}

.page-scroll-hint__mouse::before {
  content: '';
  position: absolute;
  inset: -11px;
  border-radius: inherit;
  background: radial-gradient(circle, rgba(143,224,180,.20), transparent 62%);
  filter: blur(4px);
  z-index: -1;
  animation: page-scroll-aura 2.3s ease-in-out infinite;
}

.page-scroll-hint__mouse::after {
  content: '';
  position: absolute;
  inset: 5px;
  border-radius: inherit;
  background: linear-gradient(155deg, rgba(255,255,255,.28), transparent 34%);
  opacity: .65;
  pointer-events: none;
}

.page-scroll-hint__wheel {
  position: absolute;
  left: 50%;
  top: 8px;
  width: 4px;
  height: 8px;
  border-radius: 999px;
  background: #8fe0b4;
  box-shadow: 0 0 14px rgba(143,224,180,.58);
  transform: translateX(-50%);
  animation: page-scroll-wheel 1.55s cubic-bezier(.22, 1, .36, 1) infinite;
}

.page-scroll-hint__label {
  display: block;
  max-width: max-content;
  padding: 6px 10px;
  border: 1px solid rgba(143,224,180,.16);
  border-radius: 999px;
  font-size: .78rem;
  font-weight: 950;
  line-height: 1;
  letter-spacing: .12em;
  text-transform: uppercase;
  white-space: nowrap;
  overflow-wrap: normal;
  word-break: keep-all;
  background: rgba(8,25,16,.26);
  box-shadow: 0 12px 26px rgba(0,0,0,.16), inset 0 1px 0 rgba(255,255,255,.10);
  text-shadow: 0 8px 24px rgba(0,0,0,.36);
}

.page-scroll-hint:hover {
  transform: translateX(-50%) translateY(-2px);
}

.page-scroll-hint:focus,
.page-scroll-hint:focus:not(:focus-visible) {
  outline: none;
  box-shadow: none;
}

.page-scroll-hint:focus-visible {
  outline: none;
  box-shadow: none;
}

.page-scroll-hint:focus-visible .page-scroll-hint__mouse,
.page-scroll-hint:focus-visible .page-scroll-hint__label {
  box-shadow:
    0 0 0 3px rgba(60, 179, 113, .32),
    0 0 30px rgba(60, 179, 113, .24);
}

.page-scroll-hint:hover .page-scroll-hint__mouse {
  border-color: rgba(180,243,204,.95);
  box-shadow:
    0 0 0 1px rgba(255,255,255,.09),
    0 12px 32px rgba(0,0,0,.20),
    0 0 30px rgba(60,179,113,.30);
}

.page-scroll-hint.is-hidden {
  opacity: 0;
  visibility: hidden;
  transform: translateX(-50%) translateY(10px);
  pointer-events: none;
}

html[data-theme="light"] .page-scroll-hint {
  color: #0b3f27;
}

html[data-theme="light"] .page-scroll-hint__mouse {
  border-color: #167447;
  background: rgba(249,255,250,.94);
  box-shadow:
    0 0 0 1px rgba(22,116,71,.14),
    0 12px 30px rgba(16,58,36,.16),
    0 0 26px rgba(60,179,113,.22);
}

html[data-theme="light"] .page-scroll-hint__label {
  border-color: rgba(22,116,71,.28);
  color: #0b3f27;
  background: rgba(244,252,246,.96);
  box-shadow: 0 12px 28px rgba(16,58,36,.14), inset 0 1px 0 rgba(255,255,255,.86);
  text-shadow: none;
}

html[data-theme="light"] .page-scroll-hint__wheel {
  background: #126f43;
  box-shadow: 0 0 13px rgba(18,111,67,.42);
}

@keyframes page-scroll-wheel {
  0% {
    opacity: 0;
    transform: translate(-50%, 0);
  }

  22% {
    opacity: 1;
  }

  72% {
    opacity: 1;
    transform: translate(-50%, 13px);
  }

  100% {
    opacity: 0;
    transform: translate(-50%, 17px);
  }
}

@keyframes page-scroll-float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-5px); }
}

@keyframes page-scroll-aura {
  0%, 100% { opacity: .48; transform: scale(.92); }
  50% { opacity: .86; transform: scale(1.08); }
}

@media (max-width: 720px) {
  .page-scroll-hint {
    bottom: max(16px, calc(16px + env(safe-area-inset-bottom)));
    width: max-content;
    min-width: 78px;
    min-height: 64px;
  }

  .page-scroll-hint__mouse {
    width: 22px;
    height: 36px;
  }

  .page-scroll-hint__label {
    font-size: .66rem;
    letter-spacing: .08em;
  }
}

@media (prefers-reduced-motion: reduce) {
  .page-scroll-hint__mouse {
    animation: none !important;
  }

  .page-scroll-hint {
    transition-duration: .01ms !important;
  }

  .page-scroll-hint__wheel,
  .page-scroll-hint__mouse::before {
    animation: none;
    opacity: 1;
  }
}
</style>
