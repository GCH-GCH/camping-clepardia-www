---
import { getPathContext } from '@/utils/localizedLinks';
import { resolveContentLanguage } from '@/i18n/config';
import Icon from '@/components/ui/Icon.astro';

const pathContext = getPathContext(Astro.url.pathname);
const lang = resolveContentLanguage(pathContext.languageCode);
const isHome = !pathContext.slug;
const copy = {
  pl: { home: 'Odkryj Clepardię', page: 'Zobacz więcej' },
  en: { home: 'Discover Clepardia', page: 'See more' },
  de: { home: 'Clepardia entdecken', page: 'Mehr sehen' },
  it: { home: 'Scopri Clepardia', page: 'Scopri di più' },
}[lang] ?? { home: 'Discover Clepardia', page: 'See more' };
---

<button class="page-scroll-hint" type="button" data-page-scroll-hint aria-label={isHome ? copy.home : copy.page}>
  <span>{isHome ? copy.home : copy.page}</span>
  <Icon name="chevronDown" size={17} strokeWidth={2} />
</button>

<script>
  (() => {
    const hint = document.querySelector('[data-page-scroll-hint]');
    if (!(hint instanceof HTMLButtonElement)) return;

    const getTarget = () => {
      const preferred = document.querySelector('#after-hero, [data-after-hero], main > section:nth-of-type(2)');
      return preferred instanceof HTMLElement ? preferred : null;
    };

    const scrollToTarget = () => {
      const target = getTarget();
      if (!target) return;
      const navbar = document.querySelector('[data-main-navbar], #mainNavbarShell, #mainNavbar');
      const offset = navbar instanceof HTMLElement ? navbar.getBoundingClientRect().height + 16 : 92;
      const top = Math.max(0, window.scrollY + target.getBoundingClientRect().top - offset);
      window.scrollTo({ top, behavior: 'smooth' });
    };

    const updateVisibility = () => {
      hint.classList.toggle('is-hidden', window.scrollY > 260);
    };

    hint.addEventListener('click', scrollToTarget);
    window.addEventListener('scroll', updateVisibility, { passive: true });
    updateVisibility();
  })();
</script>

<style is:global>
.page-scroll-hint {
  position: fixed;
  left: 50%;
  bottom: max(22px, calc(22px + env(safe-area-inset-bottom)));
  z-index: 920;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  min-height: 44px;
  max-width: calc(100vw - 148px);
  padding: 0 16px;
  border: 1px solid rgba(143,224,180,.25);
  border-radius: 999px;
  color: #f7fff9;
  background:
    radial-gradient(circle at 22% 0%, rgba(255,255,255,.17), transparent 32%),
    linear-gradient(135deg, rgba(13,32,24,.82), rgba(29,63,45,.74));
  box-shadow: 0 18px 48px rgba(0,0,0,.16), 0 0 30px rgba(60,179,113,.16);
  backdrop-filter: blur(18px) saturate(140%);
  -webkit-backdrop-filter: blur(18px) saturate(140%);
  transform: translateX(-50%);
  cursor: pointer;
  pointer-events: auto;
  transition: opacity .22s ease, transform .22s ease, visibility .22s ease, border-color .22s ease;
}

.page-scroll-hint span {
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: .78rem;
  font-weight: 950;
  letter-spacing: .03em;
}

.page-scroll-hint:hover {
  border-color: rgba(143,224,180,.46);
  transform: translateX(-50%) translateY(-2px);
}

.page-scroll-hint.is-hidden {
  opacity: 0;
  visibility: hidden;
  transform: translateX(-50%) translateY(10px);
  pointer-events: none;
}

@media (max-width: 720px) {
  .page-scroll-hint {
    bottom: max(14px, calc(14px + env(safe-area-inset-bottom)));
    min-height: 40px;
    max-width: calc(100vw - 120px);
    padding-inline: 13px;
  }
}

@media (prefers-reduced-motion: reduce) {
  .page-scroll-hint {
    transition-duration: .01ms !important;
  }
}
</style>
