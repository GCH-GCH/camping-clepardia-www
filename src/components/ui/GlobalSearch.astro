---
import Icon from '@/components/ui/Icon.astro';
import { getSearchIndex } from '@/data/searchIndex';
import { getPathContext } from '@/utils/localizedLinks';

const pathContext = getPathContext(Astro.url.pathname);
const entries = getSearchIndex(pathContext.languageCode);
const searchConfig = {
  entries,
  empty: pathContext.languageCode === 'pl' ? 'Wpisz np. prąd, pies, tramwaj, dokument, Wieliczka...' : 'Try electricity, dog, tram, document, Wieliczka...',
  noResults: pathContext.languageCode === 'pl' ? 'Nie znalazłem wyniku. Spróbuj innej frazy.' : 'No result. Try another phrase.',
};
const searchConfigEncoded = Buffer.from(JSON.stringify(searchConfig), 'utf-8').toString('base64');
---

<div class="global-search" data-global-search hidden aria-hidden="true">
  <div class="global-search__backdrop" data-search-close></div>
  <section class="global-search__panel" role="dialog" aria-modal="true" aria-label="Wyszukiwarka strony">
    <header class="global-search__header">
      <span aria-hidden="true"><Icon name="Search" size={22} strokeWidth={2} /></span>
      <label class="sr-only" for="globalSearchInput">Szukaj na stronie</label>
      <input id="globalSearchInput" type="search" data-search-input autocomplete="off" placeholder="Szukaj: prąd, pies, tramwaj, Google Maps..." />
      <button type="button" data-search-close aria-label="Zamknij wyszukiwarkę">
        <Icon name="X" size={22} strokeWidth={2} />
      </button>
    </header>
    <div class="global-search__hints">
      {['prąd', 'pies', 'tramwaj', 'Google Maps', 'dokument', 'Wieliczka', 'Auschwitz', 'sezon'].map((hint) => (
        <button type="button" data-search-hint={hint}>{hint}</button>
      ))}
    </div>
    <div class="global-search__results" data-search-results></div>
  </section>
</div>

<script define:vars={{ searchConfigEncoded }}>
  (() => {
    const decodeConfig = () => {
      try {
        const binary = window.atob(searchConfigEncoded);
        const bytes = Uint8Array.from(binary, (character) => character.charCodeAt(0));
        return JSON.parse(new TextDecoder().decode(bytes));
      } catch {
        return { entries: [], empty: '', noResults: '' };
      }
    };
    let config = null;
    const getConfig = () => {
      if (config) return config;
      config = decodeConfig();
      return config;
    };
    const root = document.querySelector('[data-global-search]');
    if (!(root instanceof HTMLElement)) return;

    const input = root.querySelector('[data-search-input]');
    const results = root.querySelector('[data-search-results]');
    const closeButtons = root.querySelectorAll('[data-search-close]');
    const openButtons = document.querySelectorAll('[data-search-open]');
    const hints = root.querySelectorAll('[data-search-hint]');
    let lastFocused = null;
    let closeTimer = 0;

    const normalize = (value) => value.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '');
    const resultIcon = (entry) => {
      const text = normalize(`${entry.icon || ''} ${entry.category || ''} ${entry.title || ''}`);
      const path = text.includes('tram') || text.includes('transport')
        ? '<path d="M7 16h10M8 20l2-4m6 4-2-4M7 3h10a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2Zm-2 7h14M8 7h.01M16 7h.01"/>'
        : text.includes('map') || text.includes('attraction') || text.includes('wielicz')
          ? '<path d="M9 18l-6 3V6l6-3 6 3 6-3v15l-6 3-6-3Zm0 0V3m6 18V6"/>'
          : text.includes('dog') || text.includes('pies') || text.includes('paw')
            ? '<path d="M11.5 15.5c-1.5-2-4.5-1.5-5.2.8-.7 2.4 1.8 4.2 4 3.1 1.1-.5 2.3-.5 3.4 0 2.2 1.1 4.7-.7 4-3.1-.7-2.3-3.7-2.8-5.2-.8a.65.65 0 0 1-1 0ZM6 10a2 2 0 1 0 0-4 2 2 0 0 0 0 4Zm12 0a2 2 0 1 0 0-4 2 2 0 0 0 0 4ZM10 6a2 2 0 1 0 0-4 2 2 0 0 0 0 4Zm4 0a2 2 0 1 0 0-4 2 2 0 0 0 0 4Z"/>'
            : text.includes('document') || text.includes('faq')
              ? '<path d="M6 2h8l4 4v16H6V2Zm8 0v5h5M9 12h6M9 16h6"/>'
              : '<circle cx="11" cy="11" r="7"/><path d="m20 20-4-4"/>';
      return `<svg viewBox="0 0 24 24" aria-hidden="true">${path}</svg>`;
    };

    const render = (query = '') => {
      if (!(results instanceof HTMLElement)) return;
      const activeConfig = getConfig();
      const normalizedQuery = normalize(query.trim());
      if (!normalizedQuery) {
        results.innerHTML = `<p class="global-search__empty">${activeConfig.empty}</p>`;
        return;
      }

      const matches = activeConfig.entries
        .map((entry) => {
          const haystack = normalize([entry.title, entry.description, entry.category, entry.badge, ...(entry.keywords || [])].filter(Boolean).join(' '));
          const score = haystack.includes(normalizedQuery)
            ? 4
            : normalizedQuery.split(/\s+/).some((part) => part.length > 2 && haystack.includes(part))
              ? 2
              : 0;
          return { entry, score };
        })
        .filter((item) => item.score > 0)
        .sort((a, b) => b.score - a.score)
        .slice(0, 8)
        .map((item) => item.entry);

      if (!matches.length) {
        results.innerHTML = `<p class="global-search__empty">${activeConfig.noResults}</p>`;
        return;
      }

      results.innerHTML = matches.map((entry) => `
        <a class="global-search__result" href="${entry.href}">
          ${entry.image
            ? `<img class="global-search__result-image" src="${entry.image}" alt="" width="84" height="84" loading="lazy" decoding="async">`
            : `<span class="global-search__result-icon" aria-hidden="true">${resultIcon(entry)}</span>`}
          <span>
            <small>${entry.category}${entry.badge ? ` · ${entry.badge}` : ''}</small>
            <strong>${entry.title}</strong>
            <em>${entry.description}</em>
          </span>
          <b aria-hidden="true">→</b>
        </a>
      `).join('');
    };

    const open = () => {
      lastFocused = document.activeElement instanceof HTMLElement ? document.activeElement : null;
      window.clearTimeout(closeTimer);
      root.hidden = false;
      root.setAttribute('aria-hidden', 'false');
      root.classList.remove('is-closing');
      document.body.classList.add('has-global-search-open');
      render(input instanceof HTMLInputElement ? input.value : '');
      window.requestAnimationFrame(() => {
        root.classList.add('is-open');
        window.setTimeout(() => input instanceof HTMLInputElement && input.focus({ preventScroll: true }), 90);
      });
    };

    const close = () => {
      root.setAttribute('aria-hidden', 'true');
      root.classList.remove('is-open');
      root.classList.add('is-closing');
      document.body.classList.remove('has-global-search-open');
      window.clearTimeout(closeTimer);
      closeTimer = window.setTimeout(() => {
        root.hidden = true;
        root.classList.remove('is-closing');
        lastFocused?.focus?.({ preventScroll: true });
      }, 260);
    };

    openButtons.forEach((button) => button.addEventListener('click', open));
    closeButtons.forEach((button) => button.addEventListener('click', close));
    hints.forEach((button) => button.addEventListener('click', () => {
      if (!(input instanceof HTMLInputElement)) return;
      input.value = button.dataset.searchHint || '';
      render(input.value);
      input.focus();
    }));
    if (input instanceof HTMLInputElement) {
      input.addEventListener('input', () => render(input.value));
    }
    window.addEventListener('global-search:open', (event) => {
      const detail = event instanceof CustomEvent ? event.detail : {};
      open();
      if (input instanceof HTMLInputElement && typeof detail?.query === 'string') {
        input.value = detail.query;
        render(input.value);
      }
    });
    document.addEventListener('keydown', (event) => {
      const target = event.target;
      const isTyping = target instanceof HTMLInputElement || target instanceof HTMLTextAreaElement || target instanceof HTMLSelectElement;
      if ((event.ctrlKey || event.metaKey) && event.key.toLowerCase() === 'k') {
        event.preventDefault();
        root.hidden ? open() : close();
      }
      if (event.key === 'Escape' && !root.hidden) close();
      if (!isTyping && event.key === '/' && root.hidden) {
        event.preventDefault();
        open();
      }
    });
  })();
</script>

<style>
.global-search[hidden] {
  display: none;
}

.global-search {
  position: fixed;
  inset: 0;
  z-index: 1500;
  display: grid;
  place-items: start center;
  padding: clamp(82px, 12vh, 132px) 16px 24px;
  opacity: 0;
  visibility: hidden;
  pointer-events: none;
  transition: opacity .26s ease, visibility .26s ease;
}

.global-search.is-open {
  opacity: 1;
  visibility: visible;
  pointer-events: auto;
}

.global-search__backdrop {
  position: absolute;
  inset: 0;
  background: rgba(4, 15, 10, .66);
  backdrop-filter: blur(10px);
  opacity: 0;
  transition: opacity .26s ease;
}

.global-search.is-open .global-search__backdrop {
  opacity: 1;
}

.global-search__panel {
  position: relative;
  z-index: 1;
  width: min(760px, 100%);
  max-height: min(720px, calc(100vh - 112px));
  display: grid;
  gap: 14px;
  padding: clamp(16px, 3vw, 22px);
  border: 1px solid rgba(143,224,180,.24);
  border-radius: 30px;
  overflow: auto;
  background:
    radial-gradient(circle at 16% 0%, rgba(60,179,113,.22), transparent 34%),
    rgba(11, 29, 20, .96);
  box-shadow: 0 34px 120px rgba(0,0,0,.46), 0 0 54px rgba(60,179,113,.16);
  opacity: 0;
  transform: translateY(-16px) scale(.975);
  transform-origin: top center;
  transition:
    opacity .28s cubic-bezier(.22, 1, .36, 1),
    transform .28s cubic-bezier(.22, 1, .36, 1);
}

.global-search.is-open .global-search__panel {
  opacity: 1;
  transform: translateY(0) scale(1);
}

.global-search__header {
  display: grid;
  grid-template-columns: auto minmax(0, 1fr) auto;
  gap: 12px;
  align-items: center;
  padding: 12px;
  border: 1px solid rgba(255,255,255,.12);
  border-radius: 22px;
  background: rgba(255,255,255,.08);
  color: #fff;
  transition: border-color .2s ease, box-shadow .2s ease, background .2s ease;
}

.global-search__header:focus-within {
  border-color: rgba(143,224,180,.54);
  box-shadow: 0 0 0 4px rgba(60,179,113,.14), 0 18px 42px rgba(0,0,0,.14);
}

.global-search__header input {
  width: 100%;
  border: 0;
  outline: 0;
  color: #fff;
  background: transparent;
  font: inherit;
  font-weight: 850;
}

.global-search__header input::placeholder {
  color: rgba(255,255,255,.58);
}

.global-search__header button,
.global-search__hints button {
  border: 0;
  cursor: pointer;
}

.global-search__header button {
  display: grid;
  width: 42px;
  height: 42px;
  place-items: center;
  border-radius: 15px;
  color: #fff;
  background: rgba(255,255,255,.10);
}

.global-search__hints {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.global-search__hints button {
  min-height: 34px;
  padding: 0 12px;
  border-radius: 999px;
  color: rgba(255,255,255,.82);
  background: rgba(255,255,255,.09);
  font-size: .8rem;
  font-weight: 900;
  opacity: 0;
  transform: translateY(8px);
  transition:
    opacity .24s ease,
    transform .24s ease,
    background .2s ease,
    color .2s ease;
}

.global-search.is-open .global-search__hints button {
  opacity: 1;
  transform: translateY(0);
}

.global-search.is-open .global-search__hints button:nth-child(1) { transition-delay: 45ms; }
.global-search.is-open .global-search__hints button:nth-child(2) { transition-delay: 65ms; }
.global-search.is-open .global-search__hints button:nth-child(3) { transition-delay: 85ms; }
.global-search.is-open .global-search__hints button:nth-child(4) { transition-delay: 105ms; }
.global-search.is-open .global-search__hints button:nth-child(5) { transition-delay: 125ms; }
.global-search.is-open .global-search__hints button:nth-child(6) { transition-delay: 145ms; }
.global-search.is-open .global-search__hints button:nth-child(7) { transition-delay: 165ms; }
.global-search.is-open .global-search__hints button:nth-child(8) { transition-delay: 185ms; }

.global-search__hints button:hover {
  color: #071b10;
  background: #8fe0b4;
}

.global-search__results {
  display: grid;
  gap: 10px;
}

.global-search__result {
  display: grid;
  grid-template-columns: 48px minmax(0, 1fr) auto;
  gap: 12px;
  align-items: center;
  padding: 13px;
  border: 1px solid rgba(255,255,255,.10);
  border-radius: 20px;
  color: #fff;
  background: rgba(255,255,255,.075);
  text-decoration: none;
  transition: transform .2s ease, border-color .2s ease, background .2s ease, box-shadow .2s ease;
}

.global-search__result:hover {
  transform: translateY(-2px);
  border-color: rgba(143,224,180,.34);
  background: rgba(255,255,255,.105);
  box-shadow: 0 18px 42px rgba(0,0,0,.14);
}

.global-search__result-icon {
  width: 48px;
  height: 48px;
  display: grid;
  place-items: center;
  border-radius: 15px;
  color: #082016;
  background: linear-gradient(135deg, #a8f0c7, #3CB371);
  box-shadow: 0 12px 30px rgba(60,179,113,.22);
}

.global-search__result-icon svg {
  width: 23px;
  height: 23px;
  fill: none;
  stroke: currentColor;
  stroke-width: 1.9;
  stroke-linecap: round;
  stroke-linejoin: round;
}

.global-search__result-image {
  width: 48px;
  height: 48px;
  display: block;
  border-radius: 15px;
  object-fit: cover;
  box-shadow: 0 12px 30px rgba(20,50,33,.20);
}

.global-search__result > b {
  color: #8fe0b4;
  font-size: 1.2rem;
}

.global-search__result small,
.global-search__result em {
  display: block;
  color: rgba(255,255,255,.62);
  font-style: normal;
  line-height: 1.4;
}

.global-search__result strong {
  display: block;
  margin: 3px 0;
  color: #fff;
  font-weight: 950;
}

.global-search__empty {
  margin: 0;
  padding: 18px;
  border: 1px dashed rgba(143,224,180,.24);
  border-radius: 20px;
  color: rgba(255,255,255,.70);
  background: rgba(255,255,255,.06);
}

html[data-theme="light"] .global-search__backdrop {
  background: rgba(246, 250, 244, .70);
}

html[data-theme="light"] .global-search__panel {
  background:
    radial-gradient(circle at 16% 0%, rgba(60,179,113,.18), transparent 34%),
    rgba(255,255,255,.96);
  box-shadow: 0 34px 120px rgba(16,40,28,.20);
}

html[data-theme="light"] .global-search__header,
html[data-theme="light"] .global-search__result,
html[data-theme="light"] .global-search__empty {
  color: #102018;
  border-color: rgba(21, 62, 39, .12);
  background: rgba(15, 45, 30, .06);
}

html[data-theme="light"] .global-search__header:focus-within {
  border-color: rgba(34,126,77,.34);
  box-shadow: 0 0 0 4px rgba(60,179,113,.13), 0 18px 42px rgba(16,40,28,.10);
}

html[data-theme="light"] .global-search__header input,
html[data-theme="light"] .global-search__result strong {
  color: #102018;
}

html[data-theme="light"] .global-search__result:hover {
  border-color: rgba(34,126,77,.24);
  background: rgba(255,255,255,.90);
  box-shadow: 0 18px 42px rgba(16,40,28,.10);
}

html[data-theme="light"] .global-search__result > b {
  color: #23784d;
}

html[data-theme="light"] .global-search__header input::placeholder,
html[data-theme="light"] .global-search__result small,
html[data-theme="light"] .global-search__result em,
html[data-theme="light"] .global-search__empty {
  color: rgba(16,32,24,.64);
}

html[data-theme="light"] .global-search__header button,
html[data-theme="light"] .global-search__hints button {
  color: #123422;
  background: rgba(60,179,113,.12);
}

body.has-global-search-open {
  overflow: hidden;
}

@media (max-width: 640px) {
  .global-search {
    place-items: end center;
    padding: 12px 8px max(8px, env(safe-area-inset-bottom));
  }

  .global-search__panel {
    width: 100%;
    max-height: min(84dvh, 720px);
    border-radius: 26px 26px 18px 18px;
    transform: translateY(24px) scale(.99);
  }
}

@media (prefers-reduced-motion: reduce) {
  .global-search,
  .global-search__backdrop,
  .global-search__panel,
  .global-search__hints button {
    transition-duration: .01ms !important;
    transition-delay: 0ms !important;
  }
}
</style>
