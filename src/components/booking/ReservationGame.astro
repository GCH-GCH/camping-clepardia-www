const configEncoded = Buffer.from(JSON.stringify(config)).toString('base64');
---

<section class="reservation-game booking-app-page" data-reservation-game data-config={configEncoded} data-after-hero>
  <div class="reservation-game__ambient" aria-hidden="true">
    <span></span><span></span><span></span>
  </div>
  <div class="container reservation-game__shell">
    <div class="reservation-game__mount" data-rg-mount>
      <div class="reservation-start">
        <span class="reservation-kicker">{copy.kicker}</span>
        <h1>{copy.title}</h1>
        <p>{copy.lead}</p>
        <div class="reservation-start__panel">
          <div>
            <span class="reservation-kicker">{copy.startTitle}</span>
            <p>{copy.startLead}</p>
          </div>
          <div class="reservation-choice-grid">
            {Object.entries(copy.modes).map(([mode, item]) => (
              <button class="reservation-choice" type="button" data-start-mode={mode}>
                <span>{mode === 'camping' ? 'RV' : mode === 'bungalow' ? '2/3/4' : 'MIX'}</span>
                <strong>{item[0]}</strong>
                <small>{item[1]}</small>
              </button>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script define:vars={{ configEncoded }}>
  (() => {
    const root = document.querySelector('[data-reservation-game]');
    if (!(root instanceof HTMLElement)) return;

    const mount = root.querySelector('[data-rg-mount]');
    if (!(mount instanceof HTMLElement)) return;

    const decodeConfig = () => {
      try {
        const binary = window.atob(configEncoded);
        const bytes = Uint8Array.from(binary, (character) => character.charCodeAt(0));
        return JSON.parse(new TextDecoder().decode(bytes));
      } catch {
        return null;
      }
    };

    const config = decodeConfig();
    if (!config) return;

    const t = config.copy;
    const currency = config.currency;
    const modeKeys = ['camping', 'bungalow', 'combined'];
    const stepKeys = ['dates', 'guests', 'services', 'details', 'summary'];
    const languageOptions = ['PL', 'EN', 'DE', 'IT'];

    const state = {
      mode: null,
      step: 0,
      values: {
        arrival: '',
        departure: '',
        adults: 2,
        children: 0,
        toddlers: 0,
        bungalowGuests: 2,
        campingGuests: 2,
        name: '',
        email: '',
        phone: '',
        language: config.lang.toUpperCase(),
        country: '',
        countryCode: '',
        plate: '',
        message: '',
        specialNeeds: false,
        specialNeedsText: '',
        lateCheckout: false,
        lateCheckoutTime: '',
        quiet: false,
        consent: false,
      },
      quantities: {},
      countryMatches: [],
      countryIndex: -1,
      status: '',
      success: '',
    };

    const esc = (value) => String(value ?? '').replace(/[&<>"']/g, (char) => ({
      '&': '&amp;',
      '<': '&lt;',
      '>': '&gt;',
      '"': '&quot;',
      "'": '&#039;',
    }[char]));
    const normalize = (value) => String(value ?? '').toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '').trim();
    const intValue = (value) => Math.max(0, Number.parseInt(value || '0', 10) || 0);
    const money = (value) => `${Math.max(0, Math.round(value))} ${currency}`;
    const quantityKey = (scope, id) => `${scope}:${id}`;

    const seedQuantities = () => {
      ['camping', 'bungalow', 'combinedCamping', 'combinedBungalow'].forEach((scope) => {
        (config.services[scope] ?? []).forEach((service) => {
          state.quantities[quantityKey(scope, service.id)] = 0;
        });
      });
    };
    seedQuantities();

    const getNights = () => {
      if (!state.values.arrival || !state.values.departure) return 0;
      const start = new Date(`${state.values.arrival}T12:00:00`);
      const end = new Date(`${state.values.departure}T12:00:00`);
      const diff = Math.round((end.getTime() - start.getTime()) / 86400000);
      return Math.max(0, diff);
    };

    const isHighSeason = () => {
      if (!state.values.arrival) return false;
      const [, month, day] = state.values.arrival.split('-');
      const token = `${month}-${day}`;
      return token >= config.seasons.high.start && token <= config.seasons.high.end;
    };

    const touchesSummer = () => [state.values.arrival, state.values.departure].filter(Boolean).some((value) => {
      const month = Number.parseInt(value.split('-')[1] || '0', 10);
      return month === 7 || month === 8;
    });

    const servicePrice = (service) => {
      if (service.seasonalPrices) return isHighSeason() ? service.seasonalPrices.high : service.seasonalPrices.low;
      return Number(service.price ?? 0);
    };

    const servicesForScope = (scope) => config.services[scope] ?? [];
    const selectedForScope = (scope) => servicesForScope(scope)
      .map((service) => ({
        ...service,
        scope,
        quantity: intValue(state.quantities[quantityKey(scope, service.id)]),
        unitPrice: servicePrice(service),
      }))
      .filter((service) => service.quantity > 0);

    const selectedServices = () => {
      if (state.mode === 'camping') return selectedForScope('camping');
      if (state.mode === 'bungalow') return selectedForScope('bungalow');
      if (state.mode === 'combined') return [...selectedForScope('combinedBungalow'), ...selectedForScope('combinedCamping')];
      return [];
    };

    const peopleCostPerNight = () => {
      const adultPrice = Number(config.people.adults.price ?? 0);
      const childPrice = Number(config.people.children.price ?? 0);
      if (state.mode === 'camping') return (state.values.adults * adultPrice) + (state.values.children * childPrice);
      if (state.mode === 'combined') return (state.values.campingGuests * adultPrice) + (state.values.children * childPrice);
      return 0;
    };

    const estimatedTotal = () => {
      const nights = getNights();
      if (!nights) return 0;
      const serviceTotal = selectedServices().reduce((sum, service) => sum + service.unitPrice * service.quantity, 0);
      return nights * (serviceTotal + peopleCostPerNight());
    };

    const datesLabel = () => state.values.arrival && state.values.departure
      ? `${state.values.arrival} → ${state.values.departure}`
      : '-';

    const guestsLabel = () => {
      if (state.mode === 'combined') return `${t.fields.bungalowGuests}: ${state.values.bungalowGuests}, ${t.fields.campingGuests}: ${state.values.campingGuests}, ${t.fields.children}: ${state.values.children}, ${t.fields.toddlers}: ${state.values.toddlers}`;
      return `${t.fields.adults}: ${state.values.adults}, ${t.fields.children}: ${state.values.children}, ${t.fields.toddlers}: ${state.values.toddlers}`;
    };

    const modeTitle = () => state.mode ? t.modes[state.mode][0] : '-';

    const searchCountries = (query) => {
      const needle = normalize(query);
      const pool = config.countries ?? [];
      state.countryMatches = needle
        ? pool.filter((country) => [country.code, country.names[config.lang] ?? country.names.en, country.names.en, ...country.aliases].some((value) => normalize(value).includes(needle))).slice(0, 8)
        : pool.slice(0, 7);
      state.countryIndex = state.countryMatches.length ? 0 : -1;
    };

    const selectCountry = (country) => {
      if (!country) return;
      state.values.country = country.names[config.lang] ?? country.names.en;
      state.values.countryCode = country.code;
      state.countryMatches = [];
      state.countryIndex = -1;
      render({ focusCountry: false });
    };

    const startTemplate = () => `
      <div class="reservation-start">
        <span class="reservation-kicker">${esc(t.kicker)}</span>
        <h1>${esc(t.title)}</h1>
        <p>${esc(t.lead)}</p>
        <div class="reservation-start__panel">
          <div>
            <span class="reservation-kicker">${esc(t.startTitle)}</span>
            <p>${esc(t.startLead)}</p>
          </div>
          <div class="reservation-choice-grid">
            ${modeKeys.map((mode) => `
              <button class="reservation-choice" type="button" data-start-mode="${mode}">
                <span>${mode === 'camping' ? 'RV' : mode === 'bungalow' ? '2/3/4' : 'MIX'}</span>
                <strong>${esc(t.modes[mode][0])}</strong>
                <small>${esc(t.modes[mode][1])}</small>
              </button>
            `).join('')}
          </div>
        </div>
      </div>
    `;

    const progressTemplate = () => {
      const percent = Math.round(((state.step - 1) / (stepKeys.length - 1)) * 100);
      return `
        <div class="reservation-progress">
          <div class="reservation-progress__mobile">
            <span>Krok ${state.step} z ${stepKeys.length}</span>
            <strong>${esc(t.steps[state.step - 1])}</strong>
            <i style="--progress:${percent}%"></i>
          </div>
          <div class="reservation-progress__rail" style="--progress:${percent}%">
            ${t.steps.map((label, index) => {
              const step = index + 1;
              return `
                <button type="button" data-jump-step="${step}" class="${step === state.step ? 'is-active' : ''} ${step < state.step ? 'is-complete' : ''}" ${step > state.step ? 'disabled' : ''}>
                  <span>${String(step).padStart(2, '0')}</span>
                  <strong>${esc(label)}</strong>
                </button>
              `;
            }).join('')}
          </div>
          <div class="reservation-selected">
            <span>${esc(t.summary.stay)}: <strong>${esc(modeTitle())}</strong></span>
            <button type="button" data-change-mode>${esc(t.actions.change)}</button>
          </div>
        </div>
      `;
    };

    const field = ({ key, label, type = 'text', hint = '', value = '', attrs = '' }) => `
      <label class="booking-field">
        <span>${esc(label)}</span>
        <input type="${type}" data-bind="${key}" value="${esc(value)}" ${attrs} />
        ${hint ? `<small>${esc(hint)}</small>` : ''}
      </label>
    `;

    const stepper = ({ scope, id, label, price = -1, value, icon = '+' }) => `
      <article class="booking-stepper-card">
        <div class="booking-stepper-card__meta">
          <span class="booking-stepper-card__icon">${esc(icon)}</span>
          <div>
            <strong>${esc(label)}</strong>
            ${price >= 0 ? `<small>${money(price)} / noc</small>` : ''}
          </div>
        </div>
        <div class="booking-stepper" data-stepper>
          <button type="button" data-minus="${esc(id)}" data-scope="${esc(scope)}" aria-label="${esc(`${t.actions.decrease} ${label}`)}" ${value <= 0 ? 'disabled' : ''}>−</button>
          <input type="text" inputmode="numeric" value="${value}" data-quantity="${esc(id)}" data-scope="${esc(scope)}" aria-label="${esc(label)}" />
          <button type="button" data-plus="${esc(id)}" data-scope="${esc(scope)}" aria-label="${esc(`${t.actions.increase} ${label}`)}">+</button>
        </div>
      </article>
    `;

    const guestStep = () => {
      const items = state.mode === 'combined'
        ? [
          { scope: 'value', id: 'bungalowGuests', label: t.fields.bungalowGuests, value: state.values.bungalowGuests, icon: 'DG' },
          { scope: 'value', id: 'campingGuests', label: t.fields.campingGuests, value: state.values.campingGuests, price: config.people.adults.price, icon: 'CG' },
          { scope: 'value', id: 'children', label: t.fields.children, value: state.values.children, price: config.people.children.price, icon: 'CH' },
          { scope: 'value', id: 'toddlers', label: t.fields.toddlers, value: state.values.toddlers, price: 0, icon: '0+' },
        ]
        : [
          { scope: 'value', id: 'adults', label: t.fields.adults, value: state.values.adults, price: state.mode === 'camping' ? config.people.adults.price : -1, icon: 'AD' },
          { scope: 'value', id: 'children', label: t.fields.children, value: state.values.children, price: state.mode === 'camping' ? config.people.children.price : -1, icon: 'CH' },
          { scope: 'value', id: 'toddlers', label: t.fields.toddlers, value: state.values.toddlers, price: 0, icon: '0+' },
        ];
      return `<div class="booking-stepper-grid">${items.map(stepper).join('')}</div>`;
    };

    const serviceCard = (scope, service) => {
      const value = intValue(state.quantities[quantityKey(scope, service.id)]);
      const unit = servicePrice(service);
      const subtotal = unit * value * Math.max(1, getNights());
      return `
        <article class="booking-service-card ${value > 0 ? 'is-selected' : ''}">
          <div class="booking-service-card__top">
            <span class="booking-stepper-card__icon">${esc(service.icon)}</span>
            <div>
              <strong>${esc(service.label)}</strong>
              <small>${money(unit)} / noc</small>
            </div>
          </div>
          <div class="booking-service-card__bottom">
            <div class="booking-stepper" data-stepper>
              <button type="button" data-service-minus="${esc(service.id)}" data-scope="${esc(scope)}" aria-label="${esc(`${t.actions.decrease} ${service.label}`)}" ${value <= 0 ? 'disabled' : ''}>−</button>
              <input type="text" inputmode="numeric" value="${value}" data-service-quantity="${esc(service.id)}" data-scope="${esc(scope)}" aria-label="${esc(service.label)}" />
              <button type="button" data-service-plus="${esc(service.id)}" data-scope="${esc(scope)}" aria-label="${esc(`${t.actions.increase} ${service.label}`)}">+</button>
            </div>
            ${value > 0 ? `<small>${money(subtotal)}</small>` : ''}
          </div>
        </article>
      `;
    };

    const serviceGroup = (title, scope, note = '') => `
      <section class="booking-service-group">
        <header>
          <h3>${esc(title)}</h3>
          ${note ? `<p>${esc(note)}</p>` : ''}
        </header>
        <div class="booking-service-grid">
          ${servicesForScope(scope).map((service) => serviceCard(scope, service)).join('')}
        </div>
      </section>
    `;

    const servicesStep = () => {
      if (state.mode === 'camping') return serviceGroup(t.modes.camping[0], 'camping', t.info.campingPitch);
      if (state.mode === 'bungalow') return serviceGroup(t.modes.bungalow[0], 'bungalow', t.info.bungalowHours);
      return `
        <div class="booking-combined-grid">
          ${serviceGroup(t.modes.bungalow[0], 'combinedBungalow')}
          ${serviceGroup(t.modes.camping[0], 'combinedCamping', t.info.combined)}
        </div>
      `;
    };

    const countryList = () => {
      if (!state.countryMatches.length) return '';
      return `
        <div class="booking-country-list" role="listbox">
          ${state.countryMatches.map((country, index) => `
            <button type="button" class="${index === state.countryIndex ? 'is-active' : ''}" data-country-index="${index}">
              <span class="${esc(country.flagClass)}"></span>
              <strong>${esc(country.names[config.lang] ?? country.names.en)}</strong>
              <small>${esc(country.code)}</small>
            </button>
          `).join('')}
        </div>
      `;
    };

    const detailsStep = () => `
      <div class="booking-form-grid">
        ${field({ key: 'name', label: t.fields.name, value: state.values.name, attrs: 'autocomplete="name"' })}
        ${field({ key: 'email', label: t.fields.email, type: 'email', value: state.values.email, attrs: 'autocomplete="email"' })}
        ${field({ key: 'phone', label: t.fields.phone, type: 'tel', value: state.values.phone, attrs: 'autocomplete="tel"' })}
        <label class="booking-field">
          <span>${esc(t.fields.language)}</span>
          <select data-bind="language">
            ${languageOptions.map((option) => `<option value="${option}" ${state.values.language === option ? 'selected' : ''}>${option}</option>`).join('')}
          </select>
        </label>
        <label class="booking-field booking-country">
          <span>${esc(t.fields.country)}</span>
          <input type="text" data-country-input value="${esc(state.values.country)}" placeholder="${esc(t.fields.countryPlaceholder)}" autocomplete="off" />
          <input type="hidden" value="${esc(state.values.countryCode)}" data-country-code />
          ${countryList()}
        </label>
        ${field({ key: 'plate', label: t.fields.plate, value: state.values.plate, hint: t.fields.plateHint })}
        <label class="booking-check">
          <input type="checkbox" data-check="specialNeeds" ${state.values.specialNeeds ? 'checked' : ''} />
          <span>${esc(t.fields.specialNeeds)}</span>
        </label>
        <label class="booking-check">
          <input type="checkbox" data-check="lateCheckout" ${state.values.lateCheckout ? 'checked' : ''} />
          <span>${esc(t.fields.lateCheckout)}</span>
        </label>
        ${state.values.specialNeeds ? `
          <label class="booking-field booking-field--full">
            <span>${esc(t.fields.specialNeedsText)}</span>
            <textarea data-bind="specialNeedsText">${esc(state.values.specialNeedsText)}</textarea>
          </label>
        ` : ''}
        ${state.values.lateCheckout ? `
          <label class="booking-field booking-field--full">
            <span>${esc(t.fields.lateTime)}</span>
            <select data-bind="lateCheckoutTime">
              <option value="">--</option>
              ${['13:00','14:00','15:00','16:00','17:00'].map((time) => `<option value="${time}" ${state.values.lateCheckoutTime === time ? 'selected' : ''}>${time}</option>`).join('')}
            </select>
            <small>${esc(t.info.lateCheckout)}</small>
          </label>
        ` : ''}
        <label class="booking-field booking-field--full">
          <span>${esc(t.fields.message)}</span>
          <textarea data-bind="message">${esc(state.values.message)}</textarea>
        </label>
        <label class="booking-check booking-check--full">
          <input type="checkbox" data-check="quiet" ${state.values.quiet ? 'checked' : ''} />
          <span>${esc(t.fields.quiet)}</span>
        </label>
        <label class="booking-check booking-check--full">
          <input type="checkbox" data-check="consent" ${state.values.consent ? 'checked' : ''} />
          <span>${esc(t.fields.consent)}</span>
        </label>
      </div>
    `;

    const summaryRows = () => [
      [t.summary.stay, modeTitle()],
      [t.summary.dates, datesLabel()],
      [t.fields.nights, String(getNights())],
      [t.summary.guests, guestsLabel()],
      [t.summary.country, state.values.country || '-'],
      [t.summary.language, state.values.language || '-'],
      ...(state.values.specialNeeds ? [[t.summary.specialNeeds, 'zgłoszono']] : []),
      ...(state.values.lateCheckout ? [[t.summary.lateCheckout, state.values.lateCheckoutTime || '-']] : []),
    ];

    const summaryTemplate = (full = false) => {
      const services = selectedServices();
      const total = estimatedTotal();
      const nights = Math.max(1, getNights());
      return `
        <div class="booking-summary-content">
          <span class="reservation-kicker">${esc(t.summary.title)}</span>
          ${total > 0 ? `<h2>${money(total)}</h2><p>${esc(t.summary.total)}</p>` : `<h2>${esc(t.summary.title)}</h2><p>${esc(t.summary.empty)}</p>`}
          <div class="booking-summary-rows">
            ${summaryRows().map(([label, value]) => `<dl><dt>${esc(label)}</dt><dd>${esc(value)}</dd></dl>`).join('')}
          </div>
          ${services.length ? `
            <div class="booking-summary-services">
              <h3>${esc(t.summary.services)}</h3>
              ${services.map((service) => `<p><span>${esc(service.label)} x ${service.quantity}</span><strong>${money(service.unitPrice * service.quantity * nights)}</strong></p>`).join('')}
              ${peopleCostPerNight() > 0 ? `<p><span>${esc(t.summary.guests)}</span><strong>${money(peopleCostPerNight() * nights)}</strong></p>` : ''}
            </div>
          ` : ''}
          <small>${esc(t.summary.confirm)}</small>
          ${full ? `<textarea name="reservationPayload" hidden>${esc(JSON.stringify(payload(), null, 2))}</textarea>` : ''}
        </div>
      `;
    };

    const payload = () => ({
      stayMode: state.mode,
      dates: { arrival: state.values.arrival, departure: state.values.departure, nights: getNights() },
      guests: {
        adults: state.values.adults,
        children: state.values.children,
        toddlers: state.values.toddlers,
        bungalowGuests: state.values.bungalowGuests,
        campingGuests: state.values.campingGuests,
      },
      services: selectedServices().map((service) => ({
        id: service.id,
        scope: service.scope,
        label: service.label,
        quantity: service.quantity,
        unitPrice: service.unitPrice,
      })),
      details: {
        name: state.values.name,
        email: state.values.email,
        phone: state.values.phone,
        language: state.values.language,
        country: state.values.countryCode,
        plate: state.values.plate,
        message: state.values.message,
      },
      specialNeeds: state.values.specialNeeds ? state.values.specialNeedsText : '',
      lateCheckout: state.values.lateCheckout ? state.values.lateCheckoutTime : '',
      estimatedTotal: estimatedTotal(),
    });

    const dateStep = () => {
      const info = state.mode === 'combined'
        ? `${t.info.campingHours} ${t.info.bungalowHours}`
        : state.mode === 'bungalow'
        ? t.info.bungalowHours
        : t.info.campingHours;
      return `
        <div class="booking-date-grid">
          <label class="booking-field">
            <span>${esc(t.fields.arrival)}</span>
            <input type="date" data-bind="arrival" value="${esc(state.values.arrival)}" />
          </label>
          <label class="booking-field">
            <span>${esc(t.fields.departure)}</span>
            <input type="date" data-bind="departure" value="${esc(state.values.departure)}" />
          </label>
          <div class="booking-night-card">
            <span>${esc(t.fields.nights)}</span>
            <strong>${getNights()}</strong>
          </div>
        </div>
        <p class="booking-note">${esc(info)}</p>
        ${touchesSummer() ? `<p class="booking-note booking-note--warm">${esc(t.info.summer)}</p>` : ''}
      `;
    };

    const stepBody = () => {
      if (state.step === 1) return dateStep();
      if (state.step === 2) return guestStep();
      if (state.step === 3) return servicesStep();
      if (state.step === 4) return detailsStep();
      return summaryTemplate(true);
    };

    const appTemplate = () => `
      <div class="reservation-app">
        ${progressTemplate()}
        <div class="reservation-layout">
          <form class="reservation-stage" data-reservation-form novalidate>
            <header class="reservation-step-head">
              <span class="reservation-kicker">${esc(t.steps[state.step - 1])}</span>
              <h2>${esc(t.steps[state.step - 1])}</h2>
              <p>${esc(t.stepLead[stepKeys[state.step - 1]])}</p>
            </header>
            <div class="reservation-step-panel">
              ${stepBody()}
            </div>
            <p class="reservation-status" data-status>${esc(state.status || state.success)}</p>
            <div class="reservation-nav">
              <button class="reservation-btn reservation-btn--ghost" type="button" data-back ${state.step <= 1 ? 'hidden' : ''}>${esc(t.actions.back)}</button>
              ${state.step < stepKeys.length
                ? `<button class="reservation-btn reservation-btn--primary" type="button" data-next>${esc(t.actions.next)}</button>`
                : `<button class="reservation-btn reservation-btn--primary" type="submit">${esc(t.actions.send)}</button>`}
            </div>
          </form>
          <aside class="reservation-summary">
            ${summaryTemplate(false)}
          </aside>
        </div>
      </div>
    `;

    const render = ({ focusCountry = false } = {}) => {
      mount.innerHTML = state.mode ? appTemplate() : startTemplate();
      root.dataset.mode = state.mode || '';
      root.dataset.step = String(state.step);
      if (focusCountry) {
        const input = mount.querySelector('[data-country-input]');
        if (input instanceof HTMLInputElement) {
          input.focus();
          input.setSelectionRange(input.value.length, input.value.length);
        }
      }
    };

    const startFlow = (mode) => {
      state.mode = modeKeys.includes(mode) ? mode : 'camping';
      state.step = 1;
      state.status = '';
      state.success = '';
      const url = new URL(window.location.href);
      url.searchParams.set('stay', state.mode);
      window.history.replaceState({}, '', url);
      render();
      window.requestAnimationFrame(() => root.scrollIntoView({ behavior: 'smooth', block: 'start' }));
    };

    const resetFlow = () => {
      state.mode = null;
      state.step = 0;
      state.status = '';
      state.success = '';
      const url = new URL(window.location.href);
      url.searchParams.delete('stay');
      window.history.replaceState({}, '', url);
      render();
    };

    const serviceCounts = () => {
      const camping = state.mode === 'combined' ? selectedForScope('combinedCamping') : selectedForScope('camping');
      const bungalow = state.mode === 'combined' ? selectedForScope('combinedBungalow') : selectedForScope('bungalow');
      return {
        camping: camping.filter((service) => service.group === 'camping').reduce((sum, service) => sum + service.quantity, 0),
        bungalow: bungalow.filter((service) => service.group === 'bungalow').reduce((sum, service) => sum + service.quantity, 0),
      };
    };

    const validateStep = () => {
      state.status = '';
      if (state.step !== 3) return true;
      const counts = serviceCounts();
      if (state.mode === 'camping' && counts.camping < 1) state.status = t.validation.campingService;
      if (state.mode === 'bungalow' && counts.bungalow < 1) state.status = t.validation.bungalowService;
      if (state.mode === 'combined' && (counts.camping < 1 || counts.bungalow < 1)) state.status = t.validation.combinedService;
      return !state.status;
    };

    const setStep = (nextStep) => {
      state.step = Math.max(1, Math.min(stepKeys.length, nextStep));
      state.status = '';
      render();
    };

    mount.addEventListener('click', (event) => {
      const target = event.target;
      if (!(target instanceof HTMLElement)) return;
      const startButton = target.closest('[data-start-mode]');
      if (startButton instanceof HTMLElement) {
        startFlow(startButton.dataset.startMode);
        return;
      }
      if (target.closest('[data-change-mode]')) {
        resetFlow();
        return;
      }
      const jumpButton = target.closest('[data-jump-step]');
      if (jumpButton instanceof HTMLElement) {
        const requested = Number(jumpButton.dataset.jumpStep);
        if (requested <= state.step) setStep(requested);
        return;
      }
      if (target.closest('[data-next]')) {
        if (validateStep()) setStep(state.step + 1);
        else render();
        return;
      }
      if (target.closest('[data-back]')) {
        setStep(state.step - 1);
        return;
      }
      const countryButton = target.closest('[data-country-index]');
      if (countryButton instanceof HTMLElement) {
        selectCountry(state.countryMatches[Number(countryButton.dataset.countryIndex)]);
        return;
      }
      const plus = target.closest('[data-plus], [data-minus], [data-service-plus], [data-service-minus]');
      if (plus instanceof HTMLElement) {
        const scope = plus.dataset.scope || 'value';
        const id = plus.dataset.plus || plus.dataset.minus || plus.dataset.servicePlus || plus.dataset.serviceMinus;
        const delta = plus.hasAttribute('data-plus') || plus.hasAttribute('data-service-plus') ? 1 : -1;
        if (scope === 'value') state.values[id] = Math.max(0, intValue(state.values[id]) + delta);
        else state.quantities[quantityKey(scope, id)] = Math.max(0, intValue(state.quantities[quantityKey(scope, id)]) + delta);
        render();
      }
    });

    mount.addEventListener('input', (event) => {
      const target = event.target;
      if (!(target instanceof HTMLInputElement || target instanceof HTMLTextAreaElement || target instanceof HTMLSelectElement)) return;
      if (target.matches('[data-country-input]')) {
        state.values.country = target.value;
        state.values.countryCode = '';
        searchCountries(target.value);
        render({ focusCountry: true });
        return;
      }
      const serviceQuantity = target.dataset.serviceQuantity;
      const quantity = target.dataset.quantity;
      if (serviceQuantity) {
        state.quantities[quantityKey(target.dataset.scope, serviceQuantity)] = intValue(target.value);
        render();
        return;
      }
      if (quantity) {
        state.values[quantity] = intValue(target.value);
        render();
        return;
      }
      const key = target.dataset.bind;
      if (key) {
        state.values[key] = target.value;
        render();
      }
    });

    mount.addEventListener('change', (event) => {
      const target = event.target;
      if (!(target instanceof HTMLInputElement || target instanceof HTMLTextAreaElement || target instanceof HTMLSelectElement)) return;
      const check = target.dataset.check;
      if (check) {
        state.values[check] = target instanceof HTMLInputElement ? target.checked : Boolean(target.value);
        render();
      }
    });

    mount.addEventListener('keydown', (event) => {
      const target = event.target;
      if (!(target instanceof HTMLInputElement) || !target.matches('[data-country-input]')) return;
      if (!state.countryMatches.length) return;
      if (event.key === 'Escape') {
        state.countryMatches = [];
        render({ focusCountry: true });
      }
      if (event.key === 'ArrowDown' || event.key === 'ArrowUp') {
        event.preventDefault();
        state.countryIndex = event.key === 'ArrowDown'
          ? Math.min(state.countryMatches.length - 1, state.countryIndex + 1)
          : Math.max(0, state.countryIndex - 1);
        render({ focusCountry: true });
      }
      if (event.key === 'Enter' && state.countryIndex >= 0) {
        event.preventDefault();
        selectCountry(state.countryMatches[state.countryIndex]);
      }
    });

    mount.addEventListener('submit', (event) => {
      event.preventDefault();
      if (!state.values.quiet || !state.values.consent) {
        state.status = t.validation.consents;
        state.success = '';
        render();
        return;
      }
      state.status = '';
      state.success = t.summary.success;
      render();
    });

    const params = new URLSearchParams(window.location.search);
    const stay = params.get('stay');
    if (modeKeys.includes(stay)) startFlow(stay);
    else render();
  })();
</script>

