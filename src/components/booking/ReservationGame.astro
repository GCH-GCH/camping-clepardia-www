const config = {
  lang,
  copy,
  currency: pricingConfig.currency,
  seasons: pricingConfig.seasons,
  people: pricingConfig.people,
  countries,
  services: {
    camping: campingServices,
    bungalow: bungalowServices,
    combinedCamping: combinedCampingServices,
    combinedBungalow: bungalowServices,
