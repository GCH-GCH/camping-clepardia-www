<script define:vars={{ bookingConfigEncoded }}>
  (() => {
    const root = document.querySelector('[data-booking-experience]');
    if (!(root instanceof HTMLElement)) return;

    const decodeConfig = () => {
      try {
        const binary = window.atob(bookingConfigEncoded);
        const bytes = Uint8Array.from(binary, (character) => character.charCodeAt(0));
        return JSON.parse(new TextDecoder().decode(bytes));
      } catch {
        return null;
      }
    };

    const config = decodeConfig();
    if (!config) return;

    const start = root.querySelector('[data-booking-start]');
    const flow = root.querySelector('[data-booking-flow]');
    const form = root.querySelector('[data-booking-form]');
    const stepNodes = Array.from(root.querySelectorAll('[data-booking-step]'));
    const progressButtons = Array.from(root.querySelectorAll('[data-step-jump]'));
    const prevButton = root.querySelector('[data-booking-prev]');
    const nextButton = root.querySelector('[data-booking-next]');
    const submitButton = root.querySelector('[data-booking-submit]');
    const messageNode = root.querySelector('[data-booking-message]');
    const summaryList = root.querySelector('[data-summary-list]');
    const summaryPrice = root.querySelector('[data-summary-price]');
    const finalSummary = root.querySelector('[data-final-summary]');
    const nightsOutput = root.querySelector('[data-nights-output]');
    const hoursOutput = root.querySelector('[data-hours-output]');
    const formStatus = root.querySelector('[data-form-status]');
    const summary = root.querySelector('[data-summary]');
    const summaryToggle = root.querySelector('[data-summary-toggle]');
    const countryInput = root.querySelector('[data-country-input]');
    const countryList = root.querySelector('[data-country-list]');
    const countryCode = root.querySelector('[data-country-code]');
    const specialNeeds = root.querySelector('[data-special-needs]');
    const specialDetails = root.querySelector('[data-special-details]');
    const lateCheckout = root.querySelector('[data-late-checkout]');
    const lateCheckoutDetails = root.querySelector('[data-late-checkout-details]');
    const summerBookingNotice = root.querySelector('[data-summer-booking-notice]');
    const bookingPayload = root.querySelector('[data-booking-payload]');

    if (!(start instanceof HTMLElement) || !(flow instanceof HTMLElement) || !(form instanceof HTMLFormElement)) return;

    const normalize = (value) => String(value ?? '')
      .toLowerCase()
      .normalize('NFD')
      .replace(/[\u0300-\u036f]/g, '')
      .trim();

    const state = {
      category: 'camping',
      step: 0,
      country: '',
      countryLabel: '',
      countryIndex: -1,
      countryMatches: [],
    };

    const formatMoney = (value) => `${Math.max(0, Math.round(value))} ${config.pricing.currency}`;
    const bySelector = (selector) => root.querySelector(selector);
    const getInputValue = (selector) => {
      const node = bySelector(selector);
      return node instanceof HTMLInputElement || node instanceof HTMLSelectElement || node instanceof HTMLTextAreaElement ? node.value : '';
    };
    const getChecked = (selector) => {
      const node = bySelector(selector);
      return node instanceof HTMLInputElement && node.checked;
    };
    const getNumber = (counterName) => {
      const nodes = Array.from(root.querySelectorAll(`[data-counter="${counterName}"] input`));
      const node = nodes.find((input) => input instanceof HTMLInputElement && !input.closest('[hidden]'));
      const value = node instanceof HTMLInputElement ? Number.parseInt(node.value, 10) : 0;
      return Number.isFinite(value) ? Math.max(0, value) : 0;
    };
    const getServiceInputs = (scope) => Array.from(root.querySelectorAll(`[data-service-scope="${scope}"]`))
      .filter((node) => node instanceof HTMLInputElement);
    const getServiceLinePrice = (input) => {
      if (!(input instanceof HTMLInputElement)) return 0;
      const priceKey = input.dataset.servicePriceKey;
      if (priceKey) return getBungalowPrice(priceKey);
      const price = Number.parseFloat(input.dataset.servicePrice ?? '0');
      return Number.isFinite(price) ? price : 0;
    };
    const getServicesForScope = (scope) => getServiceInputs(scope).map((input) => {
      const quantity = Math.max(0, Number.parseInt(input.value || '0', 10) || 0);
      return {
        id: input.dataset.serviceQty ?? '',
        label: input.dataset.serviceLabel ?? '',
        quantity,
        price: getServiceLinePrice(input),
      };
    }).filter((service) => service.quantity > 0);
    const sumServices = (scope) => getServicesForScope(scope).reduce((sum, service) => sum + (service.price * service.quantity), 0);

    const getNights = () => {
      const arrival = getInputValue('[data-arrival]');
      const departure = getInputValue('[data-departure]');
      if (!arrival || !departure) return 0;
      const startDate = new Date(`${arrival}T12:00:00`);
      const endDate = new Date(`${departure}T12:00:00`);
      const diff = Math.round((endDate.getTime() - startDate.getTime()) / 86400000);
      return Math.max(0, diff);
    };

    const isHighSeason = () => {
      const arrival = getInputValue('[data-arrival]');
      if (!arrival) return false;
      const [, month, day] = arrival.split('-');
      const value = `${month}-${day}`;
      return value >= config.pricing.highSeason.start && value <= config.pricing.highSeason.end;
    };

    const isSummerBookingWindow = () => {
      const values = [getInputValue('[data-arrival]'), getInputValue('[data-departure]')].filter(Boolean);
      return values.some((value) => {
        const month = Number.parseInt(String(value).split('-')[1] ?? '0', 10);
        return month === 7 || month === 8;
      });
    };

    const getBungalowPrice = (id) => {
      const option = config.pricing.bungalowTypes[id] ?? config.pricing.bungalowTypes['bungalow-2'];
      return isHighSeason() ? option.prices.high : option.prices.low;
    };

    const getCampingPrice = (id) => config.pricing.campingTypes[id]?.price ?? 0;

    const calculatePrice = () => {
      const nights = getNights();
      if (!nights) return 0;

      if (state.category === 'bungalow') {
        return nights * sumServices('bungalow');
      }

      if (state.category === 'combined') {
        const bungalowTotal = sumServices('combined-bungalow');
        const campingTotal = sumServices('combined-camping') + (getNumber('campingPeople') * config.pricing.adults);
        return nights * (bungalowTotal + campingTotal);
      }

      const peopleTotal =
        (getNumber('adults') * config.pricing.adults) +
        (getNumber('children') * config.pricing.children);
      return nights * (sumServices('camping') + peopleTotal);
    };

    const getSelectedServices = () => {
      let scopedServices = [];
      if (state.category === 'camping') scopedServices = getServicesForScope('camping');
      if (state.category === 'bungalow') scopedServices = getServicesForScope('bungalow');
      if (state.category === 'combined') {
        scopedServices = [...getServicesForScope('combined-bungalow'), ...getServicesForScope('combined-camping')];
      }
      const services = scopedServices.map((service) => `${service.label} x ${service.quantity}`);
      if (getChecked('[data-late-checkout]')) services.push(`${config.extraCopy.lateCheckout}${getInputValue('[data-late-checkout-time]') ? ` (${getInputValue('[data-late-checkout-time]')})` : ''}`);
      if (getChecked('[data-special-needs]')) services.push(config.copy.summary.specialNeeds);
      return services.filter(Boolean);
    };

    const getServiceBreakdown = () => {
      let scopedServices = [];
      if (state.category === 'camping') scopedServices = getServicesForScope('camping');
      if (state.category === 'bungalow') scopedServices = getServicesForScope('bungalow');
      if (state.category === 'combined') scopedServices = [...getServicesForScope('combined-bungalow'), ...getServicesForScope('combined-camping')];
      return scopedServices;
    };

    const updateVariantPanels = () => {
      root.dataset.stay = state.category;
      root.querySelectorAll('[data-variant-panel]').forEach((panel) => {
        if (!(panel instanceof HTMLElement)) return;
        panel.hidden = panel.dataset.variantPanel !== state.category;
      });
      root.querySelectorAll('[data-start-choice], [data-flow-choice]').forEach((button) => {
        if (!(button instanceof HTMLElement)) return;
        button.classList.toggle('is-active', button.dataset.startChoice === state.category || button.dataset.flowChoice === state.category);
      });
      if (hoursOutput instanceof HTMLElement) {
        hoursOutput.textContent = state.category === 'bungalow' ? config.copy.info.bungalowHours : config.copy.info.campingHours;
      }
      if (summerBookingNotice instanceof HTMLElement) {
        summerBookingNotice.hidden = !isSummerBookingWindow();
      }
    };

    const setStep = (step) => {
      state.step = Math.max(0, Math.min(config.copy.steps.length - 1, step));
      stepNodes.forEach((node) => {
        if (!(node instanceof HTMLElement)) return;
        node.hidden = Number(node.dataset.bookingStep) !== state.step;
      });
      progressButtons.forEach((button, index) => {
        if (!(button instanceof HTMLElement)) return;
        button.classList.toggle('is-active', index === state.step);
        button.classList.toggle('is-complete', index < state.step);
      });
      if (prevButton instanceof HTMLButtonElement) prevButton.hidden = state.step === 0;
      if (nextButton instanceof HTMLButtonElement) nextButton.hidden = state.step === config.copy.steps.length - 1;
      if (submitButton instanceof HTMLButtonElement) submitButton.hidden = state.step !== config.copy.steps.length - 1;
      if (messageNode instanceof HTMLElement) messageNode.textContent = config.copy.messages[state.step % config.copy.messages.length];
      updateSummary();
    };

    const startFlow = (category, step = 1) => {
      state.category = category;
      start.hidden = true;
      flow.hidden = false;
      updateVariantPanels();
      setStep(step);
      const url = new URL(window.location.href);
      url.searchParams.set('stay', category);
      window.history.replaceState({}, '', url);
      window.setTimeout(() => {
        const navbar = document.querySelector('[data-main-navbar], #mainNavbarShell, #mainNavbar');
        const offset = navbar instanceof HTMLElement ? navbar.getBoundingClientRect().height + 18 : 92;
        const top = Math.max(0, flow.getBoundingClientRect().top + window.scrollY - offset);
        window.scrollTo({
          top,
          behavior: window.matchMedia('(prefers-reduced-motion: reduce)').matches ? 'auto' : 'smooth',
        });
      }, 60);
    };

    const updateSummary = () => {
      const nights = getNights();
      const arrival = getInputValue('[data-arrival]');
      const departure = getInputValue('[data-departure]');
      const services = getSelectedServices();
      const serviceBreakdown = getServiceBreakdown();
      const price = calculatePrice();
      const stayLabel = config.copy.stay[state.category]?.title ?? state.category;
      const lateCheckoutRequested = getChecked('[data-late-checkout]');
      const lateCheckoutTime = getInputValue('[data-late-checkout-time]');
      const rows = [
        [config.copy.summary.stay, stayLabel],
        [config.copy.summary.dates, arrival && departure ? `${arrival} → ${departure}` : '-'],
        [config.copy.summary.nights, String(nights)],
        [config.copy.summary.services, services.length ? services.join(', ') : '-'],
        [config.copy.summary.country, state.countryLabel || '-'],
        [config.copy.summary.language, getInputValue('[data-contact-language]') || '-'],
      ];
      if (lateCheckoutRequested) rows.push([config.extraCopy.lateCheckoutTime, lateCheckoutTime || '-']);

      if (nightsOutput instanceof HTMLElement) nightsOutput.textContent = String(nights);
      if (summerBookingNotice instanceof HTMLElement) summerBookingNotice.hidden = !isSummerBookingWindow();
      if (summaryPrice instanceof HTMLElement) summaryPrice.textContent = formatMoney(price);

      const summaryHtml = rows.map(([label, value]) => `<dl><dt>${label}</dt><dd>${value}</dd></dl>`).join('');
      const serviceHtml = serviceBreakdown.length
        ? `<div class="booking-summary__services">${serviceBreakdown.map((service) => `<p><span>${service.label} x ${service.quantity}</span><strong>${formatMoney(service.price * service.quantity * Math.max(1, nights))}</strong></p>`).join('')}</div>`
        : '';
      if (summaryList instanceof HTMLElement) summaryList.innerHTML = summaryHtml + serviceHtml;
      if (finalSummary instanceof HTMLElement) finalSummary.innerHTML = summaryHtml + serviceHtml + `<strong>${config.copy.summary.price}: ${formatMoney(price)}</strong>`;

      const payload = {
        customerLanguage: getInputValue('[data-contact-language]') || config.lang,
        country: state.country || '',
        translatedSummaryPl: rows.map(([label, value]) => `${label}: ${value}`).join('\n'),
        originalMessage: getInputValue('[data-message]'),
        selectedStayType: state.category,
        services: serviceBreakdown.map((service) => ({
          id: service.id,
          label: service.label,
          quantity: service.quantity,
          unitPrice: service.price,
          lineTotal: service.price * service.quantity * Math.max(1, nights),
        })),
        estimatedTotal: price,
        dates: { arrival, departure, nights },
        vehicleRegistration: getInputValue('[data-vehicle-registration]'),
        lateCheckout: lateCheckoutRequested ? { requested: true, preferredTime: lateCheckoutTime } : { requested: false },
        specialNeeds: getChecked('[data-special-needs]') ? getInputValue('[data-special-needs-text]') : '',
      };
      if (bookingPayload instanceof HTMLTextAreaElement) bookingPayload.value = JSON.stringify(payload, null, 2);
    };

    const renderCountryMatches = () => {
      if (!(countryList instanceof HTMLElement) || !(countryInput instanceof HTMLInputElement)) return;
      countryList.innerHTML = '';
      const query = normalize(countryInput.value);
      state.countryMatches = query
        ? config.countries.filter((country) => {
          const label = country.names[config.lang] ?? country.names.en;
          return [label, country.code, ...country.aliases].some((value) => normalize(value).includes(query));
        }).slice(0, 8)
        : config.countries.slice(0, 6);

      countryList.hidden = state.countryMatches.length === 0;
      countryInput.setAttribute('aria-expanded', String(!countryList.hidden));

      state.countryMatches.forEach((country, index) => {
        const button = document.createElement('button');
        button.type = 'button';
        button.className = 'booking-country__option';
        button.dataset.countryIndex = String(index);
        button.innerHTML = `<span class="${country.flagClass}"></span><strong>${country.names[config.lang] ?? country.names.en}</strong><small>${country.code}</small>`;
        button.addEventListener('click', () => selectCountry(country));
        countryList.appendChild(button);
      });
    };

    const selectCountry = (country) => {
      if (!(countryInput instanceof HTMLInputElement)) return;
      const label = country.names[config.lang] ?? country.names.en;
      countryInput.value = label;
      state.country = country.code;
      state.countryLabel = label;
      if (countryCode instanceof HTMLInputElement) countryCode.value = country.code;
      if (countryList instanceof HTMLElement) countryList.hidden = true;
      countryInput.setAttribute('aria-expanded', 'false');
      updateSummary();
    };

    root.querySelectorAll('[data-start-choice]').forEach((button) => {
      button.addEventListener('click', () => {
        if (button instanceof HTMLElement) startFlow(button.dataset.startChoice ?? 'camping', 1);
      });
    });

    root.querySelectorAll('[data-flow-choice]').forEach((button) => {
      button.addEventListener('click', () => {
        if (!(button instanceof HTMLElement)) return;
        state.category = button.dataset.flowChoice ?? 'camping';
        updateVariantPanels();
        updateSummary();
      });
    });

    progressButtons.forEach((button, index) => button.addEventListener('click', () => setStep(index)));
    prevButton?.addEventListener('click', () => setStep(state.step - 1));
    nextButton?.addEventListener('click', () => setStep(state.step + 1));

    root.querySelectorAll('[data-counter]').forEach((counter) => {
      const input = counter.querySelector('input');
      counter.querySelectorAll('[data-counter-action]').forEach((button) => {
        button.addEventListener('click', () => {
          if (!(input instanceof HTMLInputElement) || !(button instanceof HTMLElement)) return;
          const next = Number.parseInt(input.value || '0', 10) + (button.dataset.counterAction === 'plus' ? 1 : -1);
          input.value = String(Math.max(0, next));
          updateSummary();
        });
      });
      input?.addEventListener('input', updateSummary);
    });

    root.querySelectorAll('[data-service-counter]').forEach((counter) => {
      const input = counter.querySelector('[data-service-qty]');
      counter.querySelectorAll('[data-service-action]').forEach((button) => {
        button.addEventListener('click', () => {
          if (!(input instanceof HTMLInputElement) || !(button instanceof HTMLElement)) return;
          const next = Number.parseInt(input.value || '0', 10) + (button.dataset.serviceAction === 'plus' ? 1 : -1);
          input.value = String(Math.max(0, next));
          counter.classList.add('is-bumped');
          window.setTimeout(() => counter.classList.remove('is-bumped'), 180);
          updateSummary();
        });
      });
      input?.addEventListener('input', () => {
        if (input instanceof HTMLInputElement) input.value = String(Math.max(0, Number.parseInt(input.value || '0', 10) || 0));
        updateSummary();
      });
    });

    root.querySelectorAll('input, select, textarea').forEach((field) => {
      field.addEventListener('input', updateSummary);
      field.addEventListener('change', updateSummary);
    });

    if (countryInput instanceof HTMLInputElement) {
      countryInput.addEventListener('focus', renderCountryMatches);
      countryInput.addEventListener('input', () => {
        state.country = '';
        state.countryLabel = '';
        state.countryIndex = -1;
        renderCountryMatches();
      });
      countryInput.addEventListener('keydown', (event) => {
        if (!state.countryMatches.length) return;
        if (event.key === 'Escape') {
          if (countryList instanceof HTMLElement) countryList.hidden = true;
          return;
        }
        if (event.key === 'ArrowDown' || event.key === 'ArrowUp') {
          event.preventDefault();
          state.countryIndex = event.key === 'ArrowDown'
            ? Math.min(state.countryMatches.length - 1, state.countryIndex + 1)
            : Math.max(0, state.countryIndex - 1);
          countryList?.querySelectorAll('button').forEach((button, index) => button.classList.toggle('is-active', index === state.countryIndex));
        }
        if (event.key === 'Enter' && state.countryIndex >= 0) {
          event.preventDefault();
          selectCountry(state.countryMatches[state.countryIndex]);
        }
      });
    }

    specialNeeds?.addEventListener('change', () => {
      if (specialDetails instanceof HTMLElement && specialNeeds instanceof HTMLInputElement) specialDetails.hidden = !specialNeeds.checked;
      updateSummary();
    });

    lateCheckout?.addEventListener('change', () => {
      if (lateCheckoutDetails instanceof HTMLElement && lateCheckout instanceof HTMLInputElement) lateCheckoutDetails.hidden = !lateCheckout.checked;
      updateSummary();
    });

    summaryToggle?.addEventListener('click', () => {
      if (!(summary instanceof HTMLElement) || !(summaryToggle instanceof HTMLButtonElement)) return;
      const open = !summary.classList.contains('is-open');
      summary.classList.toggle('is-open', open);
      summaryToggle.textContent = open ? config.copy.actions.closeSummary : config.copy.actions.openSummary;
    });

    form.addEventListener('submit', (event) => {
      event.preventDefault();
      const quiet = getChecked('[data-quiet-consent]');
      const consent = getChecked('[data-contact-consent]');
      if (!(formStatus instanceof HTMLElement)) return;
      if (!quiet || !consent) {
        formStatus.textContent = config.copy.summary.required;
        formStatus.classList.add('is-error');
        return;
      }
      formStatus.textContent = config.copy.summary.success;
      formStatus.classList.remove('is-error');
      formStatus.classList.add('is-success');
    });

    document.addEventListener('click', (event) => {
      const target = event.target;
      if (!(target instanceof Node) || !countryList?.contains(target) && target !== countryInput) {
        if (countryList instanceof HTMLElement) countryList.hidden = true;
      }
    });

    const params = new URLSearchParams(window.location.search);
    const stay = params.get('stay');
    if (stay === 'camping' || stay === 'bungalow' || stay === 'combined') {
      startFlow(stay, 1);
    } else {
      updateVariantPanels();
      setStep(0);
    }
  })();
</script>

