    { id: 'electricity', label: copy.fields.electricity, price: getAddonPrice('electricity'), defaultValue: 0 },
    { id: 'dog', label: copy.fields.dog, price: getAddonPrice('dog'), defaultValue: 0 },
  ],
  bungalow: [
    { id: 'bungalow-2', label: copy.options.bungalow2, priceKey: 'bungalow-2', defaultValue: 1 },
    { id: 'bungalow-3', label: copy.options.bungalow3, priceKey: 'bungalow-3', defaultValue: 0 },
    { id: 'bungalow-4', label: copy.options.bungalow4, priceKey: 'bungalow-4', defaultValue: 0 },
    { id: 'parking', label: extraCopy.parking, price: getAddonPrice('parking'), defaultValue: 0 },
    { id: 'dog', label: copy.fields.dog, price: getAddonPrice('dog'), defaultValue: 0 },
  ],
};

const bookingConfigEncoded = Buffer.from(JSON.stringify({
  lang,
  copy,
  countries,
  pricing: {
    currency: pricingConfig.currency,
    adults: 35,
    children: 20,
    toddlers: 0,
    electricity: pricingConfig.addons.find((item) => item.id === 'electricity')?.price ?? 30,
    dog: pricingConfig.addons.find((item) => item.id === 'dog')?.price ?? 0,
    car: pricingConfig.addons.find((item) => item.id === 'parking')?.price ?? 35,
    campingTypes: Object.fromEntries(campingTypes.map(([id, label, price]) => [id, { label, price }])),
    bungalowTypes: Object.fromEntries(
      pricingConfig.stayTypes
        .filter((item) => item.category === 'bungalow' && 'seasonalPrices' in item)
        .map((item) => [item.id, { label: bungalowTypes.find(([id]) => id === item.id)?.[1] ?? item.label, prices: item.seasonalPrices }])
    ),
    highSeason: pricingConfig.seasons.high,
    services: serviceItems,
  },
  extraCopy,
}), 'utf8').toString('base64');
---

