const modeEntries = Object.entries(text.modes);
const getStayTypePrice = (id: string) => {
  const stayType = pricingConfig.stayTypes.find((item) => item.id === id);
  return stayType && 'price' in stayType ? stayType.price : 0;
};
const getAddonPrice = (id: string) => pricingConfig.addons.find((item) => item.id === id)?.price ?? 0;
const getBungalowPrices = (id: string) => {
  const stayType = pricingConfig.stayTypes.find((item) => item.id === id);
  return stayType && 'seasonalPrices' in stayType ? stayType.seasonalPrices : { low: 0, high: 0 };
};

