        <span>{text.startNote}</span>
        <h2>{text.choiceTitle}</h2>
        <p>{text.choiceLead}</p>
      </div>
      <div class="booking-game-start__choices">
        {modeEntries.map(([key, item]) => (
          <button class="booking-game-choice" type="button" data-start-mode={key}>
            <span class="booking-game-choice__icon"><Icon name={item.icon} size={30} strokeWidth={1.8} /></span>
            <strong>{item.title}</strong>
            <small>{item.text}</small>
          </button>
        ))}
      </div>
    </div>

    <div class="booking-game-flow" data-game-flow hidden>
      <div class="booking-game-progress" data-game-progress aria-label={text.title}></div>
      <div class="booking-game-toast" data-game-toast aria-live="polite">{text.messages[0]}</div>
      <div class="booking-game-layout">
        <form class="booking-game-stage premium-card" data-game-form novalidate>
          <div class="booking-game-stage__content" data-game-stage></div>
          <div class="booking-game-nav">
            <button type="button" class="booking-game-btn booking-game-btn--ghost" data-game-back>{text.actions.back}</button>
            <button type="button" class="booking-game-btn booking-game-btn--primary" data-game-next>{text.actions.next}</button>
            <button type="submit" class="booking-game-btn booking-game-btn--primary" data-game-submit hidden>{text.actions.send}</button>
          </div>
          <p class="booking-game-status" data-game-status aria-live="polite"></p>
        </form>
        <aside class="booking-game-summary premium-card" data-game-summary>
          <button type="button" class="booking-game-summary__toggle" data-summary-toggle>{text.actions.openSummary}</button>
          <div class="booking-game-summary__inner" data-summary-inner></div>
        </aside>
      </div>
    </div>
  </div>
</section>

<script define:vars={{ bookingConfigEncoded }}>
  (() => {
    const root = document.querySelector('[data-booking-game]');
    if (!(root instanceof HTMLElement)) return;

    const decodeConfig = () => {
      try {
        const binary = window.atob(bookingConfigEncoded);
        const bytes = Uint8Array.from(binary, (character) => character.charCodeAt(0));
        return JSON.parse(new TextDecoder().decode(bytes));
      } catch {
        return null;
      }
    };

    const config = decodeConfig();
    if (!config) return;

    const start = root.querySelector('[data-game-start]');
    const flow = root.querySelector('[data-game-flow]');
    const stage = root.querySelector('[data-game-stage]');
    const progress = root.querySelector('[data-game-progress]');
    const form = root.querySelector('[data-game-form]');
    const backButton = root.querySelector('[data-game-back]');
    const nextButton = root.querySelector('[data-game-next]');
    const submitButton = root.querySelector('[data-game-submit]');
    const statusNode = root.querySelector('[data-game-status]');
    const toast = root.querySelector('[data-game-toast]');
    const summary = root.querySelector('[data-game-summary]');
    const summaryInner = root.querySelector('[data-summary-inner]');
    const summaryToggle = root.querySelector('[data-summary-toggle]');

    if (!(start instanceof HTMLElement) || !(flow instanceof HTMLElement) || !(stage instanceof HTMLElement) || !(progress instanceof HTMLElement) || !(form instanceof HTMLFormElement)) return;

    const t = config.text;
    const state = {
      mode: null,
      step: 0,
      values: {
        arrival: '',
        departure: '',
        adults: 2,
        children: 0,
        toddlers: 0,
        bungalowGuests: 2,
        campingGuests: 2,
        fullName: '',
        email: '',
        phone: '',
        country: '',
        countryCode: '',
        language: config.lang.toUpperCase(),
        plate: '',
        message: '',
        specialNeeds: false,
        specialNeedsText: '',
        lateCheckout: false,
        lateCheckoutTime: '',
        quietConsent: false,
        contactConsent: false,
      },
      quantities: {},
      countryMatches: [],
      countryIndex: -1,
    };

    const modeKeys = ['camping', 'bungalow', 'combined'];
    const steps = t.steps;
    const currency = config.currency;
    const clamp = (value) => Math.max(0, Number.parseInt(value || '0', 10) || 0);
    const normalize = (value) => String(value ?? '').toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '').trim();
    const esc = (value) => String(value ?? '').replace(/[&<>"']/g, (char) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#039;' }[char]));
    const money = (value) => `${Math.max(0, Math.round(value))} ${currency}`;
    const serviceId = (scope, id) => `${scope}:${id}`;

    const seedQuantities = () => {
      ['camping', 'bungalow'].forEach((scope) => {
        (config.services[scope] ?? []).forEach((item) => {
          state.quantities[serviceId(scope, item.id)] = item.defaultValue ?? 0;
        });
      });
      (config.services.bungalow ?? []).forEach((item) => {
        state.quantities[serviceId('combined-bungalow', item.id)] = item.defaultValue ?? 0;
      });
      (config.services.camping ?? []).forEach((item) => {
        state.quantities[serviceId('combined-camping', item.id)] = item.defaultValue ?? 0;
      });
    };
    seedQuantities();

    const getNights = () => {
      if (!state.values.arrival || !state.values.departure) return 0;
      const startDate = new Date(`${state.values.arrival}T12:00:00`);
      const endDate = new Date(`${state.values.departure}T12:00:00`);
      const diff = Math.round((endDate.getTime() - startDate.getTime()) / 86400000);
      return Math.max(0, diff);
    };

    const isHighSeason = () => {
      const value = state.values.arrival;
      if (!value) return false;
      const [, month, day] = value.split('-');
      const date = `${month}-${day}`;
      return date >= config.highSeason.start && date <= config.highSeason.end;
    };

    const isSummer = () => [state.values.arrival, state.values.departure].filter(Boolean).some((value) => {
      const month = Number.parseInt(String(value).split('-')[1] ?? '0', 10);
      return month === 7 || month === 8;
    });

    const servicePrice = (item) => {
      if (item.seasonalPrices) return isHighSeason() ? item.seasonalPrices.high : item.seasonalPrices.low;
      return Number(item.price ?? 0);
    };

    const scopeItems = (scope) => {
      if (scope === 'combined-bungalow') return config.services.bungalow ?? [];
      if (scope === 'combined-camping') return config.services.camping ?? [];
      return config.services[scope] ?? [];
    };

    const selectedServices = (scope) => scopeItems(scope).map((item) => ({
      ...item,
      quantity: clamp(state.quantities[serviceId(scope, item.id)]),
      unitPrice: servicePrice(item),
      scope,
    })).filter((item) => item.quantity > 0);

    const activeServices = () => {
      if (state.mode === 'camping') return selectedServices('camping');
      if (state.mode === 'bungalow') return selectedServices('bungalow');
      if (state.mode === 'combined') return [...selectedServices('combined-bungalow'), ...selectedServices('combined-camping')];
      return [];
    };

    const peopleTotal = () => {
      if (state.mode === 'camping') {
        return (state.values.adults * (config.services.peopleCamping[0]?.price ?? 0)) + (state.values.children * (config.services.peopleCamping[1]?.price ?? 0));
      }
      if (state.mode === 'combined') {
        return state.values.campingGuests * (config.services.peopleCamping[0]?.price ?? 0);
      }
      return 0;
    };

    const estimatedTotal = () => {
      const nights = getNights();
      if (!nights) return 0;
      const servicesPerNight = activeServices().reduce((sum, item) => sum + (item.unitPrice * item.quantity), 0);
      return nights * (servicesPerNight + peopleTotal());
    };

    const peopleSummary = () => {
      if (state.mode === 'camping') return `${state.values.adults} ${t.fields.adults}, ${state.values.children} ${t.fields.children}, ${state.values.toddlers} ${t.fields.toddlers}`;
      if (state.mode === 'bungalow') return `${state.values.adults} ${t.fields.adults}, ${state.values.children} ${t.fields.children}, ${state.values.toddlers} ${t.fields.toddlers}`;
      if (state.mode === 'combined') return `${t.fields.bungalowGuests}: ${state.values.bungalowGuests}, ${t.fields.campingGuests}: ${state.values.campingGuests}`;
      return '-';
    };

    const showToast = (message) => {
      if (!(toast instanceof HTMLElement)) return;
      toast.textContent = message;
      toast.classList.remove('is-visible');
      window.requestAnimationFrame(() => toast.classList.add('is-visible'));
    };

    const setValue = (key, value) => {
      if (typeof state.values[key] === 'boolean') state.values[key] = Boolean(value);
      else state.values[key] = value;
    };

    const renderProgress = () => {
      const percent = Math.round((state.step / (steps.length - 1)) * 100);
      progress.innerHTML = `
        <div class="booking-game-progress__mobile">
          <span>${esc(steps[state.step])}</span>
          <strong>${String(state.step + 1).padStart(2, '0')} / ${String(steps.length).padStart(2, '0')}</strong>
          <i style="--progress:${percent}%"></i>
        </div>
        <div class="booking-game-progress__rail" style="--progress:${percent}%">
          ${steps.map((step, index) => `
            <button type="button" data-jump-step="${index}" class="${index === state.step ? 'is-active' : ''} ${index < state.step ? 'is-complete' : ''}" ${index > state.step ? 'disabled' : ''}>
              <span>${String(index + 1).padStart(2, '0')}</span>
              <strong>${esc(step)}</strong>
            </button>
          `).join('')}
        </div>
      `;
    };

    const renderChoiceCards = () => `
      <div class="booking-game-step-head">
        <span>${esc(t.steps[0])}</span>
        <h2>${esc(t.choiceTitle)}</h2>
        <p>${esc(t.choiceLead)}</p>
      </div>
      <div class="booking-game-start__choices">
        ${modeKeys.map((mode) => `
          <button class="booking-game-choice ${state.mode === mode ? 'is-active' : ''}" type="button" data-mode-choice="${mode}">
            <span class="booking-game-choice__icon">${mode === 'camping' ? 'RV' : mode === 'bungalow' ? '2/3/4' : 'MIX'}</span>
            <strong>${esc(t.modes[mode].title)}</strong>
            <small>${esc(t.modes[mode].text)}</small>
          </button>
        `).join('')}
      </div>
    `;

    const renderDateStep = () => `
      <div class="booking-game-step-head">
        <span>${esc(t.steps[1])}</span>
        <h2>${esc(t.sections.date)}</h2>
        <p>${esc(state.mode === 'bungalow' ? t.info.bungalowHours : t.info.campingHours)}</p>
      </div>
      <div class="booking-game-date-grid">
        <label class="booking-game-field">
          <span>${esc(t.fields.arrival)}</span>
          <input type="date" data-bind="arrival" value="${esc(state.values.arrival)}" />
        </label>
        <label class="booking-game-field">
          <span>${esc(t.fields.departure)}</span>
          <input type="date" data-bind="departure" value="${esc(state.values.departure)}" />
        </label>
        <div class="booking-game-night-card">
          <span>${esc(t.fields.nights)}</span>
          <strong>${getNights()}</strong>
        </div>
      </div>
      <p class="booking-game-note">${esc(state.mode === 'bungalow' ? t.info.bungalowHours : t.info.campingHours)}</p>
      ${isSummer() ? `<p class="booking-game-note booking-game-note--warm">${esc(t.info.summer)}</p>` : ''}
    `;

    const counterCard = ({ id, label, price, value, scope = 'value', icon = '+' }) => `
      <article class="booking-game-stepper" data-stepper-card>
        <div class="booking-game-stepper__meta">
          <span class="booking-game-stepper__icon">${esc(icon)}</span>
          <div>
            <strong>${esc(label)}</strong>
            <small>${price > 0 ? `${money(price)} / noc` : price === 0 ? '0 PLN / noc' : ''}</small>
          </div>
        </div>
        <div class="booking-game-stepper__controls">
          <button type="button" data-counter-minus="${esc(id)}" data-counter-scope="${esc(scope)}" ${value <= 0 ? 'disabled' : ''}>-</button>
          <input inputmode="numeric" value="${value}" data-counter-input="${esc(id)}" data-counter-scope="${esc(scope)}" aria-label="${esc(label)}" />
          <button type="button" data-counter-plus="${esc(id)}" data-counter-scope="${esc(scope)}">+</button>
        </div>
      </article>
    `;

    const renderGuestsStep = () => {
      const people = state.mode === 'combined'
        ? [
          { id: 'bungalowGuests', label: t.fields.bungalowGuests, price: -1, value: state.values.bungalowGuests, icon: 'DG' },
          { id: 'campingGuests', label: t.fields.campingGuests, price: config.services.peopleCamping[0]?.price ?? 35, value: state.values.campingGuests, icon: 'CG' },
        ]
        : [
          { id: 'adults', label: t.fields.adults, price: state.mode === 'camping' ? (config.services.peopleCamping[0]?.price ?? 35) : -1, value: state.values.adults, icon: 'AD' },
          { id: 'children', label: t.fields.children, price: state.mode === 'camping' ? (config.services.peopleCamping[1]?.price ?? 20) : -1, value: state.values.children, icon: 'CH' },
          { id: 'toddlers', label: t.fields.toddlers, price: 0, value: state.values.toddlers, icon: '0+' },
        ];
      return `
        <div class="booking-game-step-head">
          <span>${esc(t.steps[2])}</span>
          <h2>${esc(t.sections.guests)}</h2>
          <p>${esc(state.mode === 'combined' ? t.info.combined : t.modes[state.mode].text)}</p>
        </div>
        <div class="booking-game-stepper-grid">
          ${people.map((item) => counterCard(item)).join('')}
        </div>
      `;
    };

    const serviceCard = (scope, item) => {
      const value = clamp(state.quantities[serviceId(scope, item.id)]);
      const price = servicePrice(item);
      const subtotal = price * value * Math.max(1, getNights());
      return `
        <article class="booking-game-service ${value > 0 ? 'is-selected' : ''}" data-service-card>
          <div class="booking-game-service__top">
            <span class="booking-game-stepper__icon">${esc(item.icon ?? '+')}</span>
            <div>
              <strong>${esc(item.label)}</strong>
              <small>${money(price)} / noc</small>
            </div>
          </div>
          <div class="booking-game-service__bottom">
            <div class="booking-game-stepper__controls">
              <button type="button" data-service-minus="${esc(item.id)}" data-service-scope="${esc(scope)}" ${value <= 0 ? 'disabled' : ''}>-</button>
              <input inputmode="numeric" value="${value}" data-service-input="${esc(item.id)}" data-service-scope="${esc(scope)}" aria-label="${esc(item.label)}" />
              <button type="button" data-service-plus="${esc(item.id)}" data-service-scope="${esc(scope)}">+</button>
            </div>
            <small>${money(subtotal)}</small>
          </div>
        </article>
      `;
    };

    const serviceGroup = (title, scope, note = '') => `
      <div class="booking-game-service-group">
        <div class="booking-game-service-group__head">
          <h3>${esc(title)}</h3>
          ${note ? `<p>${esc(note)}</p>` : ''}
        </div>
        <div class="booking-game-service-grid">
          ${scopeItems(scope).map((item) => serviceCard(scope, item)).join('')}
        </div>
      </div>
    `;

    const renderServicesStep = () => {
      let body = '';
      if (state.mode === 'camping') body = serviceGroup(t.sections.camping, 'camping', t.info.camping);
      if (state.mode === 'bungalow') body = serviceGroup(t.sections.bungalow, 'bungalow', t.info.bungalowHours);
      if (state.mode === 'combined') body = `<div class="booking-game-combined">${serviceGroup(t.sections.bungalow, 'combined-bungalow')}${serviceGroup(t.sections.camping, 'combined-camping', t.info.combined)}</div>`;
      return `
        <div class="booking-game-step-head">
          <span>${esc(t.steps[3])}</span>
          <h2>${esc(t.sections.services)}</h2>
          <p>${esc(state.mode === 'combined' ? t.info.combined : t.modes[state.mode].text)}</p>
        </div>
        ${body}
      `;
    };

    const renderCountryList = () => {
      if (!state.countryMatches.length) return '';
      return `
        <div class="booking-game-country__list" data-country-list>
          ${state.countryMatches.map((country, index) => `
            <button type="button" class="booking-game-country__option ${index === state.countryIndex ? 'is-active' : ''}" data-country-index="${index}">
              <span class="${esc(country.flagClass)}"></span>
              <strong>${esc(country.names[config.lang] ?? country.names.en)}</strong>
              <small>${esc(country.code)}</small>
            </button>
          `).join('')}
        </div>
      `;
    };

    const renderDetailsStep = () => `
      <div class="booking-game-step-head">
        <span>${esc(t.steps[4])}</span>
        <h2>${esc(t.sections.details)}</h2>
        <p>${esc(t.fields.plateHint)}</p>
      </div>
      <div class="booking-game-form-grid">
        ${['fullName', 'email', 'phone'].map((key) => `
          <label class="booking-game-field">
            <span>${esc(t.fields[key])}</span>
            <input type="${key === 'email' ? 'email' : key === 'phone' ? 'tel' : 'text'}" data-bind="${key}" value="${esc(state.values[key])}" autocomplete="${key === 'fullName' ? 'name' : key}" />
          </label>
        `).join('')}
        <label class="booking-game-field booking-game-country">
          <span>${esc(t.fields.country)}</span>
          <input type="text" data-country-input value="${esc(state.values.country)}" placeholder="${esc(t.fields.countryPlaceholder)}" autocomplete="off" aria-autocomplete="list" aria-expanded="${state.countryMatches.length > 0}" />
          <input type="hidden" data-country-code value="${esc(state.values.countryCode)}" />
          ${renderCountryList()}
        </label>
        <label class="booking-game-field">
          <span>${esc(t.fields.language)}</span>
          <select data-bind="language">
            ${['PL', 'EN', 'DE', 'IT'].map((item) => `<option value="${item}" ${state.values.language === item ? 'selected' : ''}>${item}</option>`).join('')}
          </select>
        </label>
        <label class="booking-game-field">
          <span>${esc(t.fields.plate)}</span>
          <input type="text" data-bind="plate" value="${esc(state.values.plate)}" placeholder="KR 12345" />
          <small>${esc(t.fields.plateHint)}</small>
        </label>
        <label class="booking-game-check">
          <input type="checkbox" data-bind-check="lateCheckout" ${state.values.lateCheckout ? 'checked' : ''} />
          <span>${esc(t.fields.lateCheckout)}</span>
        </label>
        ${state.values.lateCheckout ? `
          <label class="booking-game-field">
            <span>${esc(t.fields.lateTime)}</span>
            <select data-bind="lateCheckoutTime">
              <option value="">--</option>
              ${['13:00','14:00','15:00','16:00','17:00'].map((item) => `<option value="${item}" ${state.values.lateCheckoutTime === item ? 'selected' : ''}>${item}</option>`).join('')}
            </select>
            <small>${esc(t.info.lateCheckout)}</small>
          </label>
        ` : ''}
        <label class="booking-game-check">
          <input type="checkbox" data-bind-check="specialNeeds" ${state.values.specialNeeds ? 'checked' : ''} />
          <span>${esc(t.fields.specialNeeds)}</span>
        </label>
        ${state.values.specialNeeds ? `
          <label class="booking-game-field booking-game-field--full">
            <span>${esc(t.fields.specialNeedsDetails)}</span>
            <textarea data-bind="specialNeedsText" rows="3">${esc(state.values.specialNeedsText)}</textarea>
          </label>
        ` : ''}
        <label class="booking-game-field booking-game-field--full">
          <span>${esc(t.fields.message)}</span>
          <textarea data-bind="message" rows="5">${esc(state.values.message)}</textarea>
        </label>
      </div>
    `;

    const renderFinalStep = () => `
      <div class="booking-game-step-head">
        <span>${esc(t.steps[5])}</span>
        <h2>${esc(t.sections.summary)}</h2>
        <p>${esc(t.summary.availability)}</p>
      </div>
      <div class="booking-game-final" data-final-summary>${summaryHtml(false)}</div>
      <div class="booking-game-consents">
        <label class="booking-game-check">
          <input type="checkbox" data-bind-check="quietConsent" ${state.values.quietConsent ? 'checked' : ''} />
          <span>${esc(t.fields.quiet)}</span>
        </label>
        <label class="booking-game-check">
          <input type="checkbox" data-bind-check="contactConsent" ${state.values.contactConsent ? 'checked' : ''} />
          <span>${esc(t.fields.consent)}</span>
        </label>
      </div>
      <textarea name="bookingPayload" data-booking-payload hidden>${esc(JSON.stringify(payload(), null, 2))}</textarea>
    `;

    const modeTitle = () => state.mode ? t.modes[state.mode].title : '-';
    const dateLabel = () => state.values.arrival && state.values.departure ? `${state.values.arrival} → ${state.values.departure}` : '-';
    const summaryRows = () => [
      [t.summary.stay, modeTitle()],
      [t.summary.dates, dateLabel()],
      [t.summary.nights, String(getNights())],
      [t.summary.people, peopleSummary()],
      [t.summary.country, state.values.country || '-'],
      [t.summary.language, state.values.language || '-'],
      ...(state.values.lateCheckout ? [[t.summary.lateCheckout, state.values.lateCheckoutTime || '-']] : []),
      ...(state.values.specialNeeds ? [[t.summary.specialNeeds, 'zgłoszono']] : []),
    ];

    const summaryHtml = (compact = true) => {
      const services = activeServices();
      const nights = Math.max(1, getNights());
      const price = estimatedTotal();
      return `
        <span>${esc(t.summary.title)}</span>
        <h2>${price ? money(price) : esc(t.summary.price)}</h2>
        <p class="booking-game-summary__empty">${services.length || getNights() ? esc(t.summary.availability) : esc(t.summary.empty)}</p>
        <div class="booking-game-summary__rows">
          ${summaryRows().map(([label, value]) => `<dl><dt>${esc(label)}</dt><dd>${esc(value)}</dd></dl>`).join('')}
        </div>
        ${services.length ? `
          <div class="booking-game-summary__services">
            ${services.map((item) => `<p><span>${esc(item.scope.includes('bungalow') ? `${t.sections.bungalow}: ${item.label}` : item.label)} x ${item.quantity}</span><strong>${money(item.unitPrice * item.quantity * nights)}</strong></p>`).join('')}
            ${peopleTotal() ? `<p><span>${esc(t.summary.people)}</span><strong>${money(peopleTotal() * nights)}</strong></p>` : ''}
          </div>
        ` : ''}
        ${compact ? `<small>${esc(t.summary.availability)}</small>` : ''}
      `;
    };

    const payload = () => ({
      stayMode: state.mode,
      dates: { arrival: state.values.arrival, departure: state.values.departure, nights: getNights() },
      services: activeServices().map((item) => ({
        id: item.id,
        scope: item.scope,
        label: item.label,
        quantity: item.quantity,
        unitPrice: item.unitPrice,
        subtotal: item.unitPrice * item.quantity * Math.max(1, getNights()),
      })),
      estimatedTotal: estimatedTotal(),
      country: state.values.countryCode,
      language: state.values.language,
      vehiclePlate: state.values.plate,
      specialNeeds: state.values.specialNeeds ? state.values.specialNeedsText : '',
      lateCheckout: state.values.lateCheckout ? { requested: true, preferredTime: state.values.lateCheckoutTime } : { requested: false },
      message: state.values.message,
      translatedSummaryPl: summaryRows().map(([label, value]) => `${label}: ${value}`).join('\n'),
      originalMessage: state.values.message,
    });

    const updateSummary = () => {
      if (summaryInner instanceof HTMLElement) summaryInner.innerHTML = summaryHtml(true);
    };

    const renderStage = () => {
      const renderers = [renderChoiceCards, renderDateStep, renderGuestsStep, renderServicesStep, renderDetailsStep, renderFinalStep];
      stage.innerHTML = renderers[state.step]();
      renderProgress();
      updateSummary();
      bindStage();
      if (backButton instanceof HTMLButtonElement) backButton.hidden = state.step === 0;
      if (nextButton instanceof HTMLButtonElement) nextButton.hidden = state.step === steps.length - 1;
      if (submitButton instanceof HTMLButtonElement) submitButton.hidden = state.step !== steps.length - 1;
      root.dataset.step = String(state.step);
      root.dataset.mode = state.mode || '';
    };

    const validateStep = () => {
      if (!state.mode) return t.validation.mode;
      if (state.step !== 3) return '';
      const campingCount = selectedServices(state.mode === 'combined' ? 'combined-camping' : 'camping').filter((item) => item.group === 'camping').reduce((sum, item) => sum + item.quantity, 0);
      const bungalowCount = selectedServices(state.mode === 'combined' ? 'combined-bungalow' : 'bungalow').filter((item) => item.group === 'bungalow').reduce((sum, item) => sum + item.quantity, 0);
      if (state.mode === 'camping' && campingCount < 1) return t.validation.campingService;
      if (state.mode === 'bungalow' && bungalowCount < 1) return t.validation.bungalowService;
      if (state.mode === 'combined' && (campingCount < 1 || bungalowCount < 1)) return t.validation.combinedService;
      return '';
    };

    const setStep = (step) => {
      state.step = Math.max(0, Math.min(steps.length - 1, step));
      showToast(t.messages[state.step % t.messages.length]);
      renderStage();
    };

    const startFlow = (mode, step = 1) => {
      state.mode = modeKeys.includes(mode) ? mode : 'camping';
      start.hidden = true;
      flow.hidden = false;
      setStep(step);
      const url = new URL(window.location.href);
      url.searchParams.set('stay', state.mode);
      window.history.replaceState({}, '', url);
    };

    const selectCountry = (country) => {
      state.values.country = country.names[config.lang] ?? country.names.en;
      state.values.countryCode = country.code;
      state.countryMatches = [];
      state.countryIndex = -1;
      renderStage();
    };

    const searchCountries = (query) => {
      const normalized = normalize(query);
      state.countryMatches = normalized
        ? config.countries.filter((country) => [country.names[config.lang] ?? country.names.en, country.code, ...country.aliases].some((value) => normalize(value).includes(normalized))).slice(0, 8)
        : config.countries.slice(0, 7);
      state.countryIndex = state.countryMatches.length ? 0 : -1;
    };

    const bindStage = () => {
      stage.querySelectorAll('[data-mode-choice]').forEach((button) => {
        button.addEventListener('click', () => {
          if (!(button instanceof HTMLElement)) return;
          state.mode = button.dataset.modeChoice;
          const url = new URL(window.location.href);
          url.searchParams.set('stay', state.mode);
          window.history.replaceState({}, '', url);
          renderStage();
        });
      });

      stage.querySelectorAll('[data-bind]').forEach((input) => {
        input.addEventListener('input', () => {
          if (!(input instanceof HTMLInputElement || input instanceof HTMLTextAreaElement || input instanceof HTMLSelectElement)) return;
          setValue(input.dataset.bind, input.value);
          renderStage();
        });
        input.addEventListener('change', () => {
          if (!(input instanceof HTMLInputElement || input instanceof HTMLTextAreaElement || input instanceof HTMLSelectElement)) return;
          setValue(input.dataset.bind, input.value);
          renderStage();
        });
      });

      stage.querySelectorAll('[data-bind-check]').forEach((input) => {
        input.addEventListener('change', () => {
          if (!(input instanceof HTMLInputElement)) return;
          setValue(input.dataset.bindCheck, input.checked);
          renderStage();
        });
      });

      stage.querySelectorAll('[data-counter-minus], [data-counter-plus]').forEach((button) => {
        button.addEventListener('click', () => {
          if (!(button instanceof HTMLElement)) return;
          const id = button.dataset.counterMinus || button.dataset.counterPlus;
          const delta = button.dataset.counterPlus ? 1 : -1;
          state.values[id] = Math.max(0, clamp(state.values[id]) + delta);
          renderStage();
        });
      });

      stage.querySelectorAll('[data-counter-input]').forEach((input) => {
        input.addEventListener('input', () => {
          if (!(input instanceof HTMLInputElement)) return;
          state.values[input.dataset.counterInput] = clamp(input.value);
          renderStage();
        });
      });

      stage.querySelectorAll('[data-service-minus], [data-service-plus]').forEach((button) => {
        button.addEventListener('click', () => {
          if (!(button instanceof HTMLElement)) return;
          const id = button.dataset.serviceMinus || button.dataset.servicePlus;
          const scope = button.dataset.serviceScope;
          const delta = button.dataset.servicePlus ? 1 : -1;
          const key = serviceId(scope, id);
          state.quantities[key] = Math.max(0, clamp(state.quantities[key]) + delta);
          renderStage();
        });
      });

      stage.querySelectorAll('[data-service-input]').forEach((input) => {
        input.addEventListener('input', () => {
          if (!(input instanceof HTMLInputElement)) return;
          state.quantities[serviceId(input.dataset.serviceScope, input.dataset.serviceInput)] = clamp(input.value);
          renderStage();
        });
      });

      const countryInput = stage.querySelector('[data-country-input]');
      if (countryInput instanceof HTMLInputElement) {
        countryInput.addEventListener('input', () => {
          state.values.country = countryInput.value;
          state.values.countryCode = '';
          searchCountries(countryInput.value);
          renderStage();
          const nextInput = stage.querySelector('[data-country-input]');
          if (nextInput instanceof HTMLInputElement) {
            nextInput.focus();
            nextInput.setSelectionRange(nextInput.value.length, nextInput.value.length);
          }
        });
        countryInput.addEventListener('focus', () => {
          searchCountries(countryInput.value);
          renderStage();
        });
        countryInput.addEventListener('keydown', (event) => {
          if (!state.countryMatches.length) return;
          if (event.key === 'Escape') {
            state.countryMatches = [];
            renderStage();
          }
          if (event.key === 'ArrowDown' || event.key === 'ArrowUp') {
            event.preventDefault();
            state.countryIndex = event.key === 'ArrowDown'
              ? Math.min(state.countryMatches.length - 1, state.countryIndex + 1)
              : Math.max(0, state.countryIndex - 1);
            renderStage();
          }
          if (event.key === 'Enter' && state.countryIndex >= 0) {
            event.preventDefault();
            selectCountry(state.countryMatches[state.countryIndex]);
          }
        });
      }

      stage.querySelectorAll('[data-country-index]').forEach((button) => {
        button.addEventListener('click', () => {
          if (!(button instanceof HTMLElement)) return;
          selectCountry(state.countryMatches[Number(button.dataset.countryIndex)]);
        });
      });
    };

    progress.addEventListener('click', (event) => {
      const target = event.target;
      if (!(target instanceof HTMLElement)) return;
      const button = target.closest('[data-jump-step]');
      if (!(button instanceof HTMLElement)) return;
      const step = Number(button.dataset.jumpStep);
      if (Number.isFinite(step) && step <= state.step) setStep(step);
    });

    start.querySelectorAll('[data-start-mode]').forEach((button) => {
      button.addEventListener('click', () => {
        if (button instanceof HTMLElement) startFlow(button.dataset.startMode, 1);
      });
    });

    backButton?.addEventListener('click', () => setStep(state.step - 1));
    nextButton?.addEventListener('click', () => {
      const error = validateStep();
      if (error) {
        if (statusNode instanceof HTMLElement) statusNode.textContent = error;
        showToast(error);
        return;
      }
      if (statusNode instanceof HTMLElement) statusNode.textContent = '';
      setStep(state.step + 1);
    });

    summaryToggle?.addEventListener('click', () => {
      if (!(summary instanceof HTMLElement) || !(summaryToggle instanceof HTMLButtonElement)) return;
      const open = !summary.classList.contains('is-open');
      summary.classList.toggle('is-open', open);
      summaryToggle.textContent = open ? t.actions.closeSummary : t.actions.openSummary;
    });

    form.addEventListener('submit', (event) => {
      event.preventDefault();
      if (!state.values.quietConsent || !state.values.contactConsent) {
        if (statusNode instanceof HTMLElement) statusNode.textContent = t.validation.consents;
        showToast(t.validation.consents);
        return;
      }
      if (statusNode instanceof HTMLElement) {
        statusNode.textContent = t.summary.success;
        statusNode.classList.add('is-success');
      }
      showToast(t.summary.success);
    });

    const params = new URLSearchParams(window.location.search);
    const stay = params.get('stay');
    if (modeKeys.includes(stay)) {
      startFlow(stay, 1);
    } else {
      flow.hidden = true;
      updateSummary();
    }
  })();
</script>

