const bookingConfigEncoded = Buffer.from(JSON.stringify({
  lang,
  text,
  countries,
  currency: pricingConfig.currency,
  highSeason: pricingConfig.seasons.high,
  services: serviceCatalog,
}), 'utf8').toString('base64');
