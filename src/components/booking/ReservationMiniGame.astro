    const countryTemplate = () => {
      const matches = countryMatches();
      const hasQuery = normalize(state.details.countrySearch).length > 0;
      const showHint = state.countryOpen && !hasQuery && !state.details.countryCode;
      const showResults = state.countryOpen && state.countryDirty && hasQuery;
      return `
        <div class="reservation-country">
          <label class="reservation-field ${fieldInvalid('country') ? 'is-invalid' : ''}" data-field-key="country">
            ${fieldLabel({ icon: 'country', label: t.fields.country, badge: 'required' })}
            <input type="text" data-country-search value="${esc(state.details.countrySearch)}" placeholder="${esc(detailText.field.country.placeholder || t.fields.countryPlaceholder)}" autocomplete="off" aria-autocomplete="list" aria-expanded="${showResults ? 'true' : 'false'}" />
            <small>${esc(detailText.field.country.helper)}</small>
            ${fieldError('country')}
          </label>
          <input type="hidden" data-country-code value="${esc(state.details.countryCode)}" />
