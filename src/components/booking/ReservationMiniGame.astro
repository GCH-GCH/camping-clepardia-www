@keyframes reservationPanelIn {
  from { opacity: 0; transform: translateY(24px) scale(.985); }
  to { opacity: 1; transform: translateY(0) scale(1); }
}

@keyframes reservationElementIn {
  from { opacity: 0; transform: translateY(14px); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes reservationCardIn {
  from { opacity: 0; transform: translateY(26px) scale(.965); }
  to { opacity: 1; transform: translateY(0) scale(1); }
}

@keyframes reservationChoiceFloat {
  0%, 100% { translate: 0 0; }
  50% { translate: 0 -6px; }
}

@keyframes reservationGlowSweep {
  0%, 100% { background-position: 0 0, -80% 0; }
  50% { background-position: 0 0, 120% 0; }
}

@keyframes reservationRevealField {
  from { opacity: 0; transform: translateY(-6px); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes reservationOrb {
  0%, 100% { transform: translate3d(0, 0, 0) scale(1); }
  50% { transform: translate3d(20px, -16px, 0) scale(1.08); }
}

@keyframes reservationStepIn {
  from { opacity: 0; transform: translateY(12px); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes reservationHelpIn {
  from { opacity: 0; transform: translateX(24px); }
  to { opacity: 1; transform: translateX(0); }
}

@keyframes reservationSummaryPulse {
  0% { box-shadow: 0 24px 80px rgba(0,0,0,.22), 0 0 0 0 rgba(60,179,113,.28); }
  45% { box-shadow: 0 30px 95px rgba(60,179,113,.22), 0 0 0 8px rgba(60,179,113,.10); }
  100% { box-shadow: 0 24px 80px rgba(0,0,0,.22), 0 0 0 0 rgba(60,179,113,0); }
}

@media (prefers-reduced-motion: reduce) {
  .reservation-mini__ambient span,
  .reservation-mini__start,
  .reservation-mini__start .reservation-mini__kicker,
  .reservation-mini__start h1,
  .reservation-mini__start > p:not(.reservation-mini__note):not(.reservation-mini__kicker),
  .reservation-mini__choices,
  .reservation-simple-link,
  .reservation-mini__note,
  .stay-choice-card,
  .reservation-choice-card,
  .reservation-step-card,
  .reservation-summary,
