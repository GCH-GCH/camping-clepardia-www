  margin: 16px 0;
  padding: 16px;
  border: 1px solid rgba(255, 196, 96, .36);
  border-radius: 22px;
  color: #fff4dc;
  background:
    radial-gradient(circle at 10% 0%, rgba(255, 217, 145, .18), transparent 34%),
    linear-gradient(135deg, rgba(128, 72, 4, .36), rgba(74, 40, 0, .20));
  box-shadow: 0 18px 46px rgba(92, 50, 0, .18);
}

.reservation-summer-block > i {
  width: 52px;
  height: 52px;
  display: grid;
  place-items: center;
  border: 1px solid rgba(255, 217, 145, .36);
  border-radius: 18px;
  color: #ffd68f;
  background: rgba(255, 217, 145, .14);
}

.reservation-summer-block span,
.reservation-summer-block strong,
.reservation-summer-block p {
  display: block;
}

.reservation-summer-block span {
  width: fit-content;
  margin-bottom: 6px;
  padding: 4px 9px;
  border-radius: 999px;
  color: #341d00;
  background: #ffd990;
  font-size: .72rem;
  font-weight: 950;
  letter-spacing: .04em;
  text-transform: uppercase;
}

.reservation-summer-block strong {
  color: #fff8e8;
  font-size: 1.05rem;
}

.reservation-summer-block p {
  margin: 7px 0 0;
  color: rgba(255, 248, 232, .84);
  font-weight: 760;
}

.reservation-summer-block__actions {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  margin-top: 13px;
}

.reservation-summer-block--compact {
  grid-template-columns: 42px minmax(0, 1fr);
  padding: 13px;
}

.reservation-summer-block--compact > i {
  width: 42px;
  height: 42px;
  border-radius: 15px;
}

.reservation-summary .reservation-summer-block__actions {
  display: grid;
  grid-template-columns: 1fr;
}

.reservation-viewport-toast.is-visible {
  opacity: 1;
  transform: translate(-50%, -50%) scale(1);
  pointer-events: auto;
}

.reservation-viewport-toast[hidden] {
  display: none !important;
}

.reservation-viewport-toast button {
  width: 38px;
  height: 38px;
  display: grid;
  place-items: center;
  border: 1px solid rgba(255,255,255,.34);
  border-radius: 999px;
  color: inherit;
  background: rgba(255,255,255,.15);
  font-size: 1.25rem;
  font-weight: 950;
  cursor: pointer;
}

.reservation-viewport-toast button:hover,
.reservation-viewport-toast button:focus-visible {
  background: rgba(255,255,255,.28);
  box-shadow: 0 0 0 4px rgba(255,255,255,.15);
}

.reservation-progress__mobile {
  display: none;
  padding: 16px;
  border: 1px solid rgba(255,255,255,.14);
  border-radius: 20px;
  background: rgba(255,255,255,.08);
}

.reservation-progress__mobile strong,
.reservation-progress__mobile span {
  display: block;
}

.reservation-progress__mobile i {
  display: block;
  height: 7px;
  margin-top: 12px;
  border-radius: 999px;
  background: rgba(255,255,255,.12);
  overflow: hidden;
}

.reservation-progress__mobile b {
  display: block;
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(90deg, #8fe0b4, #3CB371);
}

.reservation-progress__desktop {
  display: grid;
  grid-template-columns: repeat(5, minmax(0, 1fr));
  gap: 10px;
}

.reservation-progress__desktop button {
  min-width: 0;
  display: grid;
  grid-template-columns: 30px 22px minmax(0, 1fr);
  align-items: center;
  gap: 10px;
  padding: 12px;
  border: 1px solid rgba(255,255,255,.14);
  border-radius: 18px;
  color: rgba(245,255,248,.68);
  background: rgba(255,255,255,.075);
}

.reservation-progress__desktop button span {
  width: 30px;
  height: 30px;
  display: grid;
  place-items: center;
  border-radius: 999px;
  background: rgba(255,255,255,.10);
  color: #fff;
  font-weight: 950;
}

.reservation-progress__desktop button i {
  width: 22px;
  height: 22px;
  display: grid;
  place-items: center;
  color: currentColor;
}

.reservation-progress__desktop button i svg,
.reservation-item-card__icon svg,
.reservation-presets button svg,
.reservation-details-section__head svg,
.reservation-option-row svg,
.reservation-help svg,
.reservation-success-modal svg {
  width: 100%;
  height: 100%;
  fill: none;
  stroke: currentColor;
  stroke-width: 2;
  stroke-linecap: round;
  stroke-linejoin: round;
  vector-effect: non-scaling-stroke;
}

.reservation-item-card__icon svg,
.reservation-details-section__head > span svg,
.reservation-option-row svg,
.reservation-help__head > span svg,
.reservation-success-modal__mark svg {
  width: 24px;
  height: 24px;
}

.reservation-presets button svg,
.reservation-help__sections article i svg {
  width: 22px;
  height: 22px;
}

.reservation-mini.is-soft-render .reservation-mini__layout,
.reservation-mini.is-soft-render .reservation-step-card,
.reservation-mini.is-soft-render .reservation-summary,
.reservation-mini.is-soft-render .reservation-final-summary,
.reservation-mini.is-soft-render .reservation-item-card,
.reservation-mini.is-soft-render .reservation-presets button,
.reservation-mini.is-soft-render .reservation-details-section {
  animation: none !important;
}

.reservation-progress__desktop button em {
  font-style: normal;
  font-weight: 850;
  white-space: nowrap;
}

.reservation-progress__desktop button.is-active {
  border-color: rgba(143,224,180,.46);
  color: #fff;
  box-shadow: 0 16px 46px rgba(60,179,113,.16), inset 0 1px 0 rgba(255,255,255,.12);
}

.reservation-progress__desktop button.is-active span,
.reservation-progress__desktop button.is-done span {
  color: #07140f;
  background: #8fe0b4;
}

.reservation-mini__layout {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 380px;
  gap: clamp(24px, 3vw, 34px);
  align-items: start;
  animation: reservationElementIn .4s cubic-bezier(.22, 1, .36, 1) both;
}

.reservation-step-card,
.reservation-summary,
.reservation-final-summary {
  border-radius: 28px;
  padding: clamp(20px, 3vw, 30px);
  animation: reservationStepIn .28s cubic-bezier(.22, 1, .36, 1) both;
}

.reservation-step-card h2 {
  margin: 6px 0 8px;
  color: #fff;
  font-size: clamp(1.7rem, 4vw, 2.7rem);
}

.reservation-form-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16px;
  margin-top: 22px;
}

.reservation-step-card--details {
  padding: clamp(20px, 3.2vw, 34px);
}

.reservation-details-stack {
  display: grid;
  gap: 18px;
  margin-top: 22px;
}

.reservation-details-section {
  display: grid;
  gap: 17px;
  padding: clamp(16px, 2vw, 22px);
  border: 1px solid rgba(255,255,255,.11);
  border-radius: 24px;
  background:
    radial-gradient(circle at 8% 0%, rgba(143,224,180,.10), transparent 35%),
    rgba(255,255,255,.055);
}

.reservation-details-section .reservation-form-grid {
  margin-top: 0;
}

.reservation-details-section__head {
  display: grid;
  grid-template-columns: 48px minmax(0, 1fr);
  gap: 13px;
  align-items: center;
}

.reservation-details-section__head > span {
  width: 48px;
  height: 48px;
  display: grid;
  place-items: center;
  border-radius: 17px;
  color: #8fe0b4;
  border: 1px solid rgba(143,224,180,.22);
  background: rgba(60,179,113,.10);
  box-shadow: 0 12px 28px rgba(60,179,113,.12), inset 0 1px 0 rgba(255,255,255,.08);
}

.reservation-details-section__head strong {
  display: block;
  color: #fff;
  font-size: 1.08rem;
}

.reservation-details-section__head p {
  margin-top: 2px;
  color: rgba(245,255,248,.62);
  font-size: .92rem;
}

.reservation-field {
  display: grid;
  gap: 8px;
  min-width: 0;
  color: #fff;
  font-weight: 850;
}

.reservation-field__label {
  display: flex !important;
  align-items: center;
  flex-wrap: wrap;
  gap: 8px;
  min-width: 0;
  color: #fff;
}

.reservation-field__label > i {
  width: 30px;
  height: 30px;
  display: grid;
  place-items: center;
  flex: 0 0 auto;
  border: 1px solid rgba(143,224,180,.22);
  border-radius: 11px;
  color: #8fe0b4;
  background: rgba(60,179,113,.10);
}

.reservation-field__label svg {
  width: 17px;
  height: 17px;
}

.reservation-field-badge {
  display: inline-flex;
  align-items: center;
  min-height: 23px;
  padding: 0 8px;
  border: 1px solid rgba(255,255,255,.13);
  border-radius: 999px;
  color: rgba(245,255,248,.72);
  background: rgba(255,255,255,.06);
  font-size: .68rem;
  font-weight: 950;
  line-height: 1;
}

.reservation-field-badge--required,
.reservation-field-badge--conditional {
  border-color: rgba(143,224,180,.24);
  color: #dffff0;
  background: rgba(60,179,113,.12);
}

.reservation-field--wide {
