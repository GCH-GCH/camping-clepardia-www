  grid-template-columns: 34px minmax(0, 1fr);
  align-items: center;
  gap: 10px;
  padding: 12px;
  border: 1px solid rgba(255,255,255,.13);
  border-radius: 18px;
  color: #f5fff8;
  background: rgba(255,255,255,.075);
