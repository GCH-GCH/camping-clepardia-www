    summerBungalow: 'Domki w sezonie warto rezerwowac wczesniej.',
  },
  en: {
    popularCountries: 'Popular countries',
    suggestedCountries: 'Search results',
    noCountries: 'Type at least 1 character, e.g. de, ge or Germany.',
    presetsTitle: 'Popular choices',
    presetsLead: 'Choose a ready-made set or adjust everything manually.',
    presetAdded: 'Popular set added \uD83C\uDF3F',
    help: {
      title: 'Help',
      open: 'Help',
      close: 'Close help',
      sections: [
        ['Camping, bungalows or combined?', 'Camping is for a camper, van, tent or caravan. Bungalows are 2-, 3- or 4-person stays. Combined is for one bungalow plus a camping pitch.'],
        ['This is an enquiry, not an automatic booking', 'Reception confirms availability, price and final conditions.'],
        ['Estimated price', 'We count nights, guests and selected services according to the price list.'],
        ['10A power and dog', '10A power is added according to the price list. Dogs are free.'],
        ['Stay hours', 'Camping: 12:00-12:00. Bungalows: check-in from 16:00, check-out by 11:00.'],
        ['Directions', 'We recommend Google Maps because access changed in 2022.'],
      ],
      shortTitle: 'Do not want to fill in all details?',
      shortCta: 'Send a short enquiry',
    },
    simple: {
      cta: 'I am not sure what to choose - help me pick',
      title: 'Short enquiry',
      desc: 'Briefly describe how you travel and what you need - reception will help choose the best option.',
    },
    summary: {
      statusLabel: 'Enquiry status',
      status: 'To be confirmed by reception',
      badge: 'Estimated price',
      depositBungalow: 'A deposit may be required for bungalows. Deposit details and availability confirmation will be sent by email.',
      depositCombined: 'This enquiry includes a bungalow, so reception may ask for a deposit for the accommodation part.',
    },
    success: {
      title: 'Thank you! \uD83C\uDF3F',
      text: 'Your enquiry has been prepared for reception. We will reply as soon as possible and confirm availability and stay details.',
      bungalow: 'A deposit may be required for bungalows. Deposit details and availability confirmation will be sent by email.',
      camping: 'This enquiry is not an automatic booking. Reception will confirm availability and stay details.',
      home: 'Back to homepage',
      maps: 'Open Google Maps',
      contact: 'Contact reception',
      again: 'New enquiry',
    },
    summerCamping: 'In July and August we do not take standard camping pitch reservations. It is best to arrive shortly after 12:00 when some guests leave. You can send an enquiry and reception will reply if help is possible.',
    summerBungalow: 'Bungalows in high season are best booked earlier.',
  },
  de: null,
  it: null,
} as const;
const ux = uxCopy[lang] ?? uxCopy.en;

const stayPrice = (id: string) => pricingConfig.stayTypes.find((item) => item.id === id) as any;
const addonPrice = (id: string) => pricingConfig.addons.find((item) => item.id === id) as any;

const campingServices = [
  { id: 'camper', label: 'Kamper', price: stayPrice('camper')?.price ?? 0 },
  { id: 'van', label: 'Van', price: stayPrice('van')?.price ?? 0 },
  { id: 'caravan', label: 'Przyczepa', price: stayPrice('caravan')?.price ?? 0 },
  { id: 'tent-small', label: 'Namiot 1-2 os.', price: stayPrice('tent-small')?.price ?? 0 },
  { id: 'tent-large', label: 'Namiot 3-4 os.', price: stayPrice('tent-large')?.price ?? 0 },
  { id: 'rooftop-tent', label: 'Auto + namiot dachowy', price: stayPrice('rooftop-tent')?.price ?? 0 },
  { id: 'parking', label: 'Samochod / parking', price: addonPrice('parking')?.price ?? 0 },
  { id: 'motorcycle', label: 'Motocykl', price: addonPrice('motorcycle')?.price ?? 0 },
  { id: 'cargo-trailer', label: 'Przyczepa bagazowa', price: addonPrice('cargo-trailer')?.price ?? 0 },
  { id: 'bus', label: 'Bus / ciezarowka', price: addonPrice('bus')?.price ?? 0 },
  { id: 'electricity', label: 'Prad 10A', price: addonPrice('electricity')?.price ?? 0 },
  { id: 'dog', label: 'Pies', price: addonPrice('dog')?.price ?? 0 },
];

const bungalowServices = [
  { id: 'bungalow-2', label: 'Domek 2-os.', seasonalPrices: stayPrice('bungalow-2')?.seasonalPrices ?? { low: 0, high: 0 } },
  { id: 'bungalow-3', label: 'Domek 3-os.', seasonalPrices: stayPrice('bungalow-3')?.seasonalPrices ?? { low: 0, high: 0 } },
  { id: 'bungalow-4', label: 'Domek 4-os.', seasonalPrices: stayPrice('bungalow-4')?.seasonalPrices ?? { low: 0, high: 0 } },
  { id: 'parking', label: 'Samochod / parking', price: addonPrice('parking')?.price ?? 0 },
  { id: 'dog', label: 'Pies', price: addonPrice('dog')?.price ?? 0 },
];

const config = {
  lang,
  t,
  currency: pricingConfig.currency,
  seasons: pricingConfig.seasons,
  people: {
    adults: { label: t.guests.adults, price: pricingConfig.people.adults.price },
    children: { label: t.guests.children, price: pricingConfig.people.children.price },
    toddlers: { label: t.guests.toddlers, price: pricingConfig.people.toddlers.price },
    bungalowGuests: { label: t.guests.bungalowGuests, price: 0 },
    campingGuests: { label: t.guests.campingGuests, price: pricingConfig.people.adults.price },
  },
  services: {
    camping: campingServices,
    bungalow: bungalowServices,
  },
  modeChips,
  ux,
  icons: iconHtml,
  countries: countries.map((country) => ({
    code: country.code,
    flagClass: country.flagClass,
    name: country.names[lang] ?? country.names.en,
    aliases: country.aliases,
  })),
};

const safeConfig = JSON.stringify(config).replace(/</g, '\\u003c');
---

<section class="reservation-mini booking-app-page" data-reservation-mini-game data-component="ReservationMiniGame" data-after-hero>
  <div class="reservation-mini__ambient" aria-hidden="true">
    <span></span>
    <span></span>
    <span></span>
  </div>

  <div class="reservation-mini__wrap">
    <div class="reservation-mini__mount" data-reservation-mini-mount>
      <div class="reservation-mini__start">
        <p class="reservation-mini__kicker">{t.kicker}</p>
        <h1>{t.title}</h1>
        <p>{t.lead}</p>
        <div class="reservation-mini__choices">
          {Object.entries(t.modes).map(([mode, [label, desc]]) => (
            <button class="stay-choice-card reservation-choice-card" type="button" data-start-mode={mode}>
              <span class:list={['reservation-choice-card__icon', `reservation-choice-card__icon--${mode}`]} aria-hidden="true" set:html={iconHtml.modes[mode as keyof typeof iconHtml.modes]} />
              <span class="reservation-choice-card__content">
                <strong>{label}</strong>
                <small>{desc}</small>
              </span>
              <span class="reservation-choice-card__chips" aria-hidden="true">
                {modeChips[mode as keyof typeof modeChips].map((chip) => <i>{chip}</i>)}
              </span>
            </button>
          ))}
        </div>
        <button class="reservation-simple-link" type="button" data-simple-start>{ux.simple.cta}</button>
        <p class="reservation-mini__note">{t.startLead}</p>
      </div>
    </div>
  </div>

  <script id="reservation-mini-config" type="application/json" set:html={safeConfig}></script>
</section>

<script is:inline>
  (() => {
    const root = document.querySelector('[data-reservation-mini-game]');
    if (!(root instanceof HTMLElement)) return;
    const mount = root.querySelector('[data-reservation-mini-mount]');
    const configNode = document.getElementById('reservation-mini-config');
    if (!(mount instanceof HTMLElement) || !configNode?.textContent) return;

    /** @type {any} */
    let config;
    try {
      config = JSON.parse(configNode.textContent);
    } catch {
      return;
    }

    const { t, currency } = config;
    const ui = config.ux;
    const steps = ['dates', 'guests', 'services', 'details', 'summary'];
    const stepTitles = t.steps;
    const stayModes = ['camping', 'bungalow', 'combined'];
    const modeChips = config.modeChips;
    const stepHints = t.progressHints;
    const state = {
      mode: null,
      step: 0,
      dates: { arrival: '', departure: '' },
      guests: { adults: 2, children: 0, toddlers: 0, bungalowGuests: 2, campingGuests: 0 },
      services: {},
      simple: { people: 2 },
      details: {
        name: '',
        email: '',
        phone: '',
        language: (config.lang || 'pl').toUpperCase(),
        countrySearch: '',
        countryCode: '',
        countryName: '',
        plate: '',
        message: '',
        specialNeeds: false,
        specialNeedsText: '',
        lateCheckout: false,
        lateTime: '13:00',
        quiet: false,
        consent: false,
      },
      hint: '',
      toast: '',
      summaryPulse: false,
      countryOpen: false,
      countryDirty: false,
      countryActiveIndex: 0,
      helpOpen: false,
      success: false,
    };

    const esc = (value) => String(value ?? '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');

    const fmt = (value) => `${Math.round(Number(value || 0))} ${currency}`;

    const normalize = (value) => String(value ?? '')
      .toLowerCase()
      .normalize('NFD')
      .replace(/[\u0300-\u036f]/g, '');

    const currentStepKey = () => steps[state.step - 1] ?? 'start';

    const countryMatches = () => {
      const query = normalize(state.details.countrySearch);
      if (!state.countryOpen) return [];
      if (!query || !state.countryDirty) return [];
      return config.countries
        .filter((country) => {
          const haystack = [country.code, country.name, ...(country.aliases || [])].map(normalize).join(' ');
          return haystack.includes(query);
        })
        .slice(0, 7);
    };

    const parseDate = (date) => {
      if (!date) return null;
      const parsed = new Date(`${date}T12:00:00`);
      return Number.isNaN(parsed.getTime()) ? null : parsed;
    };

    const nights = () => {
      const arrival = parseDate(state.dates.arrival);
      const departure = parseDate(state.dates.departure);
      if (!arrival || !departure) return 0;
      return Math.max(0, Math.round((departure.getTime() - arrival.getTime()) / 86400000));
    };

    const touchesSummer = () => {
      const arrival = parseDate(state.dates.arrival);
      const departure = parseDate(state.dates.departure);
      if (!arrival && !departure) return false;
      const start = arrival ?? departure;
      const end = departure ?? arrival;
      if (!start || !end) return false;
      const cursor = new Date(start);
      while (cursor <= end) {
        const month = cursor.getMonth() + 1;
        if (month === 7 || month === 8) return true;
        cursor.setDate(cursor.getDate() + 1);
      }
      return false;
    };

    const highSeason = () => {
      const arrival = parseDate(state.dates.arrival);
      if (!arrival) return false;
      const month = arrival.getMonth() + 1;
      return month === 7 || month === 8;
    };

    const seasonalHint = () => {
      if (!touchesSummer()) return '';
      if (state.mode === 'camping') return ui.summerCamping;
      if (state.mode === 'bungalow') return ui.summerBungalow;
      if (state.mode === 'combined') return `${ui.summerCamping} ${ui.summerBungalow}`;
      return '';
    };

    const servicePrice = (item) => {
      if (item.seasonalPrices) return highSeason() ? item.seasonalPrices.high : item.seasonalPrices.low;
      return Number(item.price || 0);
    };

    const serviceKey = (scope, id) => `${scope}:${id}`;

    const getQty = (scope, id) => Number(state.services[serviceKey(scope, id)] || 0);

    const setQty = (scope, id, next) => {
      const key = serviceKey(scope, id);
      state.services[key] = Math.max(0, Number(next) || 0);
      if (state.services[key] === 0) delete state.services[key];
    };

    const presets = {
      camping: [
        { id: 'camping-camper-power', label: '2 osoby + kamper + prad', guests: { adults: 2, children: 0, toddlers: 0 }, services: { 'camping:camper': 1, 'camping:electricity': 1 } },
        { id: 'camping-van', label: '2 osoby + van', guests: { adults: 2, children: 0, toddlers: 0 }, services: { 'camping:van': 1 } },
        { id: 'camping-caravan-power', label: '2 osoby + przyczepa + prad', guests: { adults: 2, children: 0, toddlers: 0 }, services: { 'camping:caravan': 1, 'camping:electricity': 1 } },
        { id: 'camping-tent', label: '2 osoby + namiot', guests: { adults: 2, children: 0, toddlers: 0 }, services: { 'camping:tent-small': 1 } },
        { id: 'camping-family', label: 'Rodzina: 2 doroslych + 2 dzieci + kamper + prad', guests: { adults: 2, children: 2, toddlers: 0 }, services: { 'camping:camper': 1, 'camping:electricity': 1 } },
      ],
      bungalow: [
        { id: 'bungalow-2', label: 'Domek 2-os. dla 2 osob', guests: { adults: 2, children: 0, toddlers: 0 }, services: { 'bungalow:bungalow-2': 1 } },
        { id: 'bungalow-3', label: 'Domek 3-os. dla 3 osob', guests: { adults: 3, children: 0, toddlers: 0 }, services: { 'bungalow:bungalow-3': 1 } },
        { id: 'bungalow-4-family', label: 'Domek 4-os. dla rodziny', guests: { adults: 2, children: 2, toddlers: 0 }, services: { 'bungalow:bungalow-4': 1 } },
        { id: 'bungalow-car', label: 'Domek + auto', services: { 'bungalow:bungalow-2': 1, 'bungalow:parking': 1 } },
      ],
      combined: [
        { id: 'combined-small', label: 'Domek 2-os. + kamper + 2 osoby', guests: { bungalowGuests: 2, campingGuests: 2, children: 0, toddlers: 0 }, services: { 'bungalow:bungalow-2': 1, 'camping:camper': 1 } },
        { id: 'combined-caravan', label: 'Domek 4-os. + przyczepa + prad', guests: { bungalowGuests: 4, campingGuests: 2, children: 0, toddlers: 0 }, services: { 'bungalow:bungalow-4': 1, 'camping:caravan': 1, 'camping:electricity': 1 } },
        { id: 'combined-family', label: 'Rodzina: domek + kamper obok', guests: { bungalowGuests: 4, campingGuests: 2, children: 2, toddlers: 0 }, services: { 'bungalow:bungalow-4': 1, 'camping:camper': 1, 'camping:electricity': 1 } },
      ],
      simple: [],
    };

    const visibleServiceGroups = () => {
      if (state.mode === 'camping') return [{ scope: 'camping', title: t.modes.camping[0], items: config.services.camping }];
      if (state.mode === 'bungalow') return [{ scope: 'bungalow', title: t.modes.bungalow[0], items: config.services.bungalow }];
      if (state.mode === 'combined') return [
        { scope: 'bungalow', title: t.modes.bungalow[0], items: config.services.bungalow },
        { scope: 'camping', title: t.modes.camping[0], items: config.services.camping.filter((item) => !['parking', 'motorcycle', 'cargo-trailer'].includes(item.id)) },
      ];
      return [];
    };

    const clearVisibleServices = () => {
      const scopes = new Set(visibleServiceGroups().map((group) => group.scope));
      Object.keys(state.services).forEach((key) => {
        const scope = key.split(':')[0];
        if (scopes.has(scope)) delete state.services[key];
      });
    };

    const pulseSummary = () => {
      state.summaryPulse = true;
      render();
      window.setTimeout(() => {
        state.summaryPulse = false;
        render();
      }, 520);
    };

    const applyPreset = (id) => {
      const preset = (presets[state.mode] || []).find((item) => item.id === id);
      if (!preset) return;
      if (preset.guests) {
        Object.entries(preset.guests).forEach(([key, value]) => {
          state.guests[key] = Number(value);
        });
      }
      clearVisibleServices();
      Object.entries(preset.services || {}).forEach(([key, value]) => {
        const [scope, serviceId] = key.split(':');
        setQty(scope, serviceId, Number(value));
      });
      state.toast = ui.presetAdded;
      state.hint = '';
      render();
      pulseSummary();
      window.setTimeout(() => {
        if (state.toast === ui.presetAdded) {
          state.toast = '';
          render();
        }
      }, 1800);
    };

    const selectedServices = () => visibleServiceGroups().flatMap((group) => group.items
      .map((item) => {
        const qty = getQty(group.scope, item.id);
        return qty > 0 ? { ...item, scope: group.scope, qty, price: servicePrice(item) } : null;
      })
      .filter(Boolean));

    const guestRows = () => {
      if (state.mode === 'simple') return [
        ['adults', t.guests.adults, 0],
        ['children', t.guests.children, 0],
        ['toddlers', t.guests.toddlers, 0],
      ];
      if (state.mode === 'combined') return [
        ['bungalowGuests', t.guests.bungalowGuests, 0],
        ['campingGuests', t.guests.campingGuests, config.people.campingGuests.price],
        ['children', t.guests.children, config.people.children.price],
        ['toddlers', t.guests.toddlers, config.people.toddlers.price],
      ];
      return [
        ['adults', t.guests.adults, state.mode === 'bungalow' ? 0 : config.people.adults.price],
        ['children', t.guests.children, state.mode === 'bungalow' ? 0 : config.people.children.price],
        ['toddlers', t.guests.toddlers, 0],
      ];
    };

    const guestsTotal = () => {
      if (state.mode === 'bungalow' || state.mode === 'simple') return 0;
      return guestRows().reduce((sum, [key, , price]) => sum + Number(state.guests[key] || 0) * Number(price || 0), 0);
    };

    const servicesTotal = () => selectedServices().reduce((sum, item) => sum + item.qty * item.price, 0);
    const perNightTotal = () => guestsTotal() + servicesTotal();
    const estimatedTotal = () => perNightTotal() * Math.max(1, nights() || 1);

    const hasChosenService = () => selectedServices().length > 0;

    const scrollToTop = () => {
      const top = Math.max(0, root.getBoundingClientRect().top + window.scrollY - 92);
      window.scrollTo({ top, behavior: 'smooth' });
    };

    const modeTitle = () => state.mode === 'simple' ? ui.simple.title : t.modes[state.mode]?.[0];
    const modeDescription = () => state.mode === 'simple' ? ui.simple.desc : t.modes[state.mode]?.[1];

    const iconFromConfig = (group, key) => config.icons?.[group]?.[key] ?? config.icons?.details?.help ?? '';
    const modeIcon = (mode) => iconFromConfig('modes', mode);
    const stepIcon = (index) => config.icons?.steps?.[index] ?? iconFromConfig('details', 'help');
    const serviceIcon = (id) => iconFromConfig('services', id);
    const guestIcon = (key) => iconFromConfig('guests', key);
    const detailIcon = (key) => iconFromConfig('details', key);

    const startTemplate = () => `
      <div class="reservation-mini__start">
        <p class="reservation-mini__kicker">${esc(t.kicker)}</p>
        <h1>${esc(t.title)}</h1>
        <p>${esc(t.lead)}</p>
        <div class="reservation-mini__choices">
          ${stayModes.map((mode) => `
            <button class="stay-choice-card reservation-choice-card" type="button" data-start-mode="${mode}">
              <span class="reservation-choice-card__icon reservation-choice-card__icon--${mode}" aria-hidden="true">${modeIcon(mode)}</span>
              <span class="reservation-choice-card__content">
                <strong>${esc(t.modes[mode][0])}</strong>
                <small>${esc(t.modes[mode][1])}</small>
              </span>
              <span class="reservation-choice-card__chips" aria-hidden="true">
                ${modeChips[mode].map((chip) => `<i>${esc(chip)}</i>`).join('')}
              </span>
            </button>
          `).join('')}
        </div>
        <button class="reservation-simple-link" type="button" data-simple-start>${esc(ui.simple.cta)}</button>
        <p class="reservation-mini__note">${esc(t.startLead)}</p>
      </div>
    `;

    const progressTemplate = () => {
      const percent = Math.max(0, Math.min(100, (state.step / steps.length) * 100));
      return `
        <div class="reservation-progress" aria-label="Booking progress">
          <div class="reservation-progress__mobile">
            <strong>Krok ${state.step} z ${steps.length}</strong>
            <span>${esc(stepTitles[state.step - 1])}</span>
            <i><b style="width:${percent}%"></b></i>
          </div>
          <div class="reservation-progress__desktop">
            ${steps.map((step, index) => {
              const no = index + 1;
              const active = no === state.step;
              const done = no < state.step;
              return `
                <button type="button" data-step-jump="${no}" class="${active ? 'is-active' : ''} ${done ? 'is-done' : ''}" ${done || active ? '' : 'disabled'}>
                  <span>${no}</span>
                  <i aria-hidden="true">${stepIcon(index)}</i>
                  <em>${esc(stepTitles[index])}</em>
                </button>
              `;
            }).join('')}
          </div>
        </div>
      `;
    };

    const stepperTemplate = ({ kind, key, scope = '', id = '', label, price = 0, value }) => {
      const current = Number(value ?? 0);
      const attrs = kind === 'guest' ? `data-guest-key="${esc(key)}"` : `data-service-scope="${esc(scope)}" data-service-id="${esc(id)}"`;
      return `
        <div class="reservation-stepper" ${attrs}>
          <button type="button" data-stepper-minus aria-label="${esc(t.actions.decrease)} ${esc(label)}" ${current <= 0 ? 'disabled' : ''}>&minus;</button>
          <strong aria-live="polite">${current}</strong>
          <button type="button" data-stepper-plus aria-label="${esc(t.actions.increase)} ${esc(label)}">+</button>
        </div>
      `;
    };

    const datesStep = () => `
      <section class="reservation-step-card">
        <p class="reservation-step-card__eyebrow">${esc(stepTitles[0])}</p>
        <h2>${esc(stepTitles[0])}</h2>
        <p>${esc(t.stepLead.dates)}</p>
        <div class="reservation-form-grid">
          <label class="reservation-field">
            <span>${esc(t.fields.arrival)}</span>
            <input type="date" data-field="dates.arrival" value="${esc(state.dates.arrival)}" />
          </label>
          <label class="reservation-field">
            <span>${esc(t.fields.departure)}</span>
            <input type="date" data-field="dates.departure" value="${esc(state.dates.departure)}" />
          </label>
          <div class="reservation-night-card">
            <span>${esc(t.fields.nights)}</span>
            <strong>${nights()}</strong>
          </div>
        </div>
        <div class="reservation-info-grid">
          ${(state.mode === 'camping' || state.mode === 'combined') ? `<p>${esc(t.info.campingHours)}</p>` : ''}
          ${(state.mode === 'bungalow' || state.mode === 'combined') ? `<p>${esc(t.info.bungalowHours)}</p>` : ''}
          ${state.mode === 'combined' ? `<p>${esc(t.info.combined)}</p>` : ''}
          ${seasonalHint() ? `<p class="is-warm">${esc(seasonalHint())}</p>` : ''}
        </div>
      </section>
    `;

    const guestsStep = () => `
      <section class="reservation-step-card">
        <p class="reservation-step-card__eyebrow">${esc(stepTitles[1])}</p>
        <h2>${esc(stepTitles[1])}</h2>
        <p>${esc(t.stepLead.guests)}</p>
        <div class="reservation-card-grid">
          ${guestRows().map(([key, label, price]) => `
            <article class="reservation-item-card">
              <span class="reservation-item-card__icon" aria-hidden="true">${guestIcon(key)}</span>
              <div>
                <strong>${esc(label)}</strong>
