---

<section class="reservation-mini booking-app-page" data-reservation-mini-game data-after-hero>
  <div class="reservation-mini__ambient" aria-hidden="true">
    <span></span>
    <span></span>
    <span></span>
  </div>

  <div class="reservation-mini__wrap">
    <div class="reservation-mini__mount" data-reservation-mini-mount>
      <div class="reservation-mini__start">
        <p class="reservation-mini__kicker">{t.kicker}</p>
        <h1>{t.title}</h1>
        <p>{t.lead}</p>
        <div class="reservation-mini__choices">
          {Object.entries(t.modes).map(([mode, [label, desc]]) => (
            <button class="reservation-choice-card" type="button" data-start-mode={mode}>
              <span aria-hidden="true">{mode === 'camping' ? 'RV' : mode === 'bungalow' ? 'D4' : 'R+'}</span>
              <strong>{label}</strong>
              <small>{desc}</small>
            </button>
          ))}
        </div>
        <p class="reservation-mini__note">{t.startLead}</p>
      </div>
    </div>
  </div>

  <script id="reservation-mini-config" type="application/json" set:html={safeConfig}></script>
</section>

<script is:inline>
  (() => {
    const root = document.querySelector('[data-reservation-mini-game]');
    if (!(root instanceof HTMLElement)) return;
    const mount = root.querySelector('[data-reservation-mini-mount]');
    const configNode = document.getElementById('reservation-mini-config');
    if (!(mount instanceof HTMLElement) || !configNode?.textContent) return;

    /** @type {any} */
    let config;
    try {
      config = JSON.parse(configNode.textContent);
    } catch {
      return;
    }

    const { t, currency } = config;
    const steps = ['dates', 'guests', 'services', 'details', 'summary'];
    const stepTitles = t.steps;
    const stayModes = ['camping', 'bungalow', 'combined'];
    const state = {
      mode: null,
      step: 0,
      dates: { arrival: '', departure: '' },
      guests: { adults: 2, children: 0, toddlers: 0, bungalowGuests: 2, campingGuests: 0 },
      services: {},
      details: {
        name: '',
        email: '',
        phone: '',
        language: (config.lang || 'pl').toUpperCase(),
        countrySearch: '',
        countryCode: '',
        countryName: '',
        plate: '',
        message: '',
        specialNeeds: false,
        specialNeedsText: '',
        lateCheckout: false,
        lateTime: '13:00',
        quiet: false,
        consent: false,
      },
      hint: '',
      success: false,
    };

    const esc = (value) => String(value ?? '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');

    const fmt = (value) => `${Math.round(Number(value || 0))} ${currency}`;

    const normalize = (value) => String(value ?? '')
      .toLowerCase()
      .normalize('NFD')
      .replace(/[\u0300-\u036f]/g, '');

    const currentStepKey = () => steps[state.step - 1] ?? 'start';

    const countryMatches = () => {
      const query = normalize(state.details.countrySearch);
      if (!query) return config.countries.slice(0, 6);
      return config.countries
        .filter((country) => {
          const haystack = [country.code, country.name, ...(country.aliases || [])].map(normalize).join(' ');
          return haystack.includes(query);
        })
        .slice(0, 7);
    };

    const parseDate = (date) => {
      if (!date) return null;
      const parsed = new Date(`${date}T12:00:00`);
      return Number.isNaN(parsed.getTime()) ? null : parsed;
    };

    const nights = () => {
      const arrival = parseDate(state.dates.arrival);
      const departure = parseDate(state.dates.departure);
      if (!arrival || !departure) return 0;
      return Math.max(0, Math.round((departure.getTime() - arrival.getTime()) / 86400000));
    };

    const touchesSummer = () => {
      const arrival = parseDate(state.dates.arrival);
      const departure = parseDate(state.dates.departure);
      if (!arrival && !departure) return false;
      const start = arrival ?? departure;
      const end = departure ?? arrival;
      if (!start || !end) return false;
      const cursor = new Date(start);
      while (cursor <= end) {
        const month = cursor.getMonth() + 1;
        if (month === 7 || month === 8) return true;
        cursor.setDate(cursor.getDate() + 1);
      }
      return false;
    };

    const highSeason = () => {
      const arrival = parseDate(state.dates.arrival);
      if (!arrival) return false;
      const month = arrival.getMonth() + 1;
      return month === 7 || month === 8;
    };

    const servicePrice = (item) => {
      if (item.seasonalPrices) return highSeason() ? item.seasonalPrices.high : item.seasonalPrices.low;
      return Number(item.price || 0);
    };

    const serviceKey = (scope, id) => `${scope}:${id}`;

    const getQty = (scope, id) => Number(state.services[serviceKey(scope, id)] || 0);

    const setQty = (scope, id, next) => {
      const key = serviceKey(scope, id);
      state.services[key] = Math.max(0, Number(next) || 0);
      if (state.services[key] === 0) delete state.services[key];
    };

    const visibleServiceGroups = () => {
      if (state.mode === 'camping') return [{ scope: 'camping', title: t.modes.camping[0], items: config.services.camping }];
      if (state.mode === 'bungalow') return [{ scope: 'bungalow', title: t.modes.bungalow[0], items: config.services.bungalow }];
      if (state.mode === 'combined') return [
        { scope: 'bungalow', title: t.modes.bungalow[0], items: config.services.bungalow },
        { scope: 'camping', title: t.modes.camping[0], items: config.services.camping.filter((item) => !['parking', 'motorcycle', 'cargo-trailer'].includes(item.id)) },
      ];
      return [];
    };

    const selectedServices = () => visibleServiceGroups().flatMap((group) => group.items
      .map((item) => {
        const qty = getQty(group.scope, item.id);
        return qty > 0 ? { ...item, scope: group.scope, qty, price: servicePrice(item) } : null;
      })
      .filter(Boolean));

    const guestRows = () => {
      if (state.mode === 'combined') return [
        ['bungalowGuests', t.guests.bungalowGuests, 0],
        ['campingGuests', t.guests.campingGuests, config.people.campingGuests.price],
        ['children', t.guests.children, config.people.children.price],
        ['toddlers', t.guests.toddlers, config.people.toddlers.price],
      ];
      return [
        ['adults', t.guests.adults, state.mode === 'bungalow' ? 0 : config.people.adults.price],
        ['children', t.guests.children, state.mode === 'bungalow' ? 0 : config.people.children.price],
        ['toddlers', t.guests.toddlers, 0],
      ];
    };

    const guestsTotal = () => {
      if (state.mode === 'bungalow') return 0;
      return guestRows().reduce((sum, [key, , price]) => sum + Number(state.guests[key] || 0) * Number(price || 0), 0);
    };

    const servicesTotal = () => selectedServices().reduce((sum, item) => sum + item.qty * item.price, 0);
    const perNightTotal = () => guestsTotal() + servicesTotal();
    const estimatedTotal = () => perNightTotal() * Math.max(1, nights() || 1);

    const hasChosenService = () => selectedServices().length > 0;

    const scrollToTop = () => {
      const top = Math.max(0, root.getBoundingClientRect().top + window.scrollY - 92);
      window.scrollTo({ top, behavior: 'smooth' });
    };

    const startTemplate = () => `
      <div class="reservation-mini__start">
        <p class="reservation-mini__kicker">${esc(t.kicker)}</p>
        <h1>${esc(t.title)}</h1>
        <p>${esc(t.lead)}</p>
        <div class="reservation-mini__choices">
          ${stayModes.map((mode) => `
            <button class="reservation-choice-card" type="button" data-start-mode="${mode}">
              <span aria-hidden="true">${mode === 'camping' ? 'RV' : mode === 'bungalow' ? 'D4' : 'R+'}</span>
              <strong>${esc(t.modes[mode][0])}</strong>
              <small>${esc(t.modes[mode][1])}</small>
            </button>
          `).join('')}
        </div>
        <p class="reservation-mini__note">${esc(t.startLead)}</p>
      </div>
    `;

    const progressTemplate = () => {
      const percent = Math.max(0, Math.min(100, (state.step / steps.length) * 100));
      return `
        <div class="reservation-progress" aria-label="Booking progress">
          <div class="reservation-progress__mobile">
            <strong>Krok ${state.step} z ${steps.length}</strong>
            <span>${esc(stepTitles[state.step - 1])}</span>
            <i><b style="width:${percent}%"></b></i>
          </div>
          <div class="reservation-progress__desktop">
            ${steps.map((step, index) => {
              const no = index + 1;
              const active = no === state.step;
              const done = no < state.step;
              return `
                <button type="button" data-step-jump="${no}" class="${active ? 'is-active' : ''} ${done ? 'is-done' : ''}" ${done || active ? '' : 'disabled'}>
                  <span>${no}</span>
                  <em>${esc(stepTitles[index])}</em>
                </button>
              `;
            }).join('')}
          </div>
        </div>
      `;
    };

    const stepperTemplate = ({ kind, key, scope = '', id = '', label, price = 0, value }) => {
      const current = Number(value ?? 0);
      const attrs = kind === 'guest' ? `data-guest-key="${esc(key)}"` : `data-service-scope="${esc(scope)}" data-service-id="${esc(id)}"`;
      return `
        <div class="reservation-stepper" ${attrs}>
          <button type="button" data-stepper-minus aria-label="${esc(t.actions.decrease)} ${esc(label)}" ${current <= 0 ? 'disabled' : ''}>-</button>
          <strong aria-live="polite">${current}</strong>
          <button type="button" data-stepper-plus aria-label="${esc(t.actions.increase)} ${esc(label)}">+</button>
        </div>
      `;
    };

    const datesStep = () => `
      <section class="reservation-step-card">
        <p class="reservation-step-card__eyebrow">${esc(stepTitles[0])}</p>
        <h2>${esc(stepTitles[0])}</h2>
        <p>${esc(t.stepLead.dates)}</p>
        <div class="reservation-form-grid">
          <label class="reservation-field">
            <span>${esc(t.fields.arrival)}</span>
            <input type="date" data-field="dates.arrival" value="${esc(state.dates.arrival)}" />
          </label>
          <label class="reservation-field">
            <span>${esc(t.fields.departure)}</span>
            <input type="date" data-field="dates.departure" value="${esc(state.dates.departure)}" />
          </label>
          <div class="reservation-night-card">
            <span>${esc(t.fields.nights)}</span>
            <strong>${nights()}</strong>
          </div>
        </div>
        <div class="reservation-info-grid">
          ${(state.mode === 'camping' || state.mode === 'combined') ? `<p>${esc(t.info.campingHours)}</p>` : ''}
          ${(state.mode === 'bungalow' || state.mode === 'combined') ? `<p>${esc(t.info.bungalowHours)}</p>` : ''}
          ${state.mode === 'combined' ? `<p>${esc(t.info.combined)}</p>` : ''}
          ${touchesSummer() ? `<p class="is-warm">${esc(t.info.summer)}</p>` : ''}
        </div>
      </section>
    `;

    const guestsStep = () => `
      <section class="reservation-step-card">
        <p class="reservation-step-card__eyebrow">${esc(stepTitles[1])}</p>
        <h2>${esc(stepTitles[1])}</h2>
        <p>${esc(t.stepLead.guests)}</p>
        <div class="reservation-card-grid">
          ${guestRows().map(([key, label, price]) => `
            <article class="reservation-item-card">
              <span class="reservation-item-card__icon" aria-hidden="true">${key === 'toddlers' ? '0+' : 'G'}</span>
              <div>
                <strong>${esc(label)}</strong>
                <small>${Number(price) > 0 ? `${fmt(price)} / noc` : '0 PLN / noc'}</small>
              </div>
              ${stepperTemplate({ kind: 'guest', key, label, price, value: state.guests[key] })}
            </article>
          `).join('')}
        </div>
      </section>
    `;

    const servicesStep = () => `
      <section class="reservation-step-card">
        <p class="reservation-step-card__eyebrow">${esc(stepTitles[2])}</p>
        <h2>${esc(stepTitles[2])}</h2>
        <p>${esc(t.stepLead.services)}</p>
        ${state.hint ? `<div class="reservation-hint">${esc(state.hint)}</div>` : ''}
        <div class="reservation-service-groups">
          ${visibleServiceGroups().map((group) => `
            <div class="reservation-service-group">
              <h3>${esc(group.title)}</h3>
              <div class="reservation-card-grid">
                ${group.items.map((item) => {
                  const price = servicePrice(item);
                  const qty = getQty(group.scope, item.id);
                  return `
                    <article class="reservation-item-card">
                      <span class="reservation-item-card__icon" aria-hidden="true">${esc(item.icon)}</span>
                      <div>
                        <strong>${esc(item.label)}</strong>
                        <small>${fmt(price)} / noc</small>
                        ${qty > 0 ? `<em>${fmt(price * qty)} / noc</em>` : ''}
                      </div>
                      ${stepperTemplate({ kind: 'service', scope: group.scope, id: item.id, label: item.label, price, value: qty })}
                    </article>
                  `;
                }).join('')}
              </div>
            </div>
          `).join('')}
        </div>
      </section>
    `;

    const countryTemplate = () => {
      const matches = countryMatches();
      return `
        <div class="reservation-country">
          <label class="reservation-field">
            <span>${esc(t.fields.country)}</span>
            <input type="text" data-country-search value="${esc(state.details.countrySearch)}" placeholder="${esc(t.fields.countryPlaceholder)}" autocomplete="off" aria-autocomplete="list" />
          </label>
          <input type="hidden" data-country-code value="${esc(state.details.countryCode)}" />
          <div class="reservation-country__list" role="listbox">
            ${matches.map((country) => `
              <button type="button" data-country-pick="${esc(country.code)}" role="option">
                <i class="${esc(country.flagClass)}" aria-hidden="true"></i>
                <span>${esc(country.name)}</span>
                <small>${esc(country.code)}</small>
              </button>
            `).join('')}
          </div>
        </div>
      `;
    };

    const detailsStep = () => `
      <section class="reservation-step-card">
        <p class="reservation-step-card__eyebrow">${esc(stepTitles[3])}</p>
        <h2>${esc(stepTitles[3])}</h2>
        <p>${esc(t.stepLead.details)}</p>
        ${state.hint ? `<div class="reservation-hint">${esc(state.hint)}</div>` : ''}
        <div class="reservation-form-grid">
          <label class="reservation-field">
            <span>${esc(t.fields.name)}</span>
            <input type="text" data-field="details.name" value="${esc(state.details.name)}" autocomplete="name" />
          </label>
          <label class="reservation-field">
            <span>${esc(t.fields.email)}</span>
            <input type="email" data-field="details.email" value="${esc(state.details.email)}" autocomplete="email" />
          </label>
          <label class="reservation-field">
            <span>${esc(t.fields.phone)}</span>
            <input type="tel" data-field="details.phone" value="${esc(state.details.phone)}" autocomplete="tel" />
          </label>
          <div class="reservation-field">
            <span>${esc(t.fields.language)}</span>
            <div class="reservation-pills">
              ${['PL','EN','DE','IT'].map((language) => `
                <button type="button" data-language="${language}" class="${state.details.language === language ? 'is-active' : ''}">${language}</button>
              `).join('')}
            </div>
          </div>
          ${countryTemplate()}
          <label class="reservation-field">
            <span>${esc(t.fields.plate)}</span>
            <input type="text" data-field="details.plate" value="${esc(state.details.plate)}" />
            <small>${esc(t.fields.plateHint)}</small>
          </label>
          <label class="reservation-field reservation-field--wide">
            <span>${esc(t.fields.message)}</span>
            <textarea data-field="details.message" rows="4">${esc(state.details.message)}</textarea>
          </label>
        </div>
        <div class="reservation-consents">
          <label><input type="checkbox" data-check="specialNeeds" ${state.details.specialNeeds ? 'checked' : ''} /> <span>${esc(t.fields.specialNeeds)}</span></label>
          ${state.details.specialNeeds ? `
            <label class="reservation-field reservation-field--wide">
              <span>${esc(t.fields.specialNeedsText)}</span>
              <textarea data-field="details.specialNeedsText" rows="3">${esc(state.details.specialNeedsText)}</textarea>
            </label>
          ` : ''}
          <label><input type="checkbox" data-check="lateCheckout" ${state.details.lateCheckout ? 'checked' : ''} /> <span>${esc(t.fields.lateCheckout)}</span></label>
          ${state.details.lateCheckout ? `
            <div class="reservation-late-panel">
              <label class="reservation-field">
                <span>${esc(t.fields.lateTime)}</span>
                <select data-field="details.lateTime">
                  ${['13:00','14:00','15:00','16:00','17:00'].map((time) => `<option value="${time}" ${state.details.lateTime === time ? 'selected' : ''}>${time}</option>`).join('')}
                </select>
              </label>
              <p>${esc(t.info.lateCheckout)}</p>
            </div>
          ` : ''}
          <label><input type="checkbox" data-check="quiet" ${state.details.quiet ? 'checked' : ''} /> <span>${esc(t.fields.quiet)}</span></label>
          <label><input type="checkbox" data-check="consent" ${state.details.consent ? 'checked' : ''} /> <span>${esc(t.fields.consent)}</span></label>
        </div>
      </section>
    `;

    const summaryContent = (full = false) => {
      const selected = selectedServices();
      const hasCostData = selected.length > 0;
      if (!hasCostData) {
        return `
          <h2>${esc(t.summary.title)}</h2>
          <p>${esc(t.summary.empty)}</p>
          <small>${esc(t.summary.confirm)}</small>
        `;
      }
      return `
        <h2>${esc(t.summary.title)}</h2>
        <dl>
          <div><dt>${esc(t.summary.stay)}</dt><dd>${esc(t.modes[state.mode][0])}</dd></div>
          <div><dt>${esc(t.summary.dates)}</dt><dd>${esc(state.dates.arrival || '-')} - ${esc(state.dates.departure || '-')} (${nights()} n.)</dd></div>
          <div><dt>${esc(t.summary.guests)}</dt><dd>${guestRows().map(([key, label]) => `${label}: ${Number(state.guests[key] || 0)}`).join(', ')}</dd></div>
          ${selected.length ? `<div><dt>${esc(t.summary.services)}</dt><dd>${selected.map((item) => `${item.label} x ${item.qty}`).join(', ')}</dd></div>` : ''}
          ${state.details.countryCode ? `<div><dt>${esc(t.summary.country)}</dt><dd>${esc(state.details.countryName)} (${esc(state.details.countryCode)})</dd></div>` : ''}
          <div><dt>${esc(t.summary.language)}</dt><dd>${esc(state.details.language)}</dd></div>
          ${state.details.specialNeeds ? `<div><dt>${esc(t.summary.specialNeeds)}</dt><dd>Tak</dd></div>` : ''}
          ${state.details.lateCheckout ? `<div><dt>${esc(t.summary.lateCheckout)}</dt><dd>${esc(state.details.lateTime)}</dd></div>` : ''}
        </dl>
        <div class="reservation-summary__total">
          <span>${esc(t.summary.total)}</span>
          <strong>${fmt(estimatedTotal())}</strong>
        </div>
        <small>${esc(t.summary.confirm)}</small>
        ${state.success ? `<p class="reservation-success">${esc(t.summary.success)}</p>` : ''}
        ${full ? `<textarea name="reservationPayload" hidden>${esc(JSON.stringify(payload(), null, 2))}</textarea>` : ''}
      `;
    };

    const summaryTemplate = () => `
      <aside class="reservation-summary" aria-live="polite">
        ${summaryContent(state.step === 5)}
      </aside>
    `;

    const finalStep = () => `
      <section class="reservation-step-card">
        <p class="reservation-step-card__eyebrow">${esc(stepTitles[4])}</p>
        <h2>${esc(stepTitles[4])}</h2>
        <p>${esc(t.stepLead.summary)}</p>
        <div class="reservation-final-summary">${summaryContent(true)}</div>
      </section>
    `;

    const activeStepTemplate = () => {
      if (state.step === 1) return datesStep();
      if (state.step === 2) return guestsStep();
      if (state.step === 3) return servicesStep();
      if (state.step === 4) return detailsStep();
      if (state.step === 5) return finalStep();
      return startTemplate();
    };

    const navTemplate = () => `
      <div class="reservation-nav">
        <button class="reservation-btn reservation-btn--ghost" type="button" data-back ${state.step <= 1 ? 'disabled' : ''}>${esc(t.actions.back)}</button>
        ${state.step < 5
          ? `<button class="reservation-btn reservation-btn--primary" type="button" data-next>${esc(t.actions.next)}</button>`
          : `<button class="reservation-btn reservation-btn--primary" type="button" data-submit>${esc(t.actions.send)}</button>`
        }
      </div>
    `;

    const appTemplate = () => `
      <div class="reservation-mini__app">
        <div class="reservation-mini__top">
          <div>
            <p class="reservation-mini__kicker">${esc(t.kicker)}</p>
            <h1>${esc(t.title)}</h1>
            <p>${esc(t.modes[state.mode][0])}: ${esc(t.modes[state.mode][1])}</p>
          </div>
          <button type="button" class="reservation-btn reservation-btn--ghost" data-change-mode>${esc(t.actions.change)}</button>
        </div>
        ${progressTemplate()}
        <div class="reservation-mini__layout">
          <div>
            ${activeStepTemplate()}
            ${navTemplate()}
          </div>
          ${summaryTemplate()}
        </div>
      </div>
    `;

    const payload = () => ({
      stayMode: state.mode,
      dates: state.dates,
      nights: nights(),
      guests: state.guests,
      services: selectedServices(),
      estimatedTotal: estimatedTotal(),
      country: state.details.countryCode,
      language: state.details.language,
      vehiclePlate: state.details.plate,
      specialNeeds: state.details.specialNeeds ? state.details.specialNeedsText : '',
      lateCheckout: state.details.lateCheckout ? state.details.lateTime : '',
      originalMessage: state.details.message,
      translatedSummaryPl: '',
    });

    const render = () => {
      mount.innerHTML = state.mode ? appTemplate() : startTemplate();
    };

    const startFlow = (mode) => {
      if (!stayModes.includes(mode)) return;
      state.mode = mode;
      state.step = 1;
      state.hint = '';
      const url = new URL(window.location.href);
      url.searchParams.set('stay', mode);
      window.history.replaceState({}, '', url);
      render();
      scrollToTop();
    };

    const resetFlow = () => {
      state.mode = null;
      state.step = 0;
      state.hint = '';
      const url = new URL(window.location.href);
      url.searchParams.delete('stay');
      window.history.replaceState({}, '', url);
      render();
      scrollToTop();
    };

    const updateField = (path, value) => {
      const [group, key] = path.split('.');
      if (group === 'dates') state.dates[key] = value;
      if (group === 'details') state.details[key] = value;
    };

    const validateBeforeNext = () => {
      state.hint = '';
      if (state.step === 3 && !hasChosenService()) {
        state.hint = t.hints.chooseService;
        return false;
      }
      return true;
    };

    const submit = () => {
      if (!state.details.quiet || !state.details.consent) {
        state.hint = t.hints.required;
        state.step = 4;
        render();
        return;
      }
      state.success = true;
      render();
    };

    const pickCountry = (code) => {
      const country = config.countries.find((item) => item.code === code);
      if (!country) return;
      state.details.countryCode = country.code;
      state.details.countryName = country.name;
      state.details.countrySearch = `${country.name} (${country.code})`;
      render();
      const input = mount.querySelector('[data-country-search]');
      if (input instanceof HTMLInputElement) input.focus({ preventScroll: true });
    };

    mount.addEventListener('click', (event) => {
      const target = event.target;
      if (!(target instanceof Element)) return;

      const start = target.closest('[data-start-mode]');
      if (start instanceof HTMLElement) {
        startFlow(start.dataset.startMode);
        return;
      }

      if (target.closest('[data-change-mode]')) {
        resetFlow();
        return;
      }

      const jump = target.closest('[data-step-jump]');
      if (jump instanceof HTMLElement && jump.dataset.stepJump) {
        const next = Number(jump.dataset.stepJump);
        if (next >= 1 && next <= state.step) {
          state.step = next;
          state.hint = '';
          render();
        }
        return;
      }

      const serviceStepper = target.closest('[data-service-scope][data-service-id]');
      if (serviceStepper instanceof HTMLElement && (target.closest('[data-stepper-plus]') || target.closest('[data-stepper-minus]'))) {
        const scope = serviceStepper.dataset.serviceScope;
        const id = serviceStepper.dataset.serviceId;
        const current = getQty(scope, id);
        setQty(scope, id, current + (target.closest('[data-stepper-plus]') ? 1 : -1));
        state.hint = '';
        render();
        return;
      }

      const guestStepper = target.closest('[data-guest-key]');
      if (guestStepper instanceof HTMLElement && (target.closest('[data-stepper-plus]') || target.closest('[data-stepper-minus]'))) {
        const key = guestStepper.dataset.guestKey;
        const current = Number(state.guests[key] || 0);
        state.guests[key] = Math.max(0, current + (target.closest('[data-stepper-plus]') ? 1 : -1));
        render();
        return;
      }

      const countryPick = target.closest('[data-country-pick]');
      if (countryPick instanceof HTMLElement) {
        pickCountry(countryPick.dataset.countryPick);
        return;
      }

      const language = target.closest('[data-language]');
      if (language instanceof HTMLElement) {
        state.details.language = language.dataset.language || state.details.language;
        render();
        return;
      }

      if (target.closest('[data-back]')) {
        state.step = Math.max(1, state.step - 1);
        state.hint = '';
        render();
        scrollToTop();
        return;
      }

      if (target.closest('[data-next]')) {
        if (!validateBeforeNext()) {
          render();
          return;
        }
        state.step = Math.min(5, state.step + 1);
        render();
        scrollToTop();
        return;
      }

      if (target.closest('[data-submit]')) {
        submit();
      }
    });

    mount.addEventListener('input', (event) => {
      const target = event.target;
      if (!(target instanceof HTMLInputElement || target instanceof HTMLTextAreaElement || target instanceof HTMLSelectElement)) return;
      if (target.dataset.field) {
        updateField(target.dataset.field, target.value);
        if (target.dataset.field.startsWith('dates.')) render();
        return;
      }
      if (target.hasAttribute('data-country-search')) {
        state.details.countrySearch = target.value;
        state.details.countryCode = '';
        state.details.countryName = '';
        render();
        const input = mount.querySelector('[data-country-search]');
        if (input instanceof HTMLInputElement) {
          input.focus({ preventScroll: true });
          input.setSelectionRange(input.value.length, input.value.length);
        }
      }
    });

    mount.addEventListener('change', (event) => {
      const target = event.target;
      if (!(target instanceof HTMLInputElement)) return;
      if (target.dataset.check) {
        state.details[target.dataset.check] = target.checked;
        render();
      }
    });

    mount.addEventListener('keydown', (event) => {
      const target = event.target;
      if (!(target instanceof HTMLInputElement) || !target.hasAttribute('data-country-search')) return;
      const results = countryMatches();
      if (event.key === 'Enter' && results[0]) {
        event.preventDefault();
        pickCountry(results[0].code);
      }
      if (event.key === 'Escape') {
        state.details.countrySearch = '';
        state.details.countryCode = '';
        state.details.countryName = '';
        render();
      }
    });

    const queryMode = new URLSearchParams(window.location.search).get('stay');
    if (stayModes.includes(queryMode)) {
      state.mode = queryMode;
      state.step = 1;
    }
    render();
  })();
</script>

<style>
.reservation-mini {
  position: relative;
  isolation: isolate;
  min-height: calc(100svh - 82px);
  padding: clamp(88px, 10vw, 132px) 20px 72px;
  color: #f5fff8;
