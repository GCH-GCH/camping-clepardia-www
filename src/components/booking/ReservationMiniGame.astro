      }
      if (count === 2) {
        return [
          { href: config.links?.planner || '/planer-pobytu', label: config.lang === 'pl' ? 'Plan na 2 noce' : '2-night plan' },
          { href: config.links?.attractions || '/atrakcje', label: config.lang === 'pl' ? 'Kazimierz i centrum' : 'Kazimierz and centre' },
        ];
      }
      if (count === 3) {
        return [
          { href: config.links?.attractions || '/atrakcje', label: config.lang === 'pl' ? 'Wieliczka / Auschwitz-Birkenau' : 'Wieliczka / Auschwitz-Birkenau' },
