    const tripCtaTemplate = (compact = false) => `
      <div class="${compact ? 'reservation-trip-ctas reservation-trip-ctas--compact' : 'reservation-trip-ctas'}">
        ${tripCtas().map((cta) => `<a href="${esc(cta.href)}" class="reservation-mini-link">${esc(cta.label)}</a>`).join('')}
        <a href="${esc(config.links?.tours)}" class="reservation-mini-link" target="_blank" rel="noopener noreferrer">${esc(config.tourUi?.[0] || 'Check tours')}</a>
      </div>
    `;

    const nights = () => {
      const arrival = parseDate(state.dates.arrival);
      const departure = parseDate(state.dates.departure);
      if (!arrival || !departure) return 0;
      return Math.max(0, Math.round((departure.getTime() - arrival.getTime()) / 86400000));
    };

    const touchesSummer = () => {
      const arrival = parseDate(state.dates.arrival);
      const departure = parseDate(state.dates.departure);
      if (!arrival && !departure) return false;
      const start = arrival ?? departure;
      const end = departure ?? arrival;
      if (!start || !end) return false;
      const cursor = new Date(start);
      while (cursor <= end) {
        const month = cursor.getMonth() + 1;
        if (month === 7 || month === 8) return true;
        cursor.setDate(cursor.getDate() + 1);
      }
      return false;
    };

    const highSeason = () => {
      const arrival = parseDate(state.dates.arrival);
      if (!arrival) return false;
      const month = arrival.getMonth() + 1;
      return month === 7 || month === 8;
    };

    const seasonalHint = () => {
      if (!touchesSummer()) return '';
      if (state.mode === 'camping') return ui.summerCamping;
      if (state.mode === 'bungalow') return ui.summerBungalow;
      if (state.mode === 'combined') return `${ui.summerCamping} ${ui.summerBungalow}`;
      return '';
    };

    const highSeasonCampingInfo = () => touchesSummer() && (state.mode === 'camping' || state.mode === 'combined');
    const summerCampingBlocked = () => highSeasonCampingInfo();
    const bungalowPersonalItemsNotice = () => state.mode === 'bungalow' || state.mode === 'combined';
    const arrivalTimeLabel = () => state.details.arrivalTime || (config.lang === 'pl' ? 'jeszcze nie wiem' : 'not sure yet');
    const cityCampingNotice = () => config.lang === 'pl'
      ? 'Camping Clepardia znajduje się w Krakowie: blisko tramwaju, sklepów i atrakcji. To zielona baza w mieście, dlatego czasem słychać tramwaje, samoloty i normalne miejskie życie.'
      : 'Camping Clepardia is a green city campsite close to trams, shops and attractions. You may sometimes hear trams, aircraft and normal city life.';
    const bungalowItemsNotice = () => config.lang === 'pl'
      ? 'Przy pobycie w domkach prosimy zabrać własne rzeczy osobiste, w tym ręczniki i kosmetyki.'
      : 'For a bungalow stay, please bring personal items, including towels and toiletries.';
    const highSeasonCampingNotice = () => config.summerBlock?.message || (config.lang === 'pl'
      ? 'W lipcu i sierpniu nie prowadzimy rezerwacji miejsc campingowych z wyprzedzeniem. Miejsca dla kamperów, przyczep, vanów i namiotów są dostępne według kolejności przyjazdu. W tym terminie można wysłać zapytanie tylko o domek.'
      : 'In July and August we do not accept advance reservations for camping pitches. Places for campers, caravans, vans and tents are available in arrival order. For this period you can only send an enquiry for a bungalow.');

    const servicePrice = (item) => {
      if (item.seasonalPrices) return highSeason() ? item.seasonalPrices.high : item.seasonalPrices.low;
      return Number(item.price || 0);
    };

    const serviceKey = (scope, id) => `${scope}:${id}`;

    const getQty = (scope, id) => Number(state.services[serviceKey(scope, id)] || 0);

    const setQty = (scope, id, next) => {
      const key = serviceKey(scope, id);
      state.services[key] = Math.max(0, Number(next) || 0);
      if (state.services[key] === 0) delete state.services[key];
    };

    const presets = {
      camping: [
        { id: 'camper-electricity', icon: 'camper', label: '2 osoby + kamper + prąd', guests: { adults: 2, children: 0, toddlers: 0 }, services: { 'camping:camper': 1, 'camping:electricity': 1 } },
        { id: 'van', icon: 'van', label: '2 osoby + van', guests: { adults: 2, children: 0, toddlers: 0 }, services: { 'camping:van': 1 } },
        { id: 'caravan-electricity', icon: 'caravan', label: '2 osoby + auto + przyczepa + prąd', toast: 'Dodano zestaw: 2 osoby + auto + przyczepa + prąd 🌿', guests: { adults: 2, children: 0, toddlers: 0 }, services: { 'camping:parking': 1, 'camping:caravan': 1, 'camping:electricity': 1 } },
        { id: 'tent-small', icon: 'tent-small', label: '2 osoby + namiot 1-2 os.', guests: { adults: 2, children: 0, toddlers: 0 }, services: { 'camping:tent-small': 1 } },
        { id: 'tent-large', icon: 'tent-large', label: '2 osoby + namiot 3-4 os.', guests: { adults: 2, children: 0, toddlers: 0 }, services: { 'camping:tent-large': 1 } },
        { id: 'camping-family', icon: 'camper', label: 'Rodzina: 2 dorosłych + 2 dzieci + kamper + prąd', guests: { adults: 2, children: 2, toddlers: 0 }, services: { 'camping:camper': 1, 'camping:electricity': 1 } },
      ],
      bungalow: [
        { id: 'bungalow-2', icon: 'bungalow-2', label: 'Domek 2-os. dla 2 osób', guests: { adults: 2, children: 0, toddlers: 0 }, services: { 'bungalow:bungalow-2': 1 } },
        { id: 'bungalow-3', icon: 'bungalow-3', label: 'Domek 3-os. dla 3 osób', guests: { adults: 3, children: 0, toddlers: 0 }, services: { 'bungalow:bungalow-3': 1 } },
        { id: 'bungalow-4-family', icon: 'bungalow-4', label: 'Domek 4-os. dla rodziny', guests: { adults: 2, children: 2, toddlers: 0 }, services: { 'bungalow:bungalow-4': 1 } },
        { id: 'bungalow-car', icon: 'parking', label: 'Domek + auto', services: { 'bungalow:bungalow-2': 1, 'bungalow:parking': 1 } },
      ],
      combined: [
        { id: 'combined-small', icon: 'camper', label: 'Domek 2-os. + kamper + 2 osoby', guests: { bungalowGuests: 2, campingGuests: 2, children: 0, toddlers: 0 }, services: { 'bungalow:bungalow-2': 1, 'camping:camper': 1 } },
        { id: 'combined-caravan', icon: 'caravan', label: 'Domek 4-os. + przyczepa + prąd', guests: { bungalowGuests: 4, campingGuests: 2, children: 0, toddlers: 0 }, services: { 'bungalow:bungalow-4': 1, 'camping:caravan': 1, 'camping:electricity': 1 } },
        { id: 'combined-family', icon: 'bungalow-4', label: 'Rodzina: domek + kamper obok', guests: { bungalowGuests: 4, campingGuests: 2, children: 2, toddlers: 0 }, services: { 'bungalow:bungalow-4': 1, 'camping:camper': 1, 'camping:electricity': 1 } },
      ],
      simple: [],
    };

    const visibleServiceGroups = () => {
      if (state.mode === 'camping') return [{ scope: 'camping', title: t.modes.camping[0], items: config.services.camping }];
      if (state.mode === 'bungalow') return [{ scope: 'bungalow', title: t.modes.bungalow[0], items: config.services.bungalow }];
      if (state.mode === 'combined') return [
        { scope: 'bungalow', title: t.modes.bungalow[0], items: config.services.bungalow },
        { scope: 'camping', title: t.modes.camping[0], items: config.services.camping.filter((item) => !['parking', 'motorcycle', 'cargo-trailer'].includes(item.id)) },
      ];
      return [];
    };

    const clearVisibleServices = () => {
      const scopes = new Set(visibleServiceGroups().map((group) => group.scope));
      Object.keys(state.services).forEach((key) => {
        const scope = key.split(':')[0];
        if (scopes.has(scope)) delete state.services[key];
      });
    };

    const pulseSummary = () => {
      state.summaryPulse = true;
      updateSummaryDom();
      window.setTimeout(() => {
        state.summaryPulse = false;
        updateSummaryDom();
      }, 520);
    };

    const applyPreset = (id) => {
      const preset = (presets[state.mode] || []).find((item) => item.id === id);
      if (!preset) return;
      if (preset.guests) {
        Object.entries(preset.guests).forEach(([key, value]) => {
          state.guests[key] = Number(value);
        });
      }
      clearVisibleServices();
      Object.entries(preset.services || {}).forEach(([key, value]) => {
        const [scope, serviceId] = key.split(':');
        setQty(scope, serviceId, Number(value));
      });
      state.toast = preset.toast || ui.presetAdded;
      state.hint = '';
      refreshControlDom();
      pulseSummary();
      window.setTimeout(() => {
        if (state.toast === (preset.toast || ui.presetAdded)) {
          state.toast = '';
          updateToastDom();
        }
      }, 1800);
    };

    const selectedServices = () => visibleServiceGroups().flatMap((group) => group.items
      .map((item) => {
        const qty = getQty(group.scope, item.id);
        return qty > 0 ? { ...item, scope: group.scope, qty, price: servicePrice(item) } : null;
      })
      .filter(Boolean));

    const guestRows = () => {
      if (state.mode === 'simple') return [
        ['adults', t.guests.adults, 0],
        ['children', t.guests.children, 0],
        ['toddlers', t.guests.toddlers, 0],
      ];
      if (state.mode === 'combined') return [
        ['bungalowGuests', t.guests.bungalowGuests, 0],
        ['campingGuests', t.guests.campingGuests, config.people.campingGuests.price],
        ['children', t.guests.children, config.people.children.price],
        ['toddlers', t.guests.toddlers, config.people.toddlers.price],
      ];
      return [
        ['adults', t.guests.adults, state.mode === 'bungalow' ? 0 : config.people.adults.price],
        ['children', t.guests.children, state.mode === 'bungalow' ? 0 : config.people.children.price],
        ['toddlers', t.guests.toddlers, 0],
      ];
    };

    const guestsTotal = () => {
      if (state.mode === 'bungalow' || state.mode === 'simple') return 0;
      return guestRows().reduce((sum, [key, , price]) => sum + Number(state.guests[key] || 0) * Number(price || 0), 0);
    };

    const servicesTotal = () => selectedServices().reduce((sum, item) => sum + item.qty * item.price, 0);
    const perNightTotal = () => guestsTotal() + servicesTotal();
    const estimatedTotal = () => perNightTotal() * Math.max(1, nights() || 1);

    const hasChosenService = () => selectedServices().length > 0;
    const vehicleDetailServiceIds = ['camper', 'van', 'caravan', 'rooftop-tent', 'cargo-trailer', 'bus'];
    const shouldShowVehicleDetails = () => {
      if (!(state.mode === 'camping' || state.mode === 'combined')) return false;
      return vehicleDetailServiceIds.some((id) => getQty('camping', id) > 0);
    };

    const serviceSuggestions = () => {
      const text = ui.serviceSuggestions || {};
      const suggestions = [];
      const hasCamping = state.mode === 'camping' || state.mode === 'combined';
      const has = (scope, id) => getQty(scope, id) > 0;
      if (hasCamping && has('camping', 'camper') && !has('camping', 'electricity')) {
        suggestions.push({ icon: 'electricity', text: text.camperPower, action: text.addPower, scope: 'camping', id: 'electricity' });
      }
      if (hasCamping && has('camping', 'caravan') && !has('camping', 'parking')) {
        suggestions.push({ icon: 'car', text: text.caravanCar, action: text.addCar, scope: 'camping', id: 'parking' });
      }
      if (hasCamping && (has('camping', 'tent-small') || has('camping', 'tent-large')) && !has('camping', 'parking')) {
        suggestions.push({ icon: 'car', text: text.tentCar, action: text.addCar, scope: 'camping', id: 'parking' });
      }
      if ((has('camping', 'dog') || has('bungalow', 'dog')) && text.dogFree) {
        suggestions.push({ icon: 'dog', text: text.dogFree });
      }
      if (hasCamping && touchesSummer() && (config.summerBlock?.short || text.summerCamping)) {
        suggestions.push({ icon: 'warning', text: config.summerBlock?.short || text.summerCamping });
      }
      return suggestions.slice(0, 4);
    };

    const vehiclePlateHelper = () => {
      const hints = formText.plateHints || {};
      const has = (scope, id) => getQty(scope, id) > 0;
      if (has('camping', 'caravan')) return hints.caravan;
      if (has('camping', 'camper')) return hints.camper;
      if (has('camping', 'van')) return hints.van;
      if (has('camping', 'rooftop-tent')) return hints.rooftop;
      if (has('camping', 'bus')) return hints.bus;
      if (has('camping', 'parking') || has('bungalow', 'parking')) return hints.car;
      return hints.default || t.fields.plateHint;
    };

    const vehiclePlatePlaceholder = () => {
      const placeholders = detailText.field?.plate?.placeholders || {};
      const has = (scope, id) => getQty(scope, id) > 0;
      if (has('camping', 'caravan') || has('camping', 'cargo-trailer')) return placeholders.caravan;
      if (has('camping', 'camper')) return placeholders.camper;
      if (has('camping', 'van')) return placeholders.van;
      if (has('camping', 'rooftop-tent')) return placeholders.rooftop;
      if (has('camping', 'bus')) return placeholders.bus;
      if (has('camping', 'parking') || has('bungalow', 'parking')) return placeholders.car;
      return placeholders.default || '';
    };

    const guestCount = () => {
      if (state.mode === 'combined') {
        return Number(state.guests.bungalowGuests || 0)
          + Number(state.guests.campingGuests || 0)
          + Number(state.guests.children || 0)
          + Number(state.guests.toddlers || 0);
      }
      return Number(state.guests.adults || 0)
        + Number(state.guests.children || 0)
        + Number(state.guests.toddlers || 0);
    };

    const missingItems = () => {
      const missing = [];
      if (!state.dates.arrival || !state.dates.departure || nights() < 1) {
        missing.push({ key: 'dates', icon: 'calendar', label: detailText.missing.dates });
      }
      if (guestCount() < 1) {
        missing.push({ key: 'guests', icon: 'guests', label: detailText.missing.guests });
      }
      if (state.mode !== 'simple' && !hasChosenService()) {
        missing.push({ key: 'service', icon: 'services', label: detailText.missing.service });
      }
      if (!state.details.name.trim()) {
        missing.push({ key: 'name', icon: 'name', label: detailText.missing.name });
      }
      if (!state.details.email.trim() && !state.details.phone.trim()) {
        missing.push({ key: 'contact', icon: 'contactConsent', label: detailText.missing.contact });
      }
      if (!state.details.countryCode) {
        missing.push({ key: 'country', icon: 'country', label: detailText.missing.country });
      }
      if (!state.details.quiet) {
        missing.push({ key: 'quiet', icon: 'quiet', label: detailText.missing.quiet });
      }
      if (!state.details.consent) {
        missing.push({ key: 'consent', icon: 'contactConsent', label: detailText.missing.consent });
      }
      if (!state.details.privacy) {
        missing.push({ key: 'privacy', icon: 'privacy', label: detailText.missing.privacy });
      }
      return missing;
    };

    const hasMissing = (key) => missingItems().some((item) => item.key === key);
    const fieldInvalid = (key) => Boolean(state.submitAttempted && hasMissing(key));
    const contactInvalid = () => fieldInvalid('contact');

    const fieldBadge = (kind = 'optional') => {
      const label = kind === 'required'
        ? detailText.required
        : kind === 'conditional'
          ? detailText.conditionalContact
          : detailText.optional;
      return `<b class="reservation-field-badge reservation-field-badge--${esc(kind)}">${esc(label)}</b>`;
    };

    const fieldLabel = ({ icon, label, badge = 'optional' }) => `
      <span class="reservation-field__label">
        <i aria-hidden="true">${detailIcon(icon)}</i>
        <span>${esc(label)}</span>
        ${fieldBadge(badge)}
      </span>
    `;

    const fieldError = (key) => {
      if (!fieldInvalid(key) && !(key === 'contact' && contactInvalid())) return '';
      const messages = {
        name: formText.validation.name,
        contact: formText.validation.contact,
        country: formText.validation.country,
      };
      return `<em class="reservation-field__error">${esc(messages[key] || state.hint || t.hints.required)}</em>`;
    };

    const missingListTemplate = (compact = false) => {
      const missing = missingItems();
      if (!missing.length) {
        return `
          <div class="reservation-missing-card reservation-missing-card--ready" data-missing-card>
            <i aria-hidden="true">${detailIcon('success')}</i>
            <strong>${esc(detailText.readyTitle)}</strong>
          </div>
        `;
      }
      return `
        <div class="reservation-missing-card" data-missing-card>
          <i aria-hidden="true">${detailIcon('warning')}</i>
          <div>
            <strong>${esc(detailText.missingTitle)}</strong>
            <ul>
              ${missing.slice(0, compact ? 5 : missing.length).map((item) => `
                <li><span aria-hidden="true">${detailIcon(item.icon)}</span>${esc(item.label)}</li>
              `).join('')}
            </ul>
          </div>
        </div>
      `;
    };

    const summaryRow = (icon, label, value) => {
      const hasValue = value !== undefined && value !== null && String(value).trim() !== '';
      if (!hasValue) return '';
      return `
        <div class="reservation-summary-row">
          <i aria-hidden="true">${detailIcon(icon)}</i>
          <span>
            <dt>${esc(label)}</dt>
            <dd>${esc(value)}</dd>
          </span>
        </div>
      `;
    };

    const servicesText = () => {
      const selected = selectedServices();
      return selected.length ? selected.map((item) => `${item.label} x ${item.qty}`).join(', ') : '';
    };

    const tourOptions = config.lang === 'pl'
      ? ['Wieliczka', 'Auschwitz-Birkenau', 'Zakopane', 'Ojców', 'Energylandia', 'Kazimierz / Stare Miasto', 'Nie wiem — proszę o propozycję']
      : ['Wieliczka', 'Auschwitz-Birkenau', 'Zakopane', 'Ojców', 'Energylandia', 'Kazimierz / Old Town', 'I am not sure — please suggest'];

    const toursText = () => state.tours.join(', ');

    const guestsText = () => guestRows().map(([key, label]) => `${label}: ${Number(state.guests[key] || 0)}`).join(', ');

    const consentsText = () => [
      `${detailText.missing.quiet}: ${state.details.quiet ? 'OK' : '-'}`,
      `${detailText.missing.consent}: ${state.details.consent ? 'OK' : '-'}`,
      `${detailText.missing.privacy}: ${state.details.privacy ? 'OK' : '-'}`,
    ].join(', ');

    const yesLabel = () => config.lang === 'pl' ? 'Tak' : 'Yes';

    const findScrollContainer = (element) => {
      let parent = element?.parentElement;
      while (parent && parent !== document.body && parent !== document.documentElement) {
        const style = window.getComputedStyle(parent);
        if (/(auto|scroll)/.test(style.overflowY) && parent.scrollHeight > parent.clientHeight + 2) return parent;
        parent = parent.parentElement;
      }
      return null;
    };

    const scrollToReservationSection = (target, { center = false } = {}) => {
      if (!(target instanceof HTMLElement)) return;
      const container = findScrollContainer(target);
      const targetRect = target.getBoundingClientRect();
      const start = container ? container.scrollTop : window.scrollY;
      const viewportHeight = container ? container.clientHeight : window.innerHeight;
      const containerTop = container ? container.getBoundingClientRect().top : 0;
      const relativeTop = targetRect.top - containerTop;
      const navbar = document.querySelector('[data-main-navbar], #mainNavbarShell, #mainNavbar');
      const stickyOffset = navbar instanceof HTMLElement ? navbar.getBoundingClientRect().height + 18 : 112;
      const destination = Math.max(
        0,
        start + relativeTop - (center ? Math.max(24, (viewportHeight - targetRect.height) / 2) : stickyOffset),
      );
      const behavior = reducedMotion.matches ? 'auto' : 'smooth';
      if (container) container.scrollTo({ top: destination, behavior });
      else window.scrollTo({ top: destination, behavior });
    };

    const scrollToTop = () => {
      const target = mount.querySelector('.reservation-step-card, .reservation-mini__start, .reservation-progress');
      scrollToReservationSection(target instanceof HTMLElement ? target : root);
    };

    const scheduleScrollToTop = () => {
      window.requestAnimationFrame(() => {
        window.requestAnimationFrame(scrollToTop);
      });
    };

    const modeTitle = () => state.mode === 'simple' ? ui.simple.title : t.modes[state.mode]?.[0];
    const modeDescription = () => state.mode === 'simple' ? ui.simple.desc : t.modes[state.mode]?.[1];

    const iconFromConfig = (group, key) => config.icons?.[group]?.[key] ?? config.icons?.details?.help ?? '';
    const modeIcon = (mode) => iconFromConfig('modes', mode);
    const stepIcon = (index) => config.icons?.steps?.[index] ?? iconFromConfig('details', 'help');
    const serviceIcon = (id) => iconFromConfig('services', id);
    const guestIcon = (key) => iconFromConfig('guests', key);
    const detailIcon = (key) => iconFromConfig('details', key);

    const summerBlockTemplate = (compact = false) => {
      if (!summerCampingBlocked()) return '';
      const copy = config.summerBlock || {};
      return `
        <aside class="reservation-summer-block ${compact ? 'reservation-summer-block--compact' : ''}" data-summer-camping-block>
          <i aria-hidden="true">${detailIcon('warning')}</i>
          <div>
            <span>${esc(copy.badge || 'Arrival order only')}</span>
            <strong>${esc(copy.title || 'Camping in July and August')}</strong>
            <p>${esc(copy.message || highSeasonCampingNotice())}</p>
            <div class="reservation-summer-block__actions">
              <button type="button" class="reservation-btn reservation-btn--primary" data-switch-to-bungalow>${esc(copy.switchToBungalow || 'Switch to bungalow')}</button>
              <a class="reservation-btn reservation-btn--ghost" href="${esc(config.links?.directions || '/dojazd')}">${esc(copy.rules || 'Check arrival rules')}</a>
              <button type="button" class="reservation-btn reservation-btn--ghost" data-summer-campy>${esc(copy.askCampy || 'Ask CAMPY')}</button>
            </div>
          </div>
        </aside>
      `;
    };

    const startTemplate = () => `
      <div class="reservation-mini__start">
        <p class="reservation-mini__kicker">${esc(t.kicker)}</p>
        <h1>${esc(t.title)}</h1>
        <p>${esc(t.lead)}</p>
        <div class="reservation-mini__choices">
          ${stayModes.map((mode) => `
            <button class="stay-choice-card reservation-choice-card" type="button" data-start-mode="${mode}">
              <span class="reservation-choice-card__icon reservation-choice-card__icon--${mode}" aria-hidden="true">${modeIcon(mode)}</span>
              <span class="reservation-choice-card__content">
                <strong>${esc(t.modes[mode][0])}</strong>
                <small>${esc(t.modes[mode][1])}</small>
              </span>
              <span class="reservation-choice-card__chips" aria-hidden="true">
                ${modeChips[mode].map((chip) => `<i>${esc(chip)}</i>`).join('')}
              </span>
            </button>
          `).join('')}
        </div>
        <button class="reservation-simple-link" type="button" data-simple-start>${esc(ui.simple.cta)}</button>
        <div class="reservation-trip-ctas reservation-trip-ctas--start">
          <a href="${esc(config.links?.planner || '/planer-pobytu')}" class="reservation-mini-link">${esc(config.lang === 'pl' ? 'Dodaj plan pobytu' : 'Add a stay plan')}</a>
          <a href="${esc(config.links?.attractions || '/atrakcje')}" class="reservation-mini-link">${esc(config.lang === 'pl' ? 'Zobacz atrakcje' : 'See attractions')}</a>
          <a href="${esc(config.links?.directions || '/dojazd')}" class="reservation-mini-link">${esc(config.lang === 'pl' ? 'Jak dojechać do centrum?' : 'How to reach the centre?')}</a>
        </div>
        <aside class="reservation-before-arrival">
          <strong>${esc(config.beforeArrival.title)}</strong>
          <div>
            ${config.beforeArrival.items.map((item) => `<span><i aria-hidden="true">${config.beforeArrival.icon}</i>${esc(item)}</span>`).join('')}
