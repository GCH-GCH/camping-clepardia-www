const plannerPath = getLocalizedPath(pathContext.explicitLanguage, 'planer-pobytu');
const directionsPath = getLocalizedPath(pathContext.explicitLanguage, 'dojazd');
const contactPath = getLocalizedPath(pathContext.explicitLanguage, 'kontakt');

const renderLucideIcon = (name: keyof typeof icons | string) => {
  const iconNode = icons[name as keyof typeof icons] ?? icons.CircleHelp;
  const iconName = String(name).replace(/([a-z0-9])([A-Z])/g, '$1-$2').replace(/[^a-z0-9]+/gi, '-').toLowerCase();
  const attrsToString = (attrs: Record<string, unknown>) => Object.entries(attrs)
    .map(([key, value]) => `${key}="${String(value).replace(/"/g, '&quot;')}"`)
    .join(' ');

  return `<svg class="reservation-lucide-icon lucide lucide-${iconName}" data-lucide="${iconName}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">${iconNode
    .map(([tag, attrs]) => `<${tag} ${attrsToString(attrs as Record<string, unknown>)}></${tag}>`)
    .join('')}</svg>`;
};

