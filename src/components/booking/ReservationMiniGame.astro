      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');

    const fmt = (value) => `${Math.round(Number(value || 0))} ${currency}`;
    const currencyEstimateText = (value) => {
      const rates = config.currencyEstimate?.rates || {};
      const pln = Math.max(0, Number(value) || 0);
      if (!rates.EUR || !rates.USD || !rates.GBP) return '';
      return `ok. ${Math.round(pln / rates.EUR)} EUR / ${Math.round(pln / rates.USD)} USD / ${Math.round(pln / rates.GBP)} GBP`;
    };
    const currencyDisclaimer = () => config.currencyEstimate?.disclaimer || 'Waluty obce pokazujemy wyłącznie orientacyjnie.';

    const normalize = (value) => String(value ?? '')
      .toLowerCase()
      .normalize('NFD')
      .replace(/[\u0300-\u036f]/g, '');

    const currentStepKey = () => steps[state.step - 1] ?? 'start';

    const countryMatches = () => {
      const query = normalize(state.details.countrySearch);
      if (!state.countryOpen) return [];
      if (!query || !state.countryDirty) return [];
      const preferredCode = { ge: 'DE', sv: 'SE', cs: 'CZ' }[query];
      return config.countries
        .map((country) => {
          const code = normalize(country.code);
          const name = normalize(country.name);
          const aliases = (country.aliases || []).map(normalize);
          const values = [code, name, ...aliases];
          let score = 99;
          if (preferredCode && country.code === preferredCode) score = -1;
          else if (aliases.some((alias) => alias === query)) score = 0;
          else if (code === query) score = 1;
          else if (name === query) score = 2;
          else if (aliases.some((alias) => alias.startsWith(query))) score = 3;
          else if (code.startsWith(query) || name.startsWith(query)) score = 4;
          else if (values.some((value) => value.includes(query))) score = 5;
          return { country, score };
        })
        .filter((entry) => entry.score < 99)
        .sort((a, b) => a.score - b.score || a.country.name.localeCompare(b.country.name))
        .map((entry) => entry.country)
        .slice(0, 7);
    };

    const parseDate = (date) => {
      if (!date) return null;
      const parsed = new Date(`${date}T12:00:00`);
      return Number.isNaN(parsed.getTime()) ? null : parsed;
    };

    const dateToIso = (date) =>
      `${date.getFullYear()}-${String(date.getMonth() + 1).padStart(2, '0')}-${String(date.getDate()).padStart(2, '0')}`;

    const monthStart = (iso = state.calendarMonth) => {
      const parsed = parseDate(iso) || today;
      return new Date(parsed.getFullYear(), parsed.getMonth(), 1, 12);
    };

    const monthLabel = () => monthStart().toLocaleDateString(config.lang || 'pl', {
      month: 'long',
      year: 'numeric',
    });

    const shiftCalendarMonth = (delta) => {
      const current = monthStart();
      current.setMonth(current.getMonth() + delta);
      state.calendarMonth = dateToIso(current);
    };

    const compareIso = (a, b) => {
      if (!a || !b) return 0;
      return a.localeCompare(b);
    };

    const rangeBounds = () => {
      const start = state.calendarDragging ? state.calendarDragStart : state.dates.arrival;
      const end = state.calendarDragging ? state.calendarHover : state.dates.departure;
      if (!start && !end) return { start: '', end: '' };
      if (start && end && compareIso(end, start) < 0) return { start: end, end: start };
      return { start: start || end, end: end || start };
    };

    const calendarDays = () => {
      const start = monthStart();
      const firstWeekday = (start.getDay() + 6) % 7;
      const daysInMonth = new Date(start.getFullYear(), start.getMonth() + 1, 0).getDate();
      const cells = [];
      for (let i = 0; i < firstWeekday; i += 1) cells.push(null);
      for (let day = 1; day <= daysInMonth; day += 1) {
        const date = new Date(start.getFullYear(), start.getMonth(), day, 12);
        cells.push(dateToIso(date));
      }
      while (cells.length % 7) cells.push(null);
      return cells;
    };

    const stayAdviceText = () => {
      const count = nights();
      const advice = ui.stayAdvice || {};
      if (!count) return advice.none || '';
      if (count === 1) return advice.one || '';
      if (count === 2) return advice.two || '';
      if (count === 3) return advice.three || '';
      if (count === 4) return advice.four || '';
      return advice.five || '';
    };

    const tripCtas = () => {
      const count = nights();
      if (!count) {
        return [
          { href: config.links?.planner || '/planer-pobytu', label: config.lang === 'pl' ? 'Dodaj plan pobytu' : 'Add a stay plan' },
