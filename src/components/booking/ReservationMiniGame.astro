  align-items: start;
  gap: 10px;
}

.reservation-success-row > i {
  width: 34px;
  height: 34px;
  display: grid;
  place-items: center;
  border-radius: 12px;
  color: #8fe0b4;
  background: rgba(60,179,113,.11);
}

.reservation-success-row > i svg {
  width: 18px;
  height: 18px;
}

.reservation-success-modal__card dt {
  color: rgba(245,255,248,.58);
  font-size: .74rem;
  font-weight: 950;
  text-transform: uppercase;
}

.reservation-success-modal__card dd {
  margin: 3px 0 0;
  color: #fff;
}

.reservation-success-modal__note {
  padding: 13px 14px;
  border: 1px solid rgba(242,192,120,.22);
  border-radius: 18px;
  background: rgba(242,192,120,.10);
}

.reservation-success-modal__note--deposit {
  margin-top: 10px;
}

.reservation-success-modal__copy {
  width: 100%;
  margin-top: 14px;
}

.reservation-success-modal__copy svg {
  width: 18px;
  height: 18px;
}

.reservation-copy-status {
  margin-top: 10px !important;
  padding: 10px 12px;
  border: 1px solid rgba(143,224,180,.22);
  border-radius: 14px;
  color: #dffff0 !important;
  background: rgba(60,179,113,.10);
  font-weight: 850;
}

.reservation-copy-helper {
  width: 100%;
  margin-top: 10px;
  border: 1px solid rgba(143,224,180,.24);
  border-radius: 14px;
  color: #f5fff8;
  background: rgba(6,18,13,.78);
  padding: 12px;
}

.reservation-tour-options {
  display: grid;
  gap: 14px;
  margin-top: 20px;
  padding: clamp(16px, 2.4vw, 22px);
  border: 1px solid rgba(143,224,180,.18);
  border-radius: 24px;
  background: rgba(60,179,113,.08);
}

.reservation-tour-options > div:first-child strong {
  color: #fff;
  font-size: 1.05rem;
}

.reservation-tour-options > div:first-child p {
  margin: 4px 0 0;
  color: rgba(245,255,248,.64);
}

.reservation-tour-options__grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 9px;
}

.reservation-tour-options__grid label {
  display: flex;
  align-items: center;
  gap: 9px;
  min-height: 46px;
  padding: 10px 12px;
  border: 1px solid rgba(255,255,255,.11);
  border-radius: 15px;
  color: rgba(245,255,248,.86);
  background: rgba(255,255,255,.055);
  cursor: pointer;
}

.reservation-tour-options__grid input {
  accent-color: #3CB371;
}

.reservation-success-modal__actions {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  margin-top: 18px;
}

@media (max-width: 1080px) {
  .reservation-mini__layout {
    grid-template-columns: 1fr;
  }

  .reservation-summary {
    position: static;
  }
}

@media (max-width: 780px) {
  .reservation-mini {
    min-height: auto;
    padding: 82px 14px 96px;
  }

  .reservation-mini__start {
    padding: 28px 18px;
  }

  .reservation-mini h1 {
    font-size: clamp(2rem, 10vw, 3.35rem);
    line-height: 1.04;
  }

  .reservation-mini__choices,
  .reservation-form-grid,
  .reservation-card-grid {
    grid-template-columns: 1fr;
  }

  .reservation-before-arrival > div {
    grid-template-columns: 1fr;
  }

  .reservation-mini__top {
    display: grid;
  }

  .reservation-mini__top-actions {
    justify-content: stretch;
  }

  .reservation-progress__desktop {
    display: none;
  }

  .reservation-progress__mobile {
    display: block;
  }

  .stay-choice-card,
  .reservation-choice-card {
    min-height: 220px;
  }

  .reservation-item-card {
    grid-template-columns: 50px minmax(0, 1fr);
  }

  .reservation-item-card .reservation-stepper {
    grid-column: 1 / -1;
    justify-self: stretch;
    grid-template-columns: 1fr 1fr 1fr;
  }

  .reservation-stepper button,
  .reservation-stepper strong {
    width: 100%;
    min-height: 48px;
  }

  .reservation-nav {
    display: grid;
    grid-template-columns: 1fr;
  }

  .reservation-presets__grid,
  .reservation-success-modal__card dl,
  .reservation-date-summary dl,
  .reservation-tour-options__grid,
  .reservation-success-modal__delivery {
    grid-template-columns: 1fr;
  }

  .reservation-feedback__grid {
    grid-template-columns: 1fr;
  }

  .reservation-feedback__question,
  .reservation-feedback__question--wide {
    grid-column: 1;
  }

  .reservation-calendar__head,
  .reservation-date-summary > div:first-child,
  .reservation-stay-advice,
  .reservation-smart-suggestions article {
    grid-template-columns: 1fr;
  }

  .reservation-calendar__nav {
    width: 100%;
    min-width: 0;
  }

  .reservation-calendar__weekdays,
  .reservation-calendar__grid {
    gap: 5px;
  }

  .reservation-calendar__empty,
  .reservation-calendar__day {
    min-height: 42px;
    border-radius: 13px;
  }

  .reservation-stay-advice__actions {
    display: grid;
    grid-template-columns: 1fr;
  }

  .reservation-summer-block {
    grid-template-columns: 1fr;
  }

  .reservation-summer-block__actions {
    display: grid;
    grid-template-columns: 1fr;
  }

  .reservation-help__panel {
    width: 100%;
    min-height: auto;
    align-self: end;
    border-radius: 28px 28px 0 0;
    max-height: calc(100dvh - 24px);
  }

  .reservation-btn {
    width: 100%;
  }

  .reservation-mini__note {
    border-radius: 20px;
  }
}

@media (max-width: 430px) {
  .reservation-mini {
    padding-inline: 10px;
  }

  .reservation-mini__start {
    padding: 26px 14px;
    border-radius: 24px;
  }

  .reservation-mini h1 {
    font-size: clamp(1.62rem, 8.4vw, 2.05rem);
    overflow-wrap: anywhere;
    text-wrap: balance;
  }

  .reservation-choice-card,
  .stay-choice-card {
    padding: 20px 18px;
    border-radius: 24px;
  }

  .stay-choice-card strong,
  .reservation-choice-card strong {
    font-size: clamp(1.42rem, 7vw, 1.8rem);
  }

  .reservation-choice-card__chips i {
    min-height: 28px;
    padding-inline: 9px;
    font-size: .72rem;
  }
}

