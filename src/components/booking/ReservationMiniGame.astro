          <dl>
            <div><dt>${esc(t.fields.arrival)}</dt><dd>${esc(state.dates.arrival || '-')}</dd></div>
            <div><dt>${esc(t.fields.departure)}</dt><dd>${esc(state.dates.departure || '-')}</dd></div>
            <div><dt>${esc(t.fields.nights)}</dt><dd>${nights()}</dd></div>
            <div><dt>${esc(config.lang === 'pl' ? 'Godziny' : 'Hours')}</dt><dd>${esc(stayHours)}</dd></div>
          </dl>
          <section class="reservation-stay-advice">
            <i aria-hidden="true">${detailIcon('map')}</i>
            <span>
              <strong>${esc(labels.adviceTitle || 'Stay suggestion')}</strong>
              <p>${esc(advice)}</p>
            </span>
          </section>
          <div class="reservation-stay-advice__actions">
            <a href="${esc(config.links?.attractions || '/atrakcje')}" class="reservation-mini-link">${esc(labels.ctaAttractions || 'See attractions')}</a>
            <button type="button" class="reservation-mini-link" data-ask-campy-plan>${esc(labels.ctaCampy || 'Ask CAMPY')}</button>
            ${tripCtaTemplate(true)}
          </div>
        </div>
      `;
    };

    const datesStep = () => `
      <section class="reservation-step-card">
