                  <p>${esc(labels.contactLead)}</p>
                </div>
              </header>
              <div class="reservation-form-grid">
                <label class="reservation-field ${fieldInvalid('name') ? 'is-invalid' : ''}" data-field-key="name">
                  ${fieldLabel({ icon: 'name', label: t.fields.name, badge: 'required' })}
                  <input type="text" data-field="details.name" value="${esc(state.details.name)}" placeholder="${esc(detailText.field.name.placeholder)}" autocomplete="name" aria-invalid="${fieldInvalid('name') ? 'true' : 'false'}" />
                  <small>${esc(detailText.field.name.helper)}</small>
                  ${fieldError('name')}
                </label>
                <label class="reservation-field ${contactInvalid() ? 'is-invalid' : ''}" data-field-key="email">
                  ${fieldLabel({ icon: 'email', label: t.fields.email, badge: 'conditional' })}
                  <input type="email" data-field="details.email" value="${esc(state.details.email)}" placeholder="${esc(detailText.field.email.placeholder)}" autocomplete="email" aria-invalid="${contactInvalid() ? 'true' : 'false'}" />
                  <small>${esc(detailText.field.email.helper)}</small>
                  ${contactInvalid() ? fieldError('contact') : ''}
                </label>
                <label class="reservation-field ${contactInvalid() ? 'is-invalid' : ''}" data-field-key="phone">
                  ${fieldLabel({ icon: 'phone', label: t.fields.phone, badge: 'conditional' })}
                  <input type="tel" data-field="details.phone" value="${esc(state.details.phone)}" placeholder="${esc(detailText.field.phone.placeholder)}" autocomplete="tel" aria-invalid="${contactInvalid() ? 'true' : 'false'}" />
                  <small>${esc(detailText.field.phone.helper)}</small>
                </label>
                <div class="reservation-field">
                  ${fieldLabel({ icon: 'language', label: t.fields.language, badge: 'required' })}
                  <div class="reservation-pills">
                    ${['PL','EN','DE','IT','FR','ES','NL','CS','SK','SV'].map((language) => `
                      <button type="button" data-language="${language}" class="${state.details.language === language ? 'is-active' : ''}">${language}</button>
                    `).join('')}
                  </div>
                  <small>${esc(detailText.field.language.helper)}</small>
                </div>
                ${countryTemplate()}
              </div>
            </section>
            <section class="reservation-details-section">
              <header class="reservation-details-section__head">
                <span aria-hidden="true">${detailIcon('stay')}</span>
                <div>
                  <strong>${esc(labels.stayTitle)}</strong>
                  <p>${esc(labels.stayLead)}</p>
                </div>
              </header>
              <div class="reservation-info-grid reservation-info-grid--docs">
                <p><strong>${esc(detailText.registration.title)}</strong></p>
                <p>${esc(detailText.registration.document)}</p>
                <p>${esc(detailText.registration.plate)}</p>
                <p class="is-warm">${esc(detailText.registration.trailer)}</p>
                <p class="is-warm"><strong>${esc(cityCampingNotice())}</strong></p>
                ${highSeasonCampingInfo() ? `<p class="is-warm"><strong>${esc(highSeasonCampingNotice())}</strong></p>` : ''}
                ${bungalowPersonalItemsNotice() ? `<p class="is-warm"><strong>${esc(bungalowItemsNotice())}</strong></p>` : ''}
              </div>
              <div class="reservation-form-grid">
                <label class="reservation-field">
                  ${fieldLabel({ icon: 'late', label: config.lang === 'pl' ? 'Orientacyjna godzina przyjazdu' : 'Estimated arrival time', badge: 'optional' })}
                  <select data-field="details.arrivalTime">
                    ${[
                      ['przed 12:00', 'przed 12:00'],
                      ['12:00–15:00', '12:00–15:00'],
                      ['15:00–18:00', '15:00–18:00'],
                      ['18:00–21:00', '18:00–21:00'],
                      ['po 21:00 / skontaktuj się z recepcją', 'po 21:00 / skontaktuj się z recepcją'],
                      ['jeszcze nie wiem', 'jeszcze nie wiem'],
                    ].map(([value,label]) => `<option value="${esc(value)}" ${state.details.arrivalTime === value ? 'selected' : ''}>${esc(label)}</option>`).join('')}
                  </select>
                  <small>${esc(config.lang === 'pl' ? 'Godzina jest orientacyjna i pomaga recepcji przygotować przyjazd.' : 'The time is indicative and helps reception prepare your arrival.')}</small>
                  ${state.details.arrivalTime.startsWith('po 21:00') ? `<small class="reservation-field-warning">${esc(config.lang === 'pl' ? 'Recepcja i brama mają określone godziny pracy. Przy późnym przyjeździe skontaktuj się z recepcją.' : 'Reception and gate have set opening hours. Contact reception before a late arrival.')}</small>` : ''}
                </label>
                <label class="reservation-field">
                  ${fieldLabel({ icon: 'plate', label: t.fields.plate, badge: 'optional' })}
                  <input type="text" data-field="details.plate" value="${esc(state.details.plate)}" placeholder="${esc(vehiclePlatePlaceholder())}" autocomplete="off" />
                  <small>${esc(detailText.field.plate.helper)}</small>
                  <small data-plate-helper>${esc(vehiclePlateHelper())}</small>
                </label>
                ${vehicleDetailsBlock()}
                <label class="reservation-field reservation-field--wide">
                  ${fieldLabel({ icon: 'message', label: t.fields.message, badge: 'optional' })}
                  <textarea data-field="details.message" rows="4" placeholder="${esc(detailText.field.message.placeholder)}">${esc(state.details.message)}</textarea>
                  <small>${esc(detailText.field.message.helper)}</small>
                </label>
              </div>
            </section>
            <section class="reservation-details-section">
              <header class="reservation-details-section__head">
                <span aria-hidden="true">${detailIcon('consent')}</span>
                <div>
                  <strong>${esc(labels.consentTitle)}</strong>
                  <p>${esc(labels.consentLead)}</p>
                </div>
              </header>
              <div class="reservation-consents">
                ${optionRow({ check: 'specialNeeds', icon: 'accessibility', label: t.fields.specialNeeds, helper: detailText.field.specialNeeds.helper })}
                <label class="reservation-field reservation-field--wide reservation-reveal-field" data-special-needs-field ${state.details.specialNeeds ? '' : 'hidden'}>
                    ${fieldLabel({ icon: 'accessibility', label: t.fields.specialNeedsText, badge: 'optional' })}
                    <textarea data-field="details.specialNeedsText" rows="3" placeholder="${esc(t.fields.specialNeedsText)}">${esc(state.details.specialNeedsText)}</textarea>
                </label>
                ${optionRow({ check: 'lateCheckout', icon: 'late', label: t.fields.lateCheckout, helper: detailText.field.lateCheckout.helper })}
                <div class="reservation-late-panel reservation-reveal-field" data-late-checkout-panel ${state.details.lateCheckout ? '' : 'hidden'}>
                    <label class="reservation-field">
                      ${fieldLabel({ icon: 'late', label: t.fields.lateTime, badge: 'optional' })}
                      <select data-field="details.lateTime">
                        ${['13:00','14:00','15:00','16:00','17:00'].map((time) => `<option value="${time}" ${state.details.lateTime === time ? 'selected' : ''}>${time}</option>`).join('')}
                      </select>
                    </label>
                    <p>${esc(t.info.lateCheckout)}</p>
                  </div>
              </div>
            </section>
            ${feedbackTemplate()}
            <section class="reservation-details-section reservation-details-section--required">
              <header class="reservation-details-section__head">
                <span aria-hidden="true">${detailIcon('privacy')}</span>
                <div>
                  <strong>${esc(detailText.consentSectionTitle)}</strong>
                  <p>${esc(detailText.consentSectionLead)}</p>
                </div>
              </header>
              <div class="reservation-consents">
                ${optionRow({ check: 'quiet', icon: 'quiet', label: t.fields.quiet, helper: labels.quietHelper, required: true })}
                ${optionRow({ check: 'consent', icon: 'contactConsent', label: t.fields.consent, helper: labels.consentHelper, required: true })}
                ${optionRow({
                  check: 'privacy',
                  icon: 'privacy',
                  label: formText.privacy,
                  labelHtml: `${esc(formText.privacy)} <a class="reservation-privacy-link" href="/polityka-prywatnosci" target="_blank" rel="noopener noreferrer">${esc(detailText.privacyLink)}</a>`,
                  helper: formText.privacyHelper,
                  required: true,
                })}
              </div>
            </section>
          </div>
        </section>
      `;
    };

    const summaryContent = (full = false) => {
      const selected = selectedServices();
      const hasCostData = selected.length > 0;
      const depositNote = state.mode === 'bungalow' ? ui.summary.depositBungalow : state.mode === 'combined' ? ui.summary.depositCombined : '';
      const statusText = missingItems().length ? detailText.summaryStatusMissing : detailText.summaryStatusReady;
      const dateText = state.dates.arrival || state.dates.departure
        ? `${state.dates.arrival || '-'} - ${state.dates.departure || '-'} (${nights()} n.)`
        : '';
      if (!hasCostData) {
        return `
          <div class="reservation-summary__status">
            <i aria-hidden="true">${detailIcon(missingItems().length ? 'status' : 'success')}</i>
            <span>
              <em>${esc(ui.summary.statusLabel)}</em>
              <strong>${esc(statusText)}</strong>
              <small>${esc(detailText.statusConfirmedByReception)}</small>
            </span>
          </div>
          <h2>${esc(t.summary.title)}</h2>
          <b class="reservation-summary__badge">${esc(ui.summary.badge)}</b>
          ${summerBlockTemplate(true)}
          <p>${esc(t.summary.empty)}</p>
          <dl>
            ${summaryRow('stay', t.summary.stay, modeTitle())}
            ${summaryRow('calendar', t.summary.dates, dateText)}
            ${summaryRow('late', config.lang === 'pl' ? 'Orientacyjna godzina przyjazdu' : 'Estimated arrival time', arrivalTimeLabel())}
            ${summaryRow('guests', t.summary.guests, guestsText())}
            ${state.tours.length ? summaryRow('map', config.lang === 'pl' ? 'Wycieczki' : 'Trips', toursText()) : ''}
            ${summaryRow('language', t.summary.language, state.details.language)}
            ${state.details.countryCode ? summaryRow('country', t.summary.country, `${state.details.countryName} (${state.details.countryCode})`) : ''}
            ${state.details.plate ? summaryRow('plate', t.fields.plate, state.details.plate) : ''}
            ${vehicleDetailsText() ? summaryRow('plate', vehicleLabels().title, vehicleDetailsText()) : ''}
            ${summaryRow('info', detailText.registration.title, `${detailText.registration.document} ${detailText.registration.trailer}`)}
            ${summaryRow('info', config.lang === 'pl' ? 'Dobrze wiedzieć' : 'Good to know', cityCampingNotice())}
            ${highSeasonCampingInfo() ? summaryRow('status', config.lang === 'pl' ? 'Lipiec/sierpień' : 'July/August', highSeasonCampingNotice()) : ''}
            ${bungalowPersonalItemsNotice() ? summaryRow('info', config.lang === 'pl' ? 'Domki — co zabrać' : 'Bungalows — what to bring', bungalowItemsNotice()) : ''}
            ${summaryRow('privacy', detailText.consentSectionTitle, consentsText())}
          </dl>
          ${missingListTemplate(true)}
          ${tripCtaTemplate(true)}
          <small>${esc(t.summary.confirm)}</small>
          ${depositNote ? `<p class="reservation-summary__deposit">${esc(depositNote)}</p>` : ''}
        `;
      }
      return `
        <div class="reservation-summary__status">
          <i aria-hidden="true">${detailIcon(missingItems().length ? 'status' : 'success')}</i>
          <span>
            <em>${esc(ui.summary.statusLabel)}</em>
            <strong>${esc(statusText)}</strong>
            <small>${esc(detailText.statusConfirmedByReception)}</small>
          </span>
        </div>
        <h2>${esc(t.summary.title)}</h2>
        <b class="reservation-summary__badge">${esc(ui.summary.badge)}</b>
        ${summerBlockTemplate(true)}
        <dl>
          ${summaryRow('stay', t.summary.stay, modeTitle())}
          ${summaryRow('calendar', t.summary.dates, dateText)}
          ${summaryRow('late', config.lang === 'pl' ? 'Orientacyjna godzina przyjazdu' : 'Estimated arrival time', arrivalTimeLabel())}
          ${summaryRow('guests', t.summary.guests, guestsText())}
          ${summaryRow('services', t.summary.services, servicesText())}
          ${state.tours.length ? summaryRow('map', config.lang === 'pl' ? 'Wycieczki' : 'Trips', toursText()) : ''}
          ${state.details.countryCode ? summaryRow('country', t.summary.country, `${state.details.countryName} (${state.details.countryCode})`) : ''}
          ${summaryRow('language', t.summary.language, state.details.language)}
          ${state.details.plate ? summaryRow('plate', t.fields.plate, state.details.plate) : ''}
          ${vehicleDetailsText() ? summaryRow('plate', vehicleLabels().title, vehicleDetailsText()) : ''}
          ${summaryRow('info', detailText.registration.title, `${detailText.registration.document} ${detailText.registration.trailer}`)}
          ${summaryRow('info', config.lang === 'pl' ? 'Dobrze wiedzieć' : 'Good to know', cityCampingNotice())}
          ${highSeasonCampingInfo() ? summaryRow('status', config.lang === 'pl' ? 'Lipiec/sierpień' : 'July/August', highSeasonCampingNotice()) : ''}
          ${bungalowPersonalItemsNotice() ? summaryRow('info', config.lang === 'pl' ? 'Domki — co zabrać' : 'Bungalows — what to bring', bungalowItemsNotice()) : ''}
          ${state.details.specialNeeds ? summaryRow('accessibility', t.summary.specialNeeds, yesLabel()) : ''}
          ${state.details.lateCheckout ? summaryRow('late', t.summary.lateCheckout, state.details.lateTime) : ''}
          ${summaryRow('privacy', detailText.consentSectionTitle, consentsText())}
        </dl>
        <div class="reservation-summary__total">
          <span>${esc(t.summary.total)}</span>
          <strong>${fmt(estimatedTotal())}</strong>
          <em>${esc(currencyEstimateText(estimatedTotal()))}</em>
        </div>
        <p class="reservation-currency-disclaimer">${esc(currencyDisclaimer())}</p>
        ${tripCtaTemplate(true)}
        ${missingListTemplate(true)}
        <small>${esc(t.summary.confirm)}</small>
        ${depositNote ? `<p class="reservation-summary__deposit">${esc(depositNote)}</p>` : ''}
        ${state.success ? `<p class="reservation-success">${esc(t.summary.success)}</p>` : ''}
        ${full ? `<textarea name="reservationPayload" hidden>${esc(JSON.stringify(payload(), null, 2))}</textarea>` : ''}
      `;
    };

    const summaryTemplate = () => `
      <aside class="reservation-summary ${state.summaryPulse ? 'is-pulsing' : ''}" aria-live="polite">
        ${summaryContent(state.step === 5)}
      </aside>
    `;

    const finalStep = () => `
      <section class="reservation-step-card">
        <p class="reservation-step-card__eyebrow">${esc(stepTitles[4])}</p>
        <h2>${esc(stepTitles[4])}</h2>
        <p>${esc(t.stepLead.summary)}</p>
        <div class="reservation-final-summary">${summaryContent(true)}</div>
      </section>
    `;

    const activeStepTemplate = () => {
      if (state.step === 1) return datesStep();
      if (state.step === 2) return guestsStep();
      if (state.step === 3) return servicesStep();
      if (state.step === 4) return detailsStep();
      if (state.step === 5) return finalStep();
      return startTemplate();
    };

    const navTemplate = () => `
      <div class="reservation-nav" data-reservation-nav>
        <button class="reservation-btn reservation-btn--ghost" type="button" data-back ${state.step <= 1 ? 'disabled' : ''}>${esc(t.actions.back)}</button>
        ${state.step < 5
          ? `<button class="reservation-btn reservation-btn--primary" type="button" data-next>${esc(t.actions.next)}</button>`
          : `<button class="reservation-btn reservation-btn--primary" type="button" data-submit ${state.submitting || summerCampingBlocked() ? 'disabled' : ''} title="${esc(summerCampingBlocked() ? (config.summerBlock?.short || highSeasonCampingNotice()) : '')}">${esc(state.submitting ? (ui.sending || 'Sending...') : t.actions.send)}</button>`
        }
      </div>
    `;

    const helpPanelTemplate = () => `
      <div class="reservation-help" role="dialog" aria-modal="true" aria-label="${esc(ui.help.title)}">
        <button class="reservation-help__scrim" type="button" data-help-close aria-label="${esc(ui.help.close)}"></button>
        <aside class="reservation-help__panel">
          <div class="reservation-help__head">
            <span aria-hidden="true">${detailIcon('help')}</span>
            <div>
              <p class="reservation-mini__kicker">${esc(ui.help.open)}</p>
              <h2>${esc(ui.help.title)}</h2>
            </div>
            <button type="button" data-help-close aria-label="${esc(ui.help.close)}">x</button>
          </div>
          <div class="reservation-help__sections">
            ${ui.help.sections.map(([title, text], index) => `
              <article>
                <i aria-hidden="true">${[detailIcon('stay'), detailIcon('deposit'), detailIcon('success'), detailIcon('late'), detailIcon('quiet'), detailIcon('country')][index] ?? detailIcon('help')}</i>
                <strong>${esc(title)}</strong>
                <p>${esc(text)}</p>
              </article>
            `).join('')}
          </div>
          <div class="reservation-help__short">
            <strong>${esc(ui.help.shortTitle)}</strong>
            <button type="button" class="reservation-btn reservation-btn--primary" data-simple-start>${esc(ui.help.shortCta)}</button>
          </div>
        </aside>
      </div>
    `;

    const successModalTemplate = () => {
      const copy = config.clientSuccess;
      const isSaved = Boolean(state.inquirySaved);
      const modalTitle = isSaved ? copy.title : copy.errorTitle;
      return `
        <div class="reservation-success-modal" role="dialog" aria-modal="true" aria-label="${esc(modalTitle)}" data-submit-mode="${isSaved ? 'success' : 'error'}">
          <div class="reservation-success-modal__card">
            <button class="reservation-success-modal__close" type="button" data-success-close aria-label="${esc(ui.help.close)}">×</button>
            <span class="reservation-success-modal__mark" aria-hidden="true">${detailIcon(isSaved ? 'success' : 'status')}</span>
            <span class="reservation-success-modal__badge">${esc(isSaved ? copy.badge : copy.errorTitle)}</span>
            <h2>${esc(modalTitle)}</h2>
            <p>${esc(isSaved ? copy.text : copy.errorText)}</p>
            <div class="reservation-success-modal__actions">
              <a class="reservation-btn reservation-btn--ghost" href="/">${esc(copy.home)}</a>
              <a class="reservation-btn reservation-btn--ghost" href="${esc(config.links.directions)}">${esc(copy.directions)}</a>
              <button class="reservation-btn reservation-btn--primary" type="button" data-success-campy>${esc(copy.campy)}</button>
              <a class="reservation-btn reservation-btn--ghost" href="${esc(config.links.attractions)}">${esc(copy.attractions)}</a>
            </div>
          </div>
        </div>
      `;
    };

    const appTemplate = () => `
      <div class="reservation-mini__app">
        <div class="reservation-mini__top">
          <div>
            <p class="reservation-mini__kicker">${esc(t.kicker)}</p>
            <h1>${esc(t.title)}</h1>
            <p>${esc(modeTitle())}: ${esc(modeDescription())}</p>
          </div>
          <div class="reservation-mini__top-actions">
            <button type="button" class="reservation-btn reservation-btn--ghost" data-help-open>${esc(ui.help.open)}</button>
            <button type="button" class="reservation-btn reservation-btn--ghost" data-change-mode>${esc(t.actions.change)}</button>
          </div>
        </div>
        ${progressTemplate()}
        <div class="reservation-mini__layout">
          <div>
            <div class="reservation-mini__toast" aria-live="polite">${esc(state.toast || stepHints[state.step - 1])}</div>
            <div data-reservation-active-step>${activeStepTemplate()}</div>
            ${navTemplate()}
          </div>
          ${summaryTemplate()}
        </div>
        ${state.helpOpen ? helpPanelTemplate() : ''}
        ${state.success ? successModalTemplate() : ''}
      </div>
    `;

    const servicePayload = () => selectedServices().map((item) => ({
      id: item.id,
      scope: item.scope,
      label: item.label,
      qty: item.qty,
      price: item.price,
    }));

    const payload = () => {
      const services = servicePayload();
      const countryLabel = state.details.countryName
        ? `${state.details.countryName} (${state.details.countryCode})`
        : state.details.countrySearch;
      const people = state.mode === 'combined'
        ? {
            adults: Number(state.guests.bungalowGuests || 0) + Number(state.guests.campingGuests || 0),
            children: Number(state.guests.children || 0),
            toddlers: Number(state.guests.toddlers || 0),
          }
        : {
            adults: Number(state.guests.adults || 0),
            children: Number(state.guests.children || 0),
            toddlers: Number(state.guests.toddlers || 0),
          };
      const lateCheckout = state.details.lateCheckout ? state.details.lateTime : '';
      const specialNeeds = state.details.specialNeeds ? state.details.specialNeedsText : '';
      const vehicleDetailsEnabled = shouldShowVehicleDetails();

      return {
        fullName: state.details.name,
        email: state.details.email,
        phone: state.details.phone,
        country: countryLabel,
        contactLanguage: state.details.language,
        arrivalIso: state.dates.arrival,
        departureIso: state.dates.departure,
        nights: nights(),
        stayType: modeTitle(),
        stayTypeId: state.mode,
        stayCategory: state.mode,
        selectedStayMode: state.mode,
        people,
        tours: [...state.tours],
        feedback: {
          rating: Number(state.feedback.rating || 0),
          liked: [...state.feedback.liked],
          improve: state.feedback.improve.trim(),
          easyInfo: state.feedback.easyInfo,
          easyForm: state.feedback.easyForm,
        },
        arrivalTime: arrivalTimeLabel(),
        addons: services.map((item) => `${item.label} x ${item.qty}`),
        message: [
          state.details.message,
          state.details.plate ? `Numer rejestracyjny: ${state.details.plate}` : '',
          vehicleDetailsText() ? `Dane pojazdu: ${vehicleDetailsText()}` : '',
          specialNeeds ? `Specjalne potrzeby: ${specialNeeds}` : '',
          lateCheckout ? `Późniejszy wyjazd: ${lateCheckout}` : '',
        ].filter(Boolean).join('\n\n'),
        summerNotice: touchesSummer(),
        highSeasonCampingInfo: highSeasonCampingInfo(),
        summerCampingBlocked: summerCampingBlocked(),
        bungalowPersonalItemsNotice: bungalowPersonalItemsNotice(),
        quietConsent: state.details.quiet,
        consent: state.details.consent,
        privacyConsent: state.details.privacy,
        website: '',
        source: 'website',
        locale: config.lang,
        calculatorSummary: {
          total: selectedServices().length ? fmt(estimatedTotal()) : '',
          pricePerNight: selectedServices().length ? fmt(perNightTotal()) : '',
          currencyEstimate: selectedServices().length ? currencyEstimateText(estimatedTotal()) : '',
          currencyDisclaimer: selectedServices().length ? currencyDisclaimer() : '',
          season: highSeason() ? 'high' : 'low',
          breakdown: services.map((item) => `${item.label} x ${item.qty}: ${fmt(item.price * item.qty)} / noc`),
        },
        stayMode: state.mode,
        services,
        estimatedTotal: selectedServices().length ? fmt(estimatedTotal()) : '',
        currencyEstimate: selectedServices().length ? currencyEstimateText(estimatedTotal()) : '',
        currencyDisclaimer: selectedServices().length ? currencyDisclaimer() : '',
        vehiclePlate: state.details.plate,
        vehicleDetails: vehicleDetailsEnabled ? {
          model: state.details.vehicleModel,
          length: state.details.vehicleLength,
          width: state.details.vehicleWidth,
          height: state.details.vehicleHeight,
          weight: state.details.vehicleWeight,
          large: state.details.vehicleLarge,
          asphaltNeeded: state.details.vehicleAsphalt,
          notes: state.details.vehicleNotes,
          summary: vehicleDetailsText(),
        } : undefined,
        specialNeeds,
        lateCheckout,
        originalMessage: state.details.message,
        translatedSummaryPl: '',
      };
    };

    const updateToastDom = () => {
      const toast = mount.querySelector('.reservation-mini__toast');
      if (toast instanceof HTMLElement) {
        toast.textContent = state.toast || stepHints[state.step - 1] || '';
      }
    };

    const updateSummaryDom = () => {
      mount.querySelectorAll('.reservation-summary').forEach((summary) => {
        if (!(summary instanceof HTMLElement)) return;
        summary.classList.toggle('is-pulsing', Boolean(state.summaryPulse));
        summary.innerHTML = summaryContent(state.step === 5);
      });
      const finalSummary = mount.querySelector('.reservation-final-summary');
      if (finalSummary instanceof HTMLElement) {
        finalSummary.innerHTML = summaryContent(true);
      }
    };

    const updateStepperDom = () => {
      mount.querySelectorAll('[data-guest-key]').forEach((stepper) => {
        if (!(stepper instanceof HTMLElement)) return;
        const key = stepper.dataset.guestKey;
        const current = Number(state.guests[key] || 0);
        const value = stepper.querySelector('[data-stepper-value]');
        if (value) value.textContent = String(current);
        const minus = stepper.querySelector('[data-stepper-minus]');
        if (minus instanceof HTMLButtonElement) minus.disabled = current <= 0;
      });
      mount.querySelectorAll('[data-service-scope][data-service-id]').forEach((stepper) => {
        if (!(stepper instanceof HTMLElement)) return;
        const scope = stepper.dataset.serviceScope;
        const id = stepper.dataset.serviceId;
        const current = getQty(scope, id);
        const value = stepper.querySelector('[data-stepper-value]');
        if (value) value.textContent = String(current);
        const minus = stepper.querySelector('[data-stepper-minus]');
        if (minus instanceof HTMLButtonElement) minus.disabled = current <= 0;
        const item = visibleServiceGroups().find((group) => group.scope === scope)?.items.find((service) => service.id === id);
        const subtotal = stepper.closest('.reservation-item-card')?.querySelector('[data-service-subtotal]');
        if (subtotal instanceof HTMLElement && item) {
          subtotal.textContent = `${fmt(servicePrice(item) * current)} / noc`;
          subtotal.hidden = current <= 0;
        }
      });
    };

    const updateLanguageDom = () => {
      mount.querySelectorAll('[data-language]').forEach((button) => {
        if (!(button instanceof HTMLElement)) return;
        button.classList.toggle('is-active', button.dataset.language === state.details.language);
      });
    };

    const updateConditionalFieldsDom = () => {
      const special = mount.querySelector('[data-special-needs-field]');
      if (special instanceof HTMLElement) special.hidden = !state.details.specialNeeds;
      const late = mount.querySelector('[data-late-checkout-panel]');
      if (late instanceof HTMLElement) late.hidden = !state.details.lateCheckout;
    };

    const updatePlateHelperDom = () => {
      const helper = mount.querySelector('[data-plate-helper]');
      if (helper instanceof HTMLElement) helper.textContent = vehiclePlateHelper();
    };

    const updateConsentInvalidDom = () => {
      ['quiet', 'consent', 'privacy'].forEach((key) => {
        const input = mount.querySelector(`[data-check="${key}"]`);
        const row = input?.closest('.reservation-option-row');
        if (row instanceof HTMLElement) {
          row.classList.toggle('is-invalid', Boolean(state.submitAttempted && !state.details[key]));
        }
      });
    };

    const updateValidationDom = () => {
      const toggleField = (key, invalid) => {
        mount.querySelectorAll(`[data-field-key="${key}"]`).forEach((field) => {
          if (!(field instanceof HTMLElement)) return;
          field.classList.toggle('is-invalid', Boolean(invalid));
          field.querySelectorAll('input, textarea, select').forEach((input) => {
            if (input instanceof HTMLElement) input.setAttribute('aria-invalid', invalid ? 'true' : 'false');
          });
        });
      };
      toggleField('name', fieldInvalid('name'));
      toggleField('email', contactInvalid());
      toggleField('phone', contactInvalid());
      toggleField('country', fieldInvalid('country'));
      mount.querySelectorAll('[data-missing-card]').forEach((card) => {
        if (card instanceof HTMLElement) {
          card.outerHTML = missingListTemplate(card.closest('.reservation-summary') !== null);
        }
      });
    };

    const updateCountryDom = () => {
      const input = mount.querySelector('[data-country-search]');
      const hidden = mount.querySelector('[data-country-code]');
      const hint = mount.querySelector('[data-country-hint]');
      const list = mount.querySelector('[data-country-list]');
      const resultsRoot = mount.querySelector('[data-country-results]');
      if (!(input instanceof HTMLInputElement) || !(hidden instanceof HTMLInputElement)) return;
      hidden.value = state.details.countryCode;
      const hasQuery = normalize(state.details.countrySearch).length > 0;
      const showHint = state.countryOpen && !hasQuery && !state.details.countryCode;
      const showResults = state.countryOpen && state.countryDirty && hasQuery;
      input.setAttribute('aria-expanded', showResults ? 'true' : 'false');
      if (hint instanceof HTMLElement) hint.hidden = !showHint;
      if (list instanceof HTMLElement) list.hidden = !showResults;
      if (resultsRoot instanceof HTMLElement) {
        const matches = countryMatches();
        resultsRoot.innerHTML = matches.length
          ? matches.map((country, index) => `
              <button type="button" data-country-pick="${esc(country.code)}" role="option" class="${index === state.countryActiveIndex ? 'is-active' : ''}">
                <span class="reservation-country__flag" aria-hidden="true"><i class="${esc(country.flagClass)}"></i><b>${detailIcon('country')}</b></span>
                <span>${esc(country.name)}</span>
                <small>${esc(country.code)}</small>
              </button>
            `).join('')
          : `<em>${esc(ui.noCountries)}</em>`;
      }
    };

    const refreshControlDom = () => {
      updateStepperDom();
      updateLanguageDom();
      updateConditionalFieldsDom();
      updatePlateHelperDom();
      updateConsentInvalidDom();
      updateCountryDom();
      updateSummaryDom();
      updateValidationDom();
      updateToastDom();
    };

    const syncModalScrollLock = (open) => {
      if (open && !modalScrollLock) {
        modalScrollLock = {
          htmlOverflow: document.documentElement.style.overflow,
          bodyOverflow: document.body.style.overflow,
        };
        window.scrollTo({ top: window.scrollY, behavior: 'auto' });
        document.documentElement.style.setProperty('overflow', 'hidden', 'important');
        document.body.style.setProperty('overflow', 'hidden', 'important');
        return;
      }
      if (!open && modalScrollLock) {
        document.documentElement.style.overflow = modalScrollLock.htmlOverflow;
        document.body.style.overflow = modalScrollLock.bodyOverflow;
        modalScrollLock = null;
      }
    };

    const renderStepDom = ({ motion = 'step' } = {}) => {
      root.classList.toggle('is-soft-render', motion === 'soft');
      const progress = mount.querySelector('[data-reservation-progress]');
      if (progress instanceof HTMLElement) progress.outerHTML = progressTemplate();
      const activeStep = mount.querySelector('[data-reservation-active-step]');
      if (activeStep instanceof HTMLElement) activeStep.innerHTML = activeStepTemplate();
      const nav = mount.querySelector('[data-reservation-nav]');
      if (nav instanceof HTMLElement) nav.outerHTML = navTemplate();
      updateSummaryDom();
      updateValidationDom();
      updateToastDom();
    };

    const render = ({ motion = 'soft' } = {}) => {
      root.classList.toggle('is-soft-render', motion === 'soft');
      const modalOpen = Boolean(state.success || state.helpOpen);
      if (modalOpen && !modalWasOpen) modalReturnScrollY = window.scrollY;
      document.documentElement.classList.toggle('reservation-modal-open', modalOpen);
      syncModalScrollLock(modalOpen);
      modalWasOpen = modalOpen;
      mount.innerHTML = state.mode ? appTemplate() : startTemplate();
    };

    const startFlow = (mode) => {
      if (!stayModes.includes(mode)) return;
      state.mode = mode;
      state.step = 1;
      state.hint = '';
      state.toast = '';
      state.helpOpen = false;
      state.success = false;
      state.submitError = '';
      state.inquirySaved = false;
      state.submitAttempted = false;
      const url = new URL(window.location.href);
      url.searchParams.set('stay', mode);
      window.history.replaceState({}, '', url);
      render({ motion: 'step' });
      scheduleScrollToTop();
    };

    const startSimpleFlow = () => {
      state.mode = 'simple';
      state.step = 1;
      state.hint = '';
      state.toast = '';
      state.helpOpen = false;
      state.success = false;
      state.submitError = '';
      state.inquirySaved = false;
      const url = new URL(window.location.href);
      url.searchParams.delete('stay');
      window.history.replaceState({}, '', url);
      render({ motion: 'step' });
      scheduleScrollToTop();
    };

    const resetFlow = () => {
      state.mode = null;
      state.step = 0;
      state.hint = '';
      state.toast = '';
      state.helpOpen = false;
      state.success = false;
      state.submitAttempted = false;
      state.submitError = '';
      state.inquirySaved = false;
      const url = new URL(window.location.href);
      url.searchParams.delete('stay');
      window.history.replaceState({}, '', url);
      render({ motion: 'start' });
      scheduleScrollToTop();
    };

    const updateField = (path, value) => {
      const [group, key] = path.split('.');
      if (group === 'dates') state.dates[key] = value;
      if (group === 'details') state.details[key] = value;
    };

    const normalizeDateRange = () => {
      if (state.dates.arrival && state.dates.departure && compareIso(state.dates.departure, state.dates.arrival) <= 0) {
        state.dates.departure = '';
      }
      if (state.dates.arrival) {
        const arrival = parseDate(state.dates.arrival);
        if (arrival) {
          const month = new Date(arrival.getFullYear(), arrival.getMonth(), 1, 12);
          state.calendarMonth = dateToIso(month);
        }
      }
    };

    const selectCalendarDate = (iso) => {
      if (!iso || compareIso(iso, todayIso) < 0) return;
      if (!state.dates.arrival || (state.dates.arrival && state.dates.departure)) {
        state.dates.arrival = iso;
        state.dates.departure = '';
      } else if (compareIso(iso, state.dates.arrival) > 0) {
        state.dates.departure = iso;
      } else {
        state.dates.arrival = iso;
        state.dates.departure = '';
      }
      state.calendarDragging = false;
      state.calendarDragStart = '';
      state.calendarHover = '';
      render({ motion: 'soft' });
      if (summerCampingBlocked()) showViewportToast(config.summerBlock?.short || highSeasonCampingNotice(), 'warning');
      pulseSummary();
    };

    const updateCalendarPreviewDom = () => {
      const { start, end } = rangeBounds();
      mount.querySelectorAll('[data-calendar-day]').forEach((button) => {
        if (!(button instanceof HTMLButtonElement)) return;
        const iso = button.dataset.calendarDay || '';
        const isStart = iso === state.calendarDragStart;
        const isEnd = Boolean(state.calendarHover && iso === state.calendarHover && iso !== state.calendarDragStart);
        const isRange = Boolean(start && end && compareIso(iso, start) >= 0 && compareIso(iso, end) <= 0);
        button.classList.toggle('is-start', isStart);
        button.classList.toggle('is-end', isEnd);
        button.classList.toggle('is-range', isRange);
      });
    };

    const calendarIsoFromPoint = (event) => {
      if (!('clientX' in event) || !('clientY' in event)) return '';
      const element = document.elementFromPoint(event.clientX, event.clientY);
      const day = element instanceof Element ? element.closest('[data-calendar-day]') : null;
      if (!(day instanceof HTMLButtonElement) || day.disabled) return '';
      const iso = day.dataset.calendarDay || '';
      return compareIso(iso, todayIso) >= 0 ? iso : '';
    };

    const finishCalendarDrag = (iso) => {
      if (!state.calendarDragging || !state.calendarDragStart) return;
      const end = iso && compareIso(iso, todayIso) >= 0 ? iso : state.calendarHover || state.calendarDragStart;
      const start = state.calendarDragStart;
      if (compareIso(end, start) > 0) {
        state.dates.arrival = start;
        state.dates.departure = end;
      } else if (compareIso(end, start) < 0) {
        state.dates.arrival = end;
        state.dates.departure = start;
      } else {
        state.dates.arrival = start;
        state.dates.departure = '';
      }
      state.calendarDragging = false;
      state.calendarDragStart = '';
      state.calendarHover = '';
      suppressCalendarClick = true;
      window.setTimeout(() => { suppressCalendarClick = false; }, 0);
      render({ motion: 'soft' });
      pulseSummary();
    };

    const validateBeforeNext = () => {
      state.hint = '';
      if (state.step === 1 && (!state.dates.arrival || !state.dates.departure || nights() < 1)) {
        state.hint = formText.validation.dates;
        return false;
      }
      if (state.step === 3 && state.mode !== 'simple' && !hasChosenService()) {
        state.hint = formText.validation.service || t.hints.chooseService;
        return false;
      }
      return true;
    };

    const validateForSubmit = () => {
      state.submitAttempted = true;
      state.hint = '';
      if (!state.dates.arrival || !state.dates.departure || nights() < 1) {
        state.hint = formText.validation.dates;
        state.step = 1;
        return false;
      }
      if (state.mode !== 'simple' && !hasChosenService()) {
        state.hint = formText.validation.service;
        state.step = 3;
        return false;
      }
      if (summerCampingBlocked()) {
        state.hint = config.summerBlock?.toast || highSeasonCampingNotice();
        state.step = 1;
        return false;
      }
      if (!state.details.name.trim()) {
        state.hint = formText.validation.name;
        state.step = 4;
        return false;
      }
      if (!state.details.email.trim() && !state.details.phone.trim()) {
        state.hint = formText.validation.contact;
        state.step = 4;
        return false;
      }
      if (!state.details.countryCode) {
        state.hint = formText.validation.country;
        state.step = 4;
        return false;
      }
      if (!state.details.quiet || !state.details.consent || !state.details.privacy) {
        state.hint = formText.validation.consents || t.hints.required;
        state.step = 4;
        return false;
      }
      return true;
    };

    const scrollFirstIssue = () => {
      const issue = mount.querySelector('.reservation-summer-block, .reservation-field.is-invalid, .reservation-option-row.is-invalid, .reservation-missing-card');
      if (issue instanceof HTMLElement) {
        scrollToReservationSection(issue, { center: true });
        const field = issue.querySelector('input, select, textarea, button');
        if (field instanceof HTMLElement) field.focus({ preventScroll: true });
      }
    };

    const submit = async () => {
      if (state.submitting) return;
      if (!validateForSubmit()) {
        showViewportToast(state.hint, 'error');
        renderStepDom();
        window.setTimeout(scrollFirstIssue, 50);
        return;
      }
      state.submitting = true;
      state.submitError = '';
      state.toast = '';
      render();
      try {
        const response = await fetch('/api/reservation', {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify(payload()),
        });
        const result = await response.json().catch(() => ({}));
        if (response.status === 404 && /^(localhost|127\.0\.0\.1|\[::1\])$/.test(window.location.hostname)) {
          state.inquiryId = `LOCAL-${Date.now().toString(36).toUpperCase()}`;
          state.inquirySaved = true;
          state.success = true;
          return;
        }
        state.inquirySaved = Boolean(result?.inquirySaved);
        if (!response.ok || !result?.ok) {
          const errors = result?.errors ? Object.values(result.errors).join(' ') : '';
          if (state.inquirySaved) {
            state.inquiryId = result?.inquiryId || '';
            state.success = true;
            state.step = 5;
            showViewportToast(config.clientSuccess.badge, 'success');
            return;
          }
          state.submitError = result?.reason || result?.message || errors || config.clientSuccess.errorText;
          state.hint = state.submitError;
          showViewportToast(state.submitError, 'error');
          state.step = result?.code === 'SUMMER_CAMPING_BLOCKED' ? 1 : 4;
          state.submitting = false;
          render();
          return;
        }
        state.inquiryId = result.inquiryId || '';
        state.success = true;
        showViewportToast(state.inquirySaved ? config.clientSuccess.badge : config.clientSuccess.errorText, state.inquirySaved ? 'success' : 'error');
      } catch {
        state.submitError = config.clientSuccess.errorText;
        state.hint = state.submitError;
        showViewportToast(config.clientSuccess.errorText, 'error');
        state.step = 4;
      } finally {
        state.submitting = false;
        render();
      }
    };

    const restoreCountryFocus = () => {
      const input = mount.querySelector('[data-country-search]');
      if (input instanceof HTMLInputElement) {
        input.focus({ preventScroll: true });
        input.setSelectionRange(input.value.length, input.value.length);
      }
    };

    const pickCountry = (code) => {
      const country = config.countries.find((item) => item.code === code);
      if (!country) return;
      state.details.countryCode = country.code;
      state.details.countryName = country.name;
      state.details.countrySearch = `${country.name} (${country.code})`;
      state.countryOpen = false;
      state.countryDirty = false;
      state.countryActiveIndex = 0;
      const input = mount.querySelector('[data-country-search]');
      if (input instanceof HTMLInputElement) input.value = state.details.countrySearch;
      updateCountryDom();
      updateSummaryDom();
      updateValidationDom();
    };

    mount.addEventListener('click', (event) => {
      const target = event.target;
      if (!(target instanceof Element)) return;

      const start = target.closest('[data-start-mode]');
      if (start instanceof HTMLElement) {
        event.preventDefault();
        startFlow(start.dataset.startMode);
        return;
      }

      if (target.closest('[data-simple-start]')) {
        event.preventDefault();
        startSimpleFlow();
        return;
      }

      if (target.closest('[data-change-mode]')) {
        event.preventDefault();
        resetFlow();
        return;
      }

      if (target.closest('[data-switch-to-bungalow]')) {
        event.preventDefault();
        clearVisibleServices();
        state.mode = 'bungalow';
        state.step = Math.max(1, Math.min(state.step || 1, 3));
        state.hint = '';
        state.toast = config.summerBlock?.switched || '';
        renderStepDom({ motion: 'step' });
        showViewportToast(state.toast, 'success');
        scheduleScrollToTop();
        return;
      }

      if (target.closest('[data-summer-campy]')) {
        event.preventDefault();
        window.dispatchEvent(new CustomEvent('campy:prompt', {
          detail: {
            prompt: config.summerBlock?.campyPrompt || highSeasonCampingNotice(),
            actionKey: 'summerCampingRule',
          },
        }));
        showViewportToast(config.summerBlock?.short || highSeasonCampingNotice(), 'warning');
        return;
      }

      if (target.closest('[data-help-open]')) {
        event.preventDefault();
        state.helpOpen = true;
        render();
        return;
      }

      if (target.closest('[data-help-close]')) {
        event.preventDefault();
        state.helpOpen = false;
        render();
        return;
      }

      if (target.closest('[data-new-inquiry]')) {
        event.preventDefault();
        state.success = false;
        resetFlow();
        return;
      }

      if (target.closest('[data-success-close]')) {
        event.preventDefault();
        state.success = false;
        target.closest('.reservation-success-modal')?.remove();
        document.documentElement.classList.remove('reservation-modal-open');
        syncModalScrollLock(false);
        modalWasOpen = false;
        window.requestAnimationFrame(() => {
          const currentStep = mount.querySelector('.reservation-step-card, .reservation-progress');
          if (currentStep instanceof HTMLElement) scrollToReservationSection(currentStep);
          else window.scrollTo({ top: modalReturnScrollY, behavior: reducedMotion.matches ? 'auto' : 'smooth' });
        });
        return;
      }

      if (target.closest('[data-success-campy]')) {
        event.preventDefault();
        state.success = false;
        render();
        window.requestAnimationFrame(() => {
          window.dispatchEvent(new CustomEvent('campy:prompt', {
            detail: {
              prompt: config.lang === 'pl' ? 'Pomóż mi przygotować pobyt' : 'Help me prepare my stay',
              actionKey: 'reservationHelp',
            },
          }));
        });
        return;
      }

      if (target.closest('[data-calendar-prev]')) {
        event.preventDefault();
        shiftCalendarMonth(-1);
        render({ motion: 'soft' });
        return;
      }

      if (target.closest('[data-calendar-next]')) {
        event.preventDefault();
        shiftCalendarMonth(1);
        render({ motion: 'soft' });
        return;
      }

      const calendarDay = target.closest('[data-calendar-day]');
      if (calendarDay instanceof HTMLButtonElement) {
        event.preventDefault();
        if (suppressCalendarClick) return;
        selectCalendarDate(calendarDay.dataset.calendarDay);
        return;
      }

      const suggestionAdd = target.closest('[data-suggestion-add]');
      if (suggestionAdd instanceof HTMLElement) {
        event.preventDefault();
        const [scope, id] = String(suggestionAdd.dataset.suggestionAdd || '').split(':');
        if (scope && id) {
          setQty(scope, id, Math.max(1, getQty(scope, id) || 0));
          state.toast = ui.presetAdded || '';
          refreshControlDom();
          pulseSummary();
        }
        return;
      }

      if (target.closest('[data-ask-campy-plan]')) {
        event.preventDefault();
        window.dispatchEvent(new CustomEvent('campy:prompt', {
          detail: {
            prompt: config.lang === 'pl' ? 'Zaplanuj dzień w Krakowie' : 'Plan a Krakow day',
            actionKey: 'dayPlan',
          },
        }));
        return;
      }

      const presetButton = target.closest('[data-preset]');
      if (presetButton instanceof HTMLElement) {
        event.preventDefault();
        applyPreset(presetButton.dataset.preset);
        return;
      }

      const jump = target.closest('[data-step-jump]');
      if (jump instanceof HTMLElement && jump.dataset.stepJump) {
        event.preventDefault();
        const next = Number(jump.dataset.stepJump);
        if (next >= 1 && next <= state.step) {
          state.step = next;
          state.hint = '';
          renderStepDom({ motion: 'step' });
          scheduleScrollToTop();
        }
        return;
      }

      const serviceStepper = target.closest('[data-service-scope][data-service-id]');
      if (serviceStepper instanceof HTMLElement && (target.closest('[data-stepper-plus]') || target.closest('[data-stepper-minus]'))) {
        event.preventDefault();
        const scope = serviceStepper.dataset.serviceScope;
        const id = serviceStepper.dataset.serviceId;
        const current = getQty(scope, id);
        setQty(scope, id, current + (target.closest('[data-stepper-plus]') ? 1 : -1));
        state.hint = '';
        refreshControlDom();
        pulseSummary();
        return;
      }

      const guestStepper = target.closest('[data-guest-key]');
      if (guestStepper instanceof HTMLElement && (target.closest('[data-stepper-plus]') || target.closest('[data-stepper-minus]'))) {
        event.preventDefault();
        const key = guestStepper.dataset.guestKey;
        const current = Number(state.guests[key] || 0);
        state.guests[key] = Math.max(0, current + (target.closest('[data-stepper-plus]') ? 1 : -1));
        refreshControlDom();
        pulseSummary();
        return;
      }

      const countryPick = target.closest('[data-country-pick]');
      if (countryPick instanceof HTMLElement) {
        event.preventDefault();
        pickCountry(countryPick.dataset.countryPick);
        return;
      }

      const language = target.closest('[data-language]');
      if (language instanceof HTMLElement) {
        event.preventDefault();
        state.details.language = language.dataset.language || state.details.language;
        refreshControlDom();
        return;
      }

      const feedbackRating = target.closest('[data-feedback-rating]');
      if (feedbackRating instanceof HTMLElement) {
        event.preventDefault();
        state.feedback.rating = Number(feedbackRating.dataset.feedbackRating || 0);
        renderStepDom({ motion: 'soft' });
        return;
      }

      const feedbackLiked = target.closest('[data-feedback-liked]');
      if (feedbackLiked instanceof HTMLElement) {
        event.preventDefault();
        const value = feedbackLiked.dataset.feedbackLiked || '';
        state.feedback.liked = state.feedback.liked.includes(value)
          ? state.feedback.liked.filter((item) => item !== value)
          : [...state.feedback.liked, value];
        renderStepDom({ motion: 'soft' });
        return;
      }

      const feedbackAnswer = target.closest('[data-feedback-answer]');
      if (feedbackAnswer instanceof HTMLElement) {
        event.preventDefault();
        const field = feedbackAnswer.dataset.feedbackAnswer;
        if (field === 'easyInfo' || field === 'easyForm') {
          state.feedback[field] = feedbackAnswer.dataset.feedbackValue || '';
          renderStepDom({ motion: 'soft' });
        }
        return;
      }

      if (target.closest('[data-back]')) {
        event.preventDefault();
        state.step = Math.max(1, state.step - 1);
        state.hint = '';
        renderStepDom({ motion: 'step' });
        scheduleScrollToTop();
        return;
      }

      if (target.closest('[data-next]')) {
        event.preventDefault();
        if (!validateBeforeNext()) {
          showViewportToast(state.hint, 'error');
          renderStepDom();
          window.setTimeout(scrollFirstIssue, 90);
          return;
        }
        const previousStepKey = currentStepKey();
        const reward = stepRewards[previousStepKey] || '';
        state.step = Math.min(5, state.step + 1);
        state.toast = reward;
        renderStepDom({ motion: 'step' });
        if (reward) {
          window.setTimeout(() => {
            if (state.toast === reward) {
              state.toast = '';
              updateToastDom();
            }
          }, 1900);
        }
        scheduleScrollToTop();
        return;
      }

      if (target.closest('[data-submit]')) {
        event.preventDefault();
        void submit();
      }
    });

    root.addEventListener('click', (event) => {
      const target = event.target;
      if (target instanceof Element && target.closest('[data-reservation-toast-close]')) {
        event.preventDefault();
        hideViewportToast();
      }
    });

    mount.addEventListener('pointerdown', (event) => {
      const target = event.target;
      if (!(target instanceof Element)) return;
      const day = target.closest('[data-calendar-day]');
      if (!(day instanceof HTMLButtonElement) || day.disabled || event.button !== 0) return;
      if (event.pointerType === 'touch' || window.matchMedia('(pointer: coarse)').matches) return;
      if (!event.shiftKey) return;
      const iso = day.dataset.calendarDay || '';
      if (!iso || compareIso(iso, todayIso) < 0) return;
      event.preventDefault();
      state.calendarDragging = true;
      state.calendarDragStart = iso;
      state.calendarHover = iso;
      day.setPointerCapture?.(event.pointerId);
      updateCalendarPreviewDom();
    });

    mount.addEventListener('pointermove', (event) => {
      if (!state.calendarDragging) return;
      const iso = calendarIsoFromPoint(event);
      if (!iso || iso === state.calendarHover) return;
      state.calendarHover = iso;
      updateCalendarPreviewDom();
    });

    mount.addEventListener('pointerover', (event) => {
      if (!state.calendarDragging) return;
      const target = event.target;
      if (!(target instanceof Element)) return;
      const day = target.closest('[data-calendar-day]');
      if (!(day instanceof HTMLButtonElement) || day.disabled) return;
      state.calendarHover = day.dataset.calendarDay || state.calendarHover;
      updateCalendarPreviewDom();
    });

    mount.addEventListener('pointerup', (event) => {
      if (!state.calendarDragging) return;
      finishCalendarDrag(calendarIsoFromPoint(event) || state.calendarHover);
    });

    mount.addEventListener('pointercancel', () => {
      state.calendarDragging = false;
      state.calendarDragStart = '';
      state.calendarHover = '';
      updateCalendarPreviewDom();
    });

    mount.addEventListener('input', (event) => {
      const target = event.target;
      if (!(target instanceof HTMLInputElement || target instanceof HTMLTextAreaElement || target instanceof HTMLSelectElement)) return;
      if (target.dataset.field) {
        updateField(target.dataset.field, target.value);
        if (target.dataset.field.startsWith('dates.')) {
          normalizeDateRange();
          render();
          if (summerCampingBlocked()) showViewportToast(config.summerBlock?.short || highSeasonCampingNotice(), 'warning');
        }
        else if (target.dataset.field === 'details.arrivalTime') {
          render();
          if (state.details.arrivalTime.startsWith('po 21:00')) {
            showViewportToast(
              config.lang === 'pl'
                ? 'Recepcja i brama mają określone godziny pracy. Przy późnym przyjeździe skontaktuj się z recepcją.'
                : 'Reception and gate have set opening hours. Contact reception before a late arrival.',
              'warning',
            );
          }
        }
        else {
          updateSummaryDom();
          updateValidationDom();
        }
        return;
      }
      if (target.hasAttribute('data-feedback-improve')) {
        state.feedback.improve = target.value;
        return;
      }
      if (target.hasAttribute('data-country-search')) {
        state.details.countrySearch = target.value;
        state.details.countryCode = '';
        state.details.countryName = '';
        state.countryOpen = true;
        state.countryDirty = true;
        state.countryActiveIndex = 0;
        updateCountryDom();
        updateSummaryDom();
        updateValidationDom();
      }
    });

    mount.addEventListener('focusin', (event) => {
      const target = event.target;
      if (!(target instanceof HTMLInputElement) || !target.hasAttribute('data-country-search')) return;
      if (state.countryOpen) return;
      state.countryOpen = true;
      state.countryDirty = false;
      state.countryActiveIndex = 0;
      updateCountryDom();
    });

    mount.addEventListener('change', (event) => {
      const target = event.target;
      if (!(target instanceof HTMLInputElement)) return;
      if (target.dataset.tourOption) {
        const tour = target.dataset.tourOption;
        state.tours = target.checked
          ? [...new Set([...state.tours, tour])]
          : state.tours.filter((item) => item !== tour);
        updateSummaryDom();
        return;
      }
      if (target.dataset.check) {
        state.details[target.dataset.check] = target.checked;
        refreshControlDom();
      }
    });

    mount.addEventListener('keydown', (event) => {
      const target = event.target;
      if (!(target instanceof HTMLInputElement) || !target.hasAttribute('data-country-search')) return;
      const results = countryMatches();
      if (event.key === 'ArrowDown') {
        event.preventDefault();
        state.countryOpen = true;
        state.countryDirty = true;
        state.countryActiveIndex = results.length ? Math.min(results.length - 1, state.countryActiveIndex + 1) : 0;
        updateCountryDom();
        return;
      }
      if (event.key === 'ArrowUp') {
        event.preventDefault();
        state.countryOpen = true;
        state.countryDirty = true;
        state.countryActiveIndex = Math.max(0, state.countryActiveIndex - 1);
        updateCountryDom();
        return;
      }
      if (event.key === 'Enter' && results[0]) {
        event.preventDefault();
        pickCountry((results[state.countryActiveIndex] || results[0]).code);
      }
      if (event.key === 'Escape') {
        state.countryOpen = false;
        state.countryDirty = false;
        updateCountryDom();
      }
    });

    const queryParams = new URLSearchParams(window.location.search);
    const queryMode = queryParams.get('stay');
    const queryPreset = queryParams.get('preset');
    if (stayModes.includes(queryMode)) {
      state.mode = queryMode;
      state.step = queryPreset ? 3 : 1;
      render({ motion: 'step' });
      if (queryPreset) applyPreset(queryPreset);
    }

    window.addEventListener('keydown', (event) => {
      if (event.key !== 'Escape') return;
      if (state.helpOpen) {
        state.helpOpen = false;
        render();
      }
    });
  })();
</script>

