        ];
      }
      return [
        { href: config.links?.planner || '/planer-pobytu', label: config.lang === 'pl' ? 'Plan pobytu 4+ nocy' : '4+ night stay plan' },
        { href: config.links?.attractions || '/atrakcje', label: config.lang === 'pl' ? 'Kraków i Małopolska' : 'Krakow and Lesser Poland' },
