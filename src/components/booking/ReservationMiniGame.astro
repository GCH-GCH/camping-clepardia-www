  border-radius: 16px;
  background: rgba(255,255,255,.055);
}

.reservation-date-summary dt {
  color: rgba(245,255,248,.56);
  font-size: .7rem;
  font-weight: 950;
  text-transform: uppercase;
}

.reservation-date-summary dd {
  margin: 4px 0 0;
  color: #fff;
  font-weight: 900;
}

.reservation-stay-advice {
  align-items: start;
  padding: 14px;
  border: 1px solid rgba(143,224,180,.16);
  border-radius: 18px;
  background: rgba(60,179,113,.09);
}

.reservation-stay-advice p {
  margin-top: 4px;
  color: rgba(245,255,248,.72);
}

.reservation-stay-advice__actions {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}

.reservation-trip-ctas {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  margin-top: 12px;
}

.reservation-trip-ctas--start {
