  color: rgba(245,255,248,.28);
  background: rgba(255,255,255,.025);
  box-shadow: none;
}

.reservation-date-summary > div:first-child,
.reservation-stay-advice {
  display: grid;
  grid-template-columns: 46px minmax(0, 1fr);
  gap: 12px;
  align-items: center;
}

.reservation-date-summary dl {
