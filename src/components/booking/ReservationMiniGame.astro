                      </div>
                      ${stepperTemplate({ kind: 'service', scope: group.scope, id: item.id, label: item.label, price, value: qty })}
                    </article>
                  `;
                }).join('')}
              </div>
            </div>
          `).join('')}
        </div>
        ${serviceSuggestionsTemplate()}
        <section class="reservation-tour-options">
          <div>
            <strong>${esc(config.lang === 'pl' ? 'Czy chcesz zapytać też o wycieczkę?' : 'Would you also like to ask about a trip?')}</strong>
            <p>${esc(config.lang === 'pl' ? 'Opcjonalnie — wybór nie zmienia ceny zapytania.' : 'Optional — this does not change the estimated price.')}</p>
