  background:
    radial-gradient(circle at 12% 0%, rgba(60,179,113,.12), transparent 34%),
    rgba(6,18,13,.34);
}

.reservation-vehicle-details > header {
  display: grid;
  grid-template-columns: 44px minmax(0, 1fr);
  gap: 12px;
  align-items: start;
}

.reservation-vehicle-details > header > span {
  width: 44px;
  height: 44px;
  display: grid;
  place-items: center;
  border-radius: 16px;
  color: #8fe0b4;
  background: rgba(60,179,113,.12);
  border: 1px solid rgba(143,224,180,.20);
}

.reservation-vehicle-details > header strong {
  display: block;
  color: #fff;
  font-size: 1.02rem;
}

.reservation-vehicle-details > header p {
  margin: 3px 0 0;
  color: rgba(245,255,248,.64);
  line-height: 1.55;
}

.reservation-field span,
.reservation-field small {
  display: block;
}

.reservation-field small {
  color: rgba(245,255,248,.58);
  font-weight: 600;
  line-height: 1.45;
}

.reservation-field input,
.reservation-field select,
.reservation-field textarea {
  width: 100%;
  min-width: 0;
  border: 1px solid rgba(255,255,255,.14);
  border-radius: 16px;
  color: #fff;
  background: rgba(6,18,13,.58);
  padding: 14px 15px;
  outline: none;
}

.reservation-field input:focus,
.reservation-field select:focus,
.reservation-field textarea:focus {
  border-color: rgba(143,224,180,.58);
  box-shadow: 0 0 0 4px rgba(60,179,113,.16);
}

.reservation-field.is-invalid input,
.reservation-field.is-invalid select,
.reservation-field.is-invalid textarea {
  border-color: rgba(255,122,122,.72);
  box-shadow: 0 0 0 4px rgba(255,86,86,.12);
}

.reservation-field__error {
  display: block;
  color: #ffb3b3;
  font-size: .82rem;
  font-style: normal;
  font-weight: 850;
  line-height: 1.45;
}

.reservation-night-card {
  display: grid;
  align-content: center;
  gap: 6px;
  padding: 16px;
  border: 1px solid rgba(143,224,180,.20);
  border-radius: 18px;
  background: rgba(60,179,113,.10);
}

.reservation-night-card strong {
  color: #8fe0b4;
  font-size: 2.2rem;
}

.reservation-night-card i {
  width: 36px;
  height: 36px;
  display: grid;
  place-items: center;
  margin-bottom: 2px;
  border: 1px solid rgba(143,224,180,.22);
  border-radius: 13px;
  color: #8fe0b4;
  background: rgba(60,179,113,.10);
}

.reservation-night-card i svg {
  width: 20px;
  height: 20px;
}

.reservation-night-card small {
  color: rgba(245,255,248,.60);
  font-weight: 750;
}

.reservation-date-helper {
  display: grid;
  grid-template-columns: 44px minmax(0, 1fr);
  gap: 12px;
  align-items: center;
  margin-top: 18px;
  padding: 15px;
  border: 1px solid rgba(143,224,180,.18);
  border-radius: 20px;
  background:
    radial-gradient(circle at 8% 0%, rgba(143,224,180,.13), transparent 38%),
    rgba(60,179,113,.08);
}

.reservation-date-helper > i {
  width: 44px;
  height: 44px;
  display: grid;
  place-items: center;
  border-radius: 15px;
  color: #8fe0b4;
  background: rgba(60,179,113,.12);
}

.reservation-date-helper svg {
  width: 22px;
  height: 22px;
}

.reservation-date-helper strong,
.reservation-date-helper small {
  display: block;
}

.reservation-date-helper strong {
  color: #fff;
}

.reservation-date-helper small {
  margin-top: 2px;
  color: rgba(245,255,248,.66);
  line-height: 1.45;
}

.reservation-info-grid {
  display: grid;
  gap: 10px;
  margin-top: 18px;
}

.reservation-info-grid p,
.reservation-hint {
  padding: 13px 15px;
  border: 1px solid rgba(143,224,180,.16);
  border-radius: 18px;
  background: rgba(60,179,113,.09);
}

.reservation-info-grid .is-warm {
  border-color: rgba(242,192,120,.22);
  background: rgba(242,192,120,.10);
}

.reservation-calendar,
.reservation-date-summary,
.reservation-smart-suggestions {
  display: grid;
  gap: 14px;
  margin-top: 20px;
  padding: clamp(16px, 2.2vw, 22px);
  border: 1px solid rgba(143,224,180,.18);
  border-radius: 24px;
  background:
    radial-gradient(circle at 10% 0%, rgba(143,224,180,.14), transparent 38%),
    rgba(255,255,255,.055);
  box-shadow: inset 0 1px 0 rgba(255,255,255,.08);
}

.reservation-calendar__head {
  display: grid;
  grid-template-columns: 46px minmax(0, 1fr) auto;
  gap: 12px;
  align-items: center;
}

.reservation-calendar__head > span,
.reservation-date-summary > div:first-child span,
.reservation-stay-advice > i,
.reservation-smart-suggestions article > i {
  width: 46px;
  height: 46px;
  display: grid;
  place-items: center;
  border: 1px solid rgba(143,224,180,.24);
  border-radius: 16px;
  color: #8fe0b4;
  background: rgba(60,179,113,.11);
  box-shadow: 0 14px 32px rgba(60,179,113,.12);
}

.reservation-calendar__head strong,
.reservation-date-summary strong,
.reservation-smart-suggestions > strong,
.reservation-stay-advice strong {
  color: #fff;
}

.reservation-calendar__head p {
  margin-top: 2px;
  color: rgba(245,255,248,.66);
  font-size: .9rem;
}

.reservation-calendar__nav {
  min-width: 250px;
  display: grid;
  grid-template-columns: 42px minmax(0, 1fr) 42px;
  align-items: center;
  gap: 8px;
  padding: 6px;
  border: 1px solid rgba(255,255,255,.12);
  border-radius: 999px;
  background: rgba(255,255,255,.07);
}

.reservation-calendar__nav button {
  width: 42px;
  height: 42px;
  border-radius: 999px;
  color: #fff;
  background: rgba(60,179,113,.15);
  font-size: 1.4rem;
  font-weight: 900;
}

.reservation-calendar__nav button:hover,
.reservation-calendar__nav button:focus-visible {
  background: rgba(60,179,113,.28);
  box-shadow: 0 0 0 4px rgba(60,179,113,.14);
}

.reservation-calendar__nav em {
  color: #f5fff8;
  font-style: normal;
  font-weight: 900;
  text-align: center;
  text-transform: capitalize;
}

.reservation-calendar__weekdays,
.reservation-calendar__grid {
  display: grid;
  grid-template-columns: repeat(7, minmax(0, 1fr));
  gap: 8px;
  touch-action: manipulation;
  user-select: none;
}

.reservation-calendar__weekdays span {
  color: rgba(245,255,248,.54);
  font-size: .72rem;
  font-weight: 950;
  text-align: center;
  text-transform: uppercase;
}

.reservation-calendar__empty,
.reservation-calendar__day {
  min-height: 48px;
  border-radius: 16px;
}

.reservation-calendar__day {
  position: relative;
  display: grid;
  place-items: center;
  border: 1px solid rgba(255,255,255,.10);
  color: #f5fff8;
  background: rgba(255,255,255,.055);
  font-weight: 900;
  transition: transform .18s ease, border-color .18s ease, background .18s ease, box-shadow .18s ease;
}

.reservation-calendar__day:hover,
.reservation-calendar__day:focus-visible {
  transform: translateY(-1px);
  border-color: rgba(143,224,180,.48);
  background: rgba(60,179,113,.16);
}

.reservation-calendar__day.is-today:not(.is-start):not(.is-end) {
  border-color: rgba(242,192,120,.34);
  box-shadow: inset 0 0 0 1px rgba(242,192,120,.16);
}

.reservation-calendar__day.is-range {
  border-color: rgba(143,224,180,.22);
  background: linear-gradient(135deg, rgba(60,179,113,.24), rgba(143,224,180,.10));
}

.reservation-calendar__day.is-start,
.reservation-calendar__day.is-end {
  color: #062016;
  border-color: rgba(143,224,180,.72);
  background: linear-gradient(135deg, #a8f0c4, #3CB371);
  box-shadow: 0 18px 38px rgba(60,179,113,.28);
}

.reservation-calendar__day.is-disabled {
