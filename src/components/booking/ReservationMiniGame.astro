          ${selected.length ? `<div><dt>${esc(t.summary.services)}</dt><dd>${selected.map((item) => `${item.label} x ${item.qty}`).join(', ')}</dd></div>` : ''}
          ${state.details.countryCode ? `<div><dt>${esc(t.summary.country)}</dt><dd>${esc(state.details.countryName)} (${esc(state.details.countryCode)})</dd></div>` : ''}
          <div><dt>${esc(t.summary.language)}</dt><dd>${esc(state.details.language)}</dd></div>
          ${state.details.specialNeeds ? `<div><dt>${esc(t.summary.specialNeeds)}</dt><dd>Tak</dd></div>` : ''}
          ${state.details.lateCheckout ? `<div><dt>${esc(t.summary.lateCheckout)}</dt><dd>${esc(state.details.lateTime)}</dd></div>` : ''}
        </dl>
