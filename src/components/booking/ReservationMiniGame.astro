        <p class="reservation-mini__note">${esc(t.startLead)}</p>
      </div>
    `;

    const progressTemplate = () => {
      const percent = Math.max(0, Math.min(100, (state.step / steps.length) * 100));
      const activeHint = state.toast || stepHints[state.step - 1] || '';
      return `
        <div class="reservation-progress" data-reservation-progress aria-label="Booking progress">
          <div class="reservation-progress__meter">
            <span>${esc(ui.progressLabel || 'Progress')}</span>
            <strong>${Math.round(percent)}%</strong>
            <i aria-hidden="true"><b style="width:${percent}%"></b></i>
            <p>${esc(activeHint)}</p>
          </div>
          <div class="reservation-progress__mobile">
            <strong>Krok ${state.step} z ${steps.length}</strong>
            <span>${esc(stepTitles[state.step - 1])}</span>
            <i><b style="width:${percent}%"></b></i>
          </div>
          <div class="reservation-progress__desktop">
            ${steps.map((step, index) => {
              const no = index + 1;
              const active = no === state.step;
              const done = no < state.step;
              return `
                <button type="button" data-step-jump="${no}" class="${active ? 'is-active' : ''} ${done ? 'is-done' : ''}" ${done || active ? '' : 'disabled'}>
                  <span>${no}</span>
                  <i aria-hidden="true">${stepIcon(index)}</i>
                  <em>${esc(stepTitles[index])}</em>
                </button>
              `;
            }).join('')}
          </div>
        </div>
      `;
    };

    const stepperTemplate = ({ kind, key, scope = '', id = '', label, price = 0, value }) => {
      const current = Number(value ?? 0);
      const attrs = kind === 'guest' ? `data-guest-key="${esc(key)}"` : `data-service-scope="${esc(scope)}" data-service-id="${esc(id)}"`;
      return `
        <div class="reservation-stepper" ${attrs}>
          <button type="button" data-stepper-minus aria-label="${esc(t.actions.decrease)} ${esc(label)}" ${current <= 0 ? 'disabled' : ''}>&minus;</button>
          <strong data-stepper-value aria-live="polite">${current}</strong>
          <button type="button" data-stepper-plus aria-label="${esc(t.actions.increase)} ${esc(label)}">+</button>
        </div>
      `;
    };

    const calendarTemplate = () => {
      const labels = ui.calendar || {};
      const { start, end } = rangeBounds();
      const weekDays = (config.lang === 'pl'
        ? ['Pn', 'Wt', 'Śr', 'Cz', 'Pt', 'So', 'Nd']
        : ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun']);
      return `
        <div class="reservation-calendar" data-date-calendar>
          <header class="reservation-calendar__head">
            <span aria-hidden="true">${detailIcon('calendar')}</span>
            <div>
              <strong>${esc(labels.title || 'Stay calendar')}</strong>
              <p>${esc(labels.lead || '')}</p>
            </div>
            <div class="reservation-calendar__nav">
              <button type="button" data-calendar-prev aria-label="${esc(labels.previous || 'Previous month')}">‹</button>
              <em>${esc(monthLabel())}</em>
              <button type="button" data-calendar-next aria-label="${esc(labels.next || 'Next month')}">›</button>
            </div>
          </header>
          <div class="reservation-calendar__weekdays" aria-hidden="true">
            ${weekDays.map((day) => `<span>${esc(day)}</span>`).join('')}
          </div>
          <div class="reservation-calendar__grid" role="grid" aria-label="${esc(labels.title || 'Stay calendar')}">
            ${calendarDays().map((iso) => {
              if (!iso) return '<span class="reservation-calendar__empty" aria-hidden="true"></span>';
              const disabled = compareIso(iso, todayIso) < 0;
              const isStart = iso === state.dates.arrival || (state.calendarDragging && iso === state.calendarDragStart);
              const isEnd = iso === state.dates.departure || (state.calendarDragging && iso === state.calendarHover && iso !== state.calendarDragStart);
              const inRange = start && end && compareIso(iso, start) >= 0 && compareIso(iso, end) <= 0;
              const classes = [
                'reservation-calendar__day',
                disabled ? 'is-disabled' : '',
                isStart ? 'is-start' : '',
                isEnd ? 'is-end' : '',
                inRange ? 'is-range' : '',
                iso === todayIso ? 'is-today' : '',
              ].filter(Boolean).join(' ');
              const dayNo = Number(iso.slice(-2));
              const suffix = isStart ? `, ${labels.arrival || 'Arrival'}` : isEnd ? `, ${labels.departure || 'Departure'}` : '';
              return `<button type="button" class="${classes}" data-calendar-day="${esc(iso)}" ${disabled ? 'disabled' : ''} aria-label="${esc(`${iso}${suffix}`)}"><span>${dayNo}</span></button>`;
            }).join('')}
          </div>
        </div>
      `;
    };

    const dateStaySummary = () => {
      const labels = ui.calendar || {};
      const advice = stayAdviceText();
      const stayHours = state.mode === 'bungalow'
        ? t.info.bungalowHours
