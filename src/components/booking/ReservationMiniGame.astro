              </label>
            `).join('')}
          </div>
          <a class="reservation-mini-link" href="${esc(config.links?.tours)}" target="_blank" rel="noopener noreferrer">${esc(config.tourUi?.[1] || 'Book a tour')}</a>
        </section>
