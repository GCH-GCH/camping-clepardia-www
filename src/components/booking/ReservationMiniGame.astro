      consentTitle: 'Potwierdzenia',
      consentLead: 'Kilka ważnych zasad, żeby zapytanie było kompletne.',
      specialHelper: 'Opcjonalnie. Pokażemy dodatkowe pole po zaznaczeniu.',
      lateHelper: 'Recepcja potwierdzi możliwość po przyjeździe.',
      quietHelper: 'Wymagane przed wysłaniem.',
      consentHelper: 'Wymagane przed wysłaniem.',
    } : {
      contactTitle: 'Contact details',
      contactLead: 'Reception will use them only to answer this enquiry.',
      stayTitle: 'Stay details',
      stayLead: 'Add anything that helps prepare your arrival.',
      consentTitle: 'Confirmations',
      consentLead: 'A few important rules to complete the enquiry.',
      specialHelper: 'Optional. An extra field appears after selecting it.',
      lateHelper: 'Reception confirms possibility after arrival.',
      quietHelper: 'Required before sending.',
      consentHelper: 'Required before sending.',
