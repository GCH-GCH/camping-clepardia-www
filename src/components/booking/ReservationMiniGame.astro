import { pricingConfig } from '@/data/pricing';
import { resolveContentLanguage } from '@/i18n/config';
import { getPathContext } from '@/utils/localizedLinks';

interface Props {
  languageCode?: string;
}

type SupportedLang = 'pl' | 'en' | 'de' | 'it';

const { languageCode } = Astro.props as Props;
const pathContext = getPathContext(Astro.url.pathname);
const lang = resolveContentLanguage(languageCode ?? pathContext.languageCode) as SupportedLang;

const renderLucideIcon = (name: keyof typeof icons | string) => {
  const iconNode = icons[name as keyof typeof icons] ?? icons.CircleHelp;
  const attrsToString = (attrs: Record<string, unknown>) => Object.entries(attrs)
    .map(([key, value]) => `${key}="${String(value).replace(/"/g, '&quot;')}"`)
    .join(' ');

  return `<svg class="reservation-lucide-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">${iconNode
    .map(([tag, attrs]) => `<${tag} ${attrsToString(attrs as Record<string, unknown>)}></${tag}>`)
    .join('')}</svg>`;
};

