.reservation-mini-link,
.reservation-smart-suggestions button {
  min-height: 38px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 0 13px;
  border: 1px solid rgba(143,224,180,.22);
  border-radius: 999px;
  color: #dffff0;
  background: rgba(60,179,113,.12);
  font-size: .82rem;
