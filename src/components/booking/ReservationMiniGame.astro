  padding: 18px;
  border: 1px solid rgba(143,224,180,.18);
  border-radius: 24px;
  background:
    radial-gradient(circle at 10% 0%, rgba(143,224,180,.14), transparent 38%),
    rgba(60,179,113,.08);
}

.reservation-presets > div:first-child strong,
.reservation-simple-panel strong {
  display: block;
  color: #fff;
  font-size: 1.05rem;
}

.reservation-presets > div:first-child p,
.reservation-simple-panel p {
  margin-top: 4px;
  color: rgba(245,255,248,.68);
}

.reservation-presets__grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10px;
}

.reservation-presets button {
  min-width: 0;
  display: grid;
  grid-template-columns: 34px minmax(0, 1fr);
  align-items: center;
  gap: 10px;
  padding: 12px;
  border: 1px solid rgba(255,255,255,.13);
  border-radius: 18px;
  color: #f5fff8;
  background: rgba(255,255,255,.075);
  text-align: left;
  font-weight: 900;
  transition: transform .18s ease, border-color .18s ease, background .18s ease, box-shadow .18s ease;
}

.reservation-presets button span {
  width: 34px;
  height: 34px;
  display: grid;
  place-items: center;
  color: #8fe0b4;
}

.reservation-presets button:hover,
.reservation-presets button:focus-visible {
  transform: translateY(-2px);
  border-color: rgba(143,224,180,.46);
  background: rgba(60,179,113,.15);
  box-shadow: 0 16px 38px rgba(60,179,113,.14);
}

.reservation-card-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14px;
  margin-top: 22px;
}

.reservation-service-groups {
  display: grid;
  gap: 22px;
}

.reservation-service-group h3 {
  margin: 22px 0 0;
  color: #fff;
}

.reservation-item-card {
  display: grid;
  grid-template-columns: 58px minmax(0, 1fr) auto;
  align-items: center;
  gap: 14px;
  padding: 16px;
  border-radius: 22px;
}

.reservation-item-card strong,
.reservation-item-card small,
.reservation-item-card em {
  display: block;
}

.reservation-item-card strong {
  color: #fff;
}

.reservation-item-card small,
.reservation-item-card em {
  color: rgba(245,255,248,.62);
  font-style: normal;
  line-height: 1.45;
}

.reservation-item-card em {
  color: #8fe0b4;
  font-weight: 900;
}

.reservation-stepper {
  display: grid;
  grid-template-columns: 44px 42px 44px;
  align-items: center;
  border: 1px solid rgba(255,255,255,.14);
  border-radius: 999px;
  background:
    linear-gradient(145deg, rgba(255,255,255,.055), rgba(255,255,255,.02)),
    rgba(5,16,11,.50);
  overflow: hidden;
  box-shadow: inset 0 1px 0 rgba(255,255,255,.07);
}

.reservation-stepper button,
.reservation-stepper strong {
  width: 44px;
  min-height: 44px;
  display: grid;
  place-items: center;
}

.reservation-stepper button {
  color: #fff;
  background: transparent;
  font-size: 1.25rem;
  font-weight: 950;
  transition: background .18s ease, color .18s ease, transform .18s ease;
}

.reservation-stepper button:hover:not(:disabled),
.reservation-stepper button:focus-visible {
  color: #07140f;
  background: #8fe0b4;
}

.reservation-stepper button:active:not(:disabled) {
  transform: scale(.92);
}

.reservation-stepper button:disabled {
  opacity: .36;
  cursor: not-allowed;
}

.reservation-stepper strong {
  color: #fff;
  font-size: 1rem;
  font-weight: 1000;
  transition: transform .18s ease, color .18s ease;
}

.reservation-item-card:has(.reservation-stepper button:active) {
  box-shadow: 0 24px 80px rgba(60,179,113,.14), inset 0 1px 0 rgba(255,255,255,.16);
}

.reservation-item-card:has(.reservation-stepper button:active) .reservation-stepper strong {
  transform: scale(1.12);
  color: #8fe0b4;
}

.reservation-country {
  position: relative;
  min-width: 0;
}

.reservation-country__hint {
  margin-top: 8px !important;
  width: fit-content;
  max-width: 100%;
  padding: 9px 12px;
  border: 1px solid rgba(143,224,180,.18);
  border-radius: 999px;
  color: rgba(245,255,248,.72) !important;
  background: rgba(60,179,113,.09);
  font-size: .82rem;
  line-height: 1.35;
}

.reservation-country__list {
  position: absolute;
  z-index: 30;
  inset-inline: 0;
  top: calc(100% + 8px);
  max-height: 250px;
  overflow-y: auto;
  padding: 8px;
  border: 1px solid rgba(255,255,255,.14);
  border-radius: 18px;
  background: rgba(8,26,17,.98);
  box-shadow: 0 20px 60px rgba(0,0,0,.28);
}

.reservation-country__list p,
.reservation-country__list em {
  display: block;
  margin: 0;
  padding: 8px 10px;
  color: rgba(245,255,248,.58);
  font-size: .78rem;
  font-style: normal;
  font-weight: 900;
  text-transform: uppercase;
}

.reservation-country__list button {
  width: 100%;
  display: grid;
  grid-template-columns: 24px 1fr auto;
  align-items: center;
  gap: 10px;
  padding: 10px;
  border-radius: 12px;
  color: #fff;
  text-align: left;
}

.reservation-country__list button:hover,
.reservation-country__list button:focus-visible,
.reservation-country__list button.is-active {
  background: rgba(60,179,113,.18);
}

.reservation-pills {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.reservation-pills button {
  min-height: 44px;
  padding: 0 16px;
  border: 1px solid rgba(255,255,255,.14);
  border-radius: 999px;
  color: #fff;
  background: rgba(255,255,255,.075);
  font-weight: 900;
}

.reservation-pills button.is-active {
  color: #07140f;
  background: #8fe0b4;
}

.reservation-consents {
  display: grid;
  gap: 12px;
}

.reservation-option-row {
  display: grid;
  grid-template-columns: 20px 42px minmax(0, 1fr);
  gap: 12px;
  align-items: center;
  padding: 13px 14px;
  border: 1px solid rgba(255,255,255,.12);
  border-radius: 20px;
  background:
    linear-gradient(145deg, rgba(255,255,255,.075), rgba(255,255,255,.04)),
    rgba(255,255,255,.035);
  color: rgba(245,255,248,.82);
  line-height: 1.55;
  transition: transform .2s ease, border-color .2s ease, background .2s ease;
}

.reservation-option-row:hover {
  transform: translateY(-1px);
  border-color: rgba(143,224,180,.28);
  background: rgba(60,179,113,.10);
}

.reservation-consents input[type='checkbox'] {
  width: 20px;
  height: 20px;
  margin-top: 3px;
  accent-color: #3CB371;
  flex: 0 0 auto;
}

.reservation-option-row i {
  width: 42px;
  height: 42px;
  display: grid;
  place-items: center;
  border-radius: 15px;
  color: #8fe0b4;
  background: rgba(60,179,113,.11);
}

.reservation-option-row strong,
.reservation-option-row small {
  display: block;
}

.reservation-option-row strong {
  color: #fff;
  font-size: .95rem;
}

.reservation-option-row small {
  margin-top: 2px;
  color: rgba(245,255,248,.56);
  font-weight: 650;
  line-height: 1.45;
}

.reservation-reveal-field {
  animation: reservationRevealField .26s cubic-bezier(.22, 1, .36, 1) both;
}

.reservation-late-panel {
  display: grid;
  gap: 12px;
  padding: 15px;
  border-radius: 18px;
  background: rgba(242,192,120,.10);
  border: 1px solid rgba(242,192,120,.20);
}

.reservation-summary {
  position: sticky;
  top: 110px;
}

.reservation-summary.is-pulsing {
  animation: reservationSummaryPulse .52s ease both;
}

.reservation-summary h2,
.reservation-final-summary h2 {
  margin: 0 0 12px;
  color: #fff;
}

.reservation-summary__status {
  display: grid;
  gap: 3px;
  margin-bottom: 14px;
  padding: 12px 13px;
  border: 1px solid rgba(143,224,180,.18);
  border-radius: 16px;
  background: rgba(60,179,113,.10);
}

.reservation-summary__status span {
  color: rgba(245,255,248,.58);
  font-size: .72rem;
  font-weight: 950;
  text-transform: uppercase;
}

.reservation-summary__status strong {
  color: #dffff0;
}

.reservation-summary__badge {
  width: fit-content;
  display: inline-flex;
  margin: 0 0 14px;
  padding: 7px 10px;
  border: 1px solid rgba(242,192,120,.24);
  border-radius: 999px;
  color: #ffe6ba;
  background: rgba(242,192,120,.10);
  font-size: .74rem;
  font-weight: 950;
}

.reservation-summary dl,
.reservation-final-summary dl {
  display: grid;
  gap: 10px;
  margin: 0;
}

.reservation-summary dt,
.reservation-final-summary dt {
  color: rgba(245,255,248,.54);
  font-size: .78rem;
  font-weight: 900;
  text-transform: uppercase;
}

.reservation-summary dd,
.reservation-final-summary dd {
  margin: 2px 0 0;
  color: #fff;
  line-height: 1.5;
}

.reservation-summary__total {
  display: grid;
  gap: 4px;
  margin: 16px 0 12px;
  padding: 15px;
  border-radius: 18px;
  color: #07140f;
  background: linear-gradient(135deg, #8fe0b4, #3CB371);
}

.reservation-summary__total strong {
  font-size: 2rem;
}

.reservation-success {
  margin-top: 14px !important;
  padding: 13px 15px;
  border-radius: 18px;
  color: #07140f !important;
  background: #8fe0b4;
  font-weight: 900;
}

.reservation-summary__deposit {
  margin-top: 12px !important;
  padding: 12px 13px;
  border: 1px solid rgba(242,192,120,.24);
  border-radius: 16px;
  color: #ffe6ba !important;
  background: rgba(242,192,120,.10);
  font-size: .88rem;
}

.reservation-final-summary {
  margin-top: 20px;
}

.reservation-nav {
  display: flex;
  justify-content: space-between;
  gap: 12px;
  margin-top: 18px;
}

.reservation-btn {
  min-height: 52px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 9px;
  padding: 0 22px;
  border-radius: 999px;
  font-weight: 950;
  transition: transform .2s ease, box-shadow .2s ease, border-color .2s ease;
}

.reservation-btn:hover:not(:disabled) {
  transform: translateY(-2px);
}

.reservation-btn:disabled {
  opacity: .44;
  cursor: not-allowed;
}

.reservation-btn--primary {
  color: #07140f;
  background: linear-gradient(135deg, #8fe0b4, #3CB371);
  box-shadow: 0 18px 46px rgba(60,179,113,.26);
}

.reservation-btn--ghost {
  color: #fff;
  border: 1px solid rgba(255,255,255,.16);
  background: rgba(255,255,255,.08);
}

.reservation-help,
.reservation-success-modal {
  position: fixed;
  inset: 0;
  z-index: 100000;
  display: grid;
  pointer-events: auto;
}

.reservation-help__scrim,
.reservation-success-modal::before {
  position: absolute;
  inset: 0;
  background: rgba(2, 8, 5, .62);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
}

.reservation-help__panel,
.reservation-success-modal__card {
  position: relative;
  z-index: 1;
  border: 1px solid rgba(255,255,255,.14);
  background:
    radial-gradient(circle at 12% 0%, rgba(60,179,113,.18), transparent 34%),
    linear-gradient(145deg, rgba(16,36,25,.96), rgba(6,18,13,.96));
  box-shadow: 0 30px 110px rgba(0,0,0,.40);
  color: #f5fff8;
}

.reservation-help__panel {
  width: min(520px, calc(100vw - 24px));
  min-height: 100%;
  justify-self: end;
  padding: clamp(20px, 4vw, 30px);
  overflow-y: auto;
  animation: reservationHelpIn .28s cubic-bezier(.22,1,.36,1) both;
}

.reservation-help__head {
  display: grid;
  grid-template-columns: 54px 1fr 42px;
  gap: 14px;
  align-items: center;
  margin-bottom: 18px;
}

.reservation-help__head > span,
.reservation-success-modal__mark {
  width: 54px;
  height: 54px;
  display: grid;
  place-items: center;
  border-radius: 18px;
  color: #07140f;
  background: linear-gradient(135deg, #8fe0b4, #3CB371);
}

.reservation-help__head h2,
.reservation-success-modal__card h2 {
  margin: 0;
  color: #fff;
}

.reservation-help__head button {
  width: 42px;
  height: 42px;
  border-radius: 999px;
  color: #fff;
  background: rgba(255,255,255,.10);
  font-weight: 950;
}

.reservation-help__sections {
  display: grid;
  gap: 12px;
}

.reservation-help__sections article,
.reservation-help__short {
  display: grid;
  gap: 8px;
  padding: 14px;
  border: 1px solid rgba(255,255,255,.12);
  border-radius: 18px;
  background: rgba(255,255,255,.07);
}

.reservation-help__sections article i {
  width: 28px;
  height: 28px;
  color: #8fe0b4;
}

.reservation-help__sections article strong,
.reservation-help__short strong {
  color: #fff;
}

.reservation-help__sections article p {
  color: rgba(245,255,248,.72);
}

.reservation-help__short {
  margin-top: 14px;
  border-color: rgba(143,224,180,.20);
  background: rgba(60,179,113,.10);
}

.reservation-success-modal {
  place-items: center;
  padding: 20px;
}

.reservation-success-modal__card {
  width: min(760px, 100%);
  max-height: min(760px, calc(100dvh - 40px));
  overflow-y: auto;
  padding: clamp(22px, 4vw, 34px);
  border-radius: 30px;
  animation: reservationStepIn .28s cubic-bezier(.22,1,.36,1) both;
}

.reservation-success-modal__mark {
  margin-bottom: 14px;
}

.reservation-success-modal__card p {
  color: rgba(245,255,248,.74);
}

.reservation-success-modal__card dl {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10px;
  margin: 18px 0;
}

.reservation-success-modal__card dl div {
  padding: 12px;
  border: 1px solid rgba(255,255,255,.10);
  border-radius: 16px;
  background: rgba(255,255,255,.06);
}

.reservation-success-modal__card dt {
  color: rgba(245,255,248,.58);
  font-size: .74rem;
  font-weight: 950;
  text-transform: uppercase;
}

.reservation-success-modal__card dd {
  margin: 3px 0 0;
  color: #fff;
}

.reservation-success-modal__note {
  padding: 13px 14px;
  border: 1px solid rgba(242,192,120,.22);
  border-radius: 18px;
  background: rgba(242,192,120,.10);
}

.reservation-success-modal__actions {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  margin-top: 18px;
}

@media (max-width: 1080px) {
  .reservation-mini__layout {
    grid-template-columns: 1fr;
  }

  .reservation-summary {
    position: static;
  }
}

@media (max-width: 780px) {
  .reservation-mini {
    min-height: auto;
    padding: 82px 14px 96px;
  }

  .reservation-mini__choices,
  .reservation-form-grid,
  .reservation-card-grid {
    grid-template-columns: 1fr;
  }

  .reservation-mini__top {
    display: grid;
  }

  .reservation-mini__top-actions {
    justify-content: stretch;
  }

  .reservation-progress__desktop {
    display: none;
  }

  .reservation-progress__mobile {
    display: block;
  }

  .stay-choice-card,
  .reservation-choice-card {
    min-height: 220px;
  }

  .reservation-item-card {
    grid-template-columns: 50px minmax(0, 1fr);
  }

  .reservation-item-card .reservation-stepper {
    grid-column: 1 / -1;
    justify-self: stretch;
    grid-template-columns: 1fr 1fr 1fr;
  }

  .reservation-stepper button,
  .reservation-stepper strong {
    width: 100%;
    min-height: 48px;
  }

  .reservation-nav {
    display: grid;
    grid-template-columns: 1fr;
  }

  .reservation-presets__grid,
  .reservation-success-modal__card dl {
    grid-template-columns: 1fr;
  }

  .reservation-help__panel {
    width: 100%;
    min-height: auto;
    align-self: end;
    border-radius: 28px 28px 0 0;
    max-height: calc(100dvh - 24px);
  }

  .reservation-btn {
    width: 100%;
  }

  .reservation-mini__note {
    border-radius: 20px;
  }
}

html[data-theme="light"] .reservation-mini {
  color: #122319;
  background:
    radial-gradient(circle at 11% 12%, rgba(60,179,113,.20), transparent 32%),
    radial-gradient(circle at 86% 15%, rgba(242,192,120,.20), transparent 31%),
    linear-gradient(145deg, #f7f8f1 0%, #eaf4e9 50%, #fbfbf6 100%);
}

html[data-theme="light"] .reservation-mini__start,
html[data-theme="light"] .reservation-choice-card,
html[data-theme="light"] .stay-choice-card,
html[data-theme="light"] .reservation-step-card,
html[data-theme="light"] .reservation-details-section,
html[data-theme="light"] .reservation-summary,
html[data-theme="light"] .reservation-item-card,
html[data-theme="light"] .reservation-final-summary,
html[data-theme="light"] .reservation-presets,
html[data-theme="light"] .reservation-simple-panel,
html[data-theme="light"] .reservation-help__panel,
html[data-theme="light"] .reservation-success-modal__card {
  color: #122319;
  border-color: rgba(22,56,36,.12);
  background:
    linear-gradient(145deg, rgba(255,255,255,.84), rgba(255,255,255,.58)),
    radial-gradient(circle at 14% 0%, rgba(60,179,113,.12), transparent 36%);
  box-shadow: 0 24px 80px rgba(44,71,48,.14), inset 0 1px 0 rgba(255,255,255,.72);
}

html[data-theme="light"] .reservation-mini h1,
html[data-theme="light"] .reservation-step-card h2,
html[data-theme="light"] .reservation-summary h2,
html[data-theme="light"] .reservation-final-summary h2,
html[data-theme="light"] .reservation-help__head h2,
html[data-theme="light"] .reservation-success-modal__card h2,
html[data-theme="light"] .reservation-choice-card strong,
html[data-theme="light"] .stay-choice-card strong,
html[data-theme="light"] .reservation-presets strong,
html[data-theme="light"] .reservation-details-section__head strong,
html[data-theme="light"] .reservation-option-row strong,
html[data-theme="light"] .reservation-help__sections article strong,
html[data-theme="light"] .reservation-help__short strong,
html[data-theme="light"] .reservation-item-card strong,
html[data-theme="light"] .reservation-summary dd,
html[data-theme="light"] .reservation-final-summary dd,
html[data-theme="light"] .reservation-success-modal__card dd {
  color: #122319;
}

html[data-theme="light"] .reservation-mini p,
html[data-theme="light"] .reservation-choice-card small,
html[data-theme="light"] .stay-choice-card small,
html[data-theme="light"] .reservation-item-card small,
html[data-theme="light"] .reservation-item-card em,
html[data-theme="light"] .reservation-field small,
html[data-theme="light"] .reservation-details-section__head p,
html[data-theme="light"] .reservation-option-row small,
html[data-theme="light"] .reservation-summary dt,
html[data-theme="light"] .reservation-final-summary dt,
html[data-theme="light"] .reservation-success-modal__card dt,
html[data-theme="light"] .reservation-help__sections article p,
html[data-theme="light"] .reservation-success-modal__card p {
  color: rgba(18,35,25,.68);
}

html[data-theme="light"] .reservation-choice-card__chips i,
html[data-theme="light"] .reservation-mini__toast,
html[data-theme="light"] .reservation-mini__note,
html[data-theme="light"] .reservation-simple-link,
html[data-theme="light"] .reservation-info-grid p,
html[data-theme="light"] .reservation-hint,
html[data-theme="light"] .reservation-summary__status,
html[data-theme="light"] .reservation-summary__deposit,
html[data-theme="light"] .reservation-country__hint,
html[data-theme="light"] .reservation-option-row {
  color: #1b5b3a;
  border-color: rgba(60,179,113,.20);
  background: rgba(60,179,113,.10);
}

html[data-theme="light"] .reservation-field,
html[data-theme="light"] .reservation-pills button,
html[data-theme="light"] .reservation-btn--ghost {
  color: #122319;
}

html[data-theme="light"] .reservation-field input,
html[data-theme="light"] .reservation-field select,
html[data-theme="light"] .reservation-field textarea,
html[data-theme="light"] .reservation-pills button,
html[data-theme="light"] .reservation-progress__desktop button,
html[data-theme="light"] .reservation-progress__mobile,
html[data-theme="light"] .reservation-presets button,
html[data-theme="light"] .reservation-country__list {
  color: #122319;
  border-color: rgba(22,56,36,.14);
  background: rgba(255,255,255,.72);
}

html[data-theme="light"] .reservation-country__list p,
html[data-theme="light"] .reservation-country__list em,
html[data-theme="light"] .reservation-summary__status span {
  color: rgba(18,35,25,.58);
}

html[data-theme="light"] .reservation-summary__status strong,
html[data-theme="light"] .reservation-summary__badge,
html[data-theme="light"] .reservation-summary__deposit {
  color: #1b5b3a;
}

@keyframes reservationPanelIn {
  from { opacity: 0; transform: translateY(24px) scale(.985); }
  to { opacity: 1; transform: translateY(0) scale(1); }
}

@keyframes reservationElementIn {
  from { opacity: 0; transform: translateY(14px); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes reservationCardIn {
  from { opacity: 0; transform: translateY(26px) scale(.965); }
  to { opacity: 1; transform: translateY(0) scale(1); }
}

@keyframes reservationChoiceFloat {
  0%, 100% { translate: 0 0; }
  50% { translate: 0 -6px; }
