interface Props {
  languageCode?: string;
}

type SupportedLang = 'pl' | 'en' | 'de' | 'it' | 'fr' | 'es' | 'nl' | 'cs' | 'sk' | 'sv';

const { languageCode } = Astro.props as Props;
const pathContext = getPathContext(Astro.url.pathname);
const lang = resolveContentLanguage(languageCode ?? pathContext.languageCode) as SupportedLang;
const requestedLanguage = languageCode ?? pathContext.languageCode;
const uiLang = requestedLanguage;
const tourUi = getCoreUi(requestedLanguage).tour;
