---
import { pricingConfig } from '@/data/pricing';
import { getBookingLocalizedPath, getLocalizedPath, getPathContext } from '@/utils/localizedLinks';
import { getTranslations } from '@/i18n/config';
import Icon from '@/components/ui/Icon.astro';

interface Props {
  languageCode?: string;
}

const { languageCode } = Astro.props as Props;
const pathContext = getPathContext(Astro.url.pathname);
const t = getTranslations(languageCode ?? pathContext.languageCode);

const formatPrice = (price: number) => `${price} ${pricingConfig.currency}`;

const getStayType = (id: string) => {
  const stayType = pricingConfig.stayTypes.find((item) => item.id === id);
  if (!stayType) throw new Error(`Missing pricing stay type: ${id}`);
  return stayType;
};

const getAddon = (id: string) => {
  const addon = pricingConfig.addons.find((item) => item.id === id);
  if (!addon) throw new Error(`Missing pricing addon: ${id}`);
  return addon;
};

const formatStayTypePrice = (id: string) => {
  const stayType = getStayType(id);
  if ('seasonalPrices' in stayType) return `${t.pricing.from} ${formatPrice(stayType.seasonalPrices.low)}`;
  return formatPrice(stayType.price);
};

const prices = [
  { label: t.pricing.adults, price: formatPrice(pricingConfig.people.adults.price), icon: 'user' },
  { label: t.pricing.children, price: formatPrice(pricingConfig.people.children.price), icon: 'baby' },
  { label: t.pricing.stayTypes.camper, price: formatStayTypePrice('camper'), icon: 'camper' },
  { label: t.pricing.stayTypes.caravan, price: formatStayTypePrice('caravan'), icon: 'caravan' },
  { label: t.pricing.stayTypes.van, price: formatStayTypePrice('van'), icon: 'busFront' },
  { label: t.pricing.stayTypes['tent-small'], price: formatStayTypePrice('tent-small'), icon: 'tent' },
  { label: t.pricing.stayTypes['tent-large'], price: formatStayTypePrice('tent-large'), icon: 'tent' },
  { label: t.pricing.addons['cargo-trailer'], price: formatPrice(getAddon('cargo-trailer').price), icon: 'caravan' },
  { label: t.pricing.stayTypes['bungalow-2'], price: formatStayTypePrice('bungalow-2'), icon: 'bungalow' },
  { label: t.pricing.stayTypes['bungalow-3'], price: formatStayTypePrice('bungalow-3'), icon: 'bungalow' },
  { label: t.pricing.stayTypes['bungalow-4'], price: formatStayTypePrice('bungalow-4'), icon: 'bungalow' },
  { label: t.pricing.addons.electricity, price: formatPrice(getAddon('electricity').price), icon: 'electricity' },
  { label: t.pricing.addons.dog, price: formatPrice(getAddon('dog').price), icon: 'dog' },
  { label: t.pricing.addons.bus, price: formatPrice(getAddon('bus').price), icon: 'truck' },
];

const fullPricingHref = getLocalizedPath(pathContext.explicitLanguage, 'cennik');
const bookingHref = getBookingLocalizedPath(pathContext.languageCode);
const pricingCalculatorHref = `${fullPricingHref}#oblicz-koszt`;
const sectionCopyByLanguage = {
  pl: {
    badge: 'Ceny orientacyjne',
    lead: 'Zbuduj własny wariant pobytu i zobacz koszt jednej nocy przed wysłaniem zapytania do recepcji.',
    calculate: 'Oblicz koszt',
    booking: 'Zarezerwuj pobyt',
    disclaimer: 'Ceny są orientacyjne. Finalne warunki potwierdza recepcja.',
  },
  en: {
    badge: 'Estimated prices',
    lead: 'Build your stay and check an estimated nightly cost before sending an enquiry to reception.',
    calculate: 'Calculate cost',
    booking: 'Book your stay',
    disclaimer: 'Prices are estimates. Final conditions are confirmed by reception.',
  },
  de: {
    badge: 'Richtpreise',
    lead: 'Stellen Sie Ihren Aufenthalt zusammen und sehen Sie den geschätzten Nachtpreis vor der Anfrage.',
    calculate: 'Kosten berechnen',
    booking: 'Aufenthalt buchen',
    disclaimer: 'Preise sind Richtwerte. Die Rezeption bestätigt die finalen Bedingungen.',
  },
  it: {
    badge: 'Prezzi indicativi',
    lead: 'Costruisci il soggiorno e controlla il costo stimato di una notte prima della richiesta.',
    calculate: 'Calcola costo',
    booking: 'Prenota il soggiorno',
    disclaimer: 'I prezzi sono indicativi. La reception conferma le condizioni finali.',
  },
  fr: {
    badge: 'Tarifs indicatifs',
    lead: 'Composez votre séjour et consultez le coût estimé d’une nuit avant d’envoyer la demande.',
    calculate: 'Calculer le coût',
    booking: 'Envoyer une demande',
    disclaimer: 'Les tarifs sont indicatifs. La réception confirme les conditions finales.',
  },
  es: {
    badge: 'Precios orientativos',
    lead: 'Construye tu estancia y consulta el coste estimado por noche antes de enviar la consulta.',
    calculate: 'Calcular coste',
    booking: 'Enviar consulta',
    disclaimer: 'Los precios son orientativos. Recepción confirma las condiciones finales.',
  },
  nl: {
    badge: 'Indicatieve prijzen',
    lead: 'Stel je verblijf samen en bekijk de geschatte nachtprijs voordat je een aanvraag stuurt.',
    calculate: 'Kosten berekenen',
    booking: 'Aanvraag sturen',
    disclaimer: 'Prijzen zijn indicatief. De receptie bevestigt de definitieve voorwaarden.',
  },
  cs: {
    badge: 'Orientační ceny',
    lead: 'Sestavte pobyt a zjistěte odhad ceny za noc před odesláním dotazu.',
    calculate: 'Spočítat cenu',
    booking: 'Odeslat dotaz',
    disclaimer: 'Ceny jsou orientační. Konečné podmínky potvrzuje recepce.',
  },
  sk: {
    badge: 'Orientačné ceny',
    lead: 'Zostavte pobyt a zistite odhad ceny za noc pred odoslaním dopytu.',
    calculate: 'Spočítať cenu',
    booking: 'Odoslať dopyt',
    disclaimer: 'Ceny sú orientačné. Konečné podmienky potvrdzuje recepcia.',
  },
  sv: {
    badge: 'Ungefärliga priser',
    lead: 'Bygg din vistelse och se uppskattad nattkostnad innan du skickar en förfrågan.',
    calculate: 'Beräkna kostnad',
    booking: 'Skicka förfrågan',
    disclaimer: 'Priserna är uppskattningar. Receptionen bekräftar slutliga villkor.',
  },
};
const sectionCopy = sectionCopyByLanguage[pathContext.languageCode as keyof typeof sectionCopyByLanguage] ?? sectionCopyByLanguage.en;
---

<section class="site-section pricing reveal-section" id="cennik">
  <span class="pricing__glow pricing__glow--one" aria-hidden="true"></span>
  <span class="pricing__glow pricing__glow--two" aria-hidden="true"></span>
  <div class="container">
    <div class="pricing__head">
      <div>
        <span class="section-kicker">{t.pages.cennik.overline}</span>
        <h2 class="section-title">{t.pages.cennik.title}</h2>
        <p class="pricing__lead">{sectionCopy.lead}</p>
      </div>
      <span class="pricing__badge"><Icon name="sparkles" size={16} />{sectionCopy.badge}</span>
    </div>
    <div class="pricing__grid">
      {prices.map((item) => (
        <div class="premium-card pricing__item">
          <i aria-hidden="true"><Icon name={item.icon} size={22} strokeWidth={1.85} /></i>
          <span>{item.label}</span>
          <strong>{item.price}</strong>
        </div>
      ))}
    </div>
    <div class="pricing__footer">
      <p><Icon name="info" size={17} />{sectionCopy.disclaimer}</p>
      <div class="pricing__actions">
        <a class="btn btn-glass" href={fullPricingHref}>{t.cta.pricing}</a>
        <a class="btn btn-glass" href={pricingCalculatorHref}>{sectionCopy.calculate}</a>
        <a class="btn btn-primary premium-button" href={bookingHref}>{sectionCopy.booking}</a>
      </div>
    </div>
  </div>
</section>

<style>
.pricing {
  position: relative;
  overflow: hidden;
  background:
    radial-gradient(circle at 12% 0%, rgba(60,179,113,.34), transparent 34%),
    radial-gradient(circle at 88% 14%, rgba(242,192,120,.18), transparent 32%),
    linear-gradient(145deg, #0b1910, #122b1c 54%, #0d2116);
  color: #fff;
}
.pricing::before {
  content: '';
  position: absolute;
  inset: 0;
  pointer-events: none;
  opacity: .34;
  background: repeating-linear-gradient(135deg, rgba(255,255,255,.055) 0 1px, transparent 1px 34px);
}
.pricing__glow { position: absolute; border-radius: 999px; filter: blur(30px); pointer-events: none; opacity: .55; }
.pricing__glow--one { width: 320px; height: 320px; left: -100px; bottom: -100px; background: rgba(60,179,113,.24); }
.pricing__glow--two { width: 260px; height: 260px; right: -70px; top: 12%; background: rgba(242,192,120,.16); }
.pricing .container { position: relative; z-index: 1; }
.pricing .section-title { color: #fff; }
.pricing .section-kicker { color: #8fe0b4; }
.pricing__head { display: flex; flex-direction: column; gap: 24px; justify-content: space-between; }
.pricing__lead { max-width: 720px; margin: 16px 0 0; color: rgba(239,255,245,.72); line-height: 1.7; font-weight: 720; }
.pricing__badge { display: inline-flex; width: fit-content; align-items: center; gap: 8px; padding: 10px 14px; border: 1px solid rgba(143,224,180,.30); border-radius: 999px; color: #dffff0; background: rgba(60,179,113,.14); font-size: .78rem; font-weight: 950; text-transform: uppercase; letter-spacing: .08em; }
.pricing__grid { margin-top: 42px; display: grid; grid-template-columns: 1fr; gap: 14px; }
.pricing__item { min-width: 0; padding: 18px; background: linear-gradient(145deg, rgba(255,255,255,.12), rgba(255,255,255,.055)); border-color: rgba(143,224,180,.18); color: #fff; display: grid; grid-template-columns: 48px 1fr auto; align-items: center; gap: 14px; box-shadow: 0 20px 52px rgba(0,0,0,.16), inset 0 1px 0 rgba(255,255,255,.08); transition: transform .25s ease, border-color .25s ease, background .25s ease, box-shadow .25s ease; }
.pricing__item:hover { transform: translateY(-5px); border-color: rgba(143,224,180,.42); background: linear-gradient(145deg, rgba(60,179,113,.22), rgba(255,255,255,.075)); box-shadow: 0 28px 68px rgba(0,0,0,.22), 0 0 30px rgba(60,179,113,.12); }
.pricing__item i { width: 52px; height: 52px; display: grid; place-items: center; border-radius: 20px; color: #f5fff8; border: 1px solid rgba(143,224,180,.30); background: radial-gradient(circle at 30% 18%, rgba(255,255,255,.24), transparent 34%), linear-gradient(135deg, rgba(60,179,113,.34), rgba(60,179,113,.14)); box-shadow: 0 16px 38px rgba(60,179,113,.18), inset 0 1px 0 rgba(255,255,255,.16); transition: transform .22s ease, background .22s ease, box-shadow .22s ease, border-color .22s ease; }
.pricing__item svg { width: 24px; height: 24px; fill: none; stroke: currentColor; stroke-width: 1.85; stroke-linecap: round; stroke-linejoin: round; }
.pricing__item:hover i { transform: translateY(-2px) scale(1.03); border-color: rgba(143,224,180,.54); background: radial-gradient(circle at 30% 18%, rgba(255,255,255,.32), transparent 34%), linear-gradient(135deg, #55d293, #3CB371); box-shadow: 0 20px 48px rgba(60,179,113,.30), 0 0 28px rgba(60,179,113,.18); }
.pricing__item span { color: rgba(255,255,255,.76); font-weight: 800; }
.pricing__item strong { font-size: 1.08rem; text-align: right; white-space: nowrap; }
.pricing__footer { display: flex; flex-direction: column; gap: 20px; align-items: flex-start; justify-content: space-between; margin-top: 30px; padding: 22px; border: 1px solid rgba(143,224,180,.18); border-radius: 24px; background: rgba(255,255,255,.07); }
.pricing__footer p { display: inline-flex; align-items: flex-start; gap: 9px; margin: 0; color: rgba(239,255,245,.72); line-height: 1.55; font-weight: 760; }
.pricing__actions { display: flex; flex-wrap: wrap; gap: 10px; }
.pricing__actions a { min-height: 46px; }
@media (min-width: 760px) { .pricing__head { flex-direction: row; align-items: end; } .pricing__grid { grid-template-columns: repeat(2, 1fr); } .pricing__footer { flex-direction: row; align-items: center; padding-right: clamp(22px, 7vw, 112px); } }
@media (min-width: 1120px) { .pricing__grid { grid-template-columns: repeat(4, 1fr); } }
@media (max-width: 520px) { .pricing__item { grid-template-columns: 44px 1fr; } .pricing__item strong { grid-column: 2; text-align: left; } .pricing__item i { width: 44px; height: 44px; grid-row: span 2; } .pricing__actions { width: 100%; display: grid; } .pricing__actions a { width: 100%; justify-content: center; } .pricing__item:hover { transform: none; } }
@media (prefers-reduced-motion: reduce) { .pricing__item, .pricing__item i { transition: none !important; } }
</style>
