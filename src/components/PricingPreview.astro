---
import { pricingConfig } from '@/data/pricing';
import { getLocalizedPath, getPathContext } from '@/utils/localizedLinks';

const formatPrice = (price: number) => `${price} ${pricingConfig.currency}`;

const getStayType = (id: string) => {
  const stayType = pricingConfig.stayTypes.find((item) => item.id === id);
  if (!stayType) throw new Error(`Missing pricing stay type: ${id}`);
  return stayType;
};

const getAddon = (id: string) => {
  const addon = pricingConfig.addons.find((item) => item.id === id);
  if (!addon) throw new Error(`Missing pricing addon: ${id}`);
  return addon;
};

const formatStayTypePrice = (id: string) => {
  const stayType = getStayType(id);
  if ('seasonalPrices' in stayType) return `od ${formatPrice(stayType.seasonalPrices.low)}`;
  if ('startingPrice' in stayType) return `od ${formatPrice(stayType.startingPrice)}`;
  return formatPrice(stayType.price);
};

const prices = [
  [pricingConfig.people.adults.label, formatPrice(pricingConfig.people.adults.price)],
  [pricingConfig.people.children.label, formatPrice(pricingConfig.people.children.price)],
  [getStayType('camper').label, formatStayTypePrice('camper')],
  [getStayType('caravan').label, formatStayTypePrice('caravan')],
  [getStayType('van').label, formatStayTypePrice('van')],
  [getStayType('tent-small').label, formatStayTypePrice('tent-small')],
  [getStayType('tent-large').label, formatStayTypePrice('tent-large')],
  [getStayType('bungalow-2').label, formatStayTypePrice('bungalow-2')],
  [getStayType('bungalow-3').label, formatStayTypePrice('bungalow-3')],
  [getStayType('bungalow-4').label, formatStayTypePrice('bungalow-4')],
  [getStayType('bungalow-family').label, formatStayTypePrice('bungalow-family')],
  [getAddon('electricity').label, formatPrice(getAddon('electricity').price)],
  [getAddon('dog').label, formatPrice(getAddon('dog').price)],
  [getAddon('bus').label, formatPrice(getAddon('bus').price)],
];

const pathContext = getPathContext(Astro.url.pathname);
const fullPricingHref = getLocalizedPath(pathContext.explicitLanguage, 'cennik');
---

<section class="site-section pricing reveal-section" id="cennik">
  <div class="container">
    <div class="pricing__head">
      <div>
        <span class="section-kicker">Cennik</span>
        <h2 class="section-title">Najważniejsze ceny w szybkim podglądzie.</h2>
      </div>
      <a class="premium-button" href={fullPricingHref}>Pełny cennik</a>
    </div>
    <div class="pricing__grid">
      {prices.map(([label, price]) => (
        <div class="premium-card pricing__item">
          <span>{label}</span>
          <strong>{price}</strong>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
.pricing { background: #101b14; color: #fff; }
.pricing .section-title { color: #fff; }
.pricing .section-kicker { color: #8fe0b4; }
.pricing__head { display: flex; flex-direction: column; gap: 24px; justify-content: space-between; }
.pricing__grid { margin-top: 42px; display: grid; grid-template-columns: 1fr; gap: 14px; }
.pricing__item { padding: 22px; background: rgba(255,255,255,.08); border-color: rgba(255,255,255,.12); color: #fff; display: flex; align-items: center; justify-content: space-between; gap: 18px; }
.pricing__item span { color: rgba(255,255,255,.76); font-weight: 800; }
.pricing__item strong { font-size: 1.15rem; }
@media (min-width: 760px) { .pricing__head { flex-direction: row; align-items: end; } .pricing__grid { grid-template-columns: repeat(2, 1fr); } }
@media (min-width: 1120px) { .pricing__grid { grid-template-columns: repeat(4, 1fr); } }
</style>
