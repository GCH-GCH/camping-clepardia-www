---
import { publicAssetExists, siteAssets } from '@/data/assets';
import { getTranslations } from '@/i18n/config';
import { getLocalizedPath, getPathContext } from '@/utils/localizedLinks';
import Icon from '@/components/ui/Icon.astro';

interface Props {
  languageCode?: string;
}

const { languageCode } = Astro.props as Props;
const pathContext = getPathContext(Astro.url.pathname);
const activeLanguage = languageCode ?? pathContext.languageCode;
const explicitLanguage = pathContext.explicitLanguage ?? (languageCode && languageCode !== 'pl' ? languageCode : undefined);
const t = getTranslations(activeLanguage);
const contactHref = getLocalizedPath(explicitLanguage, 'kontakt');
const pricingHref = getLocalizedPath(explicitLanguage, 'cennik');

const heroDesktopExists = publicAssetExists(siteAssets.hero.desktop);
const heroMobileExists = publicAssetExists(siteAssets.hero.mobile);
const heroTextureExists = publicAssetExists(siteAssets.hero.overlayTexture);

const heroStyle = [
  heroDesktopExists ? `--hero-bg-desktop: url('${siteAssets.hero.desktop}')` : '',
  heroMobileExists ? `--hero-bg-mobile: url('${siteAssets.hero.mobile}')` : '',
  heroTextureExists ? `--hero-texture: url('${siteAssets.hero.overlayTexture}')` : '',
].filter(Boolean).join(';');
---

<section
  class:list={[
    'hero',
    heroDesktopExists ? 'hero--image' : 'hero--fallback',
    heroMobileExists && 'hero--mobile-image',
    heroTextureExists && 'hero--texture',
  ]}
  id="hero"
  style={heroStyle || undefined}
>
  <div class="hero__parallax" data-hero-parallax aria-hidden="true"></div>
  <div class="hero__overlay hero__overlay--texture"></div>
  <div class="hero__overlay hero__overlay--cinematic"></div>
  <div class="hero__overlay hero__overlay--vignette"></div>
  <div class="hero__overlay hero__overlay--noise"></div>
  <div class="hero__overlay hero__overlay--warm"></div>
  <div class="hero__overlay hero__overlay--green"></div>

  <div class="hero__wrapper">
    <div class="hero__content">
      <span class="hero__badge">{t.home.hero.badge}</span>
      <h1 class="hero__headline" aria-label="Camping Clepardia">
        <span class="hero__headline-line">{t.home.hero.title.split(' ')[0] ?? 'Camping'}</span>
        <span class="hero__headline-line">{t.home.hero.title.split(' ').slice(1).join(' ') || 'Clepardia'}</span>
      </h1>
      <p class="hero__subheadline">
        <span>{t.home.hero.subtitle}</span>
      </p>
      <p class="hero__description">
        {t.home.hero.copy}
      </p>
      <div class="hero__cta">
        <a href={contactHref} class="btn btn-primary btn-large hero__button hero__button--primary">{t.home.hero.primary}</a>
        <a href={pricingHref} class="btn btn-glass btn-large hero__button hero__button--secondary">{t.home.hero.secondary}</a>
      </div>
    </div>
  </div>

  <div class="hero__floating-badges" aria-label="Camping Clepardia">
    {t.home.hero.badges.map((badge) => <span>{badge}</span>)}
  </div>

  <div class="hero__benefits-bar" aria-label="Camping Clepardia">
    <div class="benefits-wrapper">
      <div class="hero__benefit">
        <Icon name="tram" />
        <span>{t.home.hero.benefits[0]}</span>
      </div>
      <div class="hero__benefit">
        <Icon name="bungalow" />
        <span>{t.home.hero.benefits[1]}</span>
      </div>
      <div class="hero__benefit">
        <Icon name="camping" />
        <span>{t.home.hero.benefits[2]}</span>
      </div>
      <div class="hero__benefit">
        <Icon name="shield" />
        <span>{t.home.hero.badges[1]}</span>
      </div>
    </div>
  </div>

  <a href="#dlaczego" class="hero__scroll-indicator" aria-label={t.home.hero.scroll}>
    <span class="hero__mouse" aria-hidden="true"><i></i></span>
    <span class="hero__scroll-text">{t.home.hero.scroll}</span>
  </a>
</section>

<script>
  const hero = document.querySelector('.hero');
  const heroParallax = document.querySelector('[data-hero-parallax]');
  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
  const wideViewport = window.matchMedia('(min-width: 768px)');

  if (hero instanceof HTMLElement && heroParallax instanceof HTMLElement && !reducedMotion.matches && wideViewport.matches) {
    let ticking = false;

    const updateHeroParallax = () => {
      ticking = false;
      const rect = hero.getBoundingClientRect();
      const viewport = window.innerHeight || 1;

      if (rect.bottom < 0 || rect.top > viewport) return;

      const progress = Math.max(-1, Math.min(1, rect.top / viewport));
      heroParallax.style.transform = `translate3d(0, ${progress * -38}px, 0) scale(1.06)`;
    };

    const requestUpdate = () => {
      if (ticking) return;
      ticking = true;
      window.requestAnimationFrame(updateHeroParallax);
    };

    window.addEventListener('scroll', requestUpdate, { passive: true });
    window.addEventListener('resize', requestUpdate, { passive: true });
    updateHeroParallax();
  }
</script>

<style is:global>
.hero {
  position: relative;
  min-height: 106svh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  overflow: hidden;
  color: #fff;
  background:
    radial-gradient(circle at 72% 28%, rgba(237, 163, 82, .24), transparent 34%),
    radial-gradient(circle at 18% 58%, rgba(60, 179, 113, .20), transparent 32%),
    linear-gradient(125deg, #06100c 0%, #0b2018 42%, #11100c 72%, #211408 100%);
  isolation: isolate;
}

.hero__parallax {
  position: absolute;
  inset: -7%;
  z-index: 0;
  background-size: cover;
  background-position: center center;
  background-repeat: no-repeat;
  transform: translate3d(0, 0, 0) scale(1.06);
  will-change: transform;
}

.hero--image .hero__parallax {
  background-image:
    var(--hero-bg-desktop),
    radial-gradient(circle at 74% 30%, rgba(237, 163, 82, .22), transparent 34%),
    radial-gradient(circle at 18% 58%, rgba(60, 179, 113, .18), transparent 32%),
    linear-gradient(125deg, #06100c 0%, #0b2018 42%, #11100c 72%, #211408 100%);
}

.hero--fallback .hero__parallax {
  background:
    radial-gradient(circle at 74% 30%, rgba(237, 163, 82, .22), transparent 34%),
    radial-gradient(circle at 18% 58%, rgba(60, 179, 113, .18), transparent 32%),
    linear-gradient(125deg, #06100c 0%, #0b2018 42%, #11100c 72%, #211408 100%);
}

.hero__overlay {
  position: absolute;
  inset: 0;
  pointer-events: none;
  z-index: 1;
}

.hero__overlay--texture {
  display: none;
  background-image: var(--hero-texture);
  background-size: cover;
  background-position: center;
  opacity: .14;
  mix-blend-mode: soft-light;
}

.hero--texture .hero__overlay--texture {
  display: block;
}

.hero__overlay--cinematic {
  background:
    linear-gradient(90deg, rgba(2, 8, 5, .92) 0%, rgba(4, 17, 11, .76) 34%, rgba(7, 24, 16, .34) 70%, rgba(9, 18, 13, .10) 100%),
    linear-gradient(180deg, rgba(0, 0, 0, .32) 0%, transparent 34%, rgba(0, 0, 0, .55) 100%);
}

.hero__overlay--vignette {
  background:
    radial-gradient(ellipse at center, transparent 30%, rgba(0,0,0,.18) 62%, rgba(0,0,0,.62) 100%),
    linear-gradient(180deg, rgba(0,0,0,.18), transparent 42%, rgba(0,0,0,.28));
}

.hero__overlay--noise {
  opacity: .12;
  mix-blend-mode: overlay;
  background-image:
    radial-gradient(circle at 20% 30%, rgba(255,255,255,.18) 0 1px, transparent 1px 3px),
    radial-gradient(circle at 80% 12%, rgba(255,255,255,.12) 0 1px, transparent 1px 4px);
  background-size: 3px 3px, 5px 5px;
}

.hero__overlay--warm {
  background: radial-gradient(circle at 78% 34%, rgba(255, 184, 98, .20), rgba(255, 184, 98, .07) 24%, transparent 48%);
  mix-blend-mode: screen;
}

.hero__overlay--green {
  background:
    radial-gradient(circle at 20% 42%, rgba(60, 179, 113, .22), rgba(60, 179, 113, .07) 25%, transparent 50%),
    radial-gradient(circle at 58% 86%, rgba(60, 179, 113, .14), transparent 34%);
}

.hero__wrapper {
  position: relative;
  z-index: 2;
  width: 100%;
  max-width: 1440px;
  margin: 0 auto;
  padding: 140px 32px 170px;
}

.hero__content {
  max-width: 620px;
  animation: heroFade .9s ease both;
}

.hero__badge {
  display: inline-flex;
  padding: 10px 16px;
  margin-bottom: 28px;
  border-radius: 999px;
  border: 1px solid rgba(255,255,255,.16);
  background: rgba(255,255,255,.08);
  backdrop-filter: blur(14px);
  color: rgba(255,255,255,.88);
  font-size: .76rem;
  font-weight: 800;
  letter-spacing: .14em;
  text-transform: uppercase;
  box-shadow: 0 18px 44px rgba(0,0,0,.18), inset 0 1px 0 rgba(255,255,255,.10);
  animation: heroFade .9s cubic-bezier(.22, 1, .36, 1) .02s both;
}

.hero__headline {
  margin: 0 0 22px;
  max-width: 620px;
  color: #fff;
  font-size: clamp(2.8rem, 13vw, 4.4rem);
  line-height: .9;
  font-weight: 900;
  letter-spacing: 0;
  text-shadow: 0 4px 22px rgba(0,0,0,.48), 0 16px 54px rgba(0,0,0,.34);
}

.hero__headline-line {
  display: block;
  overflow: hidden;
  animation: heroLineReveal 1s cubic-bezier(.22, 1, .36, 1) both;
}

.hero__headline-line:nth-child(2) {
  animation-delay: .10s;
}

.hero__subheadline {
  display: grid;
  gap: 2px;
  margin: 0 0 18px;
  color: rgba(255,255,255,.94);
  font-size: clamp(1.18rem, 3vw, 1.55rem);
  line-height: 1.45;
  font-weight: 750;
  text-shadow: 0 2px 18px rgba(0,0,0,.38);
  animation: heroFade .9s cubic-bezier(.22, 1, .36, 1) .24s both;
}

.hero__subheadline span {
  display: block;
}

.hero__description {
  max-width: 620px;
  margin: 0 0 38px;
  color: rgba(255,255,255,.88);
  font-size: clamp(1rem, 1.7vw, 1.12rem);
  line-height: 1.75;
  text-shadow: 0 2px 16px rgba(0,0,0,.3);
  animation: heroFade .9s cubic-bezier(.22, 1, .36, 1) .34s both;
}

.hero__cta {
  display: flex;
  gap: 14px;
  flex-wrap: wrap;
  animation: heroFade .9s cubic-bezier(.22, 1, .36, 1) .46s both;
}

.hero__button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 52px;
  padding: 17px 30px;
  border-radius: 999px;
  font-size: .92rem;
  font-weight: 900;
  letter-spacing: .08em;
  text-transform: uppercase;
  transition: transform .25s ease, box-shadow .25s ease, background .25s ease, border-color .25s ease;
  overflow: hidden;
  isolation: isolate;
}

.hero__button--primary {
  color: #fff;
  background: linear-gradient(135deg, #63d99c 0%, #3CB371 45%, #1f744b 100%);
  box-shadow: 0 22px 58px rgba(60,179,113,.42), inset 0 1px 0 rgba(255,255,255,.30);
}

.hero__button--primary::before {
  content: '';
  position: absolute;
  inset: -3px;
  z-index: 1;
  background: linear-gradient(115deg, transparent 0%, transparent 34%, rgba(255,255,255,.48) 46%, transparent 58%, transparent 100%);
  transform: translateX(-130%) skewX(-18deg);
  transition: transform .75s cubic-bezier(.22, 1, .36, 1);
  pointer-events: none;
}

.hero__button--primary:hover {
  color: #fff;
  transform: translateY(-3px);
  box-shadow: 0 24px 64px rgba(60,179,113,.48), 0 8px 26px rgba(0,0,0,.24), inset 0 1px 0 rgba(255,255,255,.34);
}

.hero__button--primary:hover::before {
  transform: translateX(130%) skewX(-18deg);
}

.hero__button--secondary {
  color: #fff;
  border: 1px solid rgba(255,255,255,.24);
  background: rgba(255,255,255,.10);
  box-shadow: inset 0 1px 0 rgba(255,255,255,.10);
  backdrop-filter: blur(18px) saturate(140%);
  -webkit-backdrop-filter: blur(18px) saturate(140%);
}

.hero__button--secondary:hover {
  color: #fff;
  transform: translateY(-3px);
  border-color: rgba(255,255,255,.42);
  background: rgba(255,255,255,.15);
  backdrop-filter: blur(22px);
  box-shadow: 0 18px 44px rgba(0,0,0,.24);
}

.hero__benefits-bar {
  position: absolute;
  left: 50%;
  bottom: 28px;
  z-index: 3;
  width: min(1180px, calc(100% - 40px));
  transform: translateX(-50%);
  padding: 22px 26px;
  border-radius: 28px;
  border: 1px solid rgba(255,255,255,.12);
  background: rgba(8, 20, 15, .54);
  backdrop-filter: blur(22px);
  box-shadow: 0 24px 80px rgba(0,0,0,.34), inset 0 1px 0 rgba(255,255,255,.08);
  animation: benefitRise .9s ease .45s both;
}

.benefits-wrapper {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 18px;
}

.hero__benefit {
  display: flex;
  align-items: center;
  gap: 12px;
  color: rgba(255,255,255,.92);
  font-size: .82rem;
  font-weight: 850;
  letter-spacing: .08em;
  text-transform: uppercase;
}

.hero__benefit svg {
  width: 25px;
  height: 25px;
  flex: 0 0 25px;
  fill: none;
  stroke: #8fe0b4;
  stroke-width: 1.8;
  stroke-linecap: round;
  stroke-linejoin: round;
  filter: drop-shadow(0 4px 14px rgba(60,179,113,.24));
}

.hero__floating-badges {
  position: absolute;
  right: max(26px, calc((100vw - 1440px) / 2 + 42px));
  top: 50%;
  z-index: 3;
  display: grid;
  gap: 14px;
  width: min(280px, 25vw);
  transform: translateY(-42%);
  pointer-events: none;
}

.hero__floating-badges span {
  display: inline-flex;
  width: fit-content;
  min-height: 48px;
  align-items: center;
  padding: 12px 16px;
  border: 1px solid rgba(255,255,255,.14);
  border-radius: 999px;
  color: rgba(255,255,255,.90);
  background: rgba(7, 20, 14, .42);
  box-shadow: 0 18px 48px rgba(0,0,0,.22), inset 0 1px 0 rgba(255,255,255,.10);
  backdrop-filter: blur(18px) saturate(140%);
  -webkit-backdrop-filter: blur(18px) saturate(140%);
  font-size: .78rem;
  font-weight: 900;
  letter-spacing: .08em;
  text-transform: uppercase;
  animation: badgeFloat 4.8s ease-in-out infinite;
}

.hero__floating-badges span:nth-child(1) {
  animation-delay: .34s;
}

.hero__floating-badges span:nth-child(2) {
  justify-self: end;
  animation-delay: .74s;
}

.hero__floating-badges span:nth-child(3) {
  margin-left: 28px;
  animation-delay: 1.12s;
}

.hero__floating-badges span:nth-child(4) {
  justify-self: center;
  color: #102018;
  background: rgba(255,255,255,.76);
  border-color: rgba(255,255,255,.42);
  animation-delay: 1.48s;
}

.hero__scroll-indicator {
  position: absolute;
  left: 50%;
  bottom: 18px;
  z-index: 4;
  width: auto;
  min-width: 74px;
  transform: translateX(-50%);
  display: grid;
  justify-items: center;
  gap: 8px;
  color: rgba(255,255,255,.72);
}

.hero__mouse {
  width: 24px;
  height: 38px;
  display: grid;
  place-items: start center;
  padding-top: 7px;
  border: 1px solid rgba(255,255,255,.34);
  border-radius: 999px;
  background: rgba(255,255,255,.06);
  box-shadow: 0 12px 32px rgba(0,0,0,.18);
}

.hero__mouse i {
  width: 4px;
  height: 4px;
  border-radius: 999px;
  background: rgba(255,255,255,.72);
  animation: scrollDot 1.8s ease-in-out infinite;
}

.hero__scroll-text {
  color: rgba(255,255,255,.66);
  font-size: .66rem;
  font-weight: 900;
  letter-spacing: .16em;
  text-transform: uppercase;
}

@media (min-width: 900px) {
  .hero__headline { font-size: clamp(3.8rem, 7vw, 6.2rem); }
}

@media (max-width: 860px) {
  .hero--mobile-image .hero__parallax {
    background-image:
      var(--hero-bg-mobile),
      radial-gradient(circle at 74% 30%, rgba(237, 163, 82, .22), transparent 34%),
      radial-gradient(circle at 18% 58%, rgba(60, 179, 113, .18), transparent 32%),
      linear-gradient(125deg, #06100c 0%, #0b2018 42%, #11100c 72%, #211408 100%);
  }

  .hero { min-height: 100svh; }
  .hero__wrapper { padding: 126px 20px 270px; }
  .benefits-wrapper { grid-template-columns: repeat(2, 1fr); }
  .hero__floating-badges {
    left: 20px;
    right: 20px;
    top: auto;
    bottom: 178px;
    width: auto;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    transform: none;
  }

  .hero__floating-badges span {
    width: 100%;
    justify-content: center;
    min-height: 42px;
    font-size: .68rem;
    text-align: center;
  }

  .hero__floating-badges span:nth-child(n) {
    justify-self: stretch;
    margin-left: 0;
  }
}

@media (max-width: 560px) {
  .hero__wrapper { padding: 118px 18px 384px; }
  .hero__badge { font-size: .68rem; letter-spacing: .1em; }
  .hero__cta { flex-direction: column; }
  .hero__button { width: 100%; }
  .hero__floating-badges {
    bottom: 224px;
    grid-template-columns: 1fr;
    gap: 9px;
  }
  .hero__floating-badges span {
    min-height: 38px;
    padding: 10px 12px;
  }
  .hero__benefits-bar { bottom: 18px; padding: 18px; }
  .benefits-wrapper { grid-template-columns: 1fr; gap: 14px; }
  .hero__benefit { font-size: .75rem; }
  .hero__scroll-indicator { display: none; }
}

@media (prefers-reduced-motion: reduce) {
  .hero__parallax {
    will-change: auto;
    transform: scale(1.02);
  }

  .hero__badge,
  .hero__headline-line,
  .hero__subheadline,
  .hero__description,
  .hero__cta,
  .hero__benefits-bar,
  .hero__floating-badges span,
  .hero__mouse i {
    animation: none;
  }

  .hero__button,
  .hero__button:hover {
    transform: none;
  }
}

@keyframes heroFade {
  from { opacity: 0; transform: translateY(16px); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes heroLineReveal {
  from { opacity: 0; transform: translateY(110%) rotate(1.5deg); }
  to { opacity: 1; transform: translateY(0) rotate(0deg); }
}

@keyframes benefitRise {
  from { opacity: 0; transform: translateX(-50%) translateY(18px); }
  to { opacity: 1; transform: translateX(-50%) translateY(0); }
}

@keyframes badgeFloat {
  0%, 100% { transform: translate3d(0, 0, 0); }
  50% { transform: translate3d(0, -7px, 0); }
}

@keyframes scrollDot {
  0%, 100% { transform: translateY(0); opacity: .5; }
  50% { transform: translateY(12px); opacity: 1; }
}
</style>
