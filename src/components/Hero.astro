---
// Camping Clepardia Hero Section - Hard Reset
---

<section class="hero" id="hero">
  {/* Overlays */}
  <div class="hero__overlay hero__overlay--gradient"></div>
  <div class="hero__overlay hero__overlay--bottom"></div>
  <div class="hero__overlay hero__overlay--glow"></div>

  {/* Main Content */}
  <div class="hero__wrapper">
    <div class="hero__content">
      <span class="hero__badge">Camping w Krakowie • Blisko centrum</span>

      <h1 class="hero__headline">Camping Clepardia</h1>

      <p class="hero__subheadline">Komfortowy camping w Krakowie dla kamperów, namiotów, przyczep i gości domków.</p>

      <p class="hero__description">Zatrzymaj się w spokojnej, zielonej części miasta i dojedź tramwajem do Starego Miasta w kilkanaście minut. Idealna baza na zwiedzanie Krakowa i okolic.</p>

      <div class="hero__cta">
        <button type="button" class="hero__button hero__button--primary">Sprawdź dostępność</button>
        <button type="button" class="hero__button hero__button--secondary">Zobacz cennik</button>
      </div>
    </div>
  </div>

  {/* Benefits Bar */}
  <div class="hero__benefits-bar">
    <div class="benefits-wrapper">
      <div class="hero__benefit">
        <div class="benefit__icon">🚊</div>
        <div class="benefit__text">5 min do tramwaju</div>
      </div>
      <div class="hero__benefit">
        <div class="benefit__icon">🏙️</div>
        <div class="benefit__text">Blisko centrum Krakowa</div>
      </div>
      <div class="hero__benefit">
        <div class="benefit__icon">🏠</div>
        <div class="benefit__text">Domki i camping</div>
      </div>
      <div class="hero__benefit">
        <div class="benefit__icon">🛡️</div>
        <div class="benefit__text">24/7 ochrona</div>
      </div>
    </div>
  </div>
</section>

<script>
  // CTA Button Handlers
  const primaryBtn = document.querySelector('.hero__button--primary');
  const secondaryBtn = document.querySelector('.hero__button--secondary');

  if (primaryBtn) {
    primaryBtn.addEventListener('click', () => {
      const heroHeight = window.innerHeight;
      window.scrollBy({ top: heroHeight * 0.75, behavior: 'smooth' });
    });
  }

  if (secondaryBtn) {
    secondaryBtn.addEventListener('click', () => {
      // Scroll to pricing section (if exists)
      const pricingSection = document.getElementById('cennik');
      if (pricingSection) {
        pricingSection.scrollIntoView({ behavior: 'smooth' });
      }
    });
  }
</script>

<style is:global>
/* ==================== */
/* HERO FULLSCREEN SECTION */
/* ==================== */

.hero {
  position: relative;
  width: 100%;
  min-height: 100vh;
  height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-image: url('/images/hero/clepardia-hero.jpg');
  background-size: cover;
  background-position: center;
  background-repeat: no-repeat;
  background-attachment: fixed;
  overflow: hidden;
  color: #ffffff;
  padding-top: 82px;
}

/* Overlays */
.hero__overlay {
  position: absolute;
  inset: 0;
  z-index: 1;
  pointer-events: none;
}

.hero__overlay--gradient {
  background: linear-gradient(
    90deg,
    rgba(0, 0, 0, 0.78) 0%,
    rgba(0, 0, 0, 0.58) 38%,
    rgba(0, 0, 0, 0.18) 72%,
    rgba(0, 0, 0, 0.08) 100%
  );
}

.hero__overlay--bottom {
  background: linear-gradient(0deg, rgba(0, 0, 0, 0.55), transparent 45%);
}

.hero__overlay--glow {
  background: radial-gradient(
    circle at 15% 25%,
    rgba(60, 179, 113, 0.08) 0%,
    transparent 35%
  );
}

/* Wrapper & Content */
.hero__wrapper {
  position: relative;
  z-index: 2;
  width: 100%;
  max-width: 1440px;
  margin: 0 auto;
  padding: 0 32px;
  display: flex;
  align-items: center;
  flex-grow: 1;
  min-height: calc(100vh - 82px);
}

.hero__content {
  width: 100%;
  max-width: 720px;
}

/* Badge */
.hero__badge {
  display: inline-flex;
  align-items: center;
  padding: 12px 18px;
  font-size: clamp(0.7rem, 2vw, 0.85rem);
  font-weight: 700;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: rgba(255, 255, 255, 0.92);
  background: rgba(255, 255, 255, 0.08);
  border: 1px solid rgba(255, 255, 255, 0.16);
  border-radius: 999px;
  margin-bottom: 32px;
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
}

/* Headline */
.hero__headline {
  font-size: clamp(3rem, 9vw, 8.5rem);
  font-weight: 900;
  line-height: 0.88;
  letter-spacing: -0.03em;
  margin: 0 0 24px;
  color: #ffffff;
  text-shadow: 0 4px 20px rgba(0, 0, 0, 0.4);
}

/* Subheadline */
.hero__subheadline {
  font-size: clamp(1rem, 3vw, 1.25rem);
  font-weight: 600;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.9);
  margin: 0 0 20px;
  max-width: 620px;
}

/* Description */
.hero__description {
  font-size: clamp(0.95rem, 2vw, 1.1rem);
  font-weight: 400;
  line-height: 1.75;
  color: rgba(255, 255, 255, 0.84);
  margin: 0 0 40px;
  max-width: 620px;
}

/* CTA Buttons */
.hero__cta {
  display: flex;
  gap: 16px;
  flex-wrap: wrap;
  margin-bottom: 60px;
}

.hero__button {
  padding: 14px 28px;
  font-size: 0.95rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  border: none;
  border-radius: 999px;
  cursor: pointer;
  transition: all 280ms ease;
  white-space: nowrap;
}

.hero__button--primary {
  background: linear-gradient(135deg, #3cb371 0%, #2c8b57 100%);
  color: #ffffff;
  box-shadow: 0 12px 40px rgba(60, 179, 113, 0.28);
}

.hero__button--primary:hover {
  transform: translateY(-3px);
  box-shadow: 0 16px 48px rgba(60, 179, 113, 0.36);
}

.hero__button--primary:active {
  transform: translateY(-1px);
}

.hero__button--secondary {
  background: rgba(255, 255, 255, 0.12);
  color: #ffffff;
  border: 1.5px solid rgba(255, 255, 255, 0.24);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
}

.hero__button--secondary:hover {
  background: rgba(255, 255, 255, 0.18);
  border-color: rgba(255, 255, 255, 0.36);
  transform: translateY(-3px);
}

.hero__button--secondary:active {
  transform: translateY(-1px);
}

/* Benefits Bar - Sticky at Bottom */
.hero__benefits-bar {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  width: 100%;
  z-index: 3;
  background: linear-gradient(
    180deg,
    rgba(5, 15, 10, 0) 0%,
    rgba(5, 15, 10, 0.35) 100%
  );
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-top: 1px solid rgba(255, 255, 255, 0.08);
  padding: 32px 0;
}

.benefits-wrapper {
  max-width: 1440px;
  margin: 0 auto;
  padding: 0 32px;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 32px;
}

.hero__benefit {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: 12px;
}

.benefit__icon {
  font-size: 2rem;
  line-height: 1;
  display: block;
}

.benefit__text {
  font-size: clamp(0.85rem, 1.5vw, 0.95rem);
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: rgba(255, 255, 255, 0.88);
  line-height: 1.3;
}

/* ==================== */
/* RESPONSIVE */
/* ==================== */

@media (max-width: 1024px) {
  .hero {
    padding-top: 76px;
    min-height: calc(100vh - 76px);
  }

  .hero__wrapper {
    min-height: calc(100vh - 76px - 160px);
    padding: 0 24px;
  }

  .hero__headline {
    font-size: clamp(2.5rem, 8vw, 6rem);
  }

  .benefits-wrapper {
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
    padding: 0 24px;
  }

  .hero__benefits-bar {
    padding: 24px 0;
  }
}

@media (max-width: 640px) {
  .hero {
    padding-top: 76px;
    background-attachment: scroll;
  }

  .hero__wrapper {
    min-height: auto;
    padding: 40px 16px;
  }

  .hero__content {
    max-width: 100%;
  }

  .hero__headline {
    font-size: clamp(2rem, 12vw, 4rem);
    margin-bottom: 16px;
  }

  .hero__subheadline {
    font-size: 1rem;
    margin-bottom: 16px;
  }

  .hero__description {
    font-size: 0.95rem;
    margin-bottom: 28px;
  }

  .hero__badge {
    font-size: 0.75rem;
    margin-bottom: 24px;
  }

  .hero__cta {
    flex-direction: column;
    margin-bottom: 40px;
  }

  .hero__button {
    width: 100%;
    padding: 12px 20px;
    font-size: 0.9rem;
  }

  .benefits-wrapper {
    grid-template-columns: 1fr;
    gap: 16px;
    padding: 0 16px;
  }

  .benefit__icon {
    font-size: 1.75rem;
  }

  .benefit__text {
    font-size: 0.8rem;
  }

  .hero__benefits-bar {
    padding: 20px 0;
  }
}
</style>
