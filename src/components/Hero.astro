---
import { existsSync } from 'node:fs';
import { join } from 'node:path';
import { heroDesktop } from '../data/assets';

const heroImageExists = existsSync(join(process.cwd(), 'public', heroDesktop.replace(/^\//, '')));
---

<section class:list={['hero', heroImageExists ? 'hero--image' : 'hero--fallback']} id="hero" style={heroImageExists ? `background-image: url('${heroDesktop}')` : undefined}>
  <div class="hero__overlay hero__overlay--cinematic"></div>
  <div class="hero__overlay hero__overlay--warm"></div>
  <div class="hero__overlay hero__overlay--green"></div>

  <div class="hero__wrapper">
    <div class="hero__content">
      <span class="hero__badge">Kraków • camping • domki • tramwaj do centrum</span>
      <h1 class="hero__headline">Camping Clepardia</h1>
      <p class="hero__subheadline">Camping w Krakowie blisko centrum miasta</p>
      <p class="hero__description">
        Zielona, spokojna przestrzeń dla kamperów, namiotów, przyczep i gości domków. Zatrzymaj się wygodnie w Krakowie i dojedź tramwajem do Starego Miasta bez wjeżdżania autem do centrum.
      </p>
      <div class="hero__cta">
        <a href="#rezerwacja" class="hero__button hero__button--primary">Sprawdź dostępność</a>
        <a href="#cennik" class="hero__button hero__button--secondary">Zobacz cennik</a>
      </div>
    </div>
  </div>

  <div class="hero__benefits-bar" aria-label="Najważniejsze atuty Camping Clepardia">
    <div class="benefits-wrapper">
      <div class="hero__benefit">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5 16V8a4 4 0 0 1 4-4h6a4 4 0 0 1 4 4v8"/><path d="M4 16h16v3H4z"/><path d="M7 19v2M17 19v2M8 8h8M8 12h8"/></svg>
        <span>Tramwaj blisko campingu</span>
      </div>
      <div class="hero__benefit">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 21h18"/><path d="M5 21V9l7-5 7 5v12"/><path d="M9 21v-7h6v7"/></svg>
        <span>Blisko centrum Krakowa</span>
      </div>
      <div class="hero__benefit">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 18 12 5l8 13H4z"/><path d="M12 5v13"/></svg>
        <span>Domki i camping</span>
      </div>
      <div class="hero__benefit">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 22s7-4 7-11V5l-7-3-7 3v6c0 7 7 11 7 11z"/><path d="m9 12 2 2 4-5"/></svg>
        <span>Spokojna baza podróży</span>
      </div>
    </div>
  </div>

  <a href="#dlaczego" class="hero__scroll-indicator" aria-label="Przewiń do sekcji Dlaczego Clepardia">
    <span></span>
  </a>
</section>

<style is:global>
.hero {
  position: relative;
  min-height: 100svh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  overflow: hidden;
  color: #fff;
  background-size: cover;
  background-position: center center;
  background-repeat: no-repeat;
  isolation: isolate;
}

.hero--fallback {
  background:
    radial-gradient(circle at 74% 30%, rgba(237, 163, 82, .22), transparent 34%),
    radial-gradient(circle at 18% 58%, rgba(60, 179, 113, .18), transparent 32%),
    linear-gradient(125deg, #06100c 0%, #0b2018 42%, #11100c 72%, #211408 100%);
}

.hero__overlay {
  position: absolute;
  inset: 0;
  pointer-events: none;
  z-index: 1;
}

.hero__overlay--cinematic {
  background:
    linear-gradient(90deg, rgba(2, 10, 7, .82) 0%, rgba(5, 18, 13, .62) 34%, rgba(8, 22, 17, .26) 68%, rgba(9, 18, 13, .10) 100%),
    linear-gradient(180deg, rgba(0, 0, 0, .24) 0%, transparent 42%, rgba(0, 0, 0, .42) 100%);
}

.hero__overlay--warm {
  background: radial-gradient(circle at 78% 34%, rgba(255, 184, 98, .20), rgba(255, 184, 98, .07) 24%, transparent 48%);
  mix-blend-mode: screen;
}

.hero__overlay--green {
  background: radial-gradient(circle at 20% 42%, rgba(60, 179, 113, .20), rgba(60, 179, 113, .07) 25%, transparent 50%);
}

.hero__wrapper {
  position: relative;
  z-index: 2;
  width: 100%;
  max-width: 1440px;
  margin: 0 auto;
  padding: 140px 32px 170px;
}

.hero__content {
  max-width: 620px;
  animation: heroFade .9s ease both;
}

.hero__badge {
  display: inline-flex;
  padding: 10px 16px;
  margin-bottom: 28px;
  border-radius: 999px;
  border: 1px solid rgba(255,255,255,.16);
  background: rgba(255,255,255,.08);
  backdrop-filter: blur(14px);
  color: rgba(255,255,255,.88);
  font-size: .76rem;
  font-weight: 800;
  letter-spacing: .14em;
  text-transform: uppercase;
}

.hero__headline {
  margin: 0 0 22px;
  max-width: 620px;
  color: #fff;
  font-size: clamp(2.8rem, 13vw, 4.4rem);
  line-height: .9;
  font-weight: 900;
  letter-spacing: 0;
  text-shadow: 0 4px 22px rgba(0,0,0,.48), 0 16px 54px rgba(0,0,0,.34);
  animation: heroFade .9s ease .08s both;
}

.hero__subheadline {
  margin: 0 0 18px;
  color: rgba(255,255,255,.94);
  font-size: clamp(1.18rem, 3vw, 1.55rem);
  line-height: 1.45;
  font-weight: 750;
  text-shadow: 0 2px 18px rgba(0,0,0,.38);
  animation: heroFade .9s ease .18s both;
}

.hero__description {
  max-width: 620px;
  margin: 0 0 38px;
  color: rgba(255,255,255,.88);
  font-size: clamp(1rem, 1.7vw, 1.12rem);
  line-height: 1.75;
  text-shadow: 0 2px 16px rgba(0,0,0,.3);
  animation: heroFade .9s ease .28s both;
}

.hero__cta {
  display: flex;
  gap: 14px;
  flex-wrap: wrap;
  animation: heroFade .9s ease .38s both;
}

.hero__button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 52px;
  padding: 15px 26px;
  border-radius: 999px;
  font-size: .9rem;
  font-weight: 900;
  letter-spacing: .08em;
  text-transform: uppercase;
  transition: transform .25s ease, box-shadow .25s ease, background .25s ease, border-color .25s ease;
}

.hero__button--primary {
  color: #fff;
  background: linear-gradient(135deg, #63d99c 0%, #3CB371 45%, #1f744b 100%);
  box-shadow: 0 18px 48px rgba(60,179,113,.38), inset 0 1px 0 rgba(255,255,255,.28);
}

.hero__button--primary:hover {
  color: #fff;
  transform: translateY(-3px);
  box-shadow: 0 24px 64px rgba(60,179,113,.48), 0 8px 26px rgba(0,0,0,.24), inset 0 1px 0 rgba(255,255,255,.34);
}

.hero__button--secondary {
  color: #fff;
  border: 1px solid rgba(255,255,255,.24);
  background: rgba(255,255,255,.09);
  backdrop-filter: blur(16px);
}

.hero__button--secondary:hover {
  color: #fff;
  transform: translateY(-3px);
  border-color: rgba(255,255,255,.42);
  background: rgba(255,255,255,.15);
  backdrop-filter: blur(22px);
  box-shadow: 0 18px 44px rgba(0,0,0,.24);
}

.hero__benefits-bar {
  position: absolute;
  left: 50%;
  bottom: 28px;
  z-index: 3;
  width: min(1180px, calc(100% - 40px));
  transform: translateX(-50%);
  padding: 22px 26px;
  border-radius: 28px;
  border: 1px solid rgba(255,255,255,.12);
  background: rgba(8, 20, 15, .54);
  backdrop-filter: blur(22px);
  box-shadow: 0 24px 80px rgba(0,0,0,.34), inset 0 1px 0 rgba(255,255,255,.08);
  animation: benefitRise .9s ease .45s both;
}

.benefits-wrapper {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 18px;
}

.hero__benefit {
  display: flex;
  align-items: center;
  gap: 12px;
  color: rgba(255,255,255,.92);
  font-size: .82rem;
  font-weight: 850;
  letter-spacing: .08em;
  text-transform: uppercase;
}

.hero__benefit svg {
  width: 25px;
  height: 25px;
  flex: 0 0 25px;
  fill: none;
  stroke: #8fe0b4;
  stroke-width: 1.8;
  stroke-linecap: round;
  stroke-linejoin: round;
  filter: drop-shadow(0 4px 14px rgba(60,179,113,.24));
}

.hero__scroll-indicator {
  position: absolute;
  left: 50%;
  bottom: 16px;
  z-index: 4;
  width: 22px;
  height: 34px;
  transform: translateX(-50%);
  border: 1px solid rgba(255,255,255,.32);
  border-radius: 999px;
  display: grid;
  place-items: start center;
  padding-top: 7px;
}

.hero__scroll-indicator span {
  width: 4px;
  height: 4px;
  border-radius: 999px;
  background: rgba(255,255,255,.72);
  animation: scrollDot 1.8s ease-in-out infinite;
}

@media (min-width: 900px) {
  .hero__headline { font-size: clamp(3.8rem, 7vw, 6.2rem); }
}

@media (max-width: 860px) {
  .hero { min-height: auto; }
  .hero__wrapper { padding: 118px 20px 250px; }
  .benefits-wrapper { grid-template-columns: repeat(2, 1fr); }
}

@media (max-width: 560px) {
  .hero__wrapper { padding: 112px 18px 300px; }
  .hero__badge { font-size: .68rem; letter-spacing: .1em; }
  .hero__cta { flex-direction: column; }
  .hero__button { width: 100%; }
  .hero__benefits-bar { bottom: 20px; padding: 18px; }
  .benefits-wrapper { grid-template-columns: 1fr; gap: 14px; }
  .hero__benefit { font-size: .75rem; }
  .hero__scroll-indicator { display: none; }
}

@keyframes heroFade {
  from { opacity: 0; transform: translateY(16px); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes benefitRise {
  from { opacity: 0; transform: translateX(-50%) translateY(18px); }
  to { opacity: 1; transform: translateX(-50%) translateY(0); }
}

@keyframes scrollDot {
  0%, 100% { transform: translateY(0); opacity: .5; }
  50% { transform: translateY(12px); opacity: 1; }
}
</style>
