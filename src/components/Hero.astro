---
// Camping Clepardia hero section
---

<section class="hero" id="hero">
  <div class="hero__content">
    <span class="hero__badge">Camping w Krakowie blisko centrum</span>
    <h1 class="hero__title">Camping Clepardia</h1>
    <p class="hero__description">Miejsca dla kamper¾w, namiot¾w i przyczep, komfortowe domki oraz szybki dojazd tramwajem do Starego Miasta.</p>
    <div class="hero__actions">
      <button type="button" class="hero__button hero__button--primary" onclick="window.scrollBy({top: window.innerHeight * 0.78, behavior: 'smooth'})">Sprawd¤ dostĻpno£µ</button>
      <button type="button" class="hero__button hero__button--secondary">Zobacz cennik</button>
    </div>
  </div>

  <div class="hero__benefits">
    <div class="hero__benefit"><span>5 min do tramwaju</span></div>
    <div class="hero__benefit"><span>Blisko centrum</span></div>
    <div class="hero__benefit"><span>Domki i camping</span></div>
    <div class="hero__benefit"><span>24/7 ochrona</span></div>
  </div>
</section>

<style is:global>
.hero {
  position: relative;
  width: 100%;
  min-height: 100vh;
  height: 100vh;
  display: flex;
  align-items: center;
  background-image: linear-gradient(180deg, rgba(5, 7, 10, 0.58), rgba(5, 7, 10, 0.82)), url('/images/hero/clepardia-hero.jpg');
  background-size: cover;
  background-position: center center;
  background-repeat: no-repeat;
  color: #ffffff;
}

.hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at 20% 30%, rgba(60, 179, 113, 0.14), transparent 28%);
  z-index: 1;
  pointer-events: none;
}

.hero__content {
  position: relative;
  z-index: 2;
  width: min(720px, 100% - 48px);
  padding: 120px 24px 0;
}

.hero__badge {
  display: inline-flex;
  align-items: center;
  padding: 10px 16px;
  font-size: 0.82rem;
  font-weight: 700;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: rgba(255, 255, 255, 0.9);
  background: rgba(255, 255, 255, 0.08);
  border: 1px solid rgba(255, 255, 255, 0.14);
  border-radius: 999px;
  margin-bottom: 24px;
}

.hero__title {
  font-size: clamp(3rem, 8vw, 5.4rem);
  line-height: 0.96;
  margin: 0 0 24px;
  font-weight: 800;
  letter-spacing: -0.04em;
  max-width: 12ch;
}

.hero__description {
  font-size: clamp(1rem, 2vw, 1.15rem);
  line-height: 1.75;
  max-width: 680px;
  color: rgba(255, 255, 255, 0.88);
  margin: 0 0 32px;
}

.hero__actions {
  display: flex;
  flex-wrap: wrap;
  gap: 16px;
}

.hero__button {
  border: none;
  border-radius: 999px;
  cursor: pointer;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.16em;
  min-width: 170px;
  padding: 14px 22px;
  transition: transform 180ms ease, box-shadow 180ms ease, background 180ms ease;
}

.hero__button--primary {
  background: linear-gradient(135deg, #3cb371 0%, #2c7b58 100%);
  color: #ffffff;
  box-shadow: 0 16px 42px rgba(60, 179, 113, 0.22);
}

.hero__button--primary:hover,
.hero__button--primary:focus {
  transform: translateY(-2px);
}

.hero__button--secondary {
  background: rgba(255, 255, 255, 0.12);
  color: #ffffff;
  border: 1px solid rgba(255, 255, 255, 0.18);
}

.hero__button--secondary:hover,
.hero__button--secondary:focus {
  background: rgba(255, 255, 255, 0.18);
}

.hero__benefits {
  position: relative;
  z-index: 2;
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 16px;
  width: min(1080px, 100% - 48px);
  margin: auto 24px 32px;
  padding: 18px 22px;
  background: rgba(4, 6, 10, 0.67);
  border: 1px solid rgba(255, 255, 255, 0.12);
  border-radius: 22px;
}

.hero__benefit {
  padding: 0;
  color: rgba(255, 255, 255, 0.92);
  font-size: 0.95rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.14em;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
}

@media (max-width: 920px) {
  .hero__benefits {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

@media (max-width: 640px) {
  .hero {
    background-attachment: scroll;
    min-height: calc(100vh - 84px);
  }

  .hero__content {
    padding-top: 100px;
  }

  .hero__benefits {
    grid-template-columns: 1fr;
    padding: 18px;
    margin: 24px 16px 24px;
  }
}
</style>
