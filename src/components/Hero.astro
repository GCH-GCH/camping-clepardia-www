---
// Camping Clepardia Hero Section - Hard Reset
---

<section class="hero" id="hero">
  {/* Overlays */}
  <div class="hero__overlay hero__overlay--gradient"></div>
  <div class="hero__overlay hero__overlay--bottom"></div>
  <div class="hero__overlay hero__overlay--glow"></div>

  {/* Main Content */}
  <div class="hero__wrapper">
    <div class="hero__content">
      <span class="hero__badge">Camping w Krakowie • Blisko centrum</span>

      <h1 class="hero__headline">Camping Clepardia</h1>

      <p class="hero__subheadline">Komfortowy camping w Krakowie dla kamperów, namiotów, przyczep i gości domków.</p>

      <p class="hero__description">Zatrzymaj się w spokojnej, zielonej części miasta i dojedź tramwajem do Starego Miasta w kilkanaście minut. Idealna baza na zwiedzanie Krakowa i okolic.</p>

      <div class="hero__cta">
        <button type="button" class="hero__button hero__button--primary">Sprawdź dostępność</button>
        <button type="button" class="hero__button hero__button--secondary">Zobacz cennik</button>
      </div>
    </div>
  </div>

  {/* Benefits Bar */}
  <div class="hero__benefits-bar">
    <div class="benefits-wrapper">
      <div class="hero__benefit">
        <div class="benefit__icon">🚊</div>
        <div class="benefit__text">5 min do tramwaju</div>
      </div>
      <div class="hero__benefit">
        <div class="benefit__icon">🏙️</div>
        <div class="benefit__text">Blisko centrum Krakowa</div>
      </div>
      <div class="hero__benefit">
        <div class="benefit__icon">🏠</div>
        <div class="benefit__text">Domki i camping</div>
      </div>
      <div class="hero__benefit">
        <div class="benefit__icon">🛡️</div>
        <div class="benefit__text">24/7 ochrona</div>
      </div>
    </div>
  </div>

  {/* Scroll Indicator */}
  <div class="hero__scroll-indicator">
    <div class="scroll-indicator__dot"></div>
  </div>
</section>

<script>
  // CTA Button Handlers
  const primaryBtn = document.querySelector('.hero__button--primary');
  const secondaryBtn = document.querySelector('.hero__button--secondary');

  if (primaryBtn) {
    primaryBtn.addEventListener('click', () => {
      const heroHeight = window.innerHeight;
      window.scrollBy({ top: heroHeight * 0.75, behavior: 'smooth' });
    });
  }

  if (secondaryBtn) {
    secondaryBtn.addEventListener('click', () => {
      // Scroll to pricing section (if exists)
      const pricingSection = document.getElementById('cennik');
      if (pricingSection) {
        pricingSection.scrollIntoView({ behavior: 'smooth' });
      }
    });
  }
</script>

<style is:global>
/* ==================== */
/* HERO FULLSCREEN SECTION */
/* ==================== */

.hero {
  position: relative;
  width: 100%;
  min-height: 100vh;
  height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #1a3a2a 0%, #0d1f1a 40%, #1a2819 70%, #2d3a2a 100%), linear-gradient(45deg, #2a4a3a 0%, #1a3a2a 50%, #0d2a1a 100%);
  background-size: cover;
  background-position: center;
  background-repeat: no-repeat;
  background-attachment: fixed;
  overflow: hidden;
  color: #ffffff;
  padding-top: 82px;
}

/* Overlays */
.hero__overlay {
  position: absolute;
  inset: 0;
  z-index: 1;
  pointer-events: none;
}

.hero__overlay--gradient {
  background: linear-gradient(
    90deg,
    rgba(10, 25, 20, 0.72) 0%,
    rgba(5, 15, 12, 0.52) 35%,
    rgba(20, 35, 28, 0.24) 65%,
    rgba(40, 60, 50, 0.12) 100%
  );
}

.hero__overlay--bottom {
  background: linear-gradient(0deg, rgba(5, 15, 12, 0.48), transparent 50%);
}

.hero__overlay--glow {
  background: radial-gradient(
    circle at 12% 28%,
    rgba(80, 200, 140, 0.06) 0%,
    rgba(60, 179, 113, 0.03) 25%,
    transparent 45%
  );
}

/* Wrapper & Content */
.hero__wrapper {
  position: relative;
  z-index: 2;
  width: 100%;
  max-width: 1440px;
  margin: 0 auto;
  padding: 0 32px;
  display: flex;
  align-items: center;
  flex-grow: 1;
  min-height: calc(100vh - 82px);
}

.hero__content {
  width: 100%;
  max-width: 620px;
  animation: heroContentFadeIn 1s ease-out 0.2s both;
}

/* Badge */
.hero__badge {
  display: inline-flex;
  align-items: center;
  padding: 12px 18px;
  font-size: clamp(0.7rem, 2vw, 0.85rem);
  font-weight: 700;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: rgba(255, 255, 255, 0.92);
  background: rgba(255, 255, 255, 0.08);
  border: 1px solid rgba(255, 255, 255, 0.16);
  border-radius: 999px;
  margin-bottom: 32px;
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
}

/* Headline */
.hero__headline {
  font-size: clamp(2.8rem, 13vw, 6.2rem);
  font-weight: 900;
  line-height: 0.9;
  letter-spacing: -0.02em;
  margin: 0 0 28px;
  color: #ffffff;
  text-shadow: 0 2px 16px rgba(0, 0, 0, 0.5), 0 8px 32px rgba(0, 0, 0, 0.3);
  animation: heroHeadlineFadeIn 1.2s ease-out;
}

/* Subheadline */
.hero__subheadline {
  font-size: clamp(1.05rem, 2.5vw, 1.3rem);
  font-weight: 600;
  line-height: 1.7;
  color: rgba(255, 255, 255, 0.92);
  margin: 0 0 18px;
  max-width: 620px;
  animation: heroContentFadeIn 1s ease-out 0.35s both;
}

/* Description */
.hero__description {
  font-size: clamp(0.95rem, 1.8vw, 1.08rem);
  font-weight: 400;
  line-height: 1.8;
  color: rgba(255, 255, 255, 0.88);
  margin: 0 0 42px;
  max-width: 620px;
  animation: heroContentFadeIn 1s ease-out 0.45s both;
}

/* CTA Buttons */
.hero__cta {
  display: flex;
  gap: 16px;
  flex-wrap: wrap;
  margin-bottom: 60px;
}

.hero__button {
  padding: 14px 28px;
  font-size: 0.95rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  border: none;
  border-radius: 999px;
  cursor: pointer;
  transition: all 280ms ease;
  white-space: nowrap;
}

.hero__button--primary {
  background: linear-gradient(135deg, #48d998 0%, #2e8b57 100%);
  color: #ffffff;
  box-shadow: 0 8px 32px rgba(60, 179, 113, 0.32), inset 0 1px 0 rgba(255, 255, 255, 0.2);
  animation: heroContentFadeIn 1s ease-out 0.6s both;
}

.hero__button--primary:hover {
  transform: translateY(-3px);
  box-shadow: 0 16px 56px rgba(60, 179, 113, 0.42), inset 0 1px 0 rgba(255, 255, 255, 0.3);
  background: linear-gradient(135deg, #52e5a3 0%, #328c5c 100%);
}

.hero__button--primary:active {
  transform: translateY(-1px);
}

.hero__button--secondary {
  background: rgba(255, 255, 255, 0.08);
  color: #ffffff;
  border: 1.5px solid rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  animation: heroContentFadeIn 1s ease-out 0.6s both;
}

.hero__button--secondary:hover {
  background: rgba(255, 255, 255, 0.14);
  border-color: rgba(255, 255, 255, 0.32);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  transform: translateY(-3px);
  box-shadow: 0 8px 28px rgba(0, 0, 0, 0.2);
}

.hero__button--secondary:active {
  transform: translateY(-1px);
}

/* Benefits Bar - Floating Glass Panel */
.hero__benefits-bar {
  position: absolute;
  bottom: 28px;
  left: 50%;
  transform: translateX(-50%);
  width: calc(100% - 64px);
  max-width: 1376px;
  z-index: 3;
  background: rgba(10, 25, 20, 0.48);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid rgba(255, 255, 255, 0.12);
  border-radius: 28px;
  padding: 28px 32px;
  box-shadow: 0 8px 40px rgba(0, 0, 0, 0.24), inset 0 1px 0 rgba(255, 255, 255, 0.08);
  animation: benefitsBarFadeIn 1.2s ease-out 0.8s both;
}

.benefits-wrapper {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 28px;
}

.hero__benefit {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: 10px;
}

.benefit__icon {
  font-size: 2.2rem;
  line-height: 1;
  display: block;
  filter: drop-shadow(0 2px 8px rgba(0, 0, 0, 0.2));
}

.benefit__text {
  font-size: clamp(0.8rem, 1.4vw, 0.9rem);
  font-weight: 600;
  letter-spacing: 0.09em;
  text-transform: uppercase;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.35;
}

/* Scroll Indicator */
.hero__scroll-indicator {
  position: absolute;
  bottom: 40px;
  left: 50%;
  transform: translateX(-50%);
  z-index: 3;
  animation: scrollIndicatorBounce 2.4s infinite;
}

.scroll-indicator__dot {
  width: 8px;
  height: 8px;
  background: rgba(255, 255, 255, 0.6);
  border-radius: 50%;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
}

@keyframes scrollIndicatorBounce {
  0%, 20%, 50%, 80%, 100% {
    transform: translateY(0);
    opacity: 1;
  }
  40% {
    transform: translateY(8px);
  }
  60% {
    transform: translateY(4px);
  }
}

/* ==================== */
/* RESPONSIVE */
/* ==================== */

@keyframes heroHeadlineFadeIn {
  from {
    opacity: 0;
    transform: translateY(20px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes heroContentFadeIn {
  from {
    opacity: 0;
    transform: translateY(12px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes benefitsBarFadeIn {
  from {
    opacity: 0;
    transform: translateX(-50%) translateY(16px);
  }
  to {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }
}

@media (max-width: 1024px) {
  .hero {
    padding-top: 76px;
    min-height: calc(100vh - 76px);
  }

  .hero__wrapper {
    min-height: calc(100vh - 76px - 160px);
    padding: 0 24px;
  }

  .benefits-wrapper {
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }

  .hero__benefits-bar {
    padding: 24px 28px;
    width: calc(100% - 48px);
    bottom: 20px;
  }
}

@media (max-width: 640px) {
  .hero {
    padding-top: 76px;
    background-attachment: scroll;
  }

  .hero__wrapper {
    min-height: auto;
    padding: 40px 16px;
  }

  .hero__content {
    max-width: 100%;
  }

  .hero__headline {
    font-size: clamp(2rem, 12vw, 4rem);
    margin-bottom: 16px;
  }

  .hero__subheadline {
    font-size: 1rem;
    margin-bottom: 16px;
  }

  .hero__description {
    font-size: 0.95rem;
    margin-bottom: 28px;
  }

  .hero__badge {
    font-size: 0.75rem;
    margin-bottom: 24px;
  }

  .hero__cta {
    flex-direction: column;
    margin-bottom: 40px;
  }

  .hero__button {
    width: 100%;
    padding: 12px 20px;
    font-size: 0.9rem;
  }

  .benefits-wrapper {
    grid-template-columns: 1fr;
    gap: 16px;
    padding: 0 16px;
  }

  .benefit__icon {
    font-size: 1.75rem;
  }

  .benefit__text {
    font-size: 0.8rem;
  }

  .hero__benefits-bar {
    padding: 20px 0;
  }

  .hero__scroll-indicator {
    display: none;
  }
}

@media (max-width: 1024px) {
  .hero__scroll-indicator {
    bottom: 28px;
  }
}
</style>
