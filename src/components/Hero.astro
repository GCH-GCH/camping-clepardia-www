---
// Cinematic Luxury Hero Component
// Ultra premium camping experience showcase - FIXED VERSION
---

<section class="hero" id="hero">
  <!-- Background with realistic camping atmosphere -->
  <div class="hero__background">
    <!-- Realistic textured background (simulates camping/nature) -->
    <div class="hero__texture"></div>
    
    <!-- Subtle gradient overlay -->
    <div class="hero__overlay"></div>
  </div>

  <!-- Animated content -->
  <div class="hero__container">
    <div class="hero__content">
      <!-- Subtitle with animation -->
      <div class="hero__subtitle-wrapper">
        <span class="hero__subtitle">Camping w Krakowie</span>
      </div>

      <!-- Main title with reveal animation -->
      <div class="hero__title-wrapper">
        <h1 class="hero__title">
          Camping <span class="hero__title-highlight">Clepardia</span>
        </h1>
      </div>

      <!-- Description with premium feel -->
      <div class="hero__description-wrapper">
        <p class="hero__description">
          Blisko centrum Krakowa, z bezpośrednim tramwajem do Starego Miasta.
          Idealne miejsce dla kamperów, namiotów i turystów. Komfortowe domki i miejsca campingowe
          w sercu polskiej stolicy.
        </p>
      </div>

      <!-- Premium CTA Buttons -->
      <div class="hero__actions">
        <button class="hero__button hero__button--primary" onclick="window.scrollBy({top: window.innerHeight * 0.7, behavior: 'smooth'})">
          <span class="hero__button-text">Sprawdź dostępność</span>
          <span class="hero__button-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
              <line x1="16" y1="2" x2="16" y2="6"></line>
              <line x1="8" y1="2" x2="8" y2="6"></line>
              <line x1="3" y1="10" x2="21" y2="10"></line>
            </svg>
          </span>
        </button>
        <button class="hero__button hero__button--secondary">
          <span class="hero__button-text">Zobacz cennik</span>
          <span class="hero__button-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="12" y1="1" x2="12" y2="23"></line>
              <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
            </svg>
          </span>
        </button>
      </div>

      <!-- Trust indicators -->
      <div class="hero__trust">
        <div class="hero__trust-item">
          <span class="hero__trust-value">5 min</span>
          <span class="hero__trust-label">do Starego Miasta</span>
        </div>
        <div class="hero__trust-item">
          <span class="hero__trust-value">4.8★</span>
          <span class="hero__trust-label">Średnia ocen</span>
        </div>
        <div class="hero__trust-item">
          <span class="hero__trust-value">24/7</span>
          <span class="hero__trust-label">Ochrona</span>
        </div>
      </div>
    </div>

    <!-- Hero Visual/Image Frame -->
    <div class="hero__visual">
      <div class="hero__image-frame">
        <img
          src="/images/hero/clepardia-hero.jpg"
          alt="Camping Clepardia Kraków - widok na camping i Stare Miasto"
          class="hero__image"
          loading="eager"
          onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
        />
        <div class="hero__image-placeholder" style="display: none;">
          <div class="hero__placeholder-content">
            <svg class="hero__placeholder-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
              <circle cx="9" cy="9" r="2"></circle>
              <path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"></path>
            </svg>
            <p class="hero__placeholder-text">Tu dodamy zdjęcie<br/>Camping Clepardia</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="hero__scroll-indicator">
      <span class="hero__scroll-text">Explore more</span>
      <div class="hero__scroll-chevron">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="6 9 12 15 18 9"></polyline>
        </svg>
      </div>
    </div>
  </div>

  <!-- Next section teaser -->
  <div class="hero__teaser">
    <div class="hero__teaser-content">
      <p class="hero__teaser-text">Discover Our Accommodations</p>
      <svg class="hero__teaser-arrow" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <polyline points="6 9 12 15 18 9"></polyline>
      </svg>
    </div>
  </div>
</section>

<script>
  // Parallax and glassmorphism effect on scroll
  const hero = document.getElementById('hero');
  const navbar = document.querySelector('.navbar');
  const heroContent = document.querySelector('.hero__content');
  const teaserIndicator = document.querySelector('.hero__scroll-indicator');

  window.addEventListener('scroll', () => {
    if (!hero || !navbar) return;

    const scrollY = window.scrollY;
    const heroHeight = hero.offsetHeight;
    const progress = Math.min(scrollY / (heroHeight * 0.6), 1);

    // Subtle parallax background
    if (scrollY < heroHeight) {
      hero.style.transform = `translateY(${scrollY * 0.2}px)`;
    }

    // Content fade out - more gradual
    if (heroContent) {
      heroContent.style.opacity = Math.max(1 - progress * 1.2, 0);
    }

    // Hide scroll indicator when scrolling
    if (teaserIndicator) {
      teaserIndicator.style.opacity = Math.max(1 - progress, 0);
    }

    // Glassmorphism navbar effect
    if (scrollY > 100) {
      navbar?.classList.add('is-glassmorphism');
    } else {
      navbar?.classList.remove('is-glassmorphism');
    }
  });

  // Animate elements on load
  const animateElements = () => {
    const elements = document.querySelectorAll('[class*="wrapper"]');
    elements.forEach((el, index) => {
      el.style.animation = `slideIn ${0.6}s ${index * 0.12}s both var(--ease-smooth)`;
    });
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', animateElements);
  } else {
    animateElements();
  }
</script>

<style is:global>
/* ==================== */
/* HERO SECTION */
/* ==================== */
.hero {
  position: relative;
  width: 100%;
  min-height: 100vh;
  height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  background-color: #f5f5f5;
}

/* Background layers */
.hero__background {
  position: absolute;
  inset: 0;
  z-index: 1;
}

.hero__texture {
  position: absolute;
  inset: 0;
  background: 
    linear-gradient(135deg, rgba(245, 245, 245, 0.9) 0%, rgba(240, 240, 240, 0.95) 50%, rgba(235, 235, 235, 0.9) 100%),
    repeating-linear-gradient(
      90deg,
      transparent,
      transparent 2px,
      rgba(200, 200, 200, 0.02) 2px,
      rgba(200, 200, 200, 0.02) 4px
    ),
    radial-gradient(
      ellipse at 20% 50%,
      rgba(60, 179, 113, 0.08) 0%,
      transparent 50%
    ),
    radial-gradient(
      ellipse at 80% 80%,
      rgba(60, 179, 113, 0.05) 0%,
      transparent 50%
    );
  z-index: 1;
  animation: textureShift 20s ease-in-out infinite;
}

@keyframes textureShift {
  0% {
    opacity: 1;
  }
  50% {
    opacity: 1.02;
  }
  100% {
    opacity: 1;
  }
}

.hero__overlay {
  position: absolute;
  inset: 0;
  background: 
    radial-gradient(
      ellipse at center,
      rgba(255, 255, 255, 0.2) 0%,
      rgba(255, 255, 255, 0) 60%,
      rgba(60, 179, 113, 0.03) 100%
    );
  z-index: 2;
  backdrop-filter: blur(0.5px);
  -webkit-backdrop-filter: blur(0.5px);
}

/* Container and content */
.hero__container {
  position: relative;
  z-index: 10;
  width: 100%;
  max-width: var(--container-xl);
  margin: 0 auto;
  padding: var(--container-padding-mobile);
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  min-height: 100vh;
  text-align: center;
}

@media (min-width: 768px) {
  .hero__container {
    padding: var(--container-padding-tablet);
  }
}

@media (min-width: 1024px) {
  .hero__container {
    padding: var(--container-padding-desktop);
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-16);
    text-align: left;
  }
}

.hero__content {
  display: flex;
  flex-direction: column;
  gap: var(--space-8);
  align-items: center;
  width: 100%;
  max-width: 900px;
  transition: opacity var(--transition-slow) var(--ease-smooth);
}

@media (min-width: 1024px) {
  .hero__content {
    align-items: flex-start;
    max-width: 500px;
    flex: 1;
  }
}

/* Hero Visual */
.hero__visual {
  display: none;
}

@media (min-width: 1024px) {
  .hero__visual {
    display: block;
    flex: 1;
    max-width: 600px;
  }
}

.hero__image-frame {
  position: relative;
  width: 100%;
  height: 400px;
  border-radius: var(--radius-xl);
  overflow: hidden;
  box-shadow: var(--shadow-xl);
  background: linear-gradient(135deg, var(--color-gray-100) 0%, var(--color-gray-200) 100%);
}

.hero__image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform var(--transition-base) var(--ease-smooth);
}

.hero__image:hover {
  transform: scale(1.02);
}

.hero__image-placeholder {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--color-primary-light) 0%, var(--color-primary) 100%);
  color: var(--color-white);
}

.hero__placeholder-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-4);
  text-align: center;
  padding: var(--space-8);
}

.hero__placeholder-icon {
  width: 64px;
  height: 64px;
  opacity: 0.8;
}

.hero__placeholder-text {
  font-size: var(--font-size-h4);
  font-weight: var(--font-weight-medium);
  line-height: 1.4;
  margin: 0;
}

/* Subtitle */
.hero__subtitle-wrapper {
  animation: slideIn 0.6s var(--ease-smooth);
}

.hero__subtitle {
  display: inline-block;
  font-size: var(--font-size-body-sm);
  font-weight: var(--font-weight-semibold);
  letter-spacing: var(--letter-spacing-wider);
  text-transform: uppercase;
  color: var(--color-primary);
  background: rgba(60, 179, 113, 0.12);
  border: 1.5px solid rgba(60, 179, 113, 0.4);
  padding: var(--space-3) var(--space-6);
  border-radius: var(--radius-full);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  box-shadow: 0 4px 15px rgba(60, 179, 113, 0.12);
}

/* Title */
.hero__title-wrapper {
  animation: slideIn 0.6s 0.15s var(--ease-smooth) both;
}

.hero__title {
  font-size: clamp(2.25rem, 10vw, 4.5rem);
  font-weight: var(--font-weight-extra-bold);
  line-height: 1.1;
  color: var(--color-black);
  margin: 0;
  padding: 0;
  letter-spacing: var(--letter-spacing-tight);
  text-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
}

.hero__title-highlight {
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-light) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  position: relative;
  display: inline-block;
}

.hero__title-highlight::after {
  content: '';
  position: absolute;
  bottom: -8px;
  left: 0;
  right: 0;
  height: 3px;
  background: linear-gradient(90deg, var(--color-primary), var(--color-primary-light), transparent);
  border-radius: var(--radius-full);
}

/* Description */
.hero__description-wrapper {
  animation: slideIn 0.6s 0.3s var(--ease-smooth) both;
}

.hero__description {
  font-size: var(--font-size-body);
  line-height: var(--line-height-relaxed);
  color: var(--color-text-secondary);
  margin: 0;
  padding: 0;
  max-width: 650px;
  font-weight: var(--font-weight-normal);
  letter-spacing: 0.2px;
}

/* Actions */
.hero__actions {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-4);
  justify-content: center;
  align-items: center;
  animation: slideIn 0.6s 0.45s var(--ease-smooth) both;
  margin-top: var(--space-6);
}

@media (max-width: 480px) {
  .hero__actions {
    flex-direction: column;
    width: 100%;
  }
}

.hero__button {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-3);
  padding: var(--space-4) var(--space-8);
  font-size: var(--font-size-body-sm);
  font-weight: var(--font-weight-semibold);
  letter-spacing: var(--letter-spacing-wide);
  text-transform: uppercase;
  border: none;
  border-radius: var(--radius-lg);
  cursor: pointer;
  transition: all var(--transition-base) var(--ease-smooth);
  position: relative;
  overflow: hidden;
}

@media (max-width: 480px) {
  .hero__button {
    width: 100%;
    padding: var(--space-4) var(--space-6);
  }
}

/* Primary Button */
.hero__button--primary {
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
  color: var(--color-white);
  box-shadow: 0 8px 24px rgba(60, 179, 113, 0.25), inset 0 1px 0 rgba(255, 255, 255, 0.2);
  border: 1px solid rgba(255, 255, 255, 0.15);
}

.hero__button--primary:hover {
  transform: translateY(-3px);
  box-shadow: 0 12px 32px rgba(60, 179, 113, 0.35), inset 0 1px 0 rgba(255, 255, 255, 0.3);
}

.hero__button--primary:active {
  transform: translateY(-1px);
}

/* Secondary Button */
.hero__button--secondary {
  background: rgba(60, 179, 113, 0.08);
  color: var(--color-primary);
  border: 1.5px solid var(--color-primary);
  box-shadow: 0 2px 8px rgba(60, 179, 113, 0.08);
}

.hero__button--secondary:hover {
  background: var(--color-primary);
  color: var(--color-white);
  transform: translateY(-3px);
  box-shadow: 0 12px 32px rgba(60, 179, 113, 0.25);
}

.hero__button--secondary:active {
  transform: translateY(-1px);
}

.hero__button-text {
  display: block;
}

.hero__button-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 20px;
  height: 20px;
  transition: transform var(--transition-base) var(--ease-smooth);
}

.hero__button:hover .hero__button-icon {
  transform: translateY(2px);
}

/* Trust indicators */
.hero__trust {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-8);
  margin-top: var(--space-8);
  width: 100%;
  padding-top: var(--space-8);
  border-top: 1px solid rgba(60, 179, 113, 0.2);
  animation: slideIn 0.6s 0.6s var(--ease-smooth) both;
}

@media (max-width: 640px) {
  .hero__trust {
    gap: var(--space-6);
    margin-top: var(--space-6);
    padding-top: var(--space-6);
  }
}

.hero__trust-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-2);
}

.hero__trust-value {
  font-size: var(--font-size-h5);
  font-weight: var(--font-weight-bold);
  color: var(--color-primary);
  display: block;
}

.hero__trust-label {
  font-size: var(--font-size-body-xs);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-secondary);
  text-transform: uppercase;
  letter-spacing: var(--letter-spacing-wide);
}

/* Scroll indicator */
.hero__scroll-indicator {
  position: absolute;
  bottom: var(--space-16);
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-3);
  opacity: 1;
  transition: opacity var(--transition-slow) var(--ease-smooth);
}

@media (max-height: 600px) {
  .hero__scroll-indicator {
    display: none;
  }
}

.hero__scroll-text {
  font-size: var(--font-size-body-xs);
  font-weight: var(--font-weight-medium);
  color: var(--color-text-secondary);
  text-transform: uppercase;
  letter-spacing: var(--letter-spacing-wide);
}

.hero__scroll-chevron {
  width: 24px;
  height: 24px;
  color: var(--color-primary);
  animation: bounce 2s ease-in-out infinite;
}

@keyframes bounce {
  0%, 100% {
    transform: translateY(0);
    opacity: 1;
  }
  50% {
    transform: translateY(8px);
  }
}

/* Section teaser */
.hero__teaser {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 80px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(to top, var(--color-bg-primary) 0%, rgba(255, 255, 255, 0.8) 100%);
  border-top: 1px solid var(--color-gray-100);
  z-index: 5;
}

.hero__teaser-content {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  cursor: pointer;
  transition: transform var(--transition-base) var(--ease-smooth);
}

.hero__teaser-content:hover {
  transform: translateY(-2px);
}

.hero__teaser-text {
  font-size: var(--font-size-body-sm);
  font-weight: var(--font-weight-semibold);
  color: var(--color-text-secondary);
  letter-spacing: var(--letter-spacing-wide);
  text-transform: uppercase;
  margin: 0;
}

.hero__teaser-arrow {
  width: 20px;
  height: 20px;
  color: var(--color-primary);
  animation: bounce 2s ease-in-out infinite;
}

/* ==================== */
/* GLASSMORPHISM NAVBAR ON SCROLL */
/* ==================== */
.navbar.is-glassmorphism {
  background-color: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(15px);
  -webkit-backdrop-filter: blur(15px);
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
  border-bottom-color: rgba(60, 179, 113, 0.1);
}

.navbar.is-glassmorphism .navbar__link {
  color: var(--color-text-primary);
}

.navbar.is-glassmorphism .navbar__link:hover {
  color: var(--color-primary);
}
</style>

