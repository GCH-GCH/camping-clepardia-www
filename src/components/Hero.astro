---
import { publicAssetExists, siteAssets } from '@/data/assets';
import { getTranslations } from '@/i18n/config';
import { getLocalizedPath, getPathContext } from '@/utils/localizedLinks';
import Icon from '@/components/ui/Icon.astro';

interface Props {
  languageCode?: string;
}

const { languageCode } = Astro.props as Props;
const pathContext = getPathContext(Astro.url.pathname);
const activeLanguage = languageCode ?? pathContext.languageCode;
const explicitLanguage = pathContext.explicitLanguage ?? (languageCode && languageCode !== 'pl' ? languageCode : undefined);
const t = getTranslations(activeLanguage);
const contactHref = getLocalizedPath(explicitLanguage, 'kontakt');
const pricingHref = getLocalizedPath(explicitLanguage, 'cennik');

const heroDesktopExists = publicAssetExists(siteAssets.hero.desktop);
const heroMobileExists = publicAssetExists(siteAssets.hero.mobile);
const heroTextureExists = publicAssetExists(siteAssets.hero.overlayTexture);

const heroStyle = [
  heroDesktopExists ? `--hero-bg-desktop: url('${siteAssets.hero.desktop}')` : '',
  heroMobileExists ? `--hero-bg-mobile: url('${siteAssets.hero.mobile}')` : '',
  heroTextureExists ? `--hero-texture: url('${siteAssets.hero.overlayTexture}')` : '',
].filter(Boolean).join(';');
---

<section
  class:list={[
    'hero',
    heroDesktopExists ? 'hero--image' : 'hero--fallback',
    heroMobileExists && 'hero--mobile-image',
    heroTextureExists && 'hero--texture',
  ]}
  id="hero"
  style={heroStyle || undefined}
>
  <div class="hero__parallax" data-hero-parallax aria-hidden="true"></div>
  <div class="hero__overlay hero__overlay--texture"></div>
  <div class="hero__overlay hero__overlay--cinematic"></div>
  <div class="hero__overlay hero__overlay--vignette"></div>
  <div class="hero__overlay hero__overlay--noise"></div>
  <div class="hero__overlay hero__overlay--warm"></div>
  <div class="hero__overlay hero__overlay--green"></div>
  <div class="hero__particles" aria-hidden="true">
    <span></span>
    <span></span>
    <span></span>
  </div>

  <div class="hero__wrapper">
    <div class="hero__content">
      <span class="hero__badge">{t.home.hero.badge}</span>
      <h1 class="hero__headline" aria-label="Camping Clepardia">
        <span class="hero__headline-line">{t.home.hero.title.split(' ')[0] ?? 'Camping'}</span>
        <span class="hero__headline-line">{t.home.hero.title.split(' ').slice(1).join(' ') || 'Clepardia'}</span>
      </h1>
      <p class="hero__subheadline">
        <span>{t.home.hero.subtitle}</span>
      </p>
      <p class="hero__description">
        {t.home.hero.copy}
      </p>
      <div class="hero__cta">
        <a href={contactHref} class="btn btn-primary btn-large hero__button hero__button--primary">{t.home.hero.primary}</a>
        <a href={pricingHref} class="btn btn-glass btn-large hero__button hero__button--secondary">{t.home.hero.secondary}</a>
      </div>
    </div>

    <aside class="hero__experience-card" aria-label="Camping Clepardia">
      <div class="hero__award">
        <span aria-hidden="true"><Icon name="shield" size={24} /></span>
        <div>
          <strong>{t.home.hero.badges[3]}</strong>
          <small>{t.home.trust.cards[0].copy}</small>
        </div>
      </div>
      <div class="hero__mini-route">
        <span><Icon name="camping" size={18} /> Camping</span>
        <i></i>
        <span><Icon name="tram" size={18} /> {t.home.hero.badges[2]}</span>
      </div>
      <div class="hero__experience-grid">
        <span>{t.home.hero.badges[0]}</span>
        <span>{t.home.hero.badges[1]}</span>
      </div>
    </aside>
  </div>

  <div class="hero__floating-badges" aria-label="Camping Clepardia">
    {t.home.hero.badges.map((badge) => <span>{badge}</span>)}
  </div>

  <div class="hero__benefits-bar" aria-label="Camping Clepardia">
    <div class="benefits-wrapper">
      <div class="hero__benefit">
        <Icon name="tram" />
        <span>{t.home.hero.benefits[0]}</span>
      </div>
      <div class="hero__benefit">
        <Icon name="bungalow" />
        <span>{t.home.hero.benefits[1]}</span>
      </div>
      <div class="hero__benefit">
        <Icon name="camping" />
        <span>{t.home.hero.benefits[2]}</span>
      </div>
      <div class="hero__benefit">
        <Icon name="shield" />
        <span>{t.home.hero.badges[1]}</span>
      </div>
    </div>
  </div>

  <a href="#dlaczego" class="hero__scroll-indicator" aria-label={t.home.hero.scroll}>
    <span class="hero__mouse" aria-hidden="true"><i></i></span>
    <span class="hero__scroll-text">{t.home.hero.scroll}</span>
  </a>
</section>

<script>
  const hero = document.querySelector('.hero');
  const heroParallax = document.querySelector('[data-hero-parallax]');
  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
  const wideViewport = window.matchMedia('(min-width: 768px)');

  if (hero instanceof HTMLElement && heroParallax instanceof HTMLElement && !reducedMotion.matches && wideViewport.matches) {
    let ticking = false;

    const updateHeroParallax = () => {
      ticking = false;
      const rect = hero.getBoundingClientRect();
      const viewport = window.innerHeight || 1;

      if (rect.bottom < 0 || rect.top > viewport) return;

      const progress = Math.max(-1, Math.min(1, rect.top / viewport));
      heroParallax.style.transform = `translate3d(0, ${progress * -38}px, 0) scale(1.06)`;
    };

    const requestUpdate = () => {
      if (ticking) return;
      ticking = true;
      window.requestAnimationFrame(updateHeroParallax);
    };

    window.addEventListener('scroll', requestUpdate, { passive: true });
    window.addEventListener('resize', requestUpdate, { passive: true });
    updateHeroParallax();
  }
</script>

<style is:global>
.hero {
  position: relative;
  min-height: 108svh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  overflow: hidden;
  color: #fff;
  background:
    radial-gradient(circle at 74% 24%, rgba(242, 192, 120, .28), transparent 34%),
    radial-gradient(circle at 18% 58%, rgba(60, 179, 113, .20), transparent 34%),
    linear-gradient(125deg, #07140f 0%, #0d2a1c 44%, #172417 70%, #2b1b0d 100%);
  isolation: isolate;
}

.hero__parallax {
  position: absolute;
  inset: -7%;
  z-index: 0;
  background-size: cover;
  background-position: center center;
  background-repeat: no-repeat;
  transform: translate3d(0, 0, 0) scale(1.06);
  will-change: transform;
}

.hero--image .hero__parallax {
  background-image:
    var(--hero-bg-desktop),
    radial-gradient(circle at 74% 30%, rgba(237, 163, 82, .22), transparent 34%),
    radial-gradient(circle at 18% 58%, rgba(60, 179, 113, .18), transparent 32%),
    linear-gradient(125deg, #06100c 0%, #0b2018 42%, #11100c 72%, #211408 100%);
}

.hero--fallback .hero__parallax {
  background:
    radial-gradient(circle at 74% 30%, rgba(237, 163, 82, .22), transparent 34%),
    radial-gradient(circle at 18% 58%, rgba(60, 179, 113, .18), transparent 32%),
    linear-gradient(125deg, #06100c 0%, #0b2018 42%, #11100c 72%, #211408 100%);
}

.hero__overlay {
  position: absolute;
  inset: 0;
  pointer-events: none;
  z-index: 1;
}

.hero__overlay--texture {
  display: none;
  background-image: var(--hero-texture);
  background-size: cover;
  background-position: center;
  opacity: .14;
  mix-blend-mode: soft-light;
}

.hero--texture .hero__overlay--texture {
  display: block;
}

.hero__overlay--cinematic {
  background:
    linear-gradient(90deg, rgba(4, 14, 9, .94) 0%, rgba(7, 24, 15, .78) 34%, rgba(12, 34, 22, .38) 68%, rgba(17, 27, 17, .08) 100%),
    linear-gradient(180deg, rgba(2, 8, 5, .44) 0%, transparent 34%, rgba(5, 15, 10, .62) 100%);
}

.hero__overlay--vignette {
  background:
    radial-gradient(ellipse at center, transparent 26%, rgba(3, 12, 8, .14) 62%, rgba(3, 12, 8, .58) 100%),
    linear-gradient(180deg, rgba(0,0,0,.20), transparent 42%, rgba(0,0,0,.34));
}

.hero__overlay--noise {
  opacity: .12;
  mix-blend-mode: overlay;
  background-image:
    radial-gradient(circle at 20% 30%, rgba(255,255,255,.18) 0 1px, transparent 1px 3px),
    radial-gradient(circle at 80% 12%, rgba(255,255,255,.12) 0 1px, transparent 1px 4px);
  background-size: 3px 3px, 5px 5px;
}

.hero__overlay--warm {
  background:
    radial-gradient(circle at 76% 30%, rgba(255, 190, 105, .30), rgba(255, 190, 105, .10) 24%, transparent 48%),
    radial-gradient(circle at 56% 12%, rgba(242, 192, 120, .16), transparent 34%);
  mix-blend-mode: screen;
}

.hero__overlay--green {
  background:
    radial-gradient(circle at 18% 42%, rgba(60, 179, 113, .26), rgba(60, 179, 113, .08) 25%, transparent 52%),
    radial-gradient(circle at 58% 86%, rgba(60, 179, 113, .18), transparent 36%);
}

.hero__particles {
  position: absolute;
  inset: 0;
  z-index: 2;
  pointer-events: none;
  overflow: hidden;
}

.hero__particles span {
  position: absolute;
  width: clamp(120px, 15vw, 230px);
  aspect-ratio: 1;
  border-radius: 999px;
  background: radial-gradient(circle, rgba(255, 218, 155, .16), rgba(60,179,113,.06) 38%, transparent 68%);
  filter: blur(14px);
  opacity: .42;
  animation: heroParticle 12s ease-in-out infinite;
}

.hero__particles span:nth-child(1) {
  right: 12%;
  top: 24%;
}

.hero__particles span:nth-child(2) {
  right: 32%;
  bottom: 22%;
  width: clamp(90px, 11vw, 170px);
  animation-delay: -4s;
}

.hero__particles span:nth-child(3) {
  left: 8%;
  bottom: 24%;
  width: clamp(80px, 9vw, 150px);
  animation-delay: -7s;
}

.hero__wrapper {
  position: relative;
  z-index: 3;
  width: 100%;
  max-width: 1440px;
  margin: 0 auto;
  padding: 140px 32px 170px;
  display: grid;
  grid-template-columns: minmax(0, 680px) minmax(280px, 420px);
  gap: clamp(34px, 7vw, 120px);
  align-items: center;
}

.hero__content {
  max-width: 680px;
  min-width: 0;
  animation: heroFade .9s ease both;
}

.hero__badge {
  display: inline-flex;
  padding: 10px 16px;
  margin-bottom: 28px;
  border-radius: 999px;
  border: 1px solid rgba(255,255,255,.16);
  background: rgba(255,255,255,.08);
  backdrop-filter: blur(14px);
  color: rgba(255,255,255,.88);
  font-size: .76rem;
  font-weight: 800;
  letter-spacing: .14em;
  text-transform: uppercase;
  box-shadow: 0 18px 44px rgba(0,0,0,.18), inset 0 1px 0 rgba(255,255,255,.10);
  animation: heroFade .9s cubic-bezier(.22, 1, .36, 1) .02s both;
}

.hero__headline {
  margin: 0 0 22px;
  max-width: 680px;
  color: #fff;
  font-size: clamp(2.8rem, 13vw, 4.4rem);
  line-height: .9;
  font-weight: 900;
  letter-spacing: 0;
  text-shadow: 0 4px 22px rgba(0,0,0,.48), 0 16px 54px rgba(0,0,0,.34);
}

.hero__headline-line {
  display: block;
  overflow: hidden;
  animation: heroLineReveal 1s cubic-bezier(.22, 1, .36, 1) both;
}

.hero__headline-line:nth-child(2) {
  animation-delay: .10s;
}

.hero__subheadline {
  display: grid;
  gap: 2px;
  margin: 0 0 18px;
  color: rgba(255,255,255,.94);
  font-size: clamp(1.18rem, 3vw, 1.55rem);
  line-height: 1.45;
  font-weight: 750;
  text-shadow: 0 2px 18px rgba(0,0,0,.38);
  animation: heroFade .9s cubic-bezier(.22, 1, .36, 1) .24s both;
  overflow-wrap: anywhere;
}

.hero__subheadline span {
  display: block;
}

.hero__description {
  max-width: 640px;
  margin: 0 0 38px;
  color: rgba(255,255,255,.88);
  font-size: clamp(1rem, 1.7vw, 1.12rem);
  line-height: 1.75;
  text-shadow: 0 2px 16px rgba(0,0,0,.3);
  animation: heroFade .9s cubic-bezier(.22, 1, .36, 1) .34s both;
  overflow-wrap: anywhere;
}

.hero__experience-card {
  position: relative;
  align-self: center;
  display: grid;
  gap: 16px;
  padding: 22px;
  border: 1px solid rgba(255,255,255,.16);
  border-radius: 34px;
  background:
    linear-gradient(145deg, rgba(255,255,255,.15), rgba(255,255,255,.055)),
    radial-gradient(circle at 90% 0%, rgba(242,192,120,.18), transparent 34%);
  box-shadow: 0 30px 90px rgba(0,0,0,.30), inset 0 1px 0 rgba(255,255,255,.16);
  backdrop-filter: blur(22px) saturate(150%);
  -webkit-backdrop-filter: blur(22px) saturate(150%);
  animation: heroFade .9s cubic-bezier(.22, 1, .36, 1) .58s both;
}

.hero__experience-card::before {
  content: '';
  position: absolute;
  inset: -1px;
  border-radius: inherit;
  border: 1px solid rgba(143,224,180,.22);
  opacity: .62;
  pointer-events: none;
}

.hero__award {
  display: grid;
  grid-template-columns: 58px 1fr;
  gap: 16px;
  align-items: center;
  padding: 18px;
  border-radius: 26px;
  background: rgba(9, 24, 16, .42);
  border: 1px solid rgba(255,255,255,.13);
}

.hero__award > span {
  width: 58px;
  height: 58px;
  display: grid;
  place-items: center;
  border-radius: 999px;
  color: #2d2010;
  background:
    radial-gradient(circle at 30% 18%, #fff3c9, #f2c078 54%, #c08a35);
  box-shadow: 0 14px 34px rgba(242,192,120,.22);
}

.hero__award strong {
  display: block;
  color: #fff;
  font-size: 1.1rem;
  line-height: 1.1;
  font-weight: 950;
}

.hero__award small {
  display: block;
  margin-top: 8px;
  color: rgba(255,255,255,.68);
  line-height: 1.5;
}

.hero__mini-route {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 14px;
  border-radius: 22px;
  color: rgba(255,255,255,.86);
  background: rgba(255,255,255,.08);
  border: 1px solid rgba(255,255,255,.12);
}

.hero__mini-route span {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-size: .76rem;
  font-weight: 900;
  letter-spacing: .06em;
  text-transform: uppercase;
}

.hero__mini-route svg {
  color: #8fe0b4;
}

.hero__mini-route i {
  flex: 1;
  min-width: 28px;
  height: 1px;
  background: linear-gradient(90deg, rgba(143,224,180,.25), rgba(143,224,180,.9), rgba(143,224,180,.25));
}

.hero__experience-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 10px;
}

.hero__experience-grid span {
  min-height: 86px;
  display: grid;
  align-items: end;
  padding: 14px;
  border-radius: 22px;
  color: rgba(255,255,255,.84);
  background:
    radial-gradient(circle at 80% 12%, rgba(143,224,180,.16), transparent 34%),
    rgba(255,255,255,.075);
  border: 1px solid rgba(255,255,255,.11);
  font-size: .78rem;
  font-weight: 900;
  letter-spacing: .08em;
  line-height: 1.25;
  text-transform: uppercase;
}

.hero__cta {
  display: flex;
  gap: 14px;
  flex-wrap: wrap;
  animation: heroFade .9s cubic-bezier(.22, 1, .36, 1) .46s both;
}

.hero__button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  max-width: 100%;
  min-height: 52px;
  padding: 17px 30px;
  border-radius: 999px;
  font-size: .92rem;
  font-weight: 900;
  letter-spacing: .08em;
  text-transform: uppercase;
  transition: transform .25s ease, box-shadow .25s ease, background .25s ease, border-color .25s ease;
  overflow: hidden;
  isolation: isolate;
}

.hero__button--primary {
  color: #fff;
  background: linear-gradient(135deg, #63d99c 0%, #3CB371 45%, #1f744b 100%);
  box-shadow: 0 22px 58px rgba(60,179,113,.42), inset 0 1px 0 rgba(255,255,255,.30);
}

.hero__button--primary::before {
  content: '';
  position: absolute;
  inset: -3px;
  z-index: 1;
  background: linear-gradient(115deg, transparent 0%, transparent 34%, rgba(255,255,255,.48) 46%, transparent 58%, transparent 100%);
  transform: translateX(-130%) skewX(-18deg);
  transition: transform .75s cubic-bezier(.22, 1, .36, 1);
  pointer-events: none;
}

.hero__button--primary:hover {
  color: #fff;
  transform: translateY(-3px);
  box-shadow: 0 24px 64px rgba(60,179,113,.48), 0 8px 26px rgba(0,0,0,.24), inset 0 1px 0 rgba(255,255,255,.34);
}

.hero__button--primary:hover::before {
  transform: translateX(130%) skewX(-18deg);
}

.hero__button--secondary {
  color: #fff;
  border: 1px solid rgba(255,255,255,.24);
  background: rgba(255,255,255,.10);
  box-shadow: inset 0 1px 0 rgba(255,255,255,.10);
  backdrop-filter: blur(18px) saturate(140%);
  -webkit-backdrop-filter: blur(18px) saturate(140%);
}

.hero__button--secondary:hover {
  color: #fff;
  transform: translateY(-3px);
  border-color: rgba(255,255,255,.42);
  background: rgba(255,255,255,.15);
  backdrop-filter: blur(22px);
  box-shadow: 0 18px 44px rgba(0,0,0,.24);
}

.hero__benefits-bar {
  position: absolute;
  left: 50%;
  bottom: 28px;
  z-index: 3;
  width: min(1180px, calc(100% - 40px));
  transform: translateX(-50%);
  padding: 22px 26px;
  border-radius: 28px;
  border: 1px solid rgba(255,255,255,.12);
  background: rgba(8, 20, 15, .54);
  backdrop-filter: blur(22px);
  box-shadow: 0 24px 80px rgba(0,0,0,.34), inset 0 1px 0 rgba(255,255,255,.08);
  animation: benefitRise .9s ease .45s both;
}

.benefits-wrapper {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 18px;
}

.hero__benefit {
  display: flex;
  align-items: center;
  gap: 12px;
  color: rgba(255,255,255,.92);
  font-size: .82rem;
  font-weight: 850;
  letter-spacing: .08em;
  text-transform: uppercase;
}

.hero__benefit svg {
  width: 25px;
  height: 25px;
  flex: 0 0 25px;
  fill: none;
  stroke: #8fe0b4;
  stroke-width: 1.8;
  stroke-linecap: round;
  stroke-linejoin: round;
  filter: drop-shadow(0 4px 14px rgba(60,179,113,.24));
}

.hero__floating-badges {
  position: absolute;
  right: max(26px, calc((100vw - 1440px) / 2 + 42px));
  top: 50%;
  z-index: 3;
  display: grid;
  gap: 14px;
  width: min(280px, 25vw);
  transform: translateY(-42%);
  pointer-events: none;
}

.hero__floating-badges span {
  display: inline-flex;
  width: fit-content;
  min-height: 48px;
  align-items: center;
  padding: 12px 16px;
  border: 1px solid rgba(255,255,255,.14);
  border-radius: 999px;
  color: rgba(255,255,255,.90);
  background: rgba(7, 20, 14, .42);
  box-shadow: 0 18px 48px rgba(0,0,0,.22), inset 0 1px 0 rgba(255,255,255,.10);
  backdrop-filter: blur(18px) saturate(140%);
  -webkit-backdrop-filter: blur(18px) saturate(140%);
  font-size: .78rem;
  font-weight: 900;
  letter-spacing: .08em;
  text-transform: uppercase;
  animation: badgeFloat 4.8s ease-in-out infinite;
}

.hero__floating-badges span:nth-child(1) {
  animation-delay: .34s;
}

.hero__floating-badges span:nth-child(2) {
  justify-self: end;
  animation-delay: .74s;
}

.hero__floating-badges span:nth-child(3) {
  margin-left: 28px;
  animation-delay: 1.12s;
}

.hero__floating-badges span:nth-child(4) {
  justify-self: center;
  color: #102018;
  background: rgba(255,255,255,.76);
  border-color: rgba(255,255,255,.42);
  animation-delay: 1.48s;
}

.hero__scroll-indicator {
  position: absolute;
  left: 50%;
  bottom: 132px;
  z-index: 4;
  width: auto;
  min-width: 74px;
  transform: translateX(-50%);
  display: grid;
  justify-items: center;
  gap: 8px;
  color: rgba(255,255,255,.72);
}

.hero__mouse {
  width: 24px;
  height: 38px;
  display: grid;
  place-items: start center;
  padding-top: 7px;
  border: 1px solid rgba(255,255,255,.34);
  border-radius: 999px;
  background: rgba(255,255,255,.06);
  box-shadow: 0 12px 32px rgba(0,0,0,.18);
}

.hero__mouse i {
  width: 4px;
  height: 4px;
  border-radius: 999px;
  background: rgba(255,255,255,.72);
  animation: scrollDot 1.8s ease-in-out infinite;
}

.hero__scroll-text {
  color: rgba(255,255,255,.66);
  font-size: .66rem;
  font-weight: 900;
  letter-spacing: .16em;
  text-transform: uppercase;
}

@media (min-width: 900px) {
  .hero__headline { font-size: clamp(3.8rem, 7vw, 6.2rem); }
}

@media (min-width: 861px) {
  .hero__floating-badges {
    display: none;
  }
}

@media (max-width: 1120px) {
  .hero__wrapper {
    grid-template-columns: 1fr;
  }

  .hero__experience-card {
    max-width: 620px;
    align-self: start;
  }
}

@media (max-width: 860px) {
  .hero--mobile-image .hero__parallax {
    background-image:
      var(--hero-bg-mobile),
      radial-gradient(circle at 74% 30%, rgba(237, 163, 82, .22), transparent 34%),
      radial-gradient(circle at 18% 58%, rgba(60, 179, 113, .18), transparent 32%),
      linear-gradient(125deg, #06100c 0%, #0b2018 42%, #11100c 72%, #211408 100%);
  }

  .hero { min-height: 106svh; }
  .hero__wrapper { padding: 126px 20px 276px; }
  .hero__experience-card { display: none; }
