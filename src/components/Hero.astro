---
import { publicAssetExists, siteAssets } from '@/data/assets';
import { getTranslations } from '@/i18n/config';
import { getLocalizedPath, getPathContext } from '@/utils/localizedLinks';
import HeroExperienceCard from '@/components/home/HeroExperienceCard.astro';
import { getCurrentYear } from '@/utils/currentYear';

interface Props {
  languageCode?: string;
}

const { languageCode } = Astro.props as Props;
const pathContext = getPathContext(Astro.url.pathname);
const activeLanguage = languageCode ?? pathContext.languageCode;
const explicitLanguage = pathContext.explicitLanguage ?? (languageCode && languageCode !== 'pl' ? languageCode : undefined);
const t = getTranslations(activeLanguage);
const contactHref = getLocalizedPath(explicitLanguage, 'kontakt');
const pricingHref = getLocalizedPath(explicitLanguage, 'cennik');
const currentYear = getCurrentYear();
const heroYearBadge = {
  pl: `Premium camping ${currentYear}`,
  en: `Premium camping ${currentYear}`,
  de: `Premium-Camping ${currentYear}`,
  it: `Camping premium ${currentYear}`,
}[activeLanguage as 'pl' | 'en' | 'de' | 'it'] ?? `Premium camping ${currentYear}`;

const heroDesktopExists = publicAssetExists(siteAssets.hero.desktop);
const heroMobileExists = publicAssetExists(siteAssets.hero.mobile);
const heroTextureExists = publicAssetExists(siteAssets.hero.overlayTexture);

const heroStyle = [
  heroDesktopExists ? `--hero-bg-desktop: url('${siteAssets.hero.desktop}')` : '',
  heroMobileExists ? `--hero-bg-mobile: url('${siteAssets.hero.mobile}')` : '',
  heroTextureExists ? `--hero-texture: url('${siteAssets.hero.overlayTexture}')` : '',
].filter(Boolean).join(';');

---

<section
  class:list={[
    'hero',
    heroDesktopExists ? 'hero--image' : 'hero--fallback',
    heroMobileExists && 'hero--mobile-image',
    heroTextureExists && 'hero--texture',
  ]}
  id="hero"
  style={heroStyle || undefined}
>
  <div class="hero__parallax" data-hero-parallax aria-hidden="true"></div>
  <div class="hero__overlay hero__overlay--texture"></div>
  <div class="hero__overlay hero__overlay--cinematic"></div>
  <div class="hero__overlay hero__overlay--vignette"></div>
  <div class="hero__overlay hero__overlay--noise"></div>
  <div class="hero__overlay hero__overlay--warm"></div>
  <div class="hero__overlay hero__overlay--green"></div>
  <div class="hero__particles" aria-hidden="true">
    <span></span>
    <span></span>
    <span></span>
    <span></span>
    <span></span>
  </div>

  <div class="hero__wrapper">
    <div class="hero__content">
      <span class="hero__badge">{heroYearBadge}</span>
      <h1 class="hero__headline" aria-label="Camping Clepardia">
        <span class="hero__headline-line">{t.home.hero.title.split(' ')[0] ?? 'Camping'}</span>
        <span class="hero__headline-line">{t.home.hero.title.split(' ').slice(1).join(' ') || 'Clepardia'}</span>
      </h1>
      <p class="hero__subheadline">
        <span>{t.home.hero.subtitle}</span>
      </p>
      <p class="hero__description">
        {t.home.hero.copy}
      </p>
      <div class="hero__cta">
        <a href={contactHref} class="btn btn-primary btn-large hero__button hero__button--primary">{t.home.hero.primary}</a>
        <a href={pricingHref} class="btn btn-glass btn-large hero__button hero__button--secondary">{t.home.hero.secondary}</a>
      </div>
    </div>

    <HeroExperienceCard languageCode={activeLanguage} />
  </div>

  <div class="hero__floating-badges" aria-label="Camping Clepardia">
    {t.home.hero.badges.map((badge) => <span>{badge}</span>)}
  </div>
</section>

<script>
  const hero = document.querySelector('.hero');
  const heroParallax = document.querySelector('[data-hero-parallax]');
  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
  const wideViewport = window.matchMedia('(min-width: 768px)');

  if (hero instanceof HTMLElement && heroParallax instanceof HTMLElement && !reducedMotion.matches && wideViewport.matches) {
    let ticking = false;

    const updateHeroParallax = () => {
      ticking = false;
      const rect = hero.getBoundingClientRect();
      const viewport = window.innerHeight || 1;

      if (rect.bottom < 0 || rect.top > viewport) return;

      const progress = Math.max(-1, Math.min(1, rect.top / viewport));
      heroParallax.style.transform = `translate3d(0, ${progress * -38}px, 0) scale(1.06)`;
    };

    const requestUpdate = () => {
      if (ticking) return;
      ticking = true;
      window.requestAnimationFrame(updateHeroParallax);
    };

    window.addEventListener('scroll', requestUpdate, { passive: true });
    window.addEventListener('resize', requestUpdate, { passive: true });
    updateHeroParallax();
  }
</script>

<style is:global>
.hero {
  position: relative;
  min-height: 106svh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  overflow: hidden;
  color: #fff;
  background:
    radial-gradient(circle at 74% 24%, rgba(242, 192, 120, .24), transparent 36%),
    radial-gradient(circle at 18% 58%, rgba(60, 179, 113, .20), transparent 38%),
    linear-gradient(125deg, #081510 0%, #0B1A14 44%, #102117 72%, #24180d 100%);
  isolation: isolate;
}

.hero__parallax {
  position: absolute;
  inset: -7%;
  z-index: 0;
  background-size: cover;
  background-position: center center;
  background-repeat: no-repeat;
  transform: translate3d(0, 0, 0) scale(1.06);
  will-change: transform;
}

.hero--image .hero__parallax {
  background-image:
    var(--hero-bg-desktop),
    radial-gradient(circle at 74% 30%, rgba(237, 163, 82, .22), transparent 34%),
    radial-gradient(circle at 18% 58%, rgba(60, 179, 113, .18), transparent 32%),
    linear-gradient(125deg, #06100c 0%, #0b2018 42%, #11100c 72%, #211408 100%);
}

.hero--fallback .hero__parallax {
  background:
    radial-gradient(circle at 74% 30%, rgba(237, 163, 82, .22), transparent 34%),
    radial-gradient(circle at 18% 58%, rgba(60, 179, 113, .18), transparent 32%),
    linear-gradient(125deg, #06100c 0%, #0b2018 42%, #11100c 72%, #211408 100%);
}

.hero__overlay {
  position: absolute;
  inset: 0;
  pointer-events: none;
  z-index: 1;
}

.hero__overlay--texture {
  display: none;
  background-image: var(--hero-texture);
  background-size: cover;
  background-position: center;
  opacity: .14;
  mix-blend-mode: soft-light;
}

.hero--texture .hero__overlay--texture {
  display: block;
}

.hero__overlay--cinematic {
  background:
    linear-gradient(90deg, rgba(5, 17, 11, .82) 0%, rgba(8, 25, 17, .58) 34%, rgba(14, 38, 25, .24) 68%, rgba(17, 27, 17, .05) 100%),
    linear-gradient(180deg, rgba(2, 8, 5, .24) 0%, transparent 38%, rgba(5, 15, 10, .38) 100%);
}

.hero__overlay--vignette {
  background:
    radial-gradient(ellipse at center, transparent 30%, rgba(3, 12, 8, .10) 66%, rgba(3, 12, 8, .42) 100%),
    linear-gradient(180deg, rgba(0,0,0,.12), transparent 44%, rgba(0,0,0,.24));
}

.hero__overlay--noise {
  opacity: .12;
  mix-blend-mode: overlay;
  background-image:
    radial-gradient(circle at 20% 30%, rgba(255,255,255,.18) 0 1px, transparent 1px 3px),
    radial-gradient(circle at 80% 12%, rgba(255,255,255,.12) 0 1px, transparent 1px 4px);
  background-size: 3px 3px, 5px 5px;
}

.hero__overlay--warm {
  background:
    radial-gradient(circle at 76% 30%, rgba(255, 190, 105, .26), rgba(255, 190, 105, .10) 24%, transparent 50%),
    radial-gradient(circle at 56% 12%, rgba(242, 192, 120, .15), transparent 36%);
  mix-blend-mode: screen;
}

.hero__overlay--green {
  background:
    radial-gradient(circle at 18% 42%, rgba(60, 179, 113, .24), rgba(60, 179, 113, .08) 25%, transparent 54%),
    radial-gradient(circle at 58% 86%, rgba(60, 179, 113, .16), transparent 38%);
}

.hero__particles {
  position: absolute;
  inset: 0;
  z-index: 2;
  pointer-events: none;
  overflow: hidden;
}

.hero__particles span {
  position: absolute;
  width: clamp(120px, 15vw, 230px);
  aspect-ratio: 1;
  border-radius: 999px;
  background: radial-gradient(circle, rgba(255, 218, 155, .11), rgba(60,179,113,.045) 38%, transparent 68%);
  filter: blur(18px);
  opacity: .30;
  animation: heroParticle 12s ease-in-out infinite;
}

.hero__particles span:nth-child(1) {
  right: 12%;
  top: 24%;
}

.hero__particles span:nth-child(2) {
  right: 32%;
  bottom: 22%;
  width: clamp(90px, 11vw, 170px);
  animation-delay: -4s;
}

.hero__particles span:nth-child(3) {
  left: 8%;
  bottom: 24%;
  width: clamp(80px, 9vw, 150px);
  animation-delay: -7s;
}

.hero__particles span:nth-child(4) {
  left: 44%;
  top: 14%;
  width: clamp(58px, 7vw, 110px);
  opacity: .20;
  animation-delay: -9s;
}

.hero__particles span:nth-child(5) {
  right: 7%;
  bottom: 16%;
  width: clamp(64px, 8vw, 130px);
  opacity: .24;
  animation-delay: -11s;
}

.hero__wrapper {
  position: relative;
  z-index: 3;
  width: 100%;
  max-width: 1440px;
  margin: 0 auto;
  padding: 140px 32px 128px;
  display: grid;
  grid-template-columns: minmax(0, 680px) minmax(280px, 420px);
  gap: clamp(34px, 7vw, 120px);
  align-items: center;
}

.hero__content {
  width: min(100%, 680px);
  max-width: 680px;
  min-width: 0;
  animation: heroFade .9s ease both;
}

.hero__badge {
  display: inline-flex;
  padding: 10px 16px;
  margin-bottom: 28px;
  border-radius: 999px;
  border: 1px solid rgba(255,255,255,.16);
  background: rgba(255,255,255,.08);
  backdrop-filter: blur(14px);
  color: rgba(255,255,255,.88);
  font-size: .76rem;
  font-weight: 800;
  letter-spacing: .14em;
  text-transform: uppercase;
  box-shadow: 0 18px 44px rgba(0,0,0,.18), inset 0 1px 0 rgba(255,255,255,.10);
  animation: heroFade .9s cubic-bezier(.22, 1, .36, 1) .02s both;
}

.hero__headline {
  margin: 0 0 22px;
  max-width: 680px;
  color: #fff;
  font-size: clamp(2.8rem, 13vw, 4.4rem);
  line-height: .9;
  font-weight: 900;
  letter-spacing: 0;
  text-shadow: 0 4px 22px rgba(0,0,0,.48), 0 16px 54px rgba(0,0,0,.34);
}

.hero__headline-line {
  display: block;
  overflow: hidden;
  animation: heroLineReveal 1s cubic-bezier(.22, 1, .36, 1) both;
}

.hero__headline-line:nth-child(2) {
  animation-delay: .10s;
}

.hero__subheadline {
  display: grid;
  gap: 2px;
  margin: 0 0 18px;
  color: rgba(255,255,255,.94);
  font-size: clamp(1.18rem, 3vw, 1.55rem);
  line-height: 1.45;
  font-weight: 750;
  text-shadow: 0 2px 18px rgba(0,0,0,.38);
  animation: heroFade .9s cubic-bezier(.22, 1, .36, 1) .24s both;
  overflow-wrap: anywhere;
}

.hero__subheadline span {
  display: block;
  min-width: 0;
  overflow-wrap: anywhere;
}

.hero__description {
  max-width: 640px;
  margin: 0 0 38px;
  color: rgba(255,255,255,.88);
  font-size: clamp(1rem, 1.7vw, 1.12rem);
  line-height: 1.75;
  text-shadow: 0 2px 16px rgba(0,0,0,.3);
  animation: heroFade .9s cubic-bezier(.22, 1, .36, 1) .34s both;
  overflow-wrap: anywhere;
}

.hero__experience-card {
  position: relative;
  align-self: center;
  display: grid;
  gap: 18px;
  padding: clamp(20px, 2.2vw, 28px);
  border: 1px solid rgba(143,224,180,.24);
  border-radius: 36px;
  background:
    radial-gradient(circle at 18% 0%, rgba(60,179,113,.28), transparent 36%),
    radial-gradient(circle at 88% 12%, rgba(242,192,120,.22), transparent 40%),
    linear-gradient(145deg, rgba(255,255,255,.17), rgba(255,255,255,.062));
  box-shadow:
    0 34px 94px rgba(0,0,0,.30),
    0 0 66px rgba(60,179,113,.20),
    inset 0 1px 0 rgba(255,255,255,.16);
  backdrop-filter: blur(25px) saturate(158%);
  -webkit-backdrop-filter: blur(25px) saturate(158%);
  overflow: hidden;
  animation:
    heroFade .9s cubic-bezier(.22, 1, .36, 1) .58s both,
    heroExperienceFloat 7.6s ease-in-out 1.4s infinite;
}

.hero__experience-card::before {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: inherit;
  background:
    linear-gradient(135deg, rgba(255,255,255,.20), transparent 34%),
    radial-gradient(circle at 74% 76%, rgba(60,179,113,.16), transparent 36%);
  opacity: .78;
  pointer-events: none;
}

.hero__experience-card::after {
  content: '';
  position: absolute;
  inset: auto -18% -24% 22%;
  height: 150px;
  border-radius: 999px;
  background: radial-gradient(ellipse at center, rgba(60,179,113,.22), transparent 66%);
  filter: blur(20px);
  pointer-events: none;
}

.hero-experience-card__halo {
  position: absolute;
  right: -72px;
  top: -72px;
  width: 210px;
  aspect-ratio: 1;
  border-radius: 999px;
  background: radial-gradient(circle, rgba(242,192,120,.26), rgba(60,179,113,.12) 42%, transparent 70%);
  filter: blur(8px);
  opacity: .82;
  pointer-events: none;
}

.hero-experience-card__top,
.hero-experience-card__route,
.hero-experience-card__timeline,
.hero-experience-card__chips,
.hero-experience-card__footer {
  position: relative;
  z-index: 1;
}

.hero-experience-card__top {
  display: grid;
  grid-template-columns: 62px 1fr;
  gap: 16px;
  align-items: center;
  padding: 18px;
  border-radius: 28px;
  background:
    linear-gradient(145deg, rgba(12, 34, 23, .62), rgba(11, 30, 21, .38)),
    radial-gradient(circle at 88% 10%, rgba(242,192,120,.13), transparent 40%);
  border: 1px solid rgba(255,255,255,.14);
  box-shadow: inset 0 1px 0 rgba(255,255,255,.10);
}

.hero-experience-card__award-icon {
  width: 62px;
  height: 62px;
  display: grid;
  place-items: center;
  border-radius: 999px;
  color: #2d2010;
  background:
    radial-gradient(circle at 30% 18%, #fff8d8, #f2c078 52%, #bd8730);
  box-shadow:
    0 16px 42px rgba(242,192,120,.28),
    0 0 26px rgba(242,192,120,.16);
}

.hero-experience-card__eyebrow {
  display: inline-flex;
  width: fit-content;
  margin-bottom: 7px;
  color: #8fe0b4;
  font-size: .66rem;
  font-weight: 950;
  letter-spacing: .16em;
  text-transform: uppercase;
}

.hero-experience-card__top strong {
  display: block;
  color: #fff;
  font-size: clamp(1rem, 1.45vw, 1.18rem);
  line-height: 1.1;
  font-weight: 950;
}

.hero-experience-card__top small {
  display: block;
  margin-top: 8px;
  color: rgba(255,255,255,.74);
  line-height: 1.5;
}

.hero-experience-card__route {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 14px 16px;
  border-radius: 24px;
  color: rgba(255,255,255,.90);
  background:
    linear-gradient(90deg, rgba(60,179,113,.12), rgba(255,255,255,.075)),
    rgba(255,255,255,.06);
  border: 1px solid rgba(143,224,180,.18);
}

.hero-experience-card__route span {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-size: .76rem;
  font-weight: 900;
  letter-spacing: .06em;
  text-transform: uppercase;
}

.hero-experience-card__route svg {
  color: #8fe0b4;
  filter: drop-shadow(0 6px 16px rgba(60,179,113,.22));
}

.hero-experience-card__route i {
  flex: 1;
  min-width: 28px;
  height: 1px;
  background: linear-gradient(90deg, rgba(143,224,180,.25), rgba(143,224,180,.92), rgba(242,192,120,.36));
  box-shadow: 0 0 18px rgba(60,179,113,.24);
}

.hero-experience-card__timeline {
  display: grid;
  grid-template-columns: auto 1fr auto 1fr auto;
  align-items: center;
  gap: 8px;
  padding: 0 6px;
  color: rgba(255,255,255,.74);
  font-size: .64rem;
  font-weight: 950;
  letter-spacing: .12em;
  text-transform: uppercase;
}

.hero-experience-card__timeline span {
  position: relative;
  display: inline-flex;
  align-items: center;
  gap: 6px;
}

.hero-experience-card__timeline span::before {
  content: '';
  width: 8px;
  height: 8px;
  border-radius: 999px;
  background: #8fe0b4;
  box-shadow: 0 0 18px rgba(60,179,113,.58);
}

.hero-experience-card__timeline i {
  height: 1px;
  border-radius: 999px;
  background: linear-gradient(90deg, rgba(143,224,180,.18), rgba(143,224,180,.72), rgba(242,192,120,.30));
}

.hero-experience-card__chips {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 11px;
}

.hero-experience-card__chip {
  position: relative;
  min-height: 94px;
  display: grid;
  grid-template-columns: 34px 1fr;
  align-items: start;
  gap: 10px;
  padding: 14px;
  border-radius: 23px;
  color: rgba(255,255,255,.86);
  background:
    radial-gradient(circle at 84% 10%, rgba(60,179,113,.18), transparent 42%),
    linear-gradient(145deg, rgba(255,255,255,.095), rgba(255,255,255,.045));
  border: 1px solid rgba(255,255,255,.13);
  box-shadow: inset 0 1px 0 rgba(255,255,255,.08);
  transform: translateY(0);
  transition:
    transform .34s cubic-bezier(.22, 1, .36, 1),
    border-color .34s cubic-bezier(.22, 1, .36, 1),
    background .34s cubic-bezier(.22, 1, .36, 1),
    box-shadow .34s cubic-bezier(.22, 1, .36, 1);
  animation: heroChipFloat 5.8s ease-in-out infinite;
  animation-delay: calc(var(--chip-index) * -520ms);
}

.hero-experience-card__chip::before {
  content: '';
  position: absolute;
  inset: -1px;
  border-radius: inherit;
  background: linear-gradient(135deg, rgba(143,224,180,.28), transparent 48%, rgba(242,192,120,.18));
  opacity: 0;
  pointer-events: none;
  transition: opacity .34s ease;
}

.hero-experience-card__chip svg {
  position: relative;
  z-index: 1;
  width: 34px;
  height: 34px;
  padding: 8px;
  border-radius: 14px;
  color: #dfffea;
  background: rgba(60,179,113,.16);
  box-shadow: 0 10px 22px rgba(60,179,113,.13);
}

.hero-experience-card__chip strong,
.hero-experience-card__chip small {
  position: relative;
  z-index: 1;
  display: block;
}

.hero-experience-card__chip strong {
  color: #fff;
  font-size: .76rem;
  font-weight: 950;
  letter-spacing: .08em;
  line-height: 1.28;
  text-transform: uppercase;
}

.hero-experience-card__chip small {
  margin-top: 6px;
  color: rgba(255,255,255,.64);
  font-size: .72rem;
  line-height: 1.45;
}

.hero-experience-card__chip--award {
  grid-column: 1 / -1;
  min-height: 82px;
  background:
    radial-gradient(circle at 88% 18%, rgba(242,192,120,.18), transparent 38%),
    linear-gradient(145deg, rgba(242,192,120,.12), rgba(255,255,255,.055));
}

.hero-experience-card__chip.is-active {
  transform: translateY(-4px);
  border-color: rgba(143,224,180,.54);
  background:
    radial-gradient(circle at 84% 10%, rgba(60,179,113,.27), transparent 44%),
    linear-gradient(145deg, rgba(60,179,113,.16), rgba(255,255,255,.07));
  box-shadow: 0 20px 52px rgba(60,179,113,.24), inset 0 1px 0 rgba(255,255,255,.13);
}

.hero-experience-card__chip.is-active::before {
  opacity: 1;
}

.hero-experience-card__footer {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}

.hero-experience-card__footer span {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  padding: 9px 11px;
  border-radius: 999px;
  color: rgba(255,255,255,.86);
  border: 1px solid rgba(143,224,180,.18);
  background: rgba(60,179,113,.10);
  font-size: .72rem;
  font-weight: 900;
  letter-spacing: .08em;
  text-transform: uppercase;
}

.hero-experience-card__footer svg {
  color: #8fe0b4;
}

.hero__cta {
  display: flex;
  gap: 14px;
  flex-wrap: wrap;
  animation: heroFade .9s cubic-bezier(.22, 1, .36, 1) .46s both;
}

.hero__button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  max-width: 100%;
  min-height: 52px;
  padding: 17px 30px;
  border-radius: 999px;
  font-size: .92rem;
  font-weight: 900;
  letter-spacing: .08em;
  text-transform: uppercase;
  transition: transform .25s ease, box-shadow .25s ease, background .25s ease, border-color .25s ease;
  overflow: hidden;
  isolation: isolate;
}

.hero__button--primary {
  color: #fff;
  background: linear-gradient(135deg, #63d99c 0%, #3CB371 45%, #1f744b 100%);
  box-shadow: 0 22px 58px rgba(60,179,113,.42), inset 0 1px 0 rgba(255,255,255,.30);
}

.hero__button--primary::before {
  content: '';
  position: absolute;
  inset: -3px;
  z-index: 1;
  background: linear-gradient(115deg, transparent 0%, transparent 34%, rgba(255,255,255,.48) 46%, transparent 58%, transparent 100%);
  transform: translateX(-130%) skewX(-18deg);
  transition: transform .75s cubic-bezier(.22, 1, .36, 1);
  pointer-events: none;
}

.hero__button--primary:hover {
  color: #fff;
  transform: translateY(-3px);
  box-shadow: 0 24px 64px rgba(60,179,113,.48), 0 8px 26px rgba(0,0,0,.24), inset 0 1px 0 rgba(255,255,255,.34);
}

.hero__button--primary:hover::before {
  transform: translateX(130%) skewX(-18deg);
}

.hero__button--secondary {
  color: #fff;
  border: 1px solid rgba(255,255,255,.24);
  background: rgba(255,255,255,.10);
  box-shadow: inset 0 1px 0 rgba(255,255,255,.10);
  backdrop-filter: blur(18px) saturate(140%);
  -webkit-backdrop-filter: blur(18px) saturate(140%);
}

