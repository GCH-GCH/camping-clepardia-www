---
import '@/styles/global.css';
import 'flag-icons/css/flag-icons.min.css';
import MainNavbar from '@/components/layout/MainNavbar.astro';
import Footer from '@/components/Footer.astro';
import MotionFoundation from '@/components/MotionFoundation.astro';
import ScrollToTopButton from '@/components/ui/ScrollToTopButton.astro';
import FloatingChatButton from '@/components/ui/FloatingChatButton.astro';
import CamperScrollProgress from '@/components/ui/CamperScrollProgress.astro';
import AmbientBackground from '@/components/ui/AmbientBackground.astro';
import PageScrollHint from '@/components/ui/PageScrollHint.astro';
import GlobalSearch from '@/components/ui/GlobalSearch.astro';
import { logoMain, logoMainPng, publicAssetExists, siteAssets } from '@/data/assets';
import { getCampgroundJsonLd, homeSeo, resolveOgImage, siteName } from '@/data/seo';
import { getPathContext, getSeoLanguageMeta, isBookingSlug, withOrigin } from '@/utils/localizedLinks';

interface Props {
  title?: string;
  description?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  canonical?: string;
}

const { 
  title = homeSeo.title,
  description = homeSeo.description,
  ogTitle,
  ogDescription,
  ogImage = homeSeo.ogImage,
  canonical
} = Astro.props as Props;

const siteOrigin = Astro.site?.origin ?? Astro.url.origin;
const seoLanguageMeta = getSeoLanguageMeta(Astro.url.pathname, siteOrigin, canonical);
const pathContext = getPathContext(Astro.url.pathname);
const shouldPreloadHero = !pathContext.slug && publicAssetExists(siteAssets.hero.desktop);
const shouldPreloadMobileHero = !pathContext.slug && publicAssetExists(siteAssets.hero.mobile);
const isBookingExperiencePage = isBookingSlug(pathContext.slug);
const ogUrl = withOrigin(seoLanguageMeta.canonicalHref, siteOrigin ?? Astro.url.origin);
const resolvedOgTitle = ogTitle ?? title;
const resolvedOgDescription = ogDescription ?? description;
const resolvedOgImage = resolveOgImage(ogImage);
const absoluteOgImage = withOrigin(resolvedOgImage, siteOrigin);
const socialImageAlt = 'Camping Clepardia in Krakow';
const campgroundJsonLd = getCampgroundJsonLd({
  image: absoluteOgImage,
  pageUrl: seoLanguageMeta.canonicalHref,
});
---

<!doctype html>
<html lang={seoLanguageMeta.lang} dir="ltr" data-theme="dark">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="color-scheme" content="dark light" />
		<meta name="description" content={description} />
		<meta name="robots" content="index, follow" />
		<meta name="theme-color" content="#3CB371" />
		<meta name="clepardia-build" content="TASK-103-premium-gallery-attractions" />
		<meta name="clepardia-commit" content="task-102" />
		
		<!-- Open Graph / Social Media -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={ogUrl} />
		<meta property="og:site_name" content={siteName} />
		<meta property="og:title" content={resolvedOgTitle} />
		<meta property="og:description" content={resolvedOgDescription} />
		<meta property="og:image" content={absoluteOgImage} />
		<meta property="og:image:secure_url" content={absoluteOgImage} />
		<meta property="og:image:alt" content={socialImageAlt} />
		<meta property="og:locale" content={seoLanguageMeta.ogLocale} />
		
		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={resolvedOgTitle} />
		<meta name="twitter:description" content={resolvedOgDescription} />
		<meta name="twitter:image" content={absoluteOgImage} />
		<meta name="twitter:image:alt" content={socialImageAlt} />
		
		<!-- Canonical -->
		<link rel="canonical" href={seoLanguageMeta.canonicalHref} />
		{seoLanguageMeta.alternateLinks.map((alternate) => (
			<link rel="alternate" hreflang={alternate.hrefLang} href={alternate.href} />
		))}
		
		<!-- Favicon -->
		<link rel="preload" as="image" href={logoMain} type="image/svg+xml" />
		{shouldPreloadMobileHero && <link rel="preload" as="image" href={siteAssets.hero.mobile} type="image/webp" fetchpriority="high" media="(max-width: 767px)" />}
		{shouldPreloadHero && <link rel="preload" as="image" href={siteAssets.hero.desktop} type="image/webp" fetchpriority="high" media="(min-width: 768px)" />}
		<link rel="icon" type="image/svg+xml" href={logoMain} />
		<link rel="apple-touch-icon" href={logoMainPng} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		
		<!-- Preconnect -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		
		<!-- Generator -->
		<meta name="generator" content={Astro.generator} />
		<script is:inline>
			(() => {
				const storageKey = 'cc-theme';
				const root = document.documentElement;
				const themeColor = document.querySelector('meta[name="theme-color"]');
				const isTheme = (value) => value === 'dark' || value === 'light';
				const readStoredTheme = () => {
					try {
						const stored = window.localStorage.getItem(storageKey);
						return isTheme(stored) ? stored : null;
					} catch {
						return null;
					}
				};
				const applyTheme = (theme, persist = false) => {
					const nextTheme = isTheme(theme) ? theme : 'dark';
					root.dataset.theme = nextTheme;
					root.style.colorScheme = nextTheme;
					if (themeColor) themeColor.setAttribute('content', nextTheme === 'dark' ? '#091A13' : '#F7F8F3');
					if (persist) {
						try {
							window.localStorage.setItem(storageKey, nextTheme);
						} catch {}
					}
					window.dispatchEvent(new CustomEvent('cc-theme-change', { detail: { theme: nextTheme } }));
				};
				const preferredScheme = window.matchMedia?.('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
				root.dataset.systemTheme = preferredScheme;
				applyTheme(readStoredTheme() ?? 'dark');
				window.__ccSetTheme = applyTheme;
			})();
		</script>
		<script type="application/ld+json" set:html={JSON.stringify(campgroundJsonLd)} />
		
		<title>{title}</title>
	</head>
	<body class:list={[isBookingExperiencePage && 'is-booking-experience-page', isBookingExperiencePage && 'booking-app-page']}>
		<AmbientBackground />
		<MainNavbar />
		
		<main class="main-content" id="main-content">
			<slot />
		</main>
		
		{!isBookingExperiencePage && <CamperScrollProgress />}
		{!isBookingExperiencePage && <PageScrollHint />}
		<FloatingChatButton />
		<GlobalSearch />
		{!isBookingExperiencePage && <Footer />}
		{!isBookingExperiencePage && <ScrollToTopButton />}
		<MotionFoundation />
	</body>
</html>

<style is:global>
	/* Layout Container */
	html {
		height: 100%;
		scroll-behavior: smooth;
	}

	body {
		display: flex;
		flex-direction: column;
		min-height: 100vh;
		width: 100%;
		background-color: var(--color-bg-primary);
		color: var(--color-text-primary);
	}

	#main-content {
		flex: 1;
		display: flex;
		flex-direction: column;
		width: 100%;
	}

	/* Accessibility */
	a:focus-visible,
	button:focus-visible,
	input:focus-visible,
	textarea:focus-visible,
	select:focus-visible {
		outline: 2px solid var(--color-primary);
		outline-offset: 2px;
	}

	/* Reduced motion preferences */
	@media (prefers-reduced-motion: reduce) {
		*,
		*::before,
		*::after {
			animation-duration: 0.01ms !important;
			animation-iteration-count: 1 !important;
			transition-duration: 0.01ms !important;
			scroll-behavior: auto !important;
		}
	}

	/* Print styles */
	@media print {
		body {
			background-color: white;
		}

		a {
			text-decoration: underline;
		}
	}
</style>
