---
import '../styles/global.css';
import MainNavbar from '../components/layout/MainNavbar.astro';
import Footer from '../components/Footer.astro';
import MotionFoundation from '../components/MotionFoundation.astro';
import ScrollToTopButton from '../components/ui/ScrollToTopButton.astro';
import { logoMain, logoMainPng, publicAssetExists, siteAssets } from '../data/assets';
import { getSeoLanguageMeta, withOrigin } from '../utils/localizedLinks';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
}

const { 
  title = 'Camping Clepardia | Camping w Krakowie blisko centrum',
  description = 'Camping Clepardia w Krakowie: camping, domki i szybki dojazd do centrum miasta.',
  ogImage = '/og-image.jpg',
  canonical
} = Astro.props as Props;

const shouldPreloadHero = publicAssetExists(siteAssets.hero.desktop);
const siteOrigin = Astro.site?.origin;
const seoLanguageMeta = getSeoLanguageMeta(Astro.url.pathname, siteOrigin, canonical);
const ogUrl = withOrigin(seoLanguageMeta.canonicalHref, siteOrigin ?? Astro.url.origin);
---

<!doctype html>
<html lang={seoLanguageMeta.lang} dir="ltr">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="description" content={description} />
		<meta name="theme-color" content="#3CB371" />
		
		<!-- Open Graph / Social Media -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={ogUrl} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={ogImage} />
		<meta property="og:locale" content={seoLanguageMeta.ogLocale} />
		
		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImage} />
		
		<!-- Canonical -->
		<link rel="canonical" href={seoLanguageMeta.canonicalHref} />
		{seoLanguageMeta.alternateLinks.map((alternate) => (
			<link rel="alternate" hreflang={alternate.hrefLang} href={alternate.href} />
		))}
		
		<!-- Favicon -->
		<link rel="preload" as="image" href={logoMain} type="image/svg+xml" />
		{shouldPreloadHero && <link rel="preload" as="image" href={siteAssets.hero.desktop} type="image/webp" fetchpriority="high" />}
		<link rel="icon" type="image/svg+xml" href={logoMain} />
		<link rel="apple-touch-icon" href={logoMainPng} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		
		<!-- Preconnect -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		
		<!-- Generator -->
		<meta name="generator" content={Astro.generator} />
		
		<title>{title}</title>
	</head>
	<body>
		<MainNavbar />
		
		<main class="main-content" id="main-content">
			<slot />
		</main>
		
		<Footer />
		<ScrollToTopButton />
		<MotionFoundation />
		
		<script>
			// Smooth scroll behavior polyfill for older browsers
			if (!('scrollBehavior' in document.documentElement.style)) {
				console.log('Smooth scroll not supported, using polyfill');
			}
			
			console.log('Camping Clepardia homepage loaded');
		</script>
	</body>
</html>

<style is:global>
	/* Layout Container */
	html {
		height: 100%;
		scroll-behavior: smooth;
	}

	body {
		display: flex;
		flex-direction: column;
		min-height: 100vh;
		width: 100%;
		background-color: var(--color-bg-primary);
		color: var(--color-text-primary);
	}

	#main-content {
		flex: 1;
		display: flex;
		flex-direction: column;
		width: 100%;
	}

	/* Accessibility */
	a:focus-visible,
	button:focus-visible,
	input:focus-visible,
	textarea:focus-visible,
	select:focus-visible {
		outline: 2px solid var(--color-primary);
		outline-offset: 2px;
	}

	/* Reduced motion preferences */
	@media (prefers-reduced-motion: reduce) {
		*,
		*::before,
		*::after {
			animation-duration: 0.01ms !important;
			animation-iteration-count: 1 !important;
			transition-duration: 0.01ms !important;
			scroll-behavior: auto !important;
		}
	}

	/* Print styles */
	@media print {
		body {
			background-color: white;
		}

		a {
			text-decoration: underline;
		}
	}
</style>
