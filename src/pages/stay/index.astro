---
import { myStayCopy } from '@/i18n/myStay';
---

<!doctype html>
<html lang="pl" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow, noarchive" />
    <meta name="referrer" content="no-referrer" />
    <meta name="color-scheme" content="dark" />
    <meta name="theme-color" content="#0a2017" />
    <title>Twój pobyt — Camping Clepardia</title>
    <link rel="icon" href="/favicon.ico?v=3" sizes="any" />
    <link rel="icon" href="/favicon.svg?v=3" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png?v=3" />
  </head>
  <body>
    <main class="stay-shell" data-stay-app aria-live="polite">
      <section class="stay-loading">
        <img src="/brand/logo/clepardia-logo-main.svg" width="72" height="72" alt="Camping Clepardia" />
        <span class="stay-spinner" aria-hidden="true"></span>
        <p>Bezpiecznie otwieramy Twój panel pobytu…</p>
      </section>
    </main>

    <script is:inline define:vars={{ myStayCopy }}>
      window.__MY_STAY_COPY__ = myStayCopy;
    </script>
    <script>
      const app = document.querySelector('[data-stay-app]');
      const copySet = window.__MY_STAY_COPY__ || {};
      const supported = ['pl', 'en', 'de', 'it', 'fr', 'es', 'nl', 'cs', 'sk', 'sv'];
      const params = new URLSearchParams(location.search);
      const pathToken = decodeURIComponent(location.pathname.replace(/^\/stay\/?/i, '').split('/')[0] || '');
      const token = params.get('token') || pathToken;
      const requestedLanguage = (params.get('lang') || '').toLowerCase();
      let langOverride = supported.includes(requestedLanguage) ? requestedLanguage : '';
      let lang = langOverride || 'pl';
      let panelData = null;
      let feedbackRating = 0;
      let feedbackHelpful = null;
      let campyHistory = [];
      const mapsUrl = 'https://www.google.com/maps/search/?api=1&query=Camping+Clepardia+Henryka+Pacho%C5%84skiego+28A+Krak%C3%B3w';
      const toursUrl = 'https://qr.codes/vksKBT';

      const esc = (value) => String(value ?? '').replace(/[&<>'"]/g, (char) => ({ '&':'&amp;', '<':'&lt;', '>':'&gt;', "'":'&#039;', '"':'&quot;' })[char]);
      const copy = () => copySet[lang] || copySet.pl;
      const setLanguage = (next) => {
        lang = supported.includes(next) ? next : 'pl';
        document.documentElement.lang = lang;
        document.title = `${copy().title} — Camping Clepardia`;
      };
      const localeTag = () => ({ pl:'pl-PL', en:'en-GB', de:'de-DE', it:'it-IT', fr:'fr-FR', es:'es-ES', nl:'nl-NL', cs:'cs-CZ', sk:'sk-SK', sv:'sv-SE' })[lang] || 'pl-PL';
      const formatDate = (value) => {
        if (!/^\d{4}-\d{2}-\d{2}$/.test(String(value || ''))) return value || '—';
        const date = new Date(`${value}T12:00:00Z`);
        return new Intl.DateTimeFormat(localeTag(), { day:'2-digit', month:'long', year:'numeric', timeZone:'UTC' }).format(date);
      };
      const formatDateTime = (value) => value ? new Intl.DateTimeFormat(localeTag(), { dateStyle:'medium', timeStyle:'short' }).format(new Date(value)) : '—';
      const topicFor = (value) => {
        const text = String(value || '').toLowerCase();
        if (/prąd|prad|electric|strom|10a|ev/.test(text)) return 'prąd_10a_ev';
        if (/dojazd|maps|tram|center|centre|centrum|route/.test(text)) return 'dojazd';
        if (/wyciecz|tour|wielicz|auschwitz|zakop|energy/.test(text)) return 'wycieczki';
        if (/domek|bungalow|cabin/.test(text)) return 'domki';
        if (/pies|dog|hund|chien|perro|cane/.test(text)) return 'pies';
        return 'inne';
      };
      const track = (eventType, metadata = {}) => {
        fetch('/api/analytics/event', {
          method:'POST', headers:{ 'content-type':'application/json' }, keepalive:true,
          body:JSON.stringify({ eventType, pagePath:'/stay/:token', locale:lang, deviceType:matchMedia('(max-width:767px)').matches ? 'mobile' : 'desktop', metadata }),
        }).catch(() => {});
      };
      const icon = (name) => ({
        calendar:'📅', people:'👥', stay:'🏕️', service:'🧰', price:'💚', arrival:'🕘', directions:'🗺️', rules:'✓', tours:'🚌', campy:'✨', feedback:'★', after:'🌿', contact:'☎', link:'🔗'
      })[name] || '•';
      const list = (items) => `<ul class="stay-list">${items.map((item) => `<li><span aria-hidden="true">✓</span>${esc(item)}</li>`).join('')}</ul>`;
      const services = (items) => items?.length
        ? `<div class="stay-chips">${items.map((item) => `<span>${esc(item.label)}${Number(item.qty || 1) > 1 ? ` × ${esc(item.qty)}` : ''}</span>`).join('')}</div>`
        : '<span class="stay-muted">—</span>';
      const statusLabel = (status) => copy().statuses[status] || copy().received;

      const renderError = () => {
        const c = copy();
        app.innerHTML = `<section class="stay-error-card">
          <img src="/brand/logo/clepardia-logo-main.svg" width="72" height="72" alt="Camping Clepardia" />
          <span class="stay-kicker">Camping Clepardia</span><h1>${esc(c.title)}</h1><p>${esc(c.invalid)}</p>
          <div class="stay-actions"><button type="button" data-retry>${esc(c.retry)}</button><a href="tel:+48795294486">${esc(c.contact)}</a></div>
        </section>`;
        app.querySelector('[data-retry]')?.addEventListener('click', loadPanel);
      };

      const render = () => {
        const c = copy();
        const data = panelData;
        if (!data) return renderError();
        const people = data.people || {};
        const guestText = [
          people.adults ? `${people.adults} ${c.labels.adults}` : '',
          people.children ? `${people.children} ${c.labels.children}` : '',
          people.toddlers ? `${people.toddlers} ${c.labels.toddlers}` : '',
        ].filter(Boolean).join(' · ') || '—';
        const status = statusLabel(data.status);
        const feedbackDone = Boolean(data.panel?.feedbackSubmitted);
        const serviceContext = (data.services || []).map((item) => `${item.label} × ${item.qty}`).join(', ');
        const tourContext = (data.tours || []).join(', ');
        app.innerHTML = `
          <header class="stay-header">
            <div class="stay-brand"><img src="/brand/logo/clepardia-logo-main.svg" width="58" height="58" alt="" /><span><strong>Camping Clepardia</strong><small>${esc(c.privateLabel)}</small></span></div>
            <div class="stay-header__actions">
              <label class="stay-language"><span class="sr-only">Language</span><select data-language>${supported.map((code) => `<option value="${code}" ${code === lang ? 'selected' : ''}>${esc(copySet[code].languageName)}</option>`).join('')}</select></label>
              <button type="button" class="stay-button stay-button--ghost" data-copy-link>${icon('link')} ${esc(c.saveLink)}</button>
              <a class="stay-button stay-button--ghost stay-button--contact" href="tel:+48795294486">${esc(c.contact)}</a>
            </div>
          </header>
          <section class="stay-hero">
            <div><span class="stay-kicker">${esc(c.title)}</span><h1>${esc(data.customerFirstName ? `${c.hello}, ${data.customerFirstName}` : c.title)}</h1><p>${esc(c.finalPrice)}</p></div>
            <span class="stay-status" data-status="${esc(data.status)}"><i></i>${esc(status)}</span>
          </section>
          <div class="stay-layout">
            <div class="stay-main">
              <section class="stay-card stay-card--summary">
                <div class="stay-card__head"><span>${icon('stay')}</span><div><small>${esc(c.sections.stay)}</small><h2>${esc(data.stayType || c.title)}</h2></div></div>
                <div class="stay-facts">
                  <article><span>${icon('calendar')}</span><small>${esc(c.labels.dates)}</small><strong>${esc(formatDate(data.arrivalDate))} — ${esc(formatDate(data.departureDate))}</strong></article>
                  <article><span>${icon('calendar')}</span><small>${esc(c.labels.nights)}</small><strong>${esc(data.nights || '—')}</strong></article>
                  <article><span>${icon('people')}</span><small>${esc(c.labels.people)}</small><strong>${esc(guestText)}</strong></article>
                  <article><span>${icon('price')}</span><small>${esc(c.labels.price)}</small><strong>${data.estimatedTotalPln == null ? '—' : `${esc(data.estimatedTotalPln)} PLN`}</strong></article>
                </div>
                <div class="stay-summary-row"><span>${esc(c.labels.country)}</span><strong>${esc(data.country || '—')} · ${esc(lang.toUpperCase())}</strong></div>
                <div class="stay-summary-row stay-summary-row--stack"><span>${esc(c.labels.services)}</span>${services(data.services)}</div>
              </section>

              <div class="stay-grid">
                <section class="stay-card"><div class="stay-card__head"><span>${icon('arrival')}</span><h2>${esc(c.sections.arrival)}</h2></div>${list(c.arrival)}</section>
                <section class="stay-card"><div class="stay-card__head"><span>${icon('directions')}</span><h2>${esc(c.sections.directions)}</h2></div>${list(c.directions)}<div class="stay-actions"><a class="stay-button" href="${mapsUrl}" target="_blank" rel="noopener noreferrer" data-maps>${esc(c.mapsCta)}</a><button class="stay-button stay-button--ghost" type="button" data-tram>${esc(c.tramCta)}</button></div></section>
              </div>

              <section class="stay-card"><div class="stay-card__head"><span>${icon('rules')}</span><h2>${esc(c.sections.rules)}</h2></div>${list(c.rules)}</section>

              <section class="stay-card stay-card--tours"><div class="stay-card__head"><span>${icon('tours')}</span><div><h2>${esc(c.sections.tours)}</h2><p>${esc(c.toursLead)}</p></div></div>${data.tours?.length ? `<div class="stay-chips">${data.tours.map((tour) => `<span>${esc(tour)}</span>`).join('')}</div>` : ''}<a class="stay-button" href="${toursUrl}" target="_blank" rel="noopener noreferrer" data-tours>${esc(c.toursCta)}</a></section>

              <section class="stay-card stay-card--campy">
                <div class="stay-card__head"><span>${icon('campy')}</span><div><h2>${esc(c.sections.campy)}</h2><p>${esc(c.campyLead)}</p></div></div>
                <div class="stay-campy-messages" data-campy-messages><p class="is-campy">${esc(c.campyWelcome)}</p></div>
                <div class="stay-quick">${c.quick.map((question) => `<button type="button" data-campy-quick="${esc(question)}">${esc(question)}</button>`).join('')}</div>
                <form class="stay-campy-form" data-campy-form><input type="text" maxlength="600" autocomplete="off" placeholder="${esc(c.campyPlaceholder)}" aria-label="${esc(c.campyPlaceholder)}" /><button type="submit">${esc(c.campySend)}</button></form>
              </section>

              <section class="stay-card stay-card--feedback">
                <div class="stay-card__head"><span>${icon('feedback')}</span><div><h2>${esc(c.sections.feedback)}</h2><p>${esc(c.feedbackLead)}</p></div></div>
                ${feedbackDone ? `<p class="stay-feedback-success">${esc(c.feedbackThanks)}</p>` : `<form data-feedback-form>
                  <div class="stay-rating" role="radiogroup" aria-label="1-5">${[1,2,3,4,5].map((rating) => `<button type="button" role="radio" aria-checked="false" data-rating="${rating}" aria-label="${rating}/5">★</button>`).join('')}</div>
                  <fieldset><legend>${esc(c.helpful)}</legend><div class="stay-choice"><button type="button" data-helpful="true">${esc(c.yes)}</button><button type="button" data-helpful="false">${esc(c.no)}</button></div></fieldset>
                  <label><span>${esc(c.improve)}</span><textarea maxlength="700" rows="3" placeholder="${esc(c.improvePlaceholder)}"></textarea></label>
                  <p class="stay-form-status" data-feedback-status aria-live="polite"></p><button class="stay-button" type="submit">${esc(c.sendFeedback)}</button>
                </form>`}
              </section>

              <section class="stay-card stay-card--after"><div class="stay-card__head"><span>${icon('after')}</span><div><h2>${esc(c.sections.after)}</h2><p>${esc(c.afterText)}</p></div></div></section>
            </div>
            <aside class="stay-side">
              <section class="stay-contact-card"><span>${icon('contact')}</span><h2>Camping Clepardia</h2><p>Henryka Pachońskiego 28A<br />31-322 Kraków</p><a href="tel:+48795294486">+48 795 294 486</a><a href="mailto:clepardia@gmail.com">clepardia@gmail.com</a><a class="stay-button" href="tel:+48795294486">${esc(c.contact)}</a></section>
              <section class="stay-panel-meta"><span>${esc(c.received)}</span><strong>${esc(status)}</strong><small>${esc(c.labels.dates)}: ${esc(formatDate(data.arrivalDate))}</small><small>${esc(c.sections.stay)} · ${esc(data.panel?.openCount || 1)}</small></section>
            </aside>
          </div>`;

        app.querySelector('[data-language]')?.addEventListener('change', (event) => {
          const next = event.target.value;
          langOverride = next;
          setLanguage(next);
          const url = new URL(location.href);
          url.searchParams.set('lang', next);
          if (url.searchParams.has('token') && pathToken) url.searchParams.delete('token');
          history.replaceState({}, '', url);
          track('language_change', { label: next.toUpperCase(), source:'my_stay' });
          render();
        });
        app.querySelector('[data-copy-link]')?.addEventListener('click', async (event) => {
          try { await navigator.clipboard.writeText(location.href); } catch {}
          event.currentTarget.textContent = `${icon('link')} ${copy().linkSaved}`;
        });
        app.querySelector('[data-maps]')?.addEventListener('click', () => track('maps_cta_click', { label:'my_stay_maps' }));
        app.querySelector('[data-tours]')?.addEventListener('click', () => track('tour_cta_click', { label:'my_stay_tours' }));
        app.querySelector('[data-tram]')?.addEventListener('click', (event) => {
          track('tram_info_click', { label:'my_stay_tram' });
          event.currentTarget.textContent = c.directions[2];
        });

        const messages = app.querySelector('[data-campy-messages]');
        const appendCampy = (text, role) => {
          const p = document.createElement('p'); p.className = role === 'assistant' ? 'is-campy' : 'is-user'; p.textContent = text; messages.appendChild(p); messages.scrollTop = messages.scrollHeight;
        };
        const askCampy = async (question) => {
          if (!question) return;
          appendCampy(question, 'user');
          const pending = document.createElement('p'); pending.className = 'is-campy is-pending'; pending.textContent = '…'; messages.appendChild(pending);
          track('campy_question', { topic:topicFor(question), source:'my_stay' });
          const pageContext = [
            `Private stay context. Dates: ${data.arrivalDate} to ${data.departureDate}; nights: ${data.nights}.`,
            `Stay type: ${data.stayType}. Guests: ${guestText}. Services: ${serviceContext || 'none'}.`,
            `Country: ${data.country || 'unknown'}. Tours selected: ${tourContext || 'none'}. Arrival time: ${data.arrivalTime || 'unknown'}.`,
            `Electricity selected: ${data.hasElectricity ? 'yes' : 'no'}. Dog selected: ${data.hasDog ? 'yes' : 'no'}.`,
            'Use this context only to personalize practical information. Never confirm availability or invent booking status.',
          ].join(' ');
          try {
            const response = await fetch('/api/campy', { method:'POST', headers:{ 'content-type':'application/json' }, body:JSON.stringify({ message:question, language:lang, pageContext, conversationHistory:campyHistory.slice(-8) }) });
            const result = await response.json();
            const answer = result?.answer || c.campyError;
            pending.remove(); appendCampy(answer, 'assistant');
            campyHistory.push({ role:'user', content:question }, { role:'assistant', content:answer });
          } catch { pending.remove(); appendCampy(c.campyError, 'assistant'); }
        };
        app.querySelectorAll('[data-campy-quick]').forEach((button) => button.addEventListener('click', () => askCampy(button.dataset.campyQuick || '')));
        app.querySelector('[data-campy-form]')?.addEventListener('submit', (event) => { event.preventDefault(); const input = event.currentTarget.querySelector('input'); const question = input.value.trim(); input.value = ''; askCampy(question); });

        app.querySelectorAll('[data-rating]').forEach((button) => button.addEventListener('click', () => {
          feedbackRating = Number(button.dataset.rating || 0);
          app.querySelectorAll('[data-rating]').forEach((item) => { const active = Number(item.dataset.rating) <= feedbackRating; item.classList.toggle('is-active', active); item.setAttribute('aria-checked', String(Number(item.dataset.rating) === feedbackRating)); });
        }));
        app.querySelectorAll('[data-helpful]').forEach((button) => button.addEventListener('click', () => {
          feedbackHelpful = button.dataset.helpful === 'true';
          app.querySelectorAll('[data-helpful]').forEach((item) => item.classList.toggle('is-active', item === button));
        }));
        app.querySelector('[data-feedback-form]')?.addEventListener('submit', async (event) => {
          event.preventDefault(); const statusNode = event.currentTarget.querySelector('[data-feedback-status]');
          if (!feedbackRating) { statusNode.textContent = c.feedbackRequired; return; }
          const improve = event.currentTarget.querySelector('textarea').value.trim();
          try {
            const response = await fetch('/api/stay/panel', { method:'POST', headers:{ 'content-type':'application/json' }, body:JSON.stringify({ action:'feedback', token, lang, rating:feedbackRating, helpful:feedbackHelpful, improve }) });
            const result = await response.json(); if (!response.ok || !result.ok) throw new Error();
            panelData.panel.feedbackSubmitted = true; render();
          } catch { statusNode.textContent = c.invalid; }
        });
      };

      async function loadPanel() {
        setLanguage(lang);
        if (!token) return renderError();
        app.innerHTML = `<section class="stay-loading"><img src="/brand/logo/clepardia-logo-main.svg" width="72" height="72" alt="Camping Clepardia" /><span class="stay-spinner" aria-hidden="true"></span><p>${esc(copy().loading)}</p></section>`;
        try {
          const query = new URLSearchParams({ token });
          if (langOverride) query.set('lang', langOverride);
          const response = await fetch(`/api/stay/panel?${query.toString()}`, { headers:{ accept:'application/json' }, cache:'no-store' });
          const result = await response.json();
          if (!response.ok || !result.ok || !result.panel) throw new Error('STAY_PANEL_NOT_FOUND');
          panelData = result.panel;
          if (!langOverride && supported.includes(panelData.locale)) setLanguage(panelData.locale);
          render();
        } catch { renderError(); }
      }

      loadPanel();
    </script>
  </body>
</html>

<style is:global>
  :root { color-scheme: dark; font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; background:#06130e; color:#effbf3; }
  * { box-sizing:border-box; }
  body { margin:0; min-width:320px; min-height:100vh; overflow-x:hidden; background:radial-gradient(circle at 15% -10%,rgba(64,211,137,.2),transparent 32rem),radial-gradient(circle at 90% 20%,rgba(37,110,76,.2),transparent 28rem),#06130e; }
  button,input,textarea,select { font:inherit; }
  button,a { -webkit-tap-highlight-color:transparent; }
  a { color:inherit; }
  .sr-only { position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0; }
  .stay-shell { width:min(1240px,calc(100% - 32px)); margin:0 auto; padding:24px 0 64px; }
  .stay-header { min-height:76px; display:flex; align-items:center; justify-content:space-between; gap:20px; padding:10px 2px 22px; border-bottom:1px solid rgba(150,232,187,.13); }
  .stay-brand,.stay-card__head { display:flex; align-items:center; gap:13px; }
  .stay-brand img { filter:drop-shadow(0 10px 20px rgba(0,0,0,.25)); }
  .stay-brand span { display:grid; gap:3px; }
  .stay-brand strong { font-size:1.02rem; }
  .stay-brand small,.stay-muted { color:rgba(229,247,236,.6); }
  .stay-header__actions,.stay-actions { display:flex; flex-wrap:wrap; align-items:center; gap:9px; }
  .stay-language select { min-height:43px; padding:0 35px 0 13px; border:1px solid rgba(150,232,187,.2); border-radius:13px; color:#effbf3; background:#0d2419; }
  .stay-button,.stay-actions button,.stay-actions a { min-height:44px; display:inline-flex; align-items:center; justify-content:center; gap:7px; padding:0 16px; border:1px solid rgba(114,235,166,.35); border-radius:14px; color:#06130e; background:#72eba6; text-decoration:none; font-weight:850; cursor:pointer; }
  .stay-button--ghost { color:#dff9e9; background:rgba(255,255,255,.05); }
  .stay-hero { display:flex; align-items:end; justify-content:space-between; gap:28px; padding:clamp(38px,7vw,82px) 0 30px; }
  .stay-kicker { color:#78e9aa; font-size:.76rem; font-weight:900; letter-spacing:.13em; text-transform:uppercase; }
  .stay-hero h1,.stay-error-card h1 { margin:9px 0 10px; font-size:clamp(2.2rem,7vw,5rem); line-height:.94; letter-spacing:-.055em; }
  .stay-hero p,.stay-card p,.stay-error-card p { margin:0; color:rgba(231,248,237,.67); line-height:1.6; }
  .stay-status { display:inline-flex; align-items:center; gap:9px; min-height:42px; padding:0 15px; border:1px solid rgba(114,235,166,.25); border-radius:999px; color:#b9f9d4; background:rgba(30,112,68,.25); font-weight:850; white-space:nowrap; }
  .stay-status i { width:9px; height:9px; border-radius:50%; background:#5ced9a; box-shadow:0 0 0 5px rgba(92,237,154,.12); }
  .stay-status[data-status="unavailable"],.stay-status[data-status="rejected"],.stay-status[data-status="cancelled"] { color:#ffd0c8; border-color:rgba(255,112,92,.25); background:rgba(120,34,25,.25); }
  .stay-status[data-status="unavailable"] i,.stay-status[data-status="rejected"] i,.stay-status[data-status="cancelled"] i { background:#ff705c; box-shadow:0 0 0 5px rgba(255,112,92,.12); }
  .stay-layout { display:grid; grid-template-columns:minmax(0,1fr) 290px; gap:18px; align-items:start; }
  .stay-main { display:grid; gap:18px; }
  .stay-side { position:sticky; top:18px; display:grid; gap:14px; }
  .stay-card,.stay-contact-card,.stay-panel-meta,.stay-error-card,.stay-loading { border:1px solid rgba(145,225,181,.14); border-radius:26px; background:linear-gradient(145deg,rgba(20,56,38,.86),rgba(8,30,20,.9)); box-shadow:0 24px 70px rgba(0,0,0,.18); }
  .stay-card { padding:clamp(20px,3vw,30px); }
  .stay-card__head { align-items:flex-start; margin-bottom:20px; }
  .stay-card__head>span { flex:0 0 auto; display:grid; width:43px; height:43px; place-items:center; border-radius:14px; color:#bffbd8; background:rgba(79,214,137,.13); }
  .stay-card__head h2 { margin:0; font-size:clamp(1.08rem,2.4vw,1.42rem); letter-spacing:-.02em; }
  .stay-card__head small { display:block; margin-bottom:4px; color:#72eba6; font-weight:850; text-transform:uppercase; letter-spacing:.08em; }
  .stay-facts { display:grid; grid-template-columns:2fr .7fr 1.4fr 1fr; gap:10px; }
  .stay-facts article { min-width:0; display:grid; grid-template-columns:auto 1fr; gap:5px 9px; padding:15px; border:1px solid rgba(255,255,255,.07); border-radius:17px; background:rgba(255,255,255,.04); }
  .stay-facts article>span { grid-row:1/3; }
  .stay-facts small,.stay-summary-row>span { color:rgba(231,248,237,.52); font-size:.73rem; font-weight:800; }
  .stay-facts strong { overflow-wrap:anywhere; }
