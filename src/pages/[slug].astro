---
import Layout from '@/layouts/Layout.astro';
import ContentPage from '@/components/pages/ContentPage.astro';
import { pageSlugs } from '@/data/sitePages';
import { getSitePage } from '@/i18n/config';

export function getStaticPaths() {
  return pageSlugs.map((slug) => ({
    params: { slug },
    props: { page: getSitePage(slug, 'pl') },
  }));
}

const { page } = Astro.props;
---

<Layout
  title={page.seoTitle}
  description={page.seoDescription}
  ogTitle={page.seoTitle}
  ogDescription={page.seoDescription}
>
  <ContentPage page={page} languageCode="pl" />
</Layout>
