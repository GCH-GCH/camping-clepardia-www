---
import Layout from '@/layouts/Layout.astro';
import HomePage from '@/components/home/HomePage.astro';
import { languages } from '@/data/languages';
import { getHomeSeo } from '@/i18n/config';

export function getStaticPaths() {
  return languages.map((language) => ({
    params: { lang: language.code },
    props: { language },
  }));
}

const { language } = Astro.props;
const homeSeo = getHomeSeo(language.code);
---

<Layout
  title={homeSeo.title}
  description={homeSeo.description}
  ogTitle={homeSeo.ogTitle}
  ogDescription={homeSeo.ogDescription}
  ogImage={homeSeo.ogImage}
>
  <HomePage languageCode={language.code} />
</Layout>
