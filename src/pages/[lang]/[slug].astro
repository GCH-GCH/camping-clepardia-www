---
import Layout from '@/layouts/Layout.astro';
import ContentPage from '@/components/pages/ContentPage.astro';
import { languages } from '@/data/languages';
import { pageSlugs } from '@/data/sitePages';
import { getSitePage } from '@/i18n/config';

export function getStaticPaths() {
  return languages.flatMap((language) =>
    pageSlugs.map((slug) => ({
      params: { lang: language.code, slug },
      props: { language, page: getSitePage(slug, language.code) },
    }))
  );
}

const { language, page } = Astro.props;
---

<Layout
  title={`${page.seoTitle} | ${language.name}`}
  description={page.seoDescription}
  ogTitle={page.seoTitle}
  ogDescription={page.seoDescription}
>
  <ContentPage page={page} languageCode={language.code} languageName={language.name} />
</Layout>
