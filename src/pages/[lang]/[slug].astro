---
import Layout from '@/layouts/Layout.astro';
import ContentPage from '@/components/pages/ContentPage.astro';
import CoreLocalizedPage from '@/components/pages/CoreLocalizedPage.astro';
import { languages } from '@/data/languages';
import { pageSlugs } from '@/data/sitePages';
import { getSitePage } from '@/i18n/config';
import { coreCustomerSlugs, getCorePage } from '@/i18n/corePages';

export function getStaticPaths() {
  return languages.flatMap((language) =>
    pageSlugs.map((slug) => ({
      params: { lang: language.code, slug },
      props: { language, page: getSitePage(slug, language.code) },
    }))
  );
}

const { language, page } = Astro.props;
const compactPage = getCorePage(language.code, page.slug);
const useCompactPage = language.translation === 'core-ui' && coreCustomerSlugs.includes(page.slug);
const seoTitle = compactPage?.title ?? page.seoTitle;
const seoDescription = compactPage?.lead ?? page.seoDescription;
---

<Layout
  title={`${seoTitle} | ${language.name}`}
  description={seoDescription}
  ogTitle={seoTitle}
  ogDescription={seoDescription}
>
  {useCompactPage
    ? <CoreLocalizedPage languageCode={language.code} slug={page.slug} />
    : <ContentPage page={page} languageCode={language.code} languageName={language.name} />}
</Layout>
