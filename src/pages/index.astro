---
import Layout from '@/layouts/Layout.astro';
import Hero from '@/components/Hero.astro';
import HomeStatsBar from '@/components/home/HomeStatsBar.astro';
import WhyClepardia from '@/components/home/WhyClepardia.astro';
import CampingSection from '@/components/home/CampingSection.astro';
import BungalowsSection from '@/components/home/BungalowsSection.astro';
import PricingPreview from '@/components/PricingPreview.astro';
import TransportSection from '@/components/TransportSection.astro';
import AttractionsPreview from '@/components/AttractionsPreview.astro';
import TrustSection from '@/components/TrustSection.astro';
import BookingCTA from '@/components/BookingCTA.astro';
import HomeFinalCTA from '@/components/home/HomeFinalCTA.astro';
import { homeSeo } from '@/data/seo';
---

<Layout 
  title={homeSeo.title}
  description={homeSeo.description}
  ogTitle={homeSeo.ogTitle}
  ogDescription={homeSeo.ogDescription}
  ogImage={homeSeo.ogImage}
>
  <Hero />
  <HomeStatsBar />
  <WhyClepardia />
  <CampingSection />
  <BungalowsSection />
  <PricingPreview />
  <TransportSection />
  <AttractionsPreview />
  <TrustSection />
  <BookingCTA />
  <HomeFinalCTA />
</Layout>
