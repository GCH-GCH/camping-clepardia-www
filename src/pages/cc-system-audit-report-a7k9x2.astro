    padding: 10px 12px;
    border: 1px solid rgba(143,224,180,.12);
    border-radius: 999px;
    color: var(--muted);
    background: rgba(255,255,255,.04);
    font-size: .82rem;
    font-weight: 900;
  }

  .audit-section {
    display: grid;
    gap: 18px;
    margin-top: 18px;
    padding: clamp(18px, 3vw, 30px);
    border-radius: 30px;
    scroll-margin-top: 92px;
  }

  .audit-section > header {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 16px;
    align-items: start;
  }

  .section-number {
    display: grid;
    width: 48px;
    height: 48px;
    place-items: center;
    border-radius: 16px;
    color: #07140f;
    background: linear-gradient(135deg, #a8f0c7, var(--green));
    font-weight: 950;
  }

  h2 {
    font-size: clamp(1.8rem, 3vw, 3rem);
    line-height: .95;
    letter-spacing: -.05em;
  }

  .audit-section > header p {
    max-width: 920px;
    margin-top: 8px;
    color: var(--muted);
    font-weight: 800;
  }

  .sidebar-stage,
  .collapsed-stage,
  .dashboard-grid,
  .crm-preview,
  .reservations-preview,
  .calendar-preview,
  .phone-stage {
    display: grid;
    gap: 16px;
  }

  .sidebar-stage {
    grid-template-columns: 300px minmax(0, 1fr);
    align-items: stretch;
  }

  .sidebar-demo {
    display: grid;
    gap: 10px;
    align-content: start;
    min-height: 560px;
    padding: 14px;
    border: 1px solid var(--line);
    border-radius: 26px;
    background: linear-gradient(180deg, rgba(5,29,20,.98), rgba(2,16,12,.98));
  }

  .brand-pill,
  .case-header,
  .modal-card header,
  .phone-frame > header {
    display: flex;
    gap: 12px;
    align-items: center;
  }

  .brand-pill span,
  .brand-icon {
    display: grid;
    width: 44px;
    height: 44px;
    place-items: center;
    border-radius: 50%;
    color: #07140f;
    background: linear-gradient(135deg, #d8ffe5, var(--green));
    font-weight: 950;
  }

  .brand-pill small {
    color: var(--green-soft);
    font-size: .68rem;
  }

  .sidebar-group {
    display: grid;
    gap: 7px;
  }

  .sidebar-group p {
    margin: 10px 8px 3px;
    color: var(--dim);
    font-size: .72rem;
    font-weight: 950;
    text-transform: uppercase;
  }

  .sidebar-demo article,
  .mail-folders-preview button,
  .phone-frame article {
    display: grid;
    grid-template-columns: 34px minmax(0, 1fr) auto;
    gap: 9px;
    align-items: center;
    min-height: 44px;
    padding: 7px 9px;
    border: 1px solid rgba(143,224,180,.12);
    border-radius: 15px;
    background: rgba(255,255,255,.045);
  }

  .sidebar-demo article.is-active,
  .mail-folders-preview button:first-of-type,
  .thread-list-preview .is-selected {
    border-color: rgba(143,224,180,.36);
    background: linear-gradient(135deg, rgba(60,179,113,.42), rgba(60,179,113,.16));
  }

  .sidebar-demo article span {
    display: grid;
    width: 32px;
    height: 32px;
    place-items: center;
    border-radius: 12px;
    background: rgba(60,179,113,.14);
  }

  .sidebar-demo article b,
  .mail-folders-preview button span {
    font-size: .9rem;
  }

  .sidebar-demo article em,
  .mail-folders-preview b {
    display: grid;
    min-width: 22px;
    height: 22px;
    place-items: center;
    border-radius: 999px;
    color: #07140f;
    background: var(--green-soft);
    font-size: .68rem;
    font-style: normal;
    font-weight: 950;
  }

  .sidebar-demo button,
  .case-preview button,
  .modal-card button,
  .phone-detail button,
  .phone-modal button {
    min-height: 42px;
    border: 1px solid var(--line);
    border-radius: 14px;
    color: var(--text);
    background: rgba(255,255,255,.06);
    font-weight: 950;
  }

  .audit-note-card,
  .work-card,
  .case-preview,
  .reservation-detail-preview,
  .calendar-side,
  .modal-card,
  .todo-grid article {
    border: 1px solid var(--line);
    border-radius: 22px;
    background: var(--panel);
    padding: 18px;
  }

  .audit-note-card {
    display: grid;
    align-content: center;
    min-height: 300px;
    background:
      radial-gradient(circle at 12% 0%, rgba(60,179,113,.2), transparent 18rem),
      var(--panel);
  }

  .audit-note-card p,
  .work-card p,
  .todo-grid p {
    margin-top: 8px;
    color: var(--muted);
    font-weight: 800;
  }

  .collapsed-stage {
    grid-template-columns: 92px minmax(0, 1fr);
  }

  .sidebar-demo--collapsed {
    min-height: 520px;
    padding: 12px;
    justify-items: center;
  }

  .sidebar-demo--collapsed article,
  .sidebar-demo--collapsed button {
    width: 58px;
    grid-template-columns: 1fr;
    justify-items: center;
    position: relative;
  }

  .sidebar-demo--collapsed article em {
    position: absolute;
    right: -4px;
    top: -4px;
  }

  .legend-list {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 10px;
    align-content: start;
  }

  .legend-list span {
    display: flex;
    gap: 10px;
    align-items: center;
    min-height: 58px;
    padding: 12px;
    border: 1px solid var(--line);
    border-radius: 18px;
    background: rgba(255,255,255,.045);
    font-weight: 900;
  }

  .dashboard-grid {
    grid-template-columns: minmax(0, 1.1fr) minmax(280px, .9fr);
  }

  .hero-panel {
    grid-column: 1 / -1;
    padding: 24px;
    border: 1px solid var(--line);
    border-radius: 24px;
    background:
      radial-gradient(circle at 15% 0%, rgba(60,179,113,.28), transparent 20rem),
      rgba(5,29,20,.85);
  }

  .hero-panel h3 {
    margin-top: 8px;
    font-size: clamp(1.8rem, 3vw, 3.2rem);
    line-height: .95;
  }

  .kpi-grid,
  .rules-grid,
  .template-grid,
  .settings-grid-preview,
  .stats-preview,
  .todo-grid {
    display: grid;
    gap: 12px;
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .kpi-grid {
    margin-top: 18px;
  }

  .kpi-grid article,
  .rules-grid article,
  .template-grid article,
  .settings-grid-preview article,
  .stats-preview article,
  .reservation-kpis article {
    position: relative;
    display: grid;
    gap: 6px;
    min-height: 112px;
    padding: 16px;
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: 18px;
    background: rgba(255,255,255,.045);
  }

  .kpi-grid b,
  .reservation-kpis b,
  .stats-preview strong {
    font-size: 2rem;
  }

  .kpi-grid small,
  .rules-grid small,
  .settings-grid-preview span,
  .stats-preview span,
  .reservation-kpis small,
  .thread-list-preview small,
  .case-kpis small {
    color: var(--dim);
    font-weight: 850;
  }

  .mini-thread,
  .mail-line,
  .history-line,
  .stay-card,
  .module-thread-list article {
    display: grid;
    gap: 4px;
    padding: 12px;
    border: 1px solid rgba(143,224,180,.11);
    border-radius: 15px;
    background: rgba(255,255,255,.045);
  }

  .mini-thread span,
  .mini-thread small,
  .mail-line span,
  .mail-line em,
  .history-line span,
  .history-line em,
  .module-thread-list span,
  .module-thread-list em {
    color: var(--muted);
    font-style: normal;
    font-weight: 800;
  }

  .work-card {
    display: grid;
    gap: 10px;
  }

  .clean-list {
    display: grid;
    gap: 9px;
    margin: 0;
    padding-left: 20px;
    color: var(--muted);
    font-weight: 800;
  }

  .mail-center-preview {
    display: grid;
    grid-template-columns: 230px minmax(280px, .9fr) minmax(420px, 1.2fr);
    gap: 14px;
  }

  .mail-folders-preview,
  .thread-list-preview,
  .case-preview {
    min-width: 0;
  }

  .mail-folders-preview,
  .thread-list-preview {
    display: grid;
    gap: 9px;
    align-content: start;
    padding: 14px;
    border: 1px solid var(--line);
    border-radius: 22px;
    background: var(--panel);
  }

  .mail-folders-preview button {
    width: 100%;
    color: var(--text);
    text-align: left;
  }

  .thread-list-preview article {
    display: grid;
    gap: 5px;
    padding: 13px;
    border: 1px solid rgba(143,224,180,.11);
    border-radius: 16px;
    background: rgba(255,255,255,.04);
  }

  .thread-list-preview b {
    justify-self: end;
    color: var(--green-soft);
  }

  .case-preview {
    display: grid;
    gap: 14px;
  }

  .avatar {
    display: grid;
    width: 54px;
    height: 54px;
    place-items: center;
    border-radius: 50%;
    color: #07140f;
    background: linear-gradient(135deg, #c8ffd9, var(--green));
    font-weight: 950;
  }

  .avatar-lg {
    width: 74px;
    height: 74px;
    font-size: 1.35rem;
  }

  .case-header {
    justify-content: space-between;
  }

  .case-header p,
  .case-header em {
    color: var(--muted);
    font-style: normal;
    font-weight: 850;
  }

  .case-kpis {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
  }

  .case-kpis article {
    padding: 12px;
    border: 1px solid rgba(143,224,180,.10);
    border-radius: 15px;
    background: rgba(255,255,255,.04);
  }

  .warning-box {
    padding: 14px;
    border: 1px solid rgba(255,209,139,.24);
    border-radius: 18px;
    color: #fff1d6;
    background: rgba(255,209,139,.08);
  }

  .warning-box ul {
    margin-bottom: 0;
  }

  .reply-actions button:first-child,
  .modal-card footer button:first-child,
  .phone-detail button {
    color: #07140f;
    background: linear-gradient(135deg, #a8f0c7, var(--green));
  }

  .crm-preview {
    grid-template-columns: minmax(0, 1.1fr) minmax(280px, .9fr);
  }

  .crm-hero-card {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) minmax(300px, .65fr);
    gap: 18px;
    align-items: center;
    padding: 20px;
    border: 1px solid var(--line);
    border-radius: 24px;
    background: var(--panel);
  }

  .crm-hero-card p {
    margin-top: 5px;
    color: var(--muted);
    font-weight: 800;
  }

  .crm-hero-card dl {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
  }

  .crm-hero-card dt {
    color: var(--dim);
    font-size: .72rem;
    font-weight: 950;
    text-transform: uppercase;
  }

  .crm-hero-card dd {
    margin-top: 4px;
    font-weight: 950;
  }

  .tag-row span {
    color: var(--green-soft);
    background: rgba(60,179,113,.12);
  }

  .reservations-preview {
    grid-template-columns: minmax(0, 1.2fr) minmax(300px, .55fr);
  }

  .reservation-kpis {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 12px;
  }

  .reservation-table-preview {
    display: grid;
    padding: 14px;
    overflow-x: auto;
    border: 1px solid var(--line);
    border-radius: 22px;
    background: var(--panel);
  }

  .reservation-table-preview header,
  .reservation-table-preview article {
    display: grid;
    grid-template-columns: minmax(180px, 1.2fr) minmax(150px, .9fr) minmax(110px, .7fr) minmax(90px, .5fr) minmax(120px, .6fr);
    gap: 12px;
    min-width: 800px;
    align-items: center;
    padding: 12px;
    border-bottom: 1px solid rgba(255,255,255,.07);
  }

  .reservation-table-preview header {
    color: var(--dim);
    font-size: .72rem;
    font-weight: 950;
    text-transform: uppercase;
  }

  .reservation-table-preview em,
  .reservation-detail-preview em {
    color: var(--green-soft);
    font-style: normal;
    font-weight: 950;
  }

  .reservation-detail-preview {
    display: grid;
    gap: 14px;
  }

  .reservation-detail-preview p {
    color: var(--muted);
    font-weight: 800;
  }

  .mini-month {
    display: grid;
    grid-template-columns: repeat(7, minmax(0, 1fr));
    gap: 6px;
  }

  .mini-month span {
    display: grid;
    min-height: 30px;
    place-items: center;
    border-radius: 8px;
    color: var(--muted);
    background: rgba(255,255,255,.035);
    font-size: .78rem;
    font-weight: 850;
  }

  .mini-month .is-stay {
    color: #07140f;
    background: var(--green-soft);
  }

  .calendar-preview {
    grid-template-columns: minmax(0, 1fr) 310px;
  }

  .calendar-board-preview {
    overflow-x: auto;
    padding: 14px;
    border: 1px solid var(--line);
    border-radius: 22px;
    background: var(--panel);
  }

  .audit-month-strip {
    display: flex;
    gap: 8px;
    min-width: 1050px;
    margin-bottom: 12px;
  }

  .audit-month-strip button {
    border: 1px solid rgba(143,224,180,.16);
    border-radius: 12px;
    padding: 8px 12px;
    color: var(--muted);
    background: rgba(255,255,255,.04);
    font-weight: 900;
  }

  .audit-month-strip .is-active {
    color: #07140f;
    border-color: transparent;
    background: var(--green-soft);
  }

  .calendar-head,
  .calendar-row-preview {
    display: grid;
    grid-template-columns: 140px repeat(31, minmax(28px, 1fr));
    min-width: 1050px;
  }

  .calendar-head {
    padding-bottom: 10px;
    color: var(--dim);
    border-bottom: 1px solid rgba(255,255,255,.08);
  }

  .calendar-head span {
    text-align: center;
    font-size: .72rem;
    font-weight: 900;
  }

  .calendar-head .is-today,
  .calendar-row-preview > span.is-today {
    background: rgba(80,220,140,.16);
    box-shadow: inset 0 0 0 1px rgba(80,220,140,.32);
  }

  .calendar-head .is-today {
    border-radius: 9px;
    color: var(--green-soft);
  }

  .calendar-row-preview {
    position: relative;
    min-height: 58px;
    border-bottom: 1px solid rgba(255,255,255,.055);
  }

  .calendar-row-preview > b {
    z-index: 2;
    align-self: center;
  }

  .calendar-row-preview > span {
    min-height: 58px;
    border-left: 1px solid rgba(255,255,255,.045);
  }

  .calendar-row-preview article {
    z-index: 4;
    position: relative;
    align-self: center;
    display: grid;
    gap: 2px;
    min-height: 40px;
    padding: 8px 10px;
    border: 1px solid rgba(143,224,180,.22);
    border-radius: 12px;
    background: linear-gradient(135deg, rgba(49,163,96,.88), rgba(12,82,54,.88));
  }

  .calendar-row-preview article.is-cabin {
    border-color: rgba(111,178,255,.25);
    background: linear-gradient(135deg, rgba(36,101,176,.88), rgba(12,46,91,.88));
  }

  .calendar-row-preview article.is-summer {
    border-color: rgba(255,190,90,.28);
    background: linear-gradient(135deg, rgba(142,82,14,.92), rgba(73,50,13,.90));
  }

  .calendar-row-preview article small {
    color: rgba(255,255,255,.72);
  }

  .calendar-row-preview article i {
    position: absolute;
    top: 50%;
    width: 13px;
    height: 13px;
    border: 2px solid rgba(255,255,255,.88);
    background: #0b3325;
    transform: translateY(-50%) rotate(45deg);
    box-shadow: 0 0 0 4px rgba(3,18,15,.42);
  }

  .calendar-row-preview article .half-day-out {
    left: -7px;
  }

  .calendar-row-preview article .half-day-in {
    right: -7px;
  }

  .summer-note {
    min-width: 1050px;
    margin-top: 12px;
    padding: 16px;
    border: 1px dashed rgba(255,211,139,.28);
    border-radius: 16px;
    color: rgba(255,246,225,.86);
    background: repeating-linear-gradient(135deg, rgba(255,211,139,.08), rgba(255,211,139,.08) 8px, transparent 8px, transparent 18px);
    text-align: center;
    font-weight: 950;
  }

  .calendar-side {
    display: grid;
    gap: 12px;
    align-content: start;
  }

  .calendar-side p {
    color: var(--muted);
    font-weight: 850;
  }

  .rules-grid {
    grid-template-columns: repeat(6, minmax(0, 1fr));
  }

  .rules-grid article span,
  .template-grid article span {
    font-size: 1.6rem;
  }

  .rules-grid--accent article {
    background: linear-gradient(135deg, rgba(60,179,113,.14), rgba(255,255,255,.04));
  }

  .module-thread-list {
    display: grid;
    gap: 10px;
    margin-top: 14px;
  }

  .template-grid article h3 {
    margin: 0;
  }

  .template-grid article p {
    color: var(--muted);
    font-weight: 800;
  }

  .modal-preview {
    display: grid;
    place-items: center;
  }

  .modal-card {
    width: min(760px, 100%);
    padding: 0;
    overflow: hidden;
    border-color: rgba(143,224,180,.28);
    box-shadow: 0 40px 100px rgba(0,0,0,.36);
  }

  .modal-card header {
    padding: 18px;
    background: linear-gradient(135deg, rgba(60,179,113,.28), rgba(255,255,255,.05));
  }

  .modal-card header span {
    display: grid;
    width: 54px;
    height: 54px;
    place-items: center;
    border-radius: 16px;
    background: rgba(255,255,255,.09);
    font-size: 1.6rem;
  }

  .email-preview {
    display: grid;
    gap: 12px;
    margin: 16px;
    padding: 18px;
    border-radius: 18px;
    color: #132218;
    background: #f6fff8;
  }

  .email-preview p {
    color: #31483a;
    line-height: 1.55;
  }

  .composer-preview {
    display: grid;
    gap: 8px;
    padding: 12px;
    border: 1px solid rgba(143,224,180,.18);
    border-radius: 16px;
    background: rgba(255,255,255,.06);
    color: rgba(239,251,243,.78);
    font-size: .86rem;
    font-weight: 800;
  }

  .modal-card footer {
    padding: 16px;
    border-top: 1px solid rgba(255,255,255,.08);
  }

  .settings-grid-preview strong {
    color: var(--text);
  }

  .stats-preview article i {
    position: absolute;
    left: 16px;
    bottom: 12px;
    height: 5px;
    border-radius: 999px;
    background: linear-gradient(90deg, var(--green), var(--green-soft));
  }

  .phone-stage {
    place-items: center;
  }

  .phone-frame {
    width: min(390px, 100%);
    min-height: 780px;
    padding: 12px;
    border: 1px solid var(--line-strong);
    border-radius: 34px;
    background: #06130f;
    box-shadow: 0 40px 100px rgba(0,0,0,.38);
  }

  .phone-frame > header {
    justify-content: space-between;
    min-height: 48px;
  }

  .phone-frame > header button {
    width: 38px;
    height: 38px;
    border: 1px solid var(--line);
    border-radius: 12px;
    color: var(--text);
    background: rgba(255,255,255,.05);
  }

  .mobile-drawer {
    display: grid;
    gap: 7px;
    margin: 10px 0;
    padding: 10px;
    border: 1px solid var(--line);
    border-radius: 22px;
    background: rgba(9,35,24,.96);
  }

  .phone-frame main {
    display: grid;
    gap: 10px;
  }

  .phone-thread {
    grid-template-columns: 1fr;
  }

  .phone-thread span,
  .phone-thread small,
  .phone-detail p,
  .phone-modal p {
    color: var(--muted);
    font-weight: 800;
  }

  .phone-detail,
  .phone-modal {
    display: grid;
    gap: 8px;
    padding: 14px;
    border: 1px solid var(--line);
    border-radius: 18px;
    background: rgba(255,255,255,.045);
  }

  .phone-modal {
    border-color: rgba(255,211,139,.24);
    background: rgba(255,211,139,.08);
  }

  .todo-grid {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  @media (max-width: 1180px) {
    .audit-hero,
    .sidebar-stage,
    .mail-center-preview,
    .crm-preview,
    .reservations-preview,
    .calendar-preview {
      grid-template-columns: 1fr;
    }

    .rules-grid,
    .kpi-grid,
    .template-grid,
    .settings-grid-preview,
    .stats-preview,
    .todo-grid,
    .reservation-kpis {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .audit-meta {
      justify-content: flex-start;
    }

    .audit-meta small {
      text-align: left;
    }
  }

  @media (max-width: 720px) {
    .audit-shell {
      width: min(100% - 16px, 1600px);
      padding-top: 12px;
    }

    .audit-section,
    .audit-hero {
      border-radius: 22px;
    }

    .audit-section > header,
    .crm-hero-card,
    .case-header {
      grid-template-columns: 1fr;
    }

    .collapsed-stage,
    .dashboard-grid,
    .rules-grid,
