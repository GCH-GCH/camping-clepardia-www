---
import { ccSystemDemoData } from '../data/ccSystemDemoData.js';

const buildStamp = new Intl.DateTimeFormat('pl-PL', {
  dateStyle: 'medium',
  timeStyle: 'short',
  timeZone: 'Europe/Warsaw',
}).format(new Date());

const items = ccSystemDemoData;
const activeItems = items.filter((item) => !['test', 'archived', 'spam'].includes(item.status));

const statusLabels = {
  new: 'Nowe',
  needs_reply: 'Do odpowiedzi',
  replied: 'Odpowiedziane',
  needs_confirmation: 'Do potwierdzenia',
  confirmed: 'Potwierdzone',
  unavailable: 'Brak miejsc',
  rejected: 'Odrzucone',
  cancelled: 'Anulowane',
  archived: 'Archiwum',
  test: 'Test',
  spam: 'Spam/test',
};

const flagMap = {
  PL: '🇵🇱', NL: '🇳🇱', DE: '🇩🇪', FR: '🇫🇷', CH: '🇨🇭', EN: '🇬🇧',
  IT: '🇮🇹', CZ: '🇨🇿', ES: '🇪🇸', SE: '🇸🇪', GB: '🇬🇧', SK: '🇸🇰',
  NO: '🇳🇴', BE: '🇧🇪',
};

const flag = (item) => {
  const raw = `${item?.country || ''} ${item?.language || ''}`;
  const code = raw.match(/\(([A-Z]{2})\)/)?.[1] || raw.match(/\b([A-Z]{2})\b/)?.[1] || '';
  return flagMap[code] || '🌍';
};

const money = (item) => Number.isFinite(Number(item?.estimated_total_pln))
  ? `${Number(item.estimated_total_pln).toLocaleString('pl-PL')} PLN`
  : '—';

const peopleLabel = (item) => {
  const people = item?.raw_payload_json?.people || {};
  const parts = [];
  if (people.adults) parts.push(`${people.adults} dor.`);
  if (people.children) parts.push(`${people.children} dzieci`);
  if (people.toddlers) parts.push(`${people.toddlers} maluchy`);
  return parts.join(' + ') || '—';
};

const services = (item) => Array.isArray(item?.services_json) ? item.services_json : [];
const serviceText = (item) => services(item).map((service) => `${service.label} × ${service.qty}`).join(' · ') || 'Brak usług';
const tripsText = (item) => Array.isArray(item?.trips_interest_json) && item.trips_interest_json.length
  ? item.trips_interest_json.join(', ')
  : 'Brak wycieczek';

const findItem = (predicate, fallback = items[0]) => items.find(predicate) || fallback;
const dashboardLead = findItem((item) => item.id === 'DEMO-2026-0001');
const bungalowLead = findItem((item) => /Domek/i.test(item.stay_type));
const groupLead = findItem((item) => /Grupa|Scout/i.test(`${item.stay_type} ${item.message}`));
const evLead = findItem((item) => /EV|ciężki|asfalt|heavy/i.test(`${item.message} ${item.notes} ${JSON.stringify(item.vehicle_details_json || {})}`));
const unavailableLead = findItem((item) => item.status === 'unavailable');
const missingLead = findItem((item) => item.full_name === 'Missing Data Demo');
const toursLead = findItem((item) => Array.isArray(item.trips_interest_json) && item.trips_interest_json.length >= 2);

const stats = {
  all: items.length,
  active: activeItems.length,
  countries: new Set(items.map((item) => item.country).filter(Boolean)).size,
  languages: new Set(items.map((item) => String(item.language || '').toUpperCase()).filter(Boolean)).size,
  camping: items.filter((item) => /camping|kamper|van|namiot|przyczep|bus/i.test(item.stay_type)).length,
  bungalows: items.filter((item) => /domek/i.test(item.stay_type)).length,
  delivered: items.filter((item) => item.mail_delivered).length,
  failed: items.filter((item) => !item.mail_delivered).length,
};

const navGroups = [
  ['Offline workflow', [
    ['⚡', 'CAMP', ''],
    ['⛺', 'Camp PRO', ''],
    ['👤', 'Klienci', '16'],
    ['➕', 'Przedłużenia', ''],
    ['📅', 'Kalendarz', ''],
    ['🏠', 'Recepcja', '12'],
    ['📊', 'GUS', ''],
    ['📋', 'Rezerwacje pola', '24'],
    ['🗺️', 'Plan campu', ''],
    ['🗓️', 'Grafik pracy', ''],
    ['📈', 'Raporty', ''],
  ]],
  ['Zespół i operacje', [
    ['👥', 'Użytkownicy / Pracownicy', ''],
    ['✅', 'Zadania', '5'],
    ['🚗', 'Wyjazdy dziś', ''],
    ['🧑‍💼', 'Pracownicy PRO', ''],
    ['🅿️', 'Parking PRO', ''],
    ['🚌', 'Wycieczki', ''],
    ['🛒', 'Zakupy', ''],
  ]],
  ['Zaplecze', [
    ['⚙️', 'Ustawienia', ''],
    ['🧹', 'Sprzątanie', ''],
    ['🧾', 'Faktury', ''],
    ['⚠️', 'Alerty', ''],
    ['⭐', 'VIP / Blacklist', ''],
    ['📦', 'Magazyn', ''],
    ['🏡', 'Domki', ''],
  ]],
  ['Wiadomości i system', [
    ['✉️', 'Maile / Mail Center', '8'],
    ['📤', 'Eksporty', ''],
    ['🛡️', 'Backup PRO', ''],
    ['🧪', 'Testy', ''],
    ['🗄️', 'Archiwum', ''],
  ]],
];

const templates = [
  ['✅', 'Potwierdź', 'Rezerwacja możliwa, prośba o potwierdzenie danych.'],
  ['📝', 'Poproś o dane', 'Brak daty, telefonu, kraju albo liczby osób.'],
  ['⛔', 'Brak miejsc', 'Grzeczna odmowa z alternatywą i prośbą o inny termin.'],
  ['⛺', 'Camping L/S', 'Lipiec/sierpień: brak rezerwacji miejsc campingowych.'],
  ['🏡', 'Domek', 'Zasady domków, check-in/out, wyposażenie.'],
  ['⚡', 'Prąd / EV', 'Prąd 10A dla kampera, brak ładowania EV na stanowisku.'],
  ['🚌', 'Wycieczki', 'Wieliczka, Auschwitz-Birkenau, Zakopane, Ojców i inne.'],
  ['👥', 'Grupa / skauci', 'Obsługa większej grupy, zasady i dane do doprecyzowania.'],
];

const uiTokenMap = {
  Dashboard: 'HO',
  Recepcja: 'RC',
  CAMP: 'CP',
  'Camp PRO': 'CP',
  'Maile / Mail Center': 'ML',
  Klienci: 'KL',
  'Rezerwacje pola': 'RZ',
  Kalendarz: 'KA',
  'Plan campu': 'PC',
  'Grafik pracy': 'GP',
  Domki: 'DM',
  Camping: 'CP',
  Przedłużenia: 'PP',
  GUS: 'GU',
  Raporty: 'RP',
  'Użytkownicy / Pracownicy': 'UP',
  Zadania: 'ZD',
  'Wyjazdy dziś': 'WY',
  'Pracownicy PRO': 'PR',
  'Parking PRO': 'PK',
  Wycieczki: 'WY',
  Zakupy: 'ZK',
  Ustawienia: 'US',
  Sprzątanie: 'SP',
  Faktury: 'FV',
  Alerty: 'AL',
  'VIP / Blacklist': 'VB',
  Magazyn: 'MG',
  Eksporty: 'EX',
  'Backup PRO': 'BK',
  Testy: 'TE',
  Archiwum: 'AR',
  Potwierdź: 'PT',
  'Poproś o dane': 'PD',
  'Brak miejsc': 'BM',
  'Camping L/S': 'LS',
  Domek: 'DM',
  'Prąd / EV': 'EV',
  'Grupa / skauci': 'GS',
};

const uiToken = (label = '') => uiTokenMap[label] || String(label)
  .split(/[\s/–-]+/)
  .filter(Boolean)
  .map((part) => part[0])
  .join('')
  .slice(0, 2)
  .toUpperCase() || 'CC';

const sections = [
  ['audit-header', 'Header audytu'],
  ['public-i18n', 'Public i18n / CAMPY'],
  ['sidebar-expanded', 'Sidebar rozwinięty'],
  ['sidebar-collapsed', 'Sidebar rail'],
  ['dashboard', 'Dashboard / Recepcja'],
  ['mail-center', 'Centrum wiadomości'],
  ['mail-summary', 'Mail do klienta'],
  ['clients', 'Klienci / CRM'],
  ['reservations', 'Rezerwacje'],
  ['camp-pro', '/camp PRO'],
  ['calendar', 'Kalendarz'],
  ['bungalows', 'Domki'],
  ['camping', 'Camping'],
  ['reply-templates', 'Schematy odpowiedzi'],
  ['reply-modal', 'Modal odpowiedzi'],
  ['settings', 'Ustawienia'],
  ['statistics', 'Statystyki'],
  ['mobile', 'Mobile 390'],
  ['todo', 'Known Issues / TODO'],
];

const calendarResources = ['Domek 2-os.', 'Domek 3-os.', 'Domek 4-os.', 'Domek Blue', 'Domek Family', 'Pole A', 'Pole B', 'Pole C', 'Pole D', 'Pole E'];
const calendarItems = activeItems.slice(0, 10);
const monthDays = Array.from({ length: 31 }, (_, index) => index + 1);
---

<!doctype html>
<html lang="pl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex,nofollow,noarchive" />
    <title>CC SYSTEM — raport audytu</title>
    <meta name="description" content="Statyczny podgląd UI/UX CC SYSTEM na danych demo, bez API i bez prawdziwych danych." />
  </head>
  <body>
    <main class="audit-shell">
      <header class="audit-hero" id="audit-header">
        <div>
          <p class="eyebrow">Camping Clepardia · CC SYSTEM ONLINE</p>
          <h1>CC SYSTEM — raport audytu</h1>
          <p class="hero-copy">Statyczny podgląd UI/UX na danych demo, bez prawdziwych danych i bez requestów API.</p>
        </div>
        <aside class="audit-meta">
          <span>DEMO</span>
          <span>NOINDEX</span>
          <span>NO API</span>
          <span>TASK 139 OFFLINE PARITY</span>
          <span>SAFE FOR REVIEW</span>
          <small>Build/test: {buildStamp}</small>
        </aside>
      </header>

      <nav class="toc" aria-label="Spis sekcji audytu">
        {sections.map(([id, label]) => <a href={`#${id}`}>{label}</a>)}
      </nav>

      <section class="audit-section" id="public-i18n">
        <header>
          <span class="section-number">00</span>
          <div>
            <h2>Public i18n i CAMPY language lock</h2>
            <p>Co sprawdzać: publiczna strona, formularz rezerwacji i CAMPY mają działać w języku aktualnej wersji: PL, EN, DE, IT, FR, ES, NL, CS, SK, SV. CC SYSTEM pozostaje zawsze po polsku.</p>
          </div>
        </header>
        <div class="audit-note-card">
          <h3>Zakres TASK 138/139</h3>
          <p>Formularz rezerwacji ma lokalne etykiety kroków, dat, gości, usług, danych, wycieczek, podsumowania, walidacji i blokady camping lipiec/sierpień. CAMPY ma twardy język strony oraz lokalizowane intro, placeholder, szybkie tematy i odpowiedzi.</p>
          <p>TASK 139 rozszerza raport o offline parity: sidebar w kolejności offline, szeroki kalendarz z rombami/półdniami, /camp jako Nowe przyjęcie, Klienci offline+CRM, GUS offline-style, Rezerwacje operacyjne, Mail Center po polsku i plan synchronizacji offline ↔ online.</p>
          <p>QA/audit są demo-only, mają noindex/nofollow/noarchive, nie wykonują API i nie są przeznaczone do sitemap.</p>
        </div>
      </section>

      <section class="audit-section" id="sidebar-expanded">
        <header>
          <span class="section-number">01</span>
          <div>
            <h2>Sidebar rozwinięty</h2>
            <p>Co sprawdzać: czy moduły są pogrupowane, czy nazwy są czytelne i czy panel wygląda jak narzędzie recepcji, nie jak lista przypadkowych przycisków.</p>
          </div>
        </header>
        <div class="sidebar-stage">
          <aside class="sidebar-demo sidebar-demo--expanded">
            <div class="brand-pill"><span>▲</span><strong>Camping Clepardia<br /><small>CC SYSTEM ONLINE</small></strong></div>
            {navGroups.map(([group, links]) => (
              <div class="sidebar-group">
                <p>{group}</p>
                {links.map(([icon, label, count]) => (
                  <article class={label === 'Maile / Mail Center' ? 'is-active' : ''}>
                    <span>{uiToken(label)}</span><b>{label}</b>{count && <em>{count}</em>}
                  </article>
                ))}
              </div>
            ))}
            <button>← Zwiń menu</button>
          </aside>
          <div class="audit-note-card">
            <h3>Założenie UX</h3>
            <p>Domyślnie desktop ma cienki pasek ikon. Po hover wysuwa się glass overlay z pełnymi nazwami i nie przesuwa treści; pin zostawia go szerokim.</p>
          </div>
        </div>
      </section>

      <section class="audit-section" id="sidebar-collapsed">
        <header>
          <span class="section-number">02</span>
          <div>
            <h2>Sidebar collapsed</h2>
            <p>Co sprawdzać: czy po zwinięciu nadal wiadomo, gdzie są najważniejsze moduły, a ikony nie zabierają miejsca głównej pracy recepcji.</p>
          </div>
        </header>
        <div class="collapsed-stage">
          <aside class="sidebar-demo sidebar-demo--collapsed">
            <div class="brand-icon">▲</div>
            {navGroups.flatMap(([, links]) => links).map(([icon, label, count]) => (
              <article title={label}>
                <span>{uiToken(label)}</span>{count && <em>{count}</em>}
              </article>
            ))}
            <button title="Rozwiń menu">→</button>
          </aside>
          <div class="legend-list">
            {navGroups.flatMap(([, links]) => links).slice(0, 9).map(([icon, label]) => <span><b>{uiToken(label)}</b>{label}</span>)}
          </div>
        </div>
      </section>

      <section class="audit-section" id="dashboard">
        <header>
          <span class="section-number">03</span>
          <div>
            <h2>Dashboard / Recepcja</h2>
            <p>Co sprawdzać: szybkie KPI, pilne sprawy, mini skrzynkę, zadania i status operacyjny bez udawania pełnej tabeli rezerwacji.</p>
          </div>
        </header>
        <div class="dashboard-grid">
          <section class="hero-panel">
            <p class="eyebrow">Dzisiaj w recepcji</p>
            <h3>12 nowych zapytań · 5 pilnych · 100% demo safe</h3>
            <div class="kpi-grid">
              <article><span>🟢</span><b>{stats.active}</b><small>aktywnych demo</small></article>
              <article><span>🏕️</span><b>{stats.camping}</b><small>camping</small></article>
              <article><span>🏡</span><b>{stats.bungalows}</b><small>domki</small></article>
              <article><span>✉️</span><b>{stats.delivered}/{stats.all}</b><small>dostarczenie maili</small></article>
            </div>
          </section>
          <section class="work-card urgent-card">
            <h3>🔥 Pilne teraz</h3>
            {[dashboardLead, evLead, missingLead].map((item) => (
              <article class="mini-thread">
                <strong>{flag(item)} {item.full_name}</strong>
                <span>{statusLabels[item.status]} · {item.stay_type}</span>
                <small>{item.arrival_date || 'brak daty'} — {item.departure_date || 'brak wyjazdu'}</small>
              </article>
            ))}
          </section>
          <section class="work-card">
            <h3>Mini skrzynka</h3>
            {activeItems.slice(0, 4).map((item) => (
              <article class="mail-line">
                <b>{item.full_name}</b>
                <span>{item.message}</span>
                <em>{peopleLabel(item)}</em>
              </article>
            ))}
          </section>
          <section class="work-card">
            <h3>Zadania</h3>
            <ul class="clean-list">
              <li>Odpowiedzieć na camping L/S — bez potwierdzania miejsca.</li>
              <li>Poprosić o brakującą datę wyjazdu.</li>
              <li>Oznaczyć ciężki pojazd i asfalt.</li>
              <li>Przygotować odpowiedź dla grupy skautów.</li>
            </ul>
          </section>
        </div>
      </section>

      <section class="audit-section" id="mail-center">
        <header>
          <span class="section-number">04</span>
          <div>
            <h2>Centrum wiadomości — widok docelowy</h2>
            <p>Co sprawdzać: czy przypomina Gmail/CRM, czy lista wątków jest kompaktowa, czy panel sprawy jest czytelny i czy odpowiedzi są przygotowane jako akcje.</p>
          </div>
        </header>
        <div class="mail-center-preview">
          <aside class="mail-folders-preview">
            <h3>Skrzynka</h3>
            {[
              ['Wszystkie', stats.all],
              ['Nowe', items.filter((item) => item.status === 'new').length],
              ['Do odpowiedzi', items.filter((item) => item.status === 'needs_reply').length],
              ['Do potwierdzenia', items.filter((item) => item.status === 'needs_confirmation').length],
              ['Potwierdzone', items.filter((item) => item.status === 'confirmed').length],
              ['Brak miejsc', items.filter((item) => item.status === 'unavailable').length],
              ['Mail niedostarczony', items.filter((item) => !item.mail_delivered).length],
              ['Testy', items.filter((item) => item.status === 'test').length],
              ['Archiwum', items.filter((item) => item.status === 'archived').length],
            ].map(([label, value]) => <button><span>{label}</span><b>{value}</b></button>)}
          </aside>
          <section class="thread-list-preview">
            {activeItems.slice(0, 7).map((item, index) => (
              <article class={index === 0 ? 'is-selected' : ''}>
                <strong>{flag(item)} {item.full_name}</strong>
                <span>{item.arrival_date || 'brak daty'} — {item.departure_date || 'brak daty'}</span>
                <small>{peopleLabel(item)} · {item.stay_type}</small>
                <b>{peopleLabel(item)}</b>
              </article>
            ))}
          </section>
          <section class="case-preview">
            <div class="case-header">
              <span class="avatar">AK</span>
              <div>
                <h3>{dashboardLead.full_name}</h3>
                <p>{flag(dashboardLead)} {dashboardLead.country} · język {dashboardLead.language}</p>
              </div>
              <em>{statusLabels[dashboardLead.status]}</em>
            </div>
            <div class="case-kpis">
              <article><small>Termin</small><b>{dashboardLead.arrival_date} — {dashboardLead.departure_date}</b></article>
              <article><small>Osoby</small><b>{peopleLabel(dashboardLead)}</b></article>
              <article><small>Pobyt</small><b>{dashboardLead.stay_type}</b></article>
              <article><small>Język</small><b>{dashboardLead.language}</b></article>
            </div>
            <section class="warning-box">
              <h4>Ważne informacje</h4>
              <ul>
                <li>Lipiec/sierpień + camping: miejsca według kolejności przyjazdu.</li>
                <li>Prąd 10A: dostępny dla kampera/przyczepy.</li>
                <li>Nie potwierdzać konkretnego miejsca campingowego.</li>
              </ul>
            </section>
            <section class="warning-box">
              <h4>Historia rozmowy</h4>
              <ul>
                <li>Wiadomość przychodząca: formularz publiczny.</li>
                <li>Wiadomość wychodząca: odpowiedź wysłana przez Resend.</li>
                <li>Notatki recepcji: zmiany statusu i ważne informacje.</li>
              </ul>
            </section>
            <div class="reply-actions">
              <button>Utwórz odpowiedź premium</button>
              <button>Wyślij przez Resend</button>
              <button>Kopiuj podsumowanie</button>
              <button>Podgląd PL dla recepcji</button>
              <button>Oznacz jako odpowiedziane</button>
            </div>
          </section>
        </div>
      </section>

      <section class="audit-section" id="mail-summary">
        <header>
          <span class="section-number">04B</span>
          <div>
            <h2>Mail do recepcji — najważniejsze kafelki</h2>
            <p>Co sprawdzać: mail do klienta ma być czysty, bez kanałów technicznych i diagnostyki, z konkretnym pobytem, pojazdem, usługami i jasnymi warunkami.</p>
          </div>
        </header>
        <div class="modal-preview">
          <section class="modal-card">
            <header><span>⭐</span><div><h3>Najważniejsze informacje</h3><p>{dashboardLead.full_name} · {flag(dashboardLead)} {dashboardLead.country}</p></div></header>
            <div class="case-kpis">
              <article><small>Klient</small><b>{dashboardLead.full_name}</b></article>
              <article><small>Kraj</small><b>{flag(dashboardLead)} {dashboardLead.country}</b></article>
              <article><small>Termin</small><b>{dashboardLead.arrival_date} — {dashboardLead.departure_date}</b></article>
              <article><small>Pobyt / pojazd</small><b>Kamper + Prąd 10A</b></article>
              <article><small>Usługi</small><b>{serviceText(dashboardLead)}</b></article>
              <article><small>Mail</small><b>{dashboardLead.mail_delivered ? 'Dostarczony' : 'Do obsługi'}</b></article>
            </div>
            <article class="email-preview">
              <h4>Najważniejsze informacje dla klienta</h4>
              <p>Termin, pobyt/pojazd, usługi i warunki są podane jasno. Mail nie pokazuje inquiry ID, Supabase, Resend, raw payloadu, feedbacku ani zgód.</p>
            </article>
          </section>
        </div>
      </section>

      <section class="audit-section" id="clients">
        <header>
          <span class="section-number">05</span>
          <div>
            <h2>Klienci — CRM profile</h2>
            <p>Co sprawdzać: czy widok klienta łączy dane kontaktowe, pobyty, notatki, preferencje i szybkie akcje bez mieszania z inboxem.</p>
          </div>
        </header>
        <div class="crm-preview">
          <section class="crm-hero-card">
            <span class="avatar avatar-lg">AK</span>
            <div>
              <h3>{dashboardLead.full_name} {flag(dashboardLead)}</h3>
              <p>{dashboardLead.email} · {dashboardLead.phone} · {dashboardLead.country}</p>
              <div class="tag-row"><span>Klient</span><span>Camping L/S</span><span>⭐ 5/5 demo</span></div>
            </div>
            <dl>
              <div><dt>Pierwszy kontakt</dt><dd>26.06.2026</dd></div>
              <div><dt>Liczba pobytów</dt><dd>3</dd></div>
              <div><dt>Ostatni kontakt</dt><dd>26.06.2026</dd></div>
              <div><dt>Język</dt><dd>{dashboardLead.language}</dd></div>
            </dl>
          </section>
          <section class="work-card">
            <h3>Następny pobyt</h3>
            <article class="stay-card">
              <b>{dashboardLead.stay_type}</b>
              <span>{dashboardLead.arrival_date} — {dashboardLead.departure_date}</span>
              <em>{peopleLabel(dashboardLead)}</em>
            </article>
          </section>
