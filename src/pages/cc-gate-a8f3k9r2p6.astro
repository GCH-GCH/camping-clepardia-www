---
const title = 'CC SYSTEM';
---

<!doctype html>
<html lang="pl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow, noarchive" />
    <meta name="referrer" content="no-referrer" />
    <title>{title} — Recepcja online</title>
    <link rel="icon" href="/favicon.ico?v=3" sizes="any" />
    <link rel="icon" href="/favicon.svg?v=3" type="image/svg+xml" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png?v=3" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png?v=3" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png?v=3" />
    <link rel="manifest" href="/site.webmanifest?v=3" />
  </head>
  <body>
    <main class="inbox-shell">
      <section class="login-card" data-login>
        <span class="eyebrow">Panel recepcji Camping Clepardia</span>
        <h1>{title}</h1>
        <p>Wpisz kod dostępu skonfigurowany dla recepcji.</p>
        <form data-login-form>
          <label><span>Kod dostępu</span><input type="password" name="accessCode" autocomplete="current-password" required /></label>
          <button type="submit">Otwórz panel</button>
          <p class="status" data-login-status aria-live="polite"></p>
        </form>
      </section>

      <section class="inbox-app cc-system-app" data-app data-sidebar-state="rail" data-active-view="dashboard" hidden>
        <button class="cc-sidebar-scrim" type="button" data-sidebar-close aria-label="Zamknij menu"></button>
        <aside class="cc-sidebar" data-sidebar>
          <div class="cc-sidebar__brand">
            <img src="/brand/logo/clepardia-logo-main.svg" alt="Camping Clepardia" width="46" height="46" loading="eager" decoding="async" />
            <span>
              <strong>{title}</strong>
              <small>ONLINE</small>
            </span>
          </div>
          <button class="cc-sidebar__toggle" type="button" data-sidebar-toggle aria-label="Przypnij lub odepnij menu"><span>⇥</span><em>Przypnij menu</em></button>
          <nav class="view-tabs cc-sidebar__nav" aria-label="Moduły CC SYSTEM">
            <div class="cc-sidebar__group">
              <span class="cc-sidebar__group-label">Offline workflow</span>
              <button type="button" data-view="camp" aria-pressed="false"><span aria-hidden="true"></span><em>CAMP</em></button>
              <button type="button" data-view="camp-pro" aria-pressed="false"><span aria-hidden="true"></span><em>Camp PRO</em></button>
              <button type="button" data-view="customers" aria-pressed="false"><span aria-hidden="true"></span><em>Klienci</em></button>
              <button type="button" data-view="extend" aria-pressed="false"><span aria-hidden="true"></span><em>Przedłużenia</em></button>
              <button type="button" data-view="calendar" aria-pressed="false"><span aria-hidden="true"></span><em>Kalendarz</em></button>
              <button type="button" data-view="dashboard" aria-pressed="true"><span aria-hidden="true"></span><em>Recepcja</em></button>
              <button type="button" data-view="reports" aria-pressed="false"><span aria-hidden="true"></span><em>GUS</em></button>
              <button type="button" data-view="reservations" aria-pressed="false"><span aria-hidden="true"></span><em>Rezerwacje pola</em></button>
              <button type="button" data-view="camp-plan" aria-pressed="false"><span aria-hidden="true"></span><em>Plan campu</em></button>
              <button type="button" data-view="work-schedule" aria-pressed="false"><span aria-hidden="true"></span><em>Grafik pracy</em></button>
              <button type="button" data-view="stats" aria-pressed="false"><span aria-hidden="true"></span><em>Raporty</em></button>
            </div>
            <div class="cc-sidebar__group">
              <span class="cc-sidebar__group-label">Zespół i operacje</span>
              <button type="button" data-view="staff" aria-pressed="false"><span aria-hidden="true"></span><em>Użytkownicy / Pracownicy</em></button>
              <button type="button" data-view="tasks" aria-pressed="false"><span aria-hidden="true"></span><em>Zadania</em><b data-sidebar-badge="tasks">0</b></button>
              <button type="button" data-view="departures" aria-pressed="false"><span aria-hidden="true"></span><em>Wyjazdy dziś</em></button>
              <button type="button" data-view="staff-pro" aria-pressed="false"><span aria-hidden="true"></span><em>Pracownicy PRO</em></button>
              <button type="button" data-view="parking" aria-pressed="false"><span aria-hidden="true"></span><em>Parking PRO</em></button>
              <button type="button" data-view="tours" aria-pressed="false"><span aria-hidden="true"></span><em>Wycieczki</em></button>
              <button type="button" data-view="purchases" aria-pressed="false"><span aria-hidden="true"></span><em>Zakupy</em></button>
            </div>
            <div class="cc-sidebar__group">
              <span class="cc-sidebar__group-label">Zaplecze</span>
              <button type="button" data-view="settings" aria-pressed="false"><span aria-hidden="true"></span><em>Ustawienia</em></button>
              <button type="button" data-view="print" aria-pressed="false"><span aria-hidden="true"></span><em>Drukowanie</em></button>
              <button type="button" data-view="info" aria-pressed="false"><span aria-hidden="true"></span><em>Info recepcji</em></button>
              <button type="button" data-view="products" aria-pressed="false"><span aria-hidden="true"></span><em>Produkty</em></button>
              <button type="button" data-view="cleaning" aria-pressed="false"><span aria-hidden="true"></span><em>Sprzątanie</em></button>
              <button type="button" data-view="invoices" aria-pressed="false"><span aria-hidden="true"></span><em>Faktury</em></button>
              <button type="button" data-view="alerts" aria-pressed="false"><span aria-hidden="true"></span><em>Alerty</em></button>
              <button type="button" data-view="vip" aria-pressed="false"><span aria-hidden="true"></span><em>VIP / Blacklist</em></button>
              <button type="button" data-view="warehouse" aria-pressed="false"><span aria-hidden="true"></span><em>Magazyn</em></button>
              <button type="button" data-view="bungalows" aria-pressed="false"><span aria-hidden="true"></span><em>Domki</em></button>
            </div>
            <div class="cc-sidebar__group">
              <span class="cc-sidebar__group-label">Wiadomości i system</span>
              <button type="button" data-view="mail" aria-pressed="false"><span aria-hidden="true"></span><em>Maile / Mail Center</em><b data-sidebar-badge="inbox">0</b></button>
              <button type="button" data-view="inbox" aria-pressed="false"><span aria-hidden="true"></span><em>Inbox</em></button>
              <button type="button" data-view="exports" aria-pressed="false"><span aria-hidden="true"></span><em>Eksporty</em></button>
              <button type="button" data-view="backup" aria-pressed="false"><span aria-hidden="true"></span><em>Backup PRO</em></button>
              <button type="button" data-view="tests" aria-pressed="false"><span aria-hidden="true"></span><em>Testy</em><b data-sidebar-badge="tests">0</b></button>
              <button type="button" data-view="archive" aria-pressed="false"><span aria-hidden="true"></span><em>Archiwum</em></button>
            </div>
          </nav>
        </aside>

        <div class="cc-system-main">
          <header class="app-header">
            <button class="cc-mobile-menu" type="button" data-sidebar-mobile-toggle aria-label="Otwórz menu">☰</button>
            <div class="app-header__brand">
              <img class="app-header__logo" src="/brand/logo/clepardia-logo-main.svg" alt="Camping Clepardia" width="64" height="64" loading="eager" decoding="async" />
              <div>
                <span class="eyebrow">Camping Clepardia</span>
                <h1>{title} <span class="online-badge">ONLINE</span></h1>
                <p>Recepcja online · klienci · rezerwacje · kalendarz · odpowiedzi</p>
                <small data-count>Ładowanie zapytań…</small>
              </div>
            </div>
            <label class="global-search" aria-label="Globalna wyszukiwarka">
              <span>🔎</span>
              <input type="search" data-global-search placeholder="Szukaj po imieniu, emailu, kraju, terminie…" />
            </label>
            <div class="header-actions">
              <span class="connection-pill connection-pill--online" data-connection-status>Online</span>
              <span class="connection-pill connection-pill--mini" data-auto-refresh-status>Auto 25 s</span>
              <span class="connection-pill connection-pill--mini" data-resend-status>Resend</span>
              <span class="connection-pill connection-pill--mini" data-supabase-status>Supabase</span>
              <span class="connection-pill weather-pill">☀️ 23°C</span>
              <span class="notification-pill" aria-label="Powiadomienia">8</span>
              <button type="button" class="topbar-action" data-view-shortcut="camp">Nowe przyjęcie</button>
              <a class="topbar-action topbar-action--ghost" href="/rezerwacja/" target="_blank" rel="noopener">Dodaj rezerwację</a>
              <details class="topbar-more">
                <summary>Więcej</summary>
                <div>
                  <span class="connection-pill" data-last-refresh>Ostatnie odświeżenie: —</span>
                  <button type="button" data-refresh>Odśwież</button>
                  <button type="button" data-auto-refresh-toggle>Pauza auto-refresh</button>
                  <a href="/" target="_blank" rel="noopener">Strona publiczna</a>
                  <button type="button" data-view-shortcut="settings">Ustawienia</button>
                  <button type="button" data-view-shortcut="tests">Debug / testy</button>
                  <button type="button" class="ghost" data-logout>Wyloguj</button>
                </div>
              </details>
              <span class="profile-pill">Recepcja</span>
            </div>
          </header>

        <section class="mail-center-nav" aria-label="Centrum wiadomości">
          <button type="button" data-mail-status="">Skrzynka / Wiadomości</button>
          <button type="button" data-mail-status="needs_reply">Do odpowiedzi</button>
          <button type="button" data-mail-status="replied">Odpowiedziane</button>
          <button type="button" data-mail-status="needs_confirmation">Do potwierdzenia</button>
          <button type="button" data-mail-status="confirmed">Potwierdzone</button>
          <button type="button" data-mail-status="unavailable">Brak miejsc</button>
          <button type="button" data-view-shortcut="tests">Testy</button>
          <button type="button" data-view-shortcut="archive">Archiwum</button>
        </section>

        <section class="system-strip" data-system-strip aria-label="Status systemu"></section>

        <section class="stats-grid" data-stats aria-label="Statystyki inboxu"></section>

        <section class="filters" aria-label="Filtry zapytań">
          <div class="filter-shortcuts">
            <button type="button" data-view-shortcut="mail">Wszystko</button>
            <button type="button" data-clear-filters>Wyczyść filtry</button>
            <button type="button" data-view-shortcut="tests">Testy</button>
            <button type="button" data-view-shortcut="archive">Archiwum</button>
            <span data-active-filter-count>Aktywne filtry: 0</span>
          </div>
          <label class="search"><span>Szukaj</span><input type="search" data-filter="search" placeholder="Imię, email, telefon, rejestracja, kraj, wiadomość…" /></label>
          <label><span>Status</span><select data-filter="status"><option value="">Wszystkie</option></select></label>
          <label><span>Kategoria</span><select data-filter="category"><option value="">Wszystkie</option></select></label>
          <label><span>Typ pobytu</span><select data-filter="stay"><option value="">Wszystkie</option></select></label>
          <label><span>Kraj</span><select data-filter="country"><option value="">Wszystkie</option></select></label>
          <label><span>Język</span><select data-filter="language"><option value="">Wszystkie</option></select></label>
          <label><span>Przyjazd od</span><input type="date" data-filter="arrival" /></label>
          <label><span>Sortowanie</span><select data-filter="sort"><option value="newest">Najnowsze</option><option value="oldest">Najstarsze</option><option value="arrival">Przyjazd najbliżej</option></select></label>
          <label class="check"><input type="checkbox" data-filter="mailFailed" /><span>Mail niedostarczony</span></label>
          <label class="check"><input type="checkbox" data-filter="trips" /><span>Wycieczki</span></label>
          <label class="check"><input type="checkbox" data-filter="event" /><span>Wydarzenia</span></label>
          <label class="check"><input type="checkbox" data-filter="special" /><span>Specjalne potrzeby</span></label>
          <label class="check"><input type="checkbox" data-filter="heavy" /><span>Ciężki pojazd</span></label>
          <label class="check"><input type="checkbox" data-filter="ev" /><span>Prąd / EV</span></label>
          <label class="check"><input type="checkbox" data-filter="summer" /><span>Lipiec / sierpień</span></label>
          <label class="check"><input type="checkbox" data-filter="mailSent" /><span>Mail wysłany</span></label>
          <label class="check"><input type="checkbox" data-filter="group" /><span>Grupy</span></label>
          <label class="check"><input type="checkbox" data-filter="scouts" /><span>Skauci</span></label>
          <label class="check"><input type="checkbox" data-filter="missing" /><span>Brakuje danych</span></label>
          <label class="check"><input type="checkbox" data-filter="today" /><span>Dzisiaj</span></label>
          <label class="check"><input type="checkbox" data-filter="next7" /><span>7 dni</span></label>
        </section>

        <p class="app-status" data-app-status aria-live="polite"></p>
        <section class="inquiry-list" data-list></section>
        </div>
      </section>
    </main>
    <div class="panel-toast" data-panel-toast role="status" aria-live="polite" hidden></div>
    <div class="reply-modal" data-reply-modal hidden>
      <div class="reply-modal__backdrop" data-reply-close></div>
      <section class="reply-modal__card" role="dialog" aria-modal="true" aria-labelledby="reply-modal-title">
        <button class="reply-modal__close" type="button" data-reply-close aria-label="Zamknij">×</button>
        <header>
          <span class="eyebrow">Maile / Mail Center</span>
          <h2 id="reply-modal-title" data-reply-title>Odpowiedź do klienta</h2>
          <p data-reply-meta>Podgląd wiadomości klienta oraz podgląd po polsku dla recepcji</p>
        </header>
        <div class="reply-modal__fields">
          <label><span>Do</span><input type="email" data-reply-to placeholder="email klienta" /></label>
          <label><span>Temat</span><input type="text" data-reply-subject placeholder="Camping Clepardia — odpowiedź na zapytanie" /></label>
          <label><span>Język</span><select data-reply-language><option>PL</option><option>EN</option><option>DE</option><option>IT</option><option>FR</option><option>ES</option><option>NL</option><option>CS</option><option>SK</option><option>SV</option></select></label>
          <label class="reply-modal__editor"><span>Treść wysyłana do klienta</span><textarea data-reply-editor rows="9" placeholder="Treść odpowiedzi do klienta"></textarea></label>
        </div>
        <div class="reply-modal__preview" data-reply-preview></div>
        <details class="reply-modal__text">
          <summary>Tekstowa wersja wiadomości</summary>
          <pre data-reply-mailto-text></pre>
        </details>
        <div class="reply-modal__actions">
          <button type="button" data-reply-send>Wyślij z CC SYSTEM</button>
          <button type="button" data-reply-draft>Zapisz szkic</button>
          <button type="button" data-reply-copy>Kopiuj treść</button>
          <button type="button" data-reply-mailto>Otwórz mailto</button>
          <button type="button" data-reply-mark>Oznacz jako odpowiedziane</button>
          <button type="button" class="ghost" data-reply-close>Zamknij</button>
        </div>
      </section>
    </div>

    <script>
      (() => {
        const demoMode = false;
        const storageKey = 'cc-inbox-access-code';
        const inboxSendReplyEndpoint = '/api/inbox/send-reply';
        const inboxSaveDraftEndpoint = '/api/inbox/save-draft';
        const inboxActivityEndpoint = '/api/inbox/activity';
        const login = document.querySelector('[data-login]');
        const app = document.querySelector('[data-app]');
        const loginForm = document.querySelector('[data-login-form]');
        const loginStatus = document.querySelector('[data-login-status]');
        const appStatus = document.querySelector('[data-app-status]');
        const list = document.querySelector('[data-list]');
        const count = document.querySelector('[data-count]');
        const stats = document.querySelector('[data-stats]');
        const connectionStatus = document.querySelector('[data-connection-status]');
        const lastRefresh = document.querySelector('[data-last-refresh]');
        const resendStatus = document.querySelector('[data-resend-status]');
        const supabaseStatus = document.querySelector('[data-supabase-status]');
        const autoRefreshStatus = document.querySelector('[data-auto-refresh-status]');
        const autoRefreshToggle = document.querySelector('[data-auto-refresh-toggle]');
        const panelToast = document.querySelector('[data-panel-toast]');
        const replyModal = document.querySelector('[data-reply-modal]');
        const replyTitle = document.querySelector('[data-reply-title]');
        const replyMeta = document.querySelector('[data-reply-meta]');
        const replyPreview = document.querySelector('[data-reply-preview]');
        const replyMailtoText = document.querySelector('[data-reply-mailto-text]');
        const replyToInput = document.querySelector('[data-reply-to]');
        const replySubjectInput = document.querySelector('[data-reply-subject]');
        const replyLanguageSelect = document.querySelector('[data-reply-language]');
        const replyEditor = document.querySelector('[data-reply-editor]');
        const replySendButton = document.querySelector('[data-reply-send]');
        const replyDraftButton = document.querySelector('[data-reply-draft]');
        const systemStrip = document.querySelector('[data-system-strip]');
        const activeFilterCount = document.querySelector('[data-active-filter-count]');
        const viewButtons = Array.from(document.querySelectorAll('[data-view]'));
        const sidebarIcons = {
          dashboard: '<path d="M3 11.5 12 4l9 7.5"/><path d="M5.5 10.5V20h5v-5.5h3V20h5v-9.5"/>',
          mail: '<rect x="3" y="5" width="18" height="14" rx="3"/><path d="m4 7 8 6 8-6"/>',
          customers: '<circle cx="12" cy="8" r="4"/><path d="M5 21a7 7 0 0 1 14 0"/>',
          reservations: '<rect x="5" y="4" width="14" height="17" rx="2"/><path d="M9 4h6"/><path d="m9 13 2 2 4-5"/>',
          calendar: '<rect x="4" y="5" width="16" height="15" rx="3"/><path d="M8 3v4M16 3v4M4 10h16"/>',
          camp: '<path d="M13 2 5 13h6l-1 9 9-13h-6l1-7Z"/>',
          bungalows: '<path d="M3 11.5 12 4l9 7.5"/><path d="M6 10.5V20h12v-9.5"/>',
          camping: '<path d="M3.5 20 12 4l8.5 16"/><path d="M12 4v16"/><path d="M8.5 20 12 13l3.5 7"/>',
          extend: '<rect x="4" y="5" width="16" height="15" rx="3"/><path d="M8 3v4M16 3v4M4 10h16M12 13v5M9.5 15.5h5"/>',
          print: '<path d="M7 8V4h10v4"/><rect x="5" y="12" width="14" height="8" rx="2"/><path d="M7 16h10"/><path d="M6 12h12a3 3 0 0 0-3-3H9a3 3 0 0 0-3 3Z"/>',
          reports: '<path d="M4 20h16"/><path d="M7 16v-5M12 16V7M17 16v-8"/>',
          stats: '<path d="M4 19h16"/><path d="m5 15 4-4 3 3 6-8"/><circle cx="9" cy="11" r="1"/><circle cx="12" cy="14" r="1"/><circle cx="18" cy="6" r="1"/>',
          templates: '<path d="M21 12a8 8 0 0 1-8 8H6l-3 2 1.5-4A8 8 0 1 1 21 12Z"/><path d="M8 10h8M8 14h5"/>',
          staff: '<circle cx="9" cy="8" r="3"/><circle cx="17" cy="10" r="2.5"/><path d="M3.5 20a6 6 0 0 1 11 0"/><path d="M14 19a5 5 0 0 1 6.5 0"/>',
          tasks: '<rect x="4" y="5" width="16" height="15" rx="3"/><path d="m8 12 2.5 2.5L16 9"/>',
          settings: '<circle cx="12" cy="12" r="3"/><path d="M12 3v3M12 18v3M3 12h3M18 12h3M5.6 5.6l2.1 2.1M16.3 16.3l2.1 2.1M18.4 5.6l-2.1 2.1M7.7 16.3l-2.1 2.1"/>',
          tests: '<path d="M9 3h6"/><path d="M10 3v5l-4.8 8.8A3 3 0 0 0 7.8 21h8.4a3 3 0 0 0 2.6-4.2L14 8V3"/><path d="M8 15h8"/>',
          archive: '<rect x="4" y="5" width="16" height="4" rx="1"/><path d="M6 9v10h12V9"/><path d="M10 13h4"/>',
          alert: '<path d="M12 3 22 20H2L12 3Z"/><path d="M12 9v5M12 17h.01"/>',
        };
        const sidebarIconMap = {
          dashboard: 'dashboard',
          mail: 'mail',
          inbox: 'mail',
          customers: 'customers',
          reservations: 'reservations',
          calendar: 'calendar',
          camp: 'camp',
          bungalows: 'bungalows',
          camping: 'camping',
          extend: 'extend',
          print: 'print',
          reports: 'reports',
          stats: 'stats',
          templates: 'templates',
          staff: 'staff',
          tasks: 'tasks',
          settings: 'settings',
          tests: 'tests',
          archive: 'archive',
          'camp-pro': 'camp',
          'camp-plan': 'camping',
          'work-schedule': 'calendar',
          departures: 'extend',
          all: 'archive',
          'staff-pro': 'staff',
          parking: 'reservations',
          tours: 'templates',
          purchases: 'reports',
          products: 'reports',
          info: 'templates',
          cleaning: 'tasks',
          invoices: 'print',
          alerts: 'alert',
          vip: 'customers',
          warehouse: 'archive',
          exports: 'reports',
          backup: 'archive',
        };
        const sidebarSvg = (name) => `<svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">${sidebarIcons[name] || sidebarIcons.dashboard}</svg>`;
        Array.from(document.querySelectorAll('.cc-sidebar [data-view], .cc-sidebar [data-view-shortcut]')).forEach((button) => {
          const label = button.querySelector('em')?.textContent?.trim();
          const iconSlot = button.querySelector('span[aria-hidden="true"]');
          const key = button.classList.contains('cc-sidebar__mail-failed') ? 'alert' : sidebarIconMap[button.dataset.view || button.dataset.viewShortcut || 'dashboard'];
          if (iconSlot) {
            iconSlot.classList.add('cc-sidebar__icon');
            iconSlot.innerHTML = sidebarSvg(key);
          }
          if (label) {
            button.setAttribute('title', label);
            button.setAttribute('aria-label', label);
          }
        });
        const filters = Array.from(document.querySelectorAll('[data-filter]'));
        const globalSearch = document.querySelector('[data-global-search]');
        const sidebarToggle = document.querySelector('[data-sidebar-toggle]');
        const sidebarMobileToggle = document.querySelector('[data-sidebar-mobile-toggle]');
        const sidebarCloseButtons = Array.from(document.querySelectorAll('[data-sidebar-close]'));
        const sidebarBadges = Array.from(document.querySelectorAll('[data-sidebar-badge]'));
        const statusLabels = { new:'Nowe', needs_reply:'Do odpowiedzi', replied:'Odpowiedziane', needs_confirmation:'Do potwierdzenia', confirmed:'Potwierdzone', deposit:'Zaliczka', paid:'Opłacona', unpaid:'Nieopłacona', unavailable:'Brak miejsc', rejected:'Odrzucone', cancelled:'Anulowane', archived:'Archiwum', test:'Test', spam:'Spam/test' };
        const categoryLabels = {
          urgent:'Pilne', today:'Przyjazd dzisiaj', next7:'Przyjazd ≤ 7 dni', camping:'Camping', bungalow:'Domki', combined:'Pobyt łączony',
          group:'Grupa', scouts:'Harcerze / skauci', trips:'Wycieczki', feedback:'Opinia o stronie',
          event:'Wydarzenie', mailFailed:'Mail niedostarczony', late:'Późny przyjazd', special:'Specjalne potrzeby',
          heavy:'Ciężki pojazd', ev:'Prąd / EV warning', missing:'Brakuje danych', mailSent:'Mail wysłany', test:'Test', archived:'Archiwum',
