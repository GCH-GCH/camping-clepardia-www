            <div class="card-actions"><button type="button" data-reply-action="confirm" data-target-status="needs_confirmation">✅ Potwierdź</button><button type="button" data-reply-action="askMissingData" data-target-status="needs_reply">📝 Poproś o dane</button><button type="button" data-reply-action="noAvailability" data-target-status="unavailable">❌ Brak miejsc</button><button type="button" data-reply-action="heavyVehicle" data-target-status="replied">🚫 Ciężki pojazd</button><button type="button" data-reply-action="groupScout" data-target-status="needs_reply">👥 Grupa / skauci</button><button type="button" data-quick-status="replied">Odpowiedziane</button><button type="button" data-quick-status="rejected">Odrzuć</button><button type="button" data-copy-summary>Kopiuj podsumowanie</button><button type="button" data-copy-email ${item.email ? '':'disabled'}>Kopiuj email</button><button type="button" data-copy-phone ${item.phone ? '':'disabled'}>Kopiuj telefon</button><button type="button" data-copy-mail>Kopiuj treść maila</button><button type="button" data-copy-id>Kopiuj link / ID</button>${item.phone ? `<a href="tel:${esc(item.phone)}">Otwórz tel</a>`:''}<button type="button" data-quick-status="cancelled">Anulowane</button><button type="button" data-quick-status="archived">Archiwizuj</button><button type="button" data-quick-status="spam">Spam/test</button></div>`;
        };
        const card = (item) => {
          const payload = raw(item);
          const categories = categoryKeys(item);
          const country = countryInfo(item);
          const visibleCategoryBadges = categories.filter((key)=>!['mailFailed','mailSent','feedback'].includes(key));
          const categoryBadges = visibleCategoryBadges.map((key)=>`<span class="category-badge category-${esc(key)}">${esc(categoryLabels[key] || key)}</span>`).join('');
          const highSeason = Boolean(payload.highSeasonCampingInfo) || (isSummer(item) && /camping|kamper|van|namiot|przyczep|bus/i.test(item.stay_type || ''));
          const countrySummary = `${country.flag} ${country.label}${country.code ? ` (${country.code})` : ''} · ${country.language}`;
          const guests = normalizeInquiryGuests(item);
          const mainServices = services(item).slice(0,4).map((service)=>`${service.label} × ${service.qty}`).join(' + ') || 'brak usług';
          const priority = categories.includes('urgent') || categories.includes('mailFailed') || categories.includes('group') ? 'Pilne' : 'Normalne';
          const recommendedId = recommendedTemplateId(item);
          const bestSuggestion = suggestBestReply(item);
          return `<article class="inquiry-card" data-id="${esc(item.id)}">
            <header>
              <div><div class="card-badges"><span class="status-badge status-${esc(item.status)}">${esc(statusLabels[item.status] || item.status)}</span>${categoryBadges}${highSeason ? '<span class="season-badge">Lipiec/sierpień — camping bez rezerwacji</span>':''}</div><h2>${esc(item.full_name || 'Bez nazwy')}</h2><p>${esc(item.stay_type || '-')} · ${esc(item.arrival_date || '-')} — ${esc(item.departure_date || '-')} · ${esc(item.nights || 0)} nocy</p></div>
              <div class="card-date"><small>Dodano</small><strong>${esc(formatDate(item.created_at,true))}</strong><code>${esc(item.id)}</code></div>
            </header>
            <div class="inquiry-card__summary">
              <span>🏕️ ${esc(item.stay_type || '-')}</span>
              <span>📅 ${esc(item.arrival_date || '-')} — ${esc(item.departure_date || '-')}</span>
              <span class="country-pill">${esc(countrySummary)}</span>
              <span>👥 ${esc(guests.label)} · razem ${esc(guests.total || '-')}</span>
              <span>🧾 ${esc(mainServices)}</span>
              <span>💰 ${esc(item.estimated_total_pln ?? '-')} PLN</span>
              <span>⚑ ${esc(priority)}</span>
              <span>✨ ${esc(bestSuggestion.title)} · ${esc(bestSuggestion.reason)}</span>
              ${item.email ? `<a href="mailto:${esc(item.email)}">${esc(item.email)}</a>` : ''}
              ${item.phone ? `<a href="tel:${esc(item.phone)}">${esc(item.phone)}</a>` : ''}
            </div>
            <div class="quick-actions">
              <button type="button" data-reply-action="confirm" data-target-status="needs_confirmation">✅ Potwierdź</button>
              <button type="button" data-reply-action="askMissingData" data-target-status="needs_reply">📝 Poproś o dane</button>
              <button type="button" data-reply-action="noAvailability" data-target-status="unavailable">❌ Brak miejsc</button>
              <button type="button" data-reply-action="infoCampingSummer" data-target-status="replied">🏕️ Camping lipiec/sierpień</button>
              <button type="button" data-reply-action="bungalow" data-target-status="needs_confirmation">🏡 Domek</button>
              <button type="button" data-reply-action="electricityEv" data-target-status="replied">⚡ Prąd / EV</button>
              <button type="button" data-reply-action="tours" data-target-status="replied">🚌 Wycieczki</button>
              <button type="button" data-reply-action="heavyVehicle" data-target-status="replied">🚫 Ciężki pojazd</button>
              <button type="button" data-reply-action="groupScout" data-target-status="needs_reply">👥 Grupa / skauci</button>
              <button type="button" data-reply-template="${esc(recommendedId)}">📋 Kopiuj / podgląd</button>
              <button type="button" data-reply-template="${esc(recommendedId)}">✉️ Mailto</button>
              <button type="button" data-open-details>💬 Otwórz rozmowę</button>
            </div>
            <details class="inquiry-card__details">
              <summary><span>Rozwiń szczegóły zapytania</span><small>Dane klienta, usługi, wycieczki, feedback, mail i notatki recepcji</small></summary>
              <div data-details-body hidden></div>
            </details>
          </article>`;
        };
        const render = () => {
          viewButtons.forEach((button) => button.setAttribute('aria-pressed', button.dataset.view === activeView ? 'true' : 'false'));
          if (app instanceof HTMLElement) app.dataset.activeView = activeView;
          updateSidebarBadges();
          if (activeFilterCount) activeFilterCount.textContent = `Aktywne filtry: ${activeFilterTotal()}`;
          refreshHeaderStatus();
          renderSystemStrip();
          const items = visibleItems();
          if (count) count.textContent = activeView === 'dashboard'
            ? `realni: ${realItems().length} · testy: ${testItems().length}`
            : `${items.length} w widoku · realni: ${realItems().length} · testy: ${testItems().length}`;
          if (stats) {
            const statItems = activeView === 'stats'
              ? []
              : [
                ['Nowe', realItems().filter((item)=>item.status === 'new').length],
                ['Do odpowiedzi', realItems().filter((item)=>['new','needs_reply'].includes(item.status)).length],
                ['Resend OK', realItems().filter((item)=>item.mail_provider === 'resend' && item.mail_delivered).length],
                ['Mail niedostarczony', realItems().filter((item)=>!item.mail_delivered).length],
                ['Testy', testItems().length],
                ['Wycieczki', realItems().filter((item)=>categoryKeys(item).includes('trips')).length],
                ['Feedback', realItems().filter((item)=>categoryKeys(item).includes('feedback')).length],
                ['Najbliższe 7 dni', realItems().filter((item)=>categoryKeys(item).includes('next7')).length],
              ];
            stats.innerHTML = statItems.map(([label,value])=>`<article><strong>${esc(value)}</strong><span>${esc(label)}</span></article>`).join('');
          }
          if (list) {
            if (activeView === 'dashboard') list.innerHTML = renderPremiumDashboardView();
            else if (activeView === 'mail' || activeView === 'inbox') list.innerHTML = renderMailCenterWorkspace(items);
            else if (activeView === 'customers') list.innerHTML = renderCustomersView();
            else if (activeView === 'reservations') list.innerHTML = renderReservationsView();
            else if (activeView === 'calendar') list.innerHTML = renderCalendarView();
            else if (activeView === 'camp' || activeView === 'camp-pro') list.innerHTML = renderCampProView();
            else if (activeView === 'bungalows') list.innerHTML = renderBungalowsView();
            else if (activeView === 'camping') list.innerHTML = renderCampingView();
            else if (activeView === 'extend') list.innerHTML = renderExtendStayView();
            else if (activeView === 'print') list.innerHTML = renderPrintView();
            else if (activeView === 'reports') list.innerHTML = renderReportsView();
            else if (activeView === 'staff') list.innerHTML = renderStaffView();
            else if (activeView === 'tasks') list.innerHTML = renderTasksView();
            else if (activeView === 'stats') list.innerHTML = renderStatsView();
            else if (activeView === 'templates') list.innerHTML = renderTemplatesView();
            else if (activeView === 'settings') list.innerHTML = renderSettingsView();
            else if (offlineModuleMeta[activeView]) list.innerHTML = renderOfflineModuleView(activeView);
            else list.innerHTML = items.length ? items.map(card).join('') : '<div class="empty">Brak zapytań dla wybranych filtrów.</div>';
            normalizeSystemIcons(list);
          }
        };
        const load = async ({ silent = false, reason = 'manual' } = {}) => {
          if (isLoading && silent) return;
          rememberExpandedCards();
          const previousIds = new Set(inquiries.map((item)=>String(item.id)));
          isLoading = true;
          if (!silent && appStatus) appStatus.textContent = 'Ładowanie…';
          if (connectionStatus) connectionStatus.textContent = silent ? 'API sync' : 'API ...';
          try {
            const [result, healthResult] = await Promise.all([
              request('/api/inbox/list'),
              request('/api/inbox/health').catch((error)=>({ ok:false, env:{}, tableCheck:{ ok:false, error:error.message } })),
            ]);
            const nextInquiries = result.inquiries || [];
            const newItems = previousIds.size
              ? nextInquiries.filter((item)=>!previousIds.has(String(item.id)))
              : [];
            inquiries = nextInquiries;
            health = healthResult;
            setOptions('status',Object.keys(statusLabels),(value)=>statusLabels[value] || value);
            setOptions('category',Object.keys(categoryLabels),(value)=>categoryLabels[value] || value);
            setOptions('stay',inquiries.map((item)=>item.stay_type));
            setOptions('country',inquiries.map((item)=>item.country));
            setOptions('language',inquiries.map((item)=>item.language));
            if (appStatus) appStatus.textContent = '';
            if (connectionStatus) connectionStatus.textContent = 'API OK';
            if (lastRefresh) lastRefresh.textContent = `Ostatnie odświeżenie: ${new Intl.DateTimeFormat('pl-PL', { timeStyle:'short' }).format(new Date())}`;
            render();
            restoreExpandedCards();
            if (newItems.length && reason === 'auto') {
              const visibleNew = newItems.filter((item)=>itemBelongsToView(item));
              const noticeItem = visibleNew[0] || newItems[0];
              const country = countryInfo(noticeItem);
              const where = visibleNew.length ? '' : isTestInquiry(noticeItem) ? ' — w zakładce Testy' : ' — w Skrzynce';
              showToast(`Nowe zapytanie od ${noticeItem.full_name || country.label || 'klienta'}${where}`, 'success');
            }
            startAutoRefresh();
          } catch (error) {
            if (error.status === 401) {
              window.clearInterval(autoRefreshTimer);
              sessionStorage.removeItem(storageKey);
              accessCode='';
              showToast('Kod dostępu wygasł albo jest nieprawidłowy. Zaloguj się ponownie.', 'error');
              if (app instanceof HTMLElement) app.hidden=true;
              if (login instanceof HTMLElement) login.hidden=false;
            }
            if (appStatus) appStatus.textContent = error.message;
            if (loginStatus) loginStatus.textContent = error.message;
            if (connectionStatus) connectionStatus.textContent = 'API blad';
            refreshHeaderStatus();
          } finally {
            isLoading = false;
          }
        };
        const save = async (cardNode, statusOverride = '') => {
          rememberExpandedCards();
          const id = cardNode.dataset.id;
          const status = statusOverride || cardNode.querySelector('[data-status]')?.value;
          const notes = cardNode.querySelector('[data-notes]')?.value || '';
          const button = cardNode.querySelector('[data-save]');
          if (button) button.disabled = true;
          try {
            const result = await request('/api/inbox/update',{method:'PATCH',body:JSON.stringify({id,status,notes})});
            const index = inquiries.findIndex((item)=>String(item.id) === String(id));
            if (index >= 0) inquiries[index] = result.inquiry;
            trackLocalAction(id, `Zmieniono status: ${statusLabels[status] || status}`);
            render();
            restoreExpandedCards();
          } catch (error) { if (appStatus) appStatus.textContent = error.message; showToast(error.message, 'error'); }
          finally { if (button) button.disabled = false; }
        };

        loginForm?.addEventListener('submit', async (event) => {
          event.preventDefault();
          accessCode = String(new FormData(loginForm).get('accessCode') || '').trim();
          if (!accessCode) return;
          if (loginStatus) loginStatus.textContent = 'Sprawdzanie kodu…';
          await load();
          if (!accessCode) return;
          sessionStorage.setItem(storageKey,accessCode);
          if (login instanceof HTMLElement) login.hidden=true;
          if (app instanceof HTMLElement) app.hidden=false;
          startAutoRefresh();
          if (loginStatus) loginStatus.textContent='';
        });
        document.querySelector('[data-refresh]')?.addEventListener('click',()=>void load({ silent:false, reason:'manual' }));
        sidebarToggle?.addEventListener('click',toggleSidebar);
        sidebarMobileToggle?.addEventListener('click',toggleSidebar);
        sidebarCloseButtons.forEach((button)=>button.addEventListener('click',closeMobileSidebar));
        document.querySelectorAll('[data-reply-close]').forEach((button)=>button.addEventListener('click',closeReplyModal));
        document.querySelector('[data-reply-copy]')?.addEventListener('click',(event)=>{
          if (!activeReplyDraft?.template?.mailtoBodyText || !(event.currentTarget instanceof HTMLButtonElement)) return;
          const payload = activeReplyPayload();
          trackLocalAction(activeReplyDraft.itemId, 'Skopiowano odpowiedź z modala');
          if (payload) {
            void logReplyActivity({
              inquiryId: payload.item.id,
              threadId: payload.threadId,
              action: 'copied_reply',
              meta: { templateId: payload.template.id, subject: payload.subject },
            });
          }
          void copy(payload?.bodyText || activeReplyDraft.template.mailtoBodyText, event.currentTarget);
        });
        document.querySelector('[data-reply-send]')?.addEventListener('click',()=>void sendReplyThroughResend());
        document.querySelector('[data-reply-draft]')?.addEventListener('click',()=>void saveReplyDraft());
        document.querySelector('[data-reply-mailto]')?.addEventListener('click',launchReplyMailto);
        document.querySelector('[data-reply-mark]')?.addEventListener('click',markReplyHandled);
        window.addEventListener('keydown',(event)=>{
          if (event.key === 'Escape') {
            closeReplyModal();
            closeMobileSidebar();
          }
        });
        autoRefreshToggle?.addEventListener('click',()=>{
          autoRefreshPaused = !autoRefreshPaused;
          if (!autoRefreshPaused) {
            void load({ silent:true, reason:'manual' });
          } else {
            window.clearInterval(autoRefreshTimer);
            showToast('Automatyczne odświeżanie zatrzymane. Widok i filtry zostają bez zmian.', 'info');
          }
          startAutoRefresh();
          refreshHeaderStatus();
        });
        document.querySelector('[data-logout]')?.addEventListener('click',()=>{window.clearInterval(autoRefreshTimer);sessionStorage.removeItem(storageKey);location.reload();});
        viewButtons.forEach((button)=>button.addEventListener('click',()=>{
          activeView = button.dataset.view || 'inbox';
          closeMobileSidebar();
          render();
        }));
        document.querySelectorAll('[data-view-shortcut]').forEach((button)=>button.addEventListener('click',()=>{
          activeView = button.dataset.viewShortcut || 'inbox';
          clearFilters();
          if (button.classList.contains('cc-sidebar__mail-failed')) {
            const mailFailed = document.querySelector('[data-filter="mailFailed"]');
            if (mailFailed instanceof HTMLInputElement) mailFailed.checked = true;
          }
          closeMobileSidebar();
          render();
        }));
        document.querySelectorAll('[data-mail-status]').forEach((button)=>button.addEventListener('click',()=>{
          activeView = 'mail';
          clearFilters();
          const statusSelect = document.querySelector('[data-filter="status"]');
          if (statusSelect instanceof HTMLSelectElement) statusSelect.value = button.dataset.mailStatus || '';
          render();
        }));
        document.querySelector('[data-clear-filters]')?.addEventListener('click',()=>{
          activeView = 'mail';
          clearFilters();
          render();
        });
        globalSearch?.addEventListener('input',()=>{
          const search = document.querySelector('[data-filter="search"]');
          if (search instanceof HTMLInputElement && globalSearch instanceof HTMLInputElement) {
            search.value = globalSearch.value;
            activeView = 'mail';
            render();
          }
        });
        filters.forEach((filter)=>filter.addEventListener(filter instanceof HTMLInputElement && filter.type === 'search' ? 'input':'change',()=>{
          if (filter instanceof HTMLInputElement && filter.matches('[data-filter="search"]') && globalSearch instanceof HTMLInputElement) {
            globalSearch.value = filter.value;
          }
          render();
        }));
        const findItemForNode = (node) => inquiries.find((entry)=>String(entry.id) === String(node?.dataset?.id));
        const hydrateDetails = (details) => {
          if (!(details instanceof HTMLDetailsElement) || !details.classList.contains('inquiry-card__details') || !details.open) return;
          const node = details.closest('[data-id]');
          const body = details.querySelector('[data-details-body]');
          if (!(node instanceof HTMLElement) || !(body instanceof HTMLElement) || body.dataset.rendered === 'true') return;
          const item = findItemForNode(node);
          if (!item) return;
          body.innerHTML = detailsBody(item);
          body.hidden = false;
          body.dataset.rendered = 'true';
        };
        const hydrateDebug = (details) => {
          if (!(details instanceof HTMLDetailsElement) || !details.classList.contains('technical-data') || !details.open) return;
          const node = details.closest('[data-id]');
          const pre = details.querySelector('[data-raw-debug]');
          if (!(node instanceof HTMLElement) || !(pre instanceof HTMLPreElement) || pre.dataset.rendered === 'true') return;
          const item = findItemForNode(node);
          if (!item) return;
          pre.textContent = debugText(item);
          pre.dataset.rendered = 'true';
        };
        list?.addEventListener('toggle',(event)=>{
          const target = event.target;
          if (target instanceof HTMLDetailsElement) {
            const node = target.closest('[data-id]');
            const id = node instanceof HTMLElement ? String(node.dataset.id || '') : '';
            if (id && target.classList.contains('inquiry-card__details')) {
              if (target.open) expandedIds.add(id);
              else expandedIds.delete(id);
            }
            hydrateDetails(target);
            hydrateDebug(target);
          }
        }, true);
        list?.addEventListener('click',(event)=>{
          const target = event.target;
          if (!(target instanceof Element)) return;
          const calendarClose = target.closest('[data-calendar-close]');
          if (calendarClose instanceof HTMLElement) {
            const modal = list.querySelector('[data-calendar-modal]');
            if (modal instanceof HTMLElement) modal.hidden = true;
            return;
          }
          const calendarEdit = target.closest('[data-calendar-edit]');
          if (calendarEdit instanceof HTMLElement) {
            const modal = list.querySelector('[data-calendar-modal]');
            const name = list.querySelector('[data-calendar-modal-name]');
            const term = list.querySelector('[data-calendar-modal-term]');
            const dataList = list.querySelector('[data-calendar-modal-data]');
            if (name instanceof HTMLElement) name.textContent = calendarEdit.dataset.calendarName || 'Rezerwacja';
            if (term instanceof HTMLElement) term.textContent = calendarEdit.dataset.calendarTerm || 'Termin do potwierdzenia';
            if (dataList instanceof HTMLElement) {
              let rows = [];
              try { rows = JSON.parse(calendarEdit.dataset.calendarRows || '[]'); } catch {}
              dataList.innerHTML = Array.isArray(rows) && rows.length
                ? rows.map(([label,value])=>`<div><dt>${esc(label)}</dt><dd>${esc(value)}</dd></div>`).join('')
                : '<div><dt>Status</dt><dd>Dane do uzupełnienia w docelowej tabeli rezerwacji.</dd></div>';
            }
            if (modal instanceof HTMLElement) modal.hidden = false;
            showToast('Otwieram panel edycji rezerwacji.', 'info');
            return;
          }
          const dynamicShortcut = target.closest('[data-view-shortcut]');
          if (dynamicShortcut instanceof HTMLElement) {
            activeView = dynamicShortcut.dataset.viewShortcut || 'mail';
            clearFilters();
            closeMobileSidebar();
            render();
            return;
          }
          const folderButton = target.closest('[data-mail-folder]');
          if (folderButton instanceof HTMLElement) {
            const folder = folderButton.dataset.mailFolder || 'inbox';
            clearFilters();
            selectedInquiryId = '';
            activeView = 'mail';
            const statusSelect = document.querySelector('[data-filter="status"]');
            const categorySelect = document.querySelector('[data-filter="category"]');
            const mailFailed = document.querySelector('[data-filter="mailFailed"]');
            if (folder === 'tests') activeView = 'tests';
            else if (folder === 'archive') activeView = 'archive';
            else if (folder === 'mailFailed' && mailFailed instanceof HTMLInputElement) mailFailed.checked = true;
            else if (folder === 'urgent' && categorySelect instanceof HTMLSelectElement) categorySelect.value = 'urgent';
            else if (['needs_reply','replied','unavailable'].includes(folder) && statusSelect instanceof HTMLSelectElement) statusSelect.value = folder;
            else if (folder === 'confirmed' && statusSelect instanceof HTMLSelectElement) statusSelect.value = 'confirmed';
            render();
            return;
          }
          const backButton = target.closest('[data-mail-back]');
          if (backButton instanceof HTMLElement) {
            if (app instanceof HTMLElement) app.classList.remove('is-mail-detail');
            return;
          }
          const threadButton = target.closest('[data-thread-select]');
          if (threadButton instanceof HTMLElement) {
            selectedInquiryId = threadButton.dataset.threadSelect || threadButton.dataset.id || '';
            if (app instanceof HTMLElement && window.matchMedia('(max-width: 900px)').matches) app.classList.add('is-mail-detail');
            render();
            return;
          }
          const looseReplyButton = target.closest('[data-copy-reply]');
          if (looseReplyButton instanceof HTMLButtonElement && !target.closest('[data-id]')) {
            const replyText = decodeURIComponent(looseReplyButton.dataset.copyReply || '');
            if (replyText) void copy(replyText, looseReplyButton);
            return;
          }
          const node = target.closest('[data-id]');
          if (!(node instanceof HTMLElement)) return;
          const item = inquiries.find((entry)=>String(entry.id) === String(node.dataset.id));
          if (!item) return;
          const replyAction = target.closest('[data-reply-action]');
          if (replyAction instanceof HTMLElement) {
            const template = replyTemplateById(item, replyAction.dataset.replyAction || 'confirm');
            const statusAfter = replyAction.dataset.targetStatus || '';
            openReplyModal(item, template, node, statusAfter);
            return;
          }
          const replyTemplateButton = target.closest('[data-reply-template]');
          if (replyTemplateButton instanceof HTMLElement) {
            const template = replyTemplateById(item, replyTemplateButton.dataset.replyTemplate || '');
            openReplyModal(item, template, node, 'replied');
            return;
          }
          if (target.closest('[data-save]')) void save(node);
          const quick = target.closest('[data-quick-status]');
          if (quick instanceof HTMLElement) void save(node,quick.dataset.quickStatus);
          if (target.closest('[data-open-details]')) {
            const details = node.querySelector('.inquiry-card__details');
            if (details instanceof HTMLDetailsElement) {
              details.open = true;
              hydrateDetails(details);
              details.scrollIntoView({ behavior:'smooth', block:'nearest' });
            }
          }
          const templateButton = target.closest('[data-copy-template]');
          if (templateButton instanceof HTMLButtonElement) {
            const templates = generateReplyTemplates(item);
            const wanted = templateButton.dataset.copyTemplate || '';
            const chosen = templates.find((template)=>template.id === wanted) || templates[0];
            if (chosen?.body) void copy(chosen.body, templateButton);
          }
          const replyButton = target.closest('[data-copy-reply]');
          if (replyButton instanceof HTMLButtonElement) {
            const replyText = decodeURIComponent(replyButton.dataset.copyReply || '');
            if (replyText) {
              trackLocalAction(item.id, 'Skopiowano odpowiedź');
              void copy(replyText, replyButton);
            }
          }
          const actions = [
            ['[data-copy-summary]',summaryText(item)],['[data-copy-email]',item.email],['[data-copy-phone]',item.phone],
            ['[data-copy-client-safe]',clientSafeSummaryText(item)],['[data-copy-mail]',mailText(item)],['[data-copy-id]',`${location.origin}/cc-gate-a8f3k9r2p6#${item.id}\nID: ${item.id}`],
          ];
          actions.forEach(([selector,text])=>{const button=target.closest(selector);if(button instanceof HTMLButtonElement && text) void copy(text,button);});
        });
        window.addEventListener('beforeunload',()=>window.clearInterval(autoRefreshTimer));
        accessCode = sessionStorage.getItem(storageKey) || '';
        if (accessCode) { if (login instanceof HTMLElement) login.hidden=true; if (app instanceof HTMLElement) app.hidden=false; void load(); startAutoRefresh(); }
      })();
    </script>
  </body>
